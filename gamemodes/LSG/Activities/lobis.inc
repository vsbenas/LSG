public UpdateLobiai() // every 12 h
{
	LobiuDB[Lobis] = random(sizeof(lobiai));
	LobiuDB[IsPicked] = false;

	if(random(3) == 0) // every 36 h
		zuvele=true;
}

stock SearchLobis(playerid)
{
	if(GetPlayerWeapon(playerid)!= 6)
	{
		SendClientMessage(playerid,TEXTCOL_BLUE,"Kasimui jums prireiks kastuvo.");
		return 1;
	}
	//if(FALSE == false) return SendInfoMessage(playerid,"LOBIO NERA :(");
	ApplyAnimation(playerid, "MISC", "pickup_box", 4.000000, 0, 0, 0, 0, -1);

	if(!LobiuDB[IsPicked] && PlayerToPoint(3,playerid,lobiai[LobiuDB[Lobis]][0],lobiai[LobiuDB[Lobis]][1],lobiai[LobiuDB[Lobis]][2]))
	{
		FindLobis(playerid);
		return 1;
	}

	SendClientMessage(playerid,TEXTCOL_BLUE,"Cia lobio nera.");
	return 1;
}
stock FindLobis(playerid)
{
	SendClientMessage(playerid,TEXTCOL_BLUE,"Suradai lobi!");
	new sum = 5000+random(6)*1000;
	GivePlayerMoneyA(playerid,sum);
	SetPlayerScore(playerid,GetPlayerScore(playerid)+500);
	new msg[128];
	format(msg,sizeof(msg)," * Gavai 500 XP ir %i LT!",sum);
	SendClientMessage(playerid,TEXTCOL_GOLD,msg);
	ProcessAchievement(playerid,103);
	LobiuDB[IsPicked]=true;
	//LogA(playerid,"Iskase lobi");
}

stock EnableLobiai()
{
	SetTimer("UpdateLobiai",3600000*12,true);
	UpdateLobiai();
	LobiuDB[IsPicked]=true;
	zuvele=false;
}

	

