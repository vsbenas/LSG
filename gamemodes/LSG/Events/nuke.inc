stock InitRocketMarker()
{
	if(rocketmarker != -1)
		DestroyDynamicObject(rocketmarker);
	rocketmarker = CreateDynamicObject(19184, 220.1184,1822.6875,7.5309,0,180,0); //, Float:rx, Float:ry, Float:rz, worldid = -1, interiorid = -1, playerid = -1, Float:streamdistance = STREAMER_OBJECT_SD, Float:drawdistance = STREAMER_OBJECT_DD, STREAMER_TAG_AREA areaid = STREAMER_TAG_AREA -1, priority = 0)
	SetAtomBombPos(50.0,50.0);
}
new rocketicon;
stock RocketSet(playerid,set)
{
	if(set)
	{
		RocketManager=playerid;
		//rocketicon = CreateDynamicMapIcon(0, 0, 0, 56, 0, -1, -1, -1, 5000.0, MAPICON_GLOBAL);
		SetPVarFloat(playerid, "rocketX", 50.0);
		SetPVarFloat(playerid, "rocketY", 50.0);
		TogglePlayerControllableEx(playerid, false);
		SetPlayerCameraPos(playerid,222.9571,1822.6875,8.8166);
		SetPlayerCameraLookAt(playerid, 220.1184,1822.6875,6.570893, CAMERA_MOVE);
	}
	else
	{
		TogglePlayerControllableEx(playerid, true);
		SetCameraBehindPlayer(playerid);
		RocketManager=INVALID_PLAYER_ID;
	}
}

stock SetAtomBombPos(Float:xpercent,Float:ypercent)
{
	new Float:nx,Float:ny,Float:nz;
	nz = 6.570893 + 0.1; // 
	nx = 218.268096 + (xpercent/100) * (221.668151 - 218.268096);
	ny = 1821.147338 + (ypercent/100) * (1824.497924 - 1821.147338);

//AddPlayerClass(166,-2958.0000,-2962.3613,-0.1317,82.4063,0,0,0,0,0,0); // kampas 1
//AddPlayerClass(166,2958.0000,2958.0000,-0.8260,77.7428,0,0,0,0,0,0); // kampas 2

	new Float:mx,Float:my,Float:mz;
	mz = 10.0;
	mx = -2958.0000 + (ypercent/100) * 2 * 2958.0000;
	my = 2962.3613 + (xpercent/100) * 2 * (-2962.3613);
	NuclearBlast[nP][0] = mx;
	NuclearBlast[nP][1] = my;
	NuclearBlast[nP][2] = mz;
	//DestroyDynamicMapIcon(rocketicon);
	//rocketicon = CreateDynamicMapIcon(mx,my,mz, 56, 0, -1, -1, -1, 5000.0, MAPICON_GLOBAL);
	SetDynamicObjectPos(rocketmarker, nx, ny, nz);
}

stock CreateNukeObject(modelid,Float:fx,Float:fy,Float:fz,Float:rx,Float:ry,Float:rz)
{
	HelovynoObj[HelovynoCount][heObject] = CreateDynamicObject(modelid,fx,fy,fz,rx,ry,rz,_,_,_,500.0,_,_,1);// CreateDynamicObject(modelid, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz, worldid = -1, interiorid = -1, playerid = -1, Float:streamdistance = STREAMER_OBJECT_SD, Float:drawdistance = STREAMER_OBJECT_DD, STREAMER_TAG_AREA areaid = STREAMER_TAG_AREA -1, priority = 0)
	HelovynoObj[HelovynoCount][heModel] = modelid;
	HelovynoObj[HelovynoCount][heSize] = floatround(GetColSphereRadius(modelid));
	HelovynoObj[HelovynoCount][heStatus] = 1;
	HelovynoObj[HelovynoCount][heX] = fx;
	HelovynoObj[HelovynoCount][heY] = fy;
	HelovynoObj[HelovynoCount][heZ] = fz;
	NuclearBlast[TotalObjectsCreated]++;
	HelovynoCount++;
}

