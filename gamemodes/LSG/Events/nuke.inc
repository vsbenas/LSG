forward Exploding();
public Exploding()
{
	new Float:pos[3];
	new Float:vec[3];
	foreach(Player, playerid)
	{
		GetPlayerPos(playerid, pos[0], pos[1], pos[2]);
		
		vec[0] = pos[0] - NuclearBlast[nP][0];
		vec[1] = pos[1] - NuclearBlast[nP][1];
		vec[2] = pos[2] - NuclearBlast[nP][2];
		// normalize
		new Float:veclength = floatsqroot(vec[0]*vec[0] + vec[1] * vec[1] + vec[2]*vec[2]);
		if(veclength == 0.0)
			veclength = 1.0;
		vec[0] = NuclearBlast[NukeDist]*(vec[0]/veclength);
		vec[1] = NuclearBlast[NukeDist]*(vec[1]/veclength);
		vec[2] = NuclearBlast[NukeDist]*(vec[2]/veclength);
		CreateExplosionForPlayer(playerid,NuclearBlast[nP][0] + vec[0], NuclearBlast[nP][1] + vec[1],NuclearBlast[nP][2] + vec[2],  6, 50.0);
	}
	if(NuclearBlast[NukeDist]<1500)
	{
		NuclearBlast[NukeDist] += 5;
		SetTimer("Exploding", 200, false);
	}
	else
	{
		NuclearBlast[NukeInProgress]=2;
		DestroyDynamicMapIcon(rocketicon);
		SetTimer("StartRebuilding",10*60*1000,false);//10
		//SendClientMessageToAll(-1, " [ATOMINE BOMBA] Los santos mieste sprogo atominë bomba! Prađome visř Los Santos gyventojř laikytis protokolo /atominebomba");
	}

	return 1;
}
