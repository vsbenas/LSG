stock RocketManagerFunc()
{
	new playerid = RocketManager;
	if(!IsPlayerConnected(playerid) || !IsPlayerInRangeOfPointEx(30.0, playerid, 222.2627,1822.9048,6.4141))
	{
		RocketManager = INVALID_PLAYER_ID;
		return;
	}
	new keys,ud,lr;
	GetPlayerKeys(playerid, keys, ud, lr);
	new Float:xrock = GetPVarFloat(playerid, "rocketX");
	new Float:yrock = GetPVarFloat(playerid, "rocketY");
	new const Float:step = 0.5;

	if(lr == KEY_LEFT && yrock > 0)
		yrock -= step;
	else if(lr == KEY_RIGHT && yrock < 100)
		yrock += step;

	if(ud == KEY_DOWN && xrock < 100)
		xrock += step;
	else if(ud == KEY_UP && xrock > 0)
		xrock -= step;

	SetAtomBombPos(xrock,yrock);
	Streamer_Update(playerid);

	SetPVarFloat(playerid, "rocketX", xrock);
	SetPVarFloat(playerid, "rocketY", yrock);
}