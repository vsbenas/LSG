stock DestroyProps()
{
	for(new i;i<600;i++)
	{
		if(HelovynoObj[i][heStatus] != 0)
			DestroyDynamicObject(HelovynoObj[i][heObject]);
	}
	DestroyActor(h_npc); //,h_pickup,h_degaline,h_pumpkin;)
	DestroyPickup(h_pickup);
	DestroyPickup(h_degaline);

	DestroyPickup(h_pumpkin);
	h_degaline = -1;
	h_pumpkin = -1;
	h_pickup = -1;
}


stock RemoveNukeObject(modelid,Float:fX,Float:fY,Float:fZ,Float:fRadius,Float:rX,Float:rY,Float:rZ)
{
	/*new dataid = -1;
	for(new i;i<SEARCH_DATA_SIZE;i++)
	{
		if((SearchData[i][Search_Model] == modelid || SearchData[i][Search_LODModel] == modelid) && GetDistanceBetweenPoints(fX,fY,fZ, SearchData[i][SearchX],SearchData[i][SearchY],SearchData[i][SearchZ]) < 1)
		{
			dataid = i;
			break;
		}
	}*/
	new id = removedCount;
	RemovedObjects[id][rModelId] = modelid;
	//RemovedObjects[id][rDataId] = dataid;
	RemovedObjects[id][rfX] = fX;
	RemovedObjects[id][rfY] = fY;
	RemovedObjects[id][rfZ] = fZ;
	RemovedObjects[id][rfRadius] = fRadius;
	RemovedObjects[id][rfSize] = floatround(GetColSphereRadius(modelid));
	RemovedObjects[id][rActive] = 0;
	RemovedObjects[id][rrX]=rX;
	RemovedObjects[id][rrY]=rY;
	RemovedObjects[id][rrZ]=rZ;
	removedCount++;
	NuclearBlast[TotalObjectsNuked] ++;
}
stock RemoveNukeObjectsForPlayer(playerid)
{
	for(new i;i<removedCount;i++)
	{
		if(RemovedObjects[i][rActive])
		{
			RemoveBuildingForPlayer(playerid, RemovedObjects[i][rModelId], RemovedObjects[i][rfX],RemovedObjects[i][rfY] ,RemovedObjects[i][rfZ] ,RemovedObjects[i][rfRadius]);
		}
	}
}
stock RemoveNukeObjectsForAll()
{
	for(new i;i<removedCount;i++)
	{
		RemovedObjects[i][rActive]=1;
	}
	foreach(Player, i)
	{
		RemoveNukeObjectsForPlayer(i);
	}
}
stock RestoreNukeObject(id)
{
	new Float:rX = RemovedObjects[id][rrX];
	new Float:rY = RemovedObjects[id][rrY];
	new Float:rZ = RemovedObjects[id][rrZ];
	RemovedObjects[id][rfRestoredId] = CreateDynamicObject(RemovedObjects[id][rModelId], RemovedObjects[id][rfX],RemovedObjects[id][rfY] ,RemovedObjects[id][rfZ], rX, rY, rZ, -1, -1, -1, 600.0, _, _, 1); // 1 priority
	//CreateDynamicObject(modelid, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz, worldid = -1, interiorid = -1, playerid = -1, Float:streamdistance = STREAMER_OBJECT_SD, Float:drawdistance = STREAMER_OBJECT_DD, STREAMER_TAG_AREA areaid = STREAMER_TAG_AREA -1, priority = 0)
	printf("Restoring %i %.2f %.2f %.2f %.2f %.2f %.2f",RemovedObjects[id][rModelId], RemovedObjects[id][rfX],RemovedObjects[id][rfY] ,RemovedObjects[id][rfZ], rX, rY, rZ);
	RemovedObjects[id][rActive]=0;
}

stock SetNextNukeCp(playerid, type) // type 1 = restore, type 2 = remove trash
{
	if(NuclearBlast[NukeInProgress] != 3)
	{
		return 0;
	}
	if(GetPVarInt(playerid, "NukeType") == type)
	{
		new id = GetPVarInt(playerid, "NukeCP");
		if(type == 1)
		{
			if(RemovedObjects[id][rActive])
			{
				DisablePlayerCheckpoint(playerid);
				SetPlayerCheckpointDelay(playerid, RemovedObjects[id][rfX],RemovedObjects[id][rfY] ,RemovedObjects[id][rfZ],RemovedObjects[id][rfSize]+5);
				return 1;
			}	
			else
			{
				SendClientMessage(playerid, -1, " * Ieđkome pastato kurá reikëtu atstatyti...");
				SetPVarInt(playerid, "NukeType", 0);
			}
		}
		else
		{
			if(HelovynoObj[id][heStatus])
			{
				DisablePlayerCheckpoint(playerid);
				SetPlayerCheckpointDelay(playerid, HelovynoObj[id][heX],HelovynoObj[id][heY] ,HelovynoObj[id][heZ],HelovynoObj[id][heSize]+5);
				return 1;
			}
			else
			{
				SendClientMessage(playerid, -1, " * Ieđkome pastato kurá reikëtu nugriauti...");
				SetPVarInt(playerid, "NukeType", 1);
			}
		}

	}
	new notavailableList[1000];
	foreach(Player, i)
	{
		if(GetPVarInt(i, "NukeType") == type)
		{
			new id = GetPVarInt(i, "NukeCP");
			if(id != -1 && id < 1000)
			{
				notavailableList[id] = 1;
			}
		}
	}
	// ok we know which ones are taken. Now lets see if we can find one available.
	if(type == 1)
	{
		for(new id;id<removedCount;id++)
		{
			if(RemovedObjects[id][rActive] && notavailableList[id] == 0)
			{
				SetPVarInt(playerid, "NukeType", 1);
				SetPVarInt(playerid, "NukeCP", id);
				SendClientMessage(playerid, -1, " * Ţemëlapyje paţymëtas pastatas kurá reikia atstatyti!");
				DisablePlayerCheckpoint(playerid);
				SetPlayerCheckpointDelay(playerid, RemovedObjects[id][rfX],RemovedObjects[id][rfY] ,RemovedObjects[id][rfZ],RemovedObjects[id][rfSize]+5);
				return 1;
			}
		}
	}
	if(type == 2)
	{
		for(new id;id<HelovynoCount;id++)
		{
			if(HelovynoObj[id][heStatus] && notavailableList[id] == 0)
			{
				SetPVarInt(playerid, "NukeType", 2);
				SetPVarInt(playerid, "NukeCP", id);
				SendClientMessage(playerid, -1, " * Ţemëlapyje paţymëtas objektas kurá reikia nugriauti!");
				DisablePlayerCheckpoint(playerid);
				SetPlayerCheckpointDelay(playerid, HelovynoObj[id][heX],HelovynoObj[id][heY] ,HelovynoObj[id][heZ],HelovynoObj[id][heSize]+5);
				return 1;
			}
		}
	}

	// didnt find it.. ok lets try all of them
	if(type == 1)
	{
		for(new id;id<removedCount;id++)
		{
			if(RemovedObjects[id][rActive])
			{
				SetPVarInt(playerid, "NukeType", 1);
				SetPVarInt(playerid, "NukeCP", id);
				SendClientMessage(playerid, -1, " * Ţemëlapyje paţymëtas pastatas kurá reikia atstatyti.");
				DisablePlayerCheckpoint(playerid);
				SetPlayerCheckpointDelay(playerid, RemovedObjects[id][rfX],RemovedObjects[id][rfY] ,RemovedObjects[id][rfZ],RemovedObjects[id][rfSize]+5);
				return 1;
			}
		}
	}
	if(type == 2)
	{
		for(new id;id<HelovynoCount;id++)
		{
			if(HelovynoObj[id][heStatus])
			{
				SetPVarInt(playerid, "NukeType", 2);
				SetPVarInt(playerid, "NukeCP", id);
				SendClientMessage(playerid, -1, " * Ţemëlapyje paţymëtas objektas kurá reikia nugriauti!");
				DisablePlayerCheckpoint(playerid);
				SetPlayerCheckpointDelay(playerid, HelovynoObj[id][heX],HelovynoObj[id][heY] ,HelovynoObj[id][heZ],HelovynoObj[id][heSize]+5);
				return 1;
			}
		}
	}
	SendClientMessage(playerid, -1, " * Đis darbas jau visiđkai atliktas Los Santos mieste! Bandykite pasiimti kitŕ transporto priemonć.");
	return 0;
}
stock CheckNukeCp(playerid,offset = 0)
{
	new type = GetPVarInt(playerid, "NukeType");
	if(type == 0)
		return 0;
	else if(type == 1) // restore
	{
		new id = GetPVarInt(playerid, "NukeCP");
		if(IsPlayerInRangeOfPointEx(RemovedObjects[id][rfSize]+10+offset, playerid,  RemovedObjects[id][rfX],RemovedObjects[id][rfY] ,RemovedObjects[id][rfZ]))
		{
			if(RemovedObjects[id][rActive] == 0)
			{
				SendClientMessage(playerid, -1, " * Đá pastatŕ jau atstatë kitas ţaidëjas!");
				SetPVarInt(playerid, "NukeType", 0);
				SetPVarInt(playerid, "NukeCP", 0);
				SetNextNukeCp(playerid, type);
			}
			else
			{
				SendInfoMessage(playerid,"Prasome palaukti.");
				SetTimerEx("Freeze",500,false,"i",playerid);
				StartSomething(playerid,191,"Statome_objekta"); 
				
			}
			return 1;
		}
	}
	else if(type == 2) // remove trash
	{
		new id = GetPVarInt(playerid, "NukeCP");
		if(IsPlayerInRangeOfPointEx(HelovynoObj[id][heSize]+10.0+offset,playerid, HelovynoObj[id][heX],HelovynoObj[id][heY] ,HelovynoObj[id][heZ]))
		{
			if(!HelovynoObj[id][heStatus])
			{
				SendClientMessage(playerid, -1, " * Đá pastatŕ jau nugriovë kitas ţaidëjas!");
				SetPVarInt(playerid, "NukeType", 0);
				SetPVarInt(playerid, "NukeCP", 0);
				SetNextNukeCp(playerid, type);
			}
			else
			{
				SendInfoMessage(playerid,"Prasome palaukti.");
				SetTimerEx("Freeze",500,false,"i",playerid);
				StartSomething(playerid,192,"Griauname_objekta"); 
			}
			return 1;
		}

	}
	return 0;
}
