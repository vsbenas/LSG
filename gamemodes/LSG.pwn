stock AddName(vardas[],color[], reload=0)
{
	new vard[MAX_PLAYER_NAME];
	format(vard,sizeof(vard),"%s",vardas);
	if(strlen(vard) > 19)
		vard[19] = '\0';
	if(NameCount >= MAX_NAMES)
		return 0;
	new boardid = NameCount / NAMES_ON_STULPELIS; // NAMES_ON_STULPELIS on one board
	//new boardpos = NameCount % NAMES_ON_STULPELIS; // get position on this board
	//new col = NameCount % 2; // 0 is first, 1 is second, 2 is first, etc.

	
	format(NamesOnBoards[NameCount], 20 + 8, "{%s}%s",color,vard); //.F5F5F5
	NameCount++;
	if(reload)
		ReloadBoard(boardid);
	return 1;
}
stock ReloadBoard(boardid)
{
	new msg[2048];
	// refresh the board
	new base = boardid*NAMES_ON_STULPELIS;
	for(new i; i<NAMES_ON_STULPELIS;i++) if(base + i < NameCount)
	{
		format(msg,2048,"%s%s\n",msg,NamesOnBoards[base + i]);
	}
	if(strlen(msg) > 0)
		SetDynamicObjectMaterialText(NameTags[boardid][ntObject], 0, msg, 140, "Ariel", 20, 1, 0x00000000, 0x00000000, 0);
}

stock AddPlayerName(playerid)
{
	if(GetPlayerScore(playerid) < 1000)
		return SendInfoMessage(playerid,"~r~Pasirasyti galesi tik nuo 1k XP!");
	new query[256];

	new pname[24];
	GetPlayerName(playerid, pname, 24);
	format(query,256,"SELECT * From Siena Where Name='%s'",pname);
	mysql_function_query(SQL, query, true, "SQL_CheckSiena", "i",playerid);
	return 1;
}

stock NaujokoPagalba(playerid)
{
	// kaip uzvesti varikli?
	new pstate = GetPlayerState(playerid);
	if(pstate == PLAYER_STATE_DRIVER)
	{
		new vehicleid = GetPlayerVehicleID(playerid);
		new model = GetVehicleModel(vehicleid);
	    GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
    	if(!VehVars[0] && model != BMX && model != MTBIKE && model != BIKE && !IsPlayerNPC(playerid))
		{
			if(vehicleDB[vehicleid][gas] < 1)
			{
				NaujokoZinute(playerid,"Baigesi degalai!~n~/kviesti");
			}
			else
			{
				NaujokoZinute(playerid,"Spausk MOUSE1");
			}
		}
		return 1;
	}
	else if(pstate == PLAYER_STATE_ONFOOT)
	{
		for ( new i; i < BENTRANCES_COUNT; i++ )
		{
			if (IsPlayerInRangeOfPointEx( 2.5,playerid, BEntrances[ i ][ bEnt_x ], BEntrances[ i ][ bEnt_y ], BEntrances[ i ][ bEnt_z ] ) || IsPlayerInRangeOfPointEx(2.5, playerid, BEntrances[ i ][ bExi_x ], BEntrances[ i ][ bExi_y ], BEntrances[ i ][ bExi_z ]))
			{
				NaujokoZinute(playerid,"Spausk ENTER");
			}
		}
		/*new world = GetPlayerVirtualWorld(playerid);
		if(world > 0)
		{
		    if(world >= MAX_HOUSES*2) // bizniai
			{
				world-=MAX_HOUSES*2;
			    if(IsPlayerInRangeOfPointEx(3.0, playerid, BusinessInfo[world][bExitX],BusinessInfo[world][bExitY],BusinessInfo[world][bExitZ]))
			    {
			        NaujokoZinute(playerid,"Spausk ENTER");
				}
			}
			else if (world < MAX_HOUSES) // name
			{
				if(IsPlayerInRangeOfPointEx(3.0, playerid, Inter[ hInfo[world][vidus] ][ IntX ],Inter[ hInfo[world][vidus] ][ IntY ],Inter[ hInfo[world][vidus] ][ IntZ ] ) )
				{
					NaujokoZinute(playerid,"Spausk ENTER");
				}
			}

		}*/
		foreach(Daugiabuciai, i)
		{
			if(IsPlayerInRangeOfPointEx(2.5,playerid,Daugiabuciai[i][dX],Daugiabuciai[i][dY],Daugiabuciai[i][dZ]))
			{
				NaujokoZinute(playerid,"Spausk ENTER");
			}
		}
		foreach(Businesses,i)
		{
		    if(IsPlayerInRangeOfPointEx(2.0, playerid, BusinessInfo[i][bEnterX],BusinessInfo[i][bEnterY],BusinessInfo[i][bEnterZ]))
		    {
		    	NaujokoZinute(playerid,"Spausk ENTER");
			}
		}
		return 1;
	}
	return 1;
}
stock NaujokoZinute(playerid,textaz[])
{
	if(Iter_Contains(PlayersFading, playerid))
		return;
	new zin[256];
	format(zin,sizeof(zin),"~n~~n~~n~~n~~n~~g~%s",textaz); // /g 
	GameTextForPlayer(playerid, zin, 4000, 3);
}
new LastStreamerUpdate[MAX_PLAYERS];
stock UpdateStreamerFW(Float:xla,Float:yla,Float:zla)
{
	new tick = GetTickCount();
	foreach(Player, i)
	{
		if(tick - LastStreamerUpdate[i] < 200)
			continue;
		LastStreamerUpdate[i] = tick;
		if(IsPlayerInRangeOfPoint(i, 300.0, xla,yla,zla))
		{
			Streamer_Update(i);
		}
	}
}
stock LogMetricInt(metric[], value)
{
	new temp[12];
	format(temp,sizeof(temp),"%i",value);
	LogMetric(metric,temp);
}
stock LogMetricFloat(metric[], Float:value)
{
	new temp[24];
	format(temp,sizeof(temp),"%f",value);
	LogMetric(metric,temp);
}
stock LogMetric(metric[], value[])
{
	new queryza[128];
	format(queryza,sizeof(queryza),"INSERT INTO `Metrics`(`metric`,`value`,`time`) VALUES ('%s','%s',NOW())",metric, value);
	mysql_query(queryza);
}

stock Dovanoti(playerid,tid)
{
	new obj = 19054+random(5);
	SetPlayerSpecialAction(playerid, SPECIAL_ACTION_CARRY);
	SetPlayerAttachedObject(playerid, SLOT_KROVINYS, obj, 1, 0.294613, 0.520760, 0.000000, 0.000000, 90.217391, 0.000000, 0.75,0.75,0.75 );
	SetTimerEx("Dovanoti2", 2000, false, "ii", playerid, tid);
}

PUB:Dovanoti2(playerid,tid)
{
	if(!IsPlayerConnected(playerid))
		return 1;
	SetPlayerSpecialAction(playerid, SPECIAL_ACTION_NONE);
	RemovePlayerAttachedObject(playerid, SLOT_KROVINYS);
	if(!IsPlayerConnected(tid))
	{
		VykdoMisija(playerid,6,2);
		return SendInfoMessage(playerid,"Zaidejas atsijunge!");
	}

	PlayerPlaySound(playerid,4201,0,0,0);
	PlayerPlaySound(tid,4201,0,0,0);

	new dovanastr[50];
	switch(random(6))
	{
		case 0:
		{
			dovanastr = "300 kulkř Deagle";
			if(GunData[tid][GetWeaponsSlot(24)][0] == 24 && GunData[tid][GetWeaponsSlot(24)][1] == -100)
			{ 
				DeletePlayerWeapon(tid, 24);
			}
			GivePlayerWeaponEx(tid,24,300);
		}
		case 1:
		{
			dovanastr = "200 kulkř Sniper rifle";
			if(GunData[tid][GetWeaponsSlot(34)][0] == 34 && GunData[tid][GetWeaponsSlot(34)][1] == -100)
			{ 
				DeletePlayerWeapon(tid, 34);
			}
			GivePlayerWeaponEx(tid,34,200);
		}
		case 2:
		{
			dovanastr = "Laimingas loterijos bilietas 10.000$";
			GivePlayerMoneyA(tid, 10000);
		}
		case 3:
		{
			dovanastr = "5 vnt. Amfetamino";
			playerDB[tid][amfetaminas]+=5;
		}
		case 4:
		{
			dovanastr = "7 vnt. LSD";
			playerDB[tid][lsd]+=7;
		}
		case 5:
		{
			dovanastr = "Chainsaw";
			GivePlayerWeaponEx(tid,9,1);
		}
	}


	new msg[256];
	format(msg,256," * %s duoda dovana %s (%s)",ReturnName(playerid),ReturnName(tid), dovanastr);
	ProxDetector(12.0, playerid, msg, COLOR_CHAT1,COLOR_CHAT2,COLOR_CHAT3,COLOR_CHAT4,COLOR_CHAT5);

	return 1;

}

stock KaleduMisija2(playerid, kaledudiena) // check win condition
{
	new msgas[600];
	new gavodovana = 0;
	switch(kaledudiena)
	{
		case 0: // 20
		{
			if(playerDB[playerid][zuvis] >= 10)
			{
				playerDB[playerid][zuvis] -= 10;
				if(playerDB[playerid][vip] == true)
				{
					format(msgas,600,"{cb4335}Los Santos Gyvenimas\n{FFFFFF}Đv. Kalëdos 2020\n\n\n\
						Ačiű tau uţ pagalbŕ! Đtai, kŕ noriu padovanoti tau atgal:\n\
						• "#TEXT_BLUE"+10 dienř VIP statuso"#TEXT_WHITE"\n\
						Sugráţk rytoj ir turësiu tau naujŕ misijŕ!");
				}
				else
				{
					format(msgas,600,"{cb4335}Los Santos Gyvenimas\n{FFFFFF}Đv. Kalëdos 2020\n\n\n\
						Ačiű tau uţ pagalbŕ! Đtai, kŕ noriu padovanoti tau atgal:\n\
						• "#TEXT_BLUE"10 dienř VIP statuso"#TEXT_WHITE"\n\
						Sugráţk rytoj ir turësiu tau naujŕ misijŕ!");
				}
				playerDB[playerid][vip]=true;
				new query[256];
				format(query,sizeof(query),"UPDATE `Account` SET `Vip`=`Vip`+10 WHERE `Name` = '%s'",ReturnName(playerid));
				mysql_query(query);
				gavodovana=3;
			}
		}
		case 1: // 21
		{
			if(IsPlayerAttachedObjectSlotUsed(playerid, SLOT_LAGAMINAS))
			{
				RemovePlayerAttachedObject(playerid, SLOT_LAGAMINAS);
				format(msgas,600,"{cb4335}Los Santos Gyvenimas\n{FFFFFF}Đv. Kalëdos 2020\n\n\n\
					Ačiű tau uţ pagalbŕ!\n\n\
					3 laiđkai dël veluojančiř mokesčiř, 4 laiđkai kalbantys apie pasiekimus... Na bent jau turime 2 laiđkus Kalëdř Seneliui!\n\
					O tavo namai dar nepapuođti đventëms? Đtai, kŕ noriu padovanoti tau atgal:\n\
					• "#TEXT_BLUE"Kalëdiniai papuođimai namams"#TEXT_WHITE"\n\
					• "#TEXT_BLUE"5.000$"#TEXT_WHITE"\n\n\
					Naudok komandŕ "#TEXT_BLUE"/padetidovana"#TEXT_WHITE" savo namuose, kad pasidëtum baldus.\n\
					Sugráţk rytoj ir turësiu tau naujŕ misijŕ!");
				GivePlayerMoneyA(playerid, 5000);
				gavodovana=2;
			}
		}
		case 2: // 22
		{
			if(GetPVarInt(playerid, "Mesos") >= 10)
			{
				SetPVarInt(playerid, "Mesos", 0);
				SetPVarInt(playerid, "RenkaMesas", 0);
				format(msgas,600,"{cb4335}Los Santos Gyvenimas\n{FFFFFF}Đv. Kalëdos 2020\n\n\n\
					Ačiű tau uţ pagalbŕ! Dar kartŕ perskaičiau laiđkŕ ir supratau, kad manćs prađë mësos koldűnř, o ne statűlos...\n\
					Nebeţinau, kur man dëti visus điuos lavonus. Galbűt jie domina tave? Đtai, kŕ noriu padovanoti tau atgal:\n\
					• "#TEXT_BLUE"Mësos statűlos baldai"#TEXT_WHITE"\n\
					• "#TEXT_BLUE"1.000 XP"#TEXT_WHITE"\n\n\
					Naudok komandŕ "#TEXT_BLUE"/padetidovana"#TEXT_WHITE" savo namuose, kad pasidëtum baldus.\n\
					Ir nepamirđk iđsisaugoti ţaidimo! Sugráţk rytoj ir turësiu tau naujŕ misijŕ!");
				SetPlayerScore(playerid, GetPlayerScore(playerid) + 1000);
				SetPlayerWantedLevel(playerid, 0);
				gavodovana=2;
			}
		}
		case 3: // 23 vynas
		{
			if(GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_DRINK_WINE)
			{
				SetPlayerSpecialAction(playerid, SPECIAL_ACTION_NONE);
				format(msgas,600,"{cb4335}Los Santos Gyvenimas\n{FFFFFF}Đv. Kalëdos 2020\n\n\n\
					Vaje.. koká tu čia man rađalŕ atneđei?? Tiek to,\n\
					per toká đaltá ađ nors ir spiritŕ gerčiau, duok čia! Đtai, kŕ noriu padovanoti tau atgal:\n\
					• "#TEXT_BLUE"10 vnt. raktř"#TEXT_WHITE"\n\
					• "#TEXT_BLUE"200 kulkř Deagle"#TEXT_WHITE"\n\n\
					Sugráţk rytoj ir turësiu tau naujŕ misijŕ!");
				playerDB[playerid][raktas]+=10;
				if(GunData[playerid][GetWeaponsSlot(24)][0] == 24 && GunData[playerid][GetWeaponsSlot(24)][1] == -100)
				{ 
					DeletePlayerWeapon(playerid, 24);
				}
				GivePlayerWeaponEx(playerid,24,200);
				gavodovana=3;
			}
		}
		case 4: // 24 playerDB[playerid][maistaslauk]=1;
		{
			if(playerDB[playerid][maistaslauk])
			{
				playerDB[playerid][maistaslauk]=0;
				format(msgas,600,"{cb4335}Los Santos Gyvenimas\n{FFFFFF}Đv. Kalëdos 2020\n\n\n\
					Mësainis, tu gal juokauji? Na, bulvytes tai paimsiu.\n\
					Đtai, kŕ noriu padovanoti tau atgal:\n\
					• "#TEXT_BLUE"300 kulkř CSG"#TEXT_WHITE"\n\n\
					Sugráţk rytoj ir turësiu tau naujŕ misijŕ!");
				DeletePlayerWeapon(playerid, 27);
				if(GunData[playerid][GetWeaponsSlot(27)][0] == 27 && GunData[playerid][GetWeaponsSlot(27)][1] == -100)
				{ 
					DeletePlayerWeapon(playerid, 27);
				}
				GivePlayerWeaponEx(playerid,27,300);
				gavodovana=3;
			}
		}
		case 5: // 25 1g zoles
		{
			if(playerDB[playerid][zole] > 0)
			{
				playerDB[playerid][zole]--;
				format(msgas,600,"{cb4335}Los Santos Gyvenimas\n{FFFFFF}Đv. Kalëdos 2020\n\n\n\
					Ačiű tau uţ pagalbŕ! Đtai, kŕ noriu padovanoti tau atgal:\n\
					• "#TEXT_BLUE"20 vnt. sëklř"#TEXT_WHITE"\n\
					• "#TEXT_BLUE"5 vnt. LSD"#TEXT_WHITE"\n\n\
					Sugráţk rytoj ir turësiu tau naujŕ misijŕ!");
				playerDB[playerid][seklos]+=20;
				playerDB[playerid][lsd]+=5;
				gavodovana=3;
			}
		}
		case 6: // 26 /dovana V_P
		{
			format(msgas,600,"{cb4335}Los Santos Gyvenimas\n{FFFFFF}Đv. Kalëdos 2020\n\n\n\
				Ačiű tau uţ pagalbŕ! Ir ačiű uţ dalyvavimŕ LSG Kalëdiniam evente, iki susitikimo kitais metais!!");
			ShowPlayerDialog(playerid, 15548, DIALOG_STYLE_MSGBOX, "Kalëdř Senelis",msgas, "Gerai","");
			return 1;
			//gavodovana=true;
		}
		default:
		{
			SendInfoMessage(playerid,"~r~Klaida!");
			return 1;
		}
	}
	if(gavodovana)
	{
		ShowPlayerDialog(playerid, 15548, DIALOG_STYLE_MSGBOX, "Kalëdř Senelis",msgas, "Gerai","");
		PlayerPlaySound(playerid,4201,0,0,0);
		VykdoMisija(playerid,kaledudiena,gavodovana); // 2 - pending prize or 3 - prize received
	}
	else
	{
		KaleduMisija(playerid,kaledudiena);
	}
	return 1;
}
