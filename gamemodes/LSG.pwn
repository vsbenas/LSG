				/*if(playerDB[playerid][amfetaminas]+kiek>10)
				{
					SendInfoMessage(playerid,"Negali tiek pirkti, nes Nepavilksi !");
					SendInfoMessage(playerid," Nepavelka");
					return 0;
				}*/
				if(playerDB[dealeris][amfetaminas] < kiek) return SendInfoMessage(playerid,"Jis tiek nebeturi!");
				playerDB[dealeris][amfetaminas]-=kiek;
				ProcessAchievement(dealeris,35);
				playerDB[playerid][amfetaminas]+=kiek;
				GivePlayerMoneyA(playerid,-kaina*kiek);
				GivePlayerMoneyA(dealeris,kaina*kiek);
				SendInfoMessage(playerid," Narkotikai priimti.");
				SendInfoMessage(playerid," Narkotikai atiduoti.");

