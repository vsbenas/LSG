new AC_PutInVehicle[MAX_PLAYERS];
stock PutPlayerInVehicleEx(playerid, vehicleid, seatid)
{
	AC_PutInVehicle[playerid]=1;
	return PutPlayerInVehicle(playerid, vehicleid, seatid);
}
#define PutPlayerInVehicle PutPlayerInVehicleEx


stock SetPlayerSkinEx(playerid,skinid)
{
	if( GetPlayerSpecialAction( playerid ) != SPECIAL_ACTION_NONE )
        SetPlayerSpecialAction( playerid, SPECIAL_ACTION_NONE );
	if(playerDB[playerid][akiniai])
	{
		if(IsPlayerAttachedObjectSlotUsed(playerid,AKINIU_SLOT))
			SetPlayerAttachedObject(playerid, AKINIU_SLOT, CommonRed+playerDB[playerid][akiniai]-1, 2, AkiniuOffSet[skinid][0], AkiniuOffSet[skinid][1], AkiniuOffSet[skinid][2], AkiniuOffSet[skinid][3], AkiniuOffSet[skinid][4], AkiniuOffSet[skinid][5],AkiniuOffSet[skinid][6],AkiniuOffSet[skinid][6]);
	}
	if(playerDB[playerid][kepure])
	{
		if(IsPlayerAttachedObjectSlotUsed(playerid,CAP_SLOT))
			AttachKepure(playerid,skinid);			
	}
	if(playerDB[playerid][salmas])
	{
		if(IsPlayerAttachedObjectSlotUsed(playerid,SALMO_SLOT))
			UzdetiSalma(playerid,Salmai[playerDB[playerid][salmas]-1]);
	}
	new vehicle, seat = GetPlayerVehicleSeat(playerid);
    if(seat != -1) 
    {
        vehicle = GetPlayerVehicleID(playerid);
        ClearAnimations(playerid);
        SetPlayerSkin(playerid, skinid);        
        PutPlayerInVehicle(playerid, vehicle, seat);
    }
	return SetPlayerSkin(playerid,skinid);
}
#define SetPlayerSkin(%0,%1) SetPlayerSkinEx(%0,%1)
stock AddVehicleComponentEx(vehicleid,componentid)
{
	if(!IsComponentidCompatible(GetVehicleModel(vehicleid), componentid)) return 0;
	if(componentid == 1010)
	{
		VehicleNitro[vehicleid]=1;
	}
	return AddVehicleComponent(vehicleid,componentid);
}
#define AddVehicleComponent AddVehicleComponentEx
