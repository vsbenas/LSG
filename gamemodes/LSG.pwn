PUB:LoadRadio(playerid)
{
	Streamer_Update(playerid);
	new place = GetPlace(playerid);
	if(place == PLACE_HOUSE)
	{
		new housenumber = GetPlayerHouseID(playerid);
		if(housenumber >= 0 && hInfo[housenumber][hRadio] > 0 && (hInfo[housenumber][hRadio] -1 < sizeof(RADIO_PLUGIN)) && !playerDB[playerid][klausoimtuvo])
		{
			/*
			Audio_Stop(playerid,playerDB[playerid][radija]);*/
			StopAudioStreamForPlayer(playerid);
			if(hInfo[housenumber][polyId] != -1)
				PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[hInfo[housenumber][hRadio]-1][RADIO_URL],hInfo[housenumber][iconx],hInfo[housenumber][icony],hInfo[housenumber][iconz],50.0,true);
			else
				PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[hInfo[housenumber][hRadio]-1][RADIO_URL],Inter[ hInfo[housenumber][vidus] ][ IntX ],Inter[ hInfo[housenumber][vidus] ][ IntY ],Inter[ hInfo[housenumber][vidus] ][ IntZ ],200.0); // zip
			playerDB[playerid][stotis] = hInfo[housenumber][hRadio]-1;
			playerDB[playerid][klausosi] = 0;		
		}
	}
	if(place == PLACE_BIZ)
	{
		new i = GetPlayerVirtualWorld(playerid) - MAX_HOUSES*2;
		if(i >= 0 && BusinessInfo[i][bRadio] > 0 && (BusinessInfo[i][bRadio]-1 < sizeof(RADIO_PLUGIN)) && !playerDB[playerid][klausoimtuvo])
		{
			StopAudioStreamForPlayer(playerid);
			PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[BusinessInfo[i][bRadio]-1][RADIO_URL],BusinessInfo[i][bExitX],BusinessInfo[i][bExitY],BusinessInfo[i][bExitZ],200.0,true);	
		}
	}
}



public GavaiEmail(playerid)
{
	GameTextForPlayer(playerid,"Gautas E-Mail(/email)", 2000,5);

