stock GetPlayerAmmoEx(playerid)
{
	new var = GetPlayerAmmo(playerid);
	if(GetPlayerWeapon(playerid) != 42)
	{
		if(var > 10000) var=-100;
		else if(var < -1) var=-100;
	}
	else
	{
		if(var < -1) var=-var;
	}
	return var;
}
#define GetPlayerAmmo GetPlayerAmmoEx
stock GetPlayerWeaponDataEx(playerid,slot,&weapons,&ammo)
{
	new a,b;
	new var = GetPlayerWeaponData(playerid,slot,a,b);
	weapons=a;
	ammo=b;

	if(weapons != 42)
	{
		if(ammo > 10000) ammo=-100;
		else if(ammo < -1) ammo=-100;
	}
	else
	{
		if(ammo < -1) ammo=-ammo;
	}
	if(weapons >= 47)
		weapons=46;


	return var;
}
