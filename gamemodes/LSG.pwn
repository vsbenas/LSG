stock LikoSedeti(playerid)
{
	if(playerDB[playerid][kalejimo_laikas] < 1)
	{
		if(playerDB[playerid][kalejimo_total] >= 7200) ProcessAchievement(playerid,23);
	    UnjailPlayer(playerid,1862.1591,-1708.8055,3203.5859,359.00,0);
		return 1;
	}

	playerDB[playerid][kalejimo_laikas] --;
	
	new msg[128];
	new minutess = playerDB[playerid][kalejimo_laikas] / 60;
	new atsakimas = minutess * 60;
	new sekunde = playerDB[playerid][kalejimo_laikas] - atsakimas;
	new valanda = minutess / 60;
	new atsakimas2 = valanda * 60;
	if (minutess > 60){ minutess =  minutess - atsakimas2; }

	if(sekunde <= 9)
	{
		format(msg,sizeof(msg),"        ~n~~n~~n~~n~~n~~n~~n~~n~~n~~g~Busi Laisveje po~y~ %02d:%02d:0%i",valanda,minutess,sekunde);
		GameTextForPlayer(playerid, msg, 1500, 3);
	}else{
		format(msg,sizeof(msg),"        ~n~~n~~n~~n~~n~~n~~n~~n~~n~~g~Busi Laisveje po~y~ %02d:%02d:%i",valanda,minutess,sekunde);
		GameTextForPlayer(playerid, msg, 1500, 3);
	}

	return 1;
}


stock Stats(playerid,forplayerid)
{
	new teisesz[128],HP[128],gau[128],pinigeliai[128];
	new Float:xhealth, Float:xarmour;
	GetPlayerHealth(playerid,xhealth);
	GetPlayerArmour(playerid,xarmour);
	SendClientMessage(forplayerid,GREEN,"____________________Informacija___________________________");
	format(teisesz,sizeof(teisesz),"|Vardas [%s] Pavardë [%s] Patirtis [%sXP]|",GetPlayerFirstName(playerid),GetPlayerLastName(playerid),FormatNumber(GetPlayerScore(playerid)));
	format(HP,sizeof(HP),"|Sveikatos bűklë [%i%%] Đarvai [%i%%] Sotumas [%i%%]|",floatround(xhealth),floatround(xarmour),(floatround(playerDB[playerid][sotumas])));
	if(playerid == forplayerid)
		format(gau,sizeof(gau),"|Gaudomas [%i lygiř] Kalëjime [%i sec] Kreditai [%i]|",GetPlayerWantedLevel(playerid),playerDB[playerid][kalejimo_laikas],playerDB[playerid][kreditai]);
    else
    	format(gau,sizeof(gau),"|Gaudomas [%i lygiř] Kalëjime [%i sec]|",GetPlayerWantedLevel(playerid),playerDB[playerid][kalejimo_laikas]);
    format(pinigeliai,sizeof(pinigeliai),"|Pinigai [%s€] Banke [%s€] Darbas [%s]|",FormatNumber(playerDB[playerid][pinigai]),FormatNumber(playerDB[playerid][banke]),ReturnJob(playerDB[playerid][specialybe]));
	SendClientMessage(forplayerid,YELLOW,teisesz);
	SendClientMessage(forplayerid,COLOR,HP);
	SendClientMessage(forplayerid,RED,gau);
	SendClientMessage(forplayerid,WHITE,pinigeliai);
	/*
	new bizid = ArTuriBiz(playerid);
	if(bizid != -1)
	{
	    format(teisesz,sizeof(teisesz),"|Verslas: [%s(%s)] Sukaupta pinigu: [%i€]|",BusinessInfo[bizid][bName],GetBussinessType(BusinessInfo[bizid][bType]),BusinessInfo[bizid][bEarning]);
	    SendClientMessage(forplayerid,COLOR,teisesz);
	}*/
	new hid1=-1,
	    hid2=-1,
		name[MAX_PLAYER_NAME];
	GetPlayerName(playerid,name,sizeof(name));
	foreach(Houses,i)
	{
	    if(0==strcmp(name,hInfo[i][Name],false))
	    {
	        if(hid1==-1)
	        {
	            hid1=i;
	            continue;
	        }
	        else
	        {
	            hid2=i;
	            break;
	        }
	    }
	}
	new msg[128];
	if(hid1 == -1 && playerDB[playerid][namu]!=0) playerDB[playerid][namu]=0;
	if(hid1!=-1)
	{
		if(hid2==-1 && playerDB[playerid][namu]<1) playerDB[playerid][namu]=1;
		else if(hid2 !=-1 && playerDB[playerid][namu]<2) playerDB[playerid][namu]=2;
		if(hid2==-1)format(msg,sizeof(msg),"|Namai: Nr.%i(%i lvl, %s€)|",hid1,hInfo[hid1][vidus]+1,FormatNumber(hInfo[hid1][pinigai]));
		else format(msg,sizeof(msg),"|Namai: Nr.%i(%i lvl, %s€), Nr.%i(%i lvl, %s€)|",hid1,hInfo[hid1][vidus]+1,FormatNumber(hInfo[hid1][pinigai]),hid2,hInfo[hid2][vidus]+1,FormatNumber(hInfo[hid2][pinigai]));
		SendClientMessage(forplayerid,COLOR,msg);
	}
	SendClientMessage(forplayerid,GREEN,"_______________________________________________________________");
	if(ArTuriBiz(playerid) != -1) SendClientMessage(forplayerid,RED,"Verslu informacija galite suzinoti parase /verslai");
	return 1;
}


