stock SetPlayerFaceActor(actorid,giveplayerid) 
{
    new
        Float: pX,
        Float: pY,
        Float: pZ,
        Float: gX,
        Float: gY,
        Float: gZ
    ;
    if(GetActorPos(actorid, pX, pY, pZ) && GetPlayerPos(giveplayerid, gX, gY, gZ)) {
    	new Float:ang = 180-atan2((gX - pX), (gY - pY));
        SetPlayerFacingAngle(giveplayerid, ang);
    }
    return false;
}

stock ActorServe(playerid)
{
	new Float:dist = 999999.9;
	new actorid = -1;
	new Float:Coo[3];
	for(new i;i<MAX_ACTORS;i++) if(IsValidActor(i) && IsActorStreamedIn(i, playerid))
	{
		GetActorPos(i, Coo[0], Coo[1], Coo[2]);
		new Float: di = GetPlayerDistanceFromPoint(playerid, Coo[0], Coo[1], Coo[2]);
		if(di < dist)
		{
			dist = di;
			actorid = i;
		}
	}
	if(IsPlayerAdmin(playerid))
	{
		new msg[256];
		format(msg,256,"%.2f",dist);
		SendClientMessage(playerid, -1, msg);
	}
	if(actorid == -1)
		return 1;
	SetPlayerFaceActor(actorid,playerid);
	ApplyActorAnimation(actorid, "SHOP", "SHP_Serve_End", 4.0,0,0,0,0,0);
	//SetTimerEx("BackToIdle", 7000, false, "i", actorid);
	ApplyAnimation(playerid, "DEALER", "shop_pay", 4.0, 0, 0, 0, 0, 0); 
	return 1;
}

stock TryIrengti(playerid,nta,houseid)
{
	new query[256];
	format(query,256,"SELECT * FROM Irengimas Where houseid=%i AND data > SUBDATE(NOW(), 1)",houseid);
	mysql_function_query(SQL, query, true, "SQL_CheckNTA", "iii", playerid,nta,houseid);
}

stock LoadNTA(playerid)
{
	new query[256];
	format(query,256,"SELECT houseid FROM Irengimas Where nta='%s' AND data > SUBDATE(NOW(), 1) order by data desc",ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_LoadNTA", "i", playerid);
}

stock CheckNTAIrengimas(playerid,houseid,showdialog=0)
{
	new query[256];
	format(query,256,"SELECT * FROM Irengimas Where houseid=%i AND nta='%s' AND data > SUBDATE(NOW(), 1)",houseid,ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_CheckNTABaldai", "iii", playerid,houseid,showdialog);

}


