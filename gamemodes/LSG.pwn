			SendClientMessage(playerid,COLOR,"Suma bus neismokama, jei:");
			SendClientMessage(playerid,COLOR,"1. Susizeisite pats.");
			SendClientMessage(playerid,COLOR,"2. Susizeisite avarijoje.");
