		case 2: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 18637, 4, 0.3, 0, 0, 0, 170, 270, 1, 1, 1); // police shield
		case 3: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 18641, 5, 0.1, 0.02, -0.05, 0, 0, 0, 1, 1, 1); // flashlight
		case 4: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 19318, 6); // gitara
		case 5: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 19319, 6); // gitara 2
		case 6: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 355, 1, 0.200000, -0.119999, -0.059999, 0.000000, 206.000000, 0.000000, 1.000000, 1.000000, 1.000000); // zaislinis ak-47
		case 7: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 356, 1, 0.200000, -0.119999, -0.059999, 0.000000, 206.000000, 0.000000, 1.000000, 1.000000, 1.000000); // zaislinis m16
		case 8: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 18643, 6, 0.105354, -0.000235, 0.042348, 208.893966, 15.041192, 356.708282 ); // raudonas lazeris
		case 9: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 19080, 6, 0.105354, -0.000235, 0.042348, 208.893966, 15.041192, 356.708282 ); // melynas lazeris
		case 10: SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 19083, 6, 0.105354, -0.000235, 0.042348, 208.893966, 15.041192, 356.708282 ); // zalias lazeris
		case 11: SetPlayerAttachedObject( playerid, DOVANOS_SLOT, 19078, 1, 0.328340, -0.019586, -0.157024, 0.000000, 0.000000, 0.000000, 0.509503, 0.486798, 0.625176 ); 
		case 12: SetPlayerAttachedObject( playerid, DOVANOS_SLOT, 19079, 1, 0.328340, -0.019586, -0.157024, 0.000000, 0.000000, 0.000000, 0.509503, 0.486798, 0.625176 ); 
