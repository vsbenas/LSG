#define SendClientMessage(%0,%1,%2) SendClientMessageLT(%0,%1,%2)
#define SendClientMessageToAll(%0,%1) SendClientMessageToAllLT(%0,%1)

stock SendClientMessageEx(playerid, color, text[], secondcolor = INVALID_PLAYER_ID)
{
    if(strlen(text) > 120)
    {
		new string[200];
        new text1[200],
            text2[200];
        new cutoff = 120;
        for(new i=120;i>109;i--)
        {
        	if(text[i] == ' ')
        	{
        		cutoff=i;
        		break;
        	}
        }

        strmid(text2, text, cutoff, 200);
        strmid(text1, text, 0, cutoff);
                
        format(string, 200, "%s...", text1);
        SendClientMessage(playerid, color, string);
        
        format(string, 200, "...%s", text2);
        if(secondcolor != INVALID_PLAYER_ID)
        	color=secondcolor;
        SendClientMessage(playerid, color, string);
    }
    else SendClientMessage(playerid, color, text);
}
stock SendClientMessageToAllEx(color, text[])
{
    if(strlen(text) > 100)
    {
		new string[128];
        new text1[128],
            text2[128];

        new cutoff = 100;
        for(new i=100;i>90;i--)
        {
        	if(text[i] == ' ')
        	{
        		cutoff=i;
        		break;
        	}
        }    
        strmid(text2, text, cutoff, 200);
        strmid(text1, text, 0, cutoff);
                
        format(string, 128, "%s...", text1);
        SendClientMessageToAll(color, string);
        
        format(string, 128, "...%s", text2);
        SendClientMessageToAll(color, string);
    }
    else SendClientMessageToAll(color, text);
}

