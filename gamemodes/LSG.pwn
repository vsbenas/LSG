}

new StoredNames[MAX_PLAYERS][MAX_PLAYER_NAME];
public OnPlayerConnect(playerid)
{
	if(AntiNameHack(playerid)) return 1;
	initAuthKey(playerid);
	SetPVarInt(playerid, "PXP", -1);
	if(IsPlayerNPC(playerid))
	{
		PlayerSpectated[playerid] = -1;
		PlayerNPC[playerid]=1;
		new ip_addr_npc[64+1];
        new ip_addr_server[64+1];
        GetServerVarAsString("bind",ip_addr_server,64);
        GetPlayerIp(playerid,ip_addr_npc,64);
        
        if(!strlen(ip_addr_server)) {
            ip_addr_server = "127.0.0.1";
        }
        
        if(strcmp(ip_addr_npc,ip_addr_server,true) != 0) 
		{
            // this bot is remote connecting
            printf("NPC: Got a remote NPC connecting from %s and I'm kicking it.",ip_addr_npc);
            Kick(playerid);
            return 0;
        }
        printf("NPC: Connection from %s is allowed.",ip_addr_npc);
		return 1;
	}	
	else PlayerNPC[playerid]=0;
	Streamer_SetPlayerTickRate(playerid, 70);
	RenderTexts(playerid);
