stock ShowPlayerDialogEx(playerid,dialogid,styles,captionas[],infox[],button1s[],button2s[])
{
	if(isnull(infox) || strlen(infox) < 2)
		return 1;
	gPlayerDialog[playerid]=dialogid;
	if(BitFlag_Get(PConfig[playerid],PCFG_RAIDES)) //if(sulietuvinti[playerid])
	{
		new infoxx[4096],
			captionasx[64],
			button1sx[50],
			button2sx[50];
		for(new i=0, j=strlen(infox);i<j;i++)
		{
			switch(infox[i]) 
			{
				case 'ŕ': infoxx[i]='a';
				case 'č': infoxx[i]='c';
				case 'ć': infoxx[i]='e';
				case 'ë': infoxx[i]='e';
				case 'á': infoxx[i]='i';
				case 'đ': infoxx[i]='s';
				case 'ř': infoxx[i]='u';
				case 'ű': infoxx[i]='u';
				case 'ţ': infoxx[i]='z';
				case 'Ŕ': infoxx[i]='A';
				case 'Č': infoxx[i]='C';
				case 'Ć': infoxx[i]='E';
				case 'Ë': infoxx[i]='E';
				case 'Á': infoxx[i]='I';
				case 'Đ': infoxx[i]='S';
				case 'Ř': infoxx[i]='U';
				case 'Ű': infoxx[i]='U';
				case 'Ţ': infoxx[i]='Z';
				default: infoxx[i]=infox[i];
			}
		}
		for(new i=0, j=strlen(button1s);i<j;i++)
		{
			switch(button1s[i]) 
			{
				case 'ŕ': button1sx[i]='a';
				case 'č': button1sx[i]='c';
				case 'ć': button1sx[i]='e';
				case 'ë': button1sx[i]='e';
				case 'á': button1sx[i]='i';
				case 'đ': button1sx[i]='s';
				case 'ř': button1sx[i]='u';
				case 'ű': button1sx[i]='u';
				case 'ţ': button1sx[i]='z';

				case 'Ŕ': button1sx[i]='A';
				case 'Č': button1sx[i]='C';
				case 'Ć': button1sx[i]='E';
				case 'Ë': button1sx[i]='E';
				case 'Á': button1sx[i]='I';
				case 'Đ': button1sx[i]='S';
				case 'Ř': button1sx[i]='U';
				case 'Ű': button1sx[i]='U';
				case 'Ţ': button1sx[i]='Z';
				default: button1sx[i]=button1s[i];
			}
		}
		for(new i=0, j=strlen(button2s);i<j;i++)
		{
			switch(button2s[i]) 
			{
				case 'ŕ': button2sx[i]='a';
				case 'č': button2sx[i]='c';
				case 'ć': button2sx[i]='e';
				case 'ë': button2sx[i]='e';
				case 'á': button2sx[i]='i';
				case 'đ': button2sx[i]='s';
				case 'ř': button2sx[i]='u';
				case 'ű': button2sx[i]='u';
				case 'ţ': button2sx[i]='z';

				case 'Ŕ': button2sx[i]='A';
				case 'Č': button2sx[i]='C';
				case 'Ć': button2sx[i]='E';
				case 'Ë': button2sx[i]='E';
				case 'Á': button2sx[i]='I';
				case 'Đ': button2sx[i]='S';
				case 'Ř': button2sx[i]='U';
				case 'Ű': button2sx[i]='U';
				case 'Ţ': button2sx[i]='Z';
				default: button2sx[i]=button2s[i];
			}
		}
		for(new i=0, j=strlen(captionas);i<j;i++)
		{
			switch(captionas[i]) 
			{
				case 'ŕ': captionasx[i]='a';
				case 'č': captionasx[i]='c';
				case 'ć': captionasx[i]='e';
				case 'ë': captionasx[i]='e';
				case 'á': captionasx[i]='i';
				case 'đ': captionasx[i]='s';
				case 'ř': captionasx[i]='u';
				case 'ű': captionasx[i]='u';
				case 'ţ': captionasx[i]='z';

				case 'Ŕ': captionasx[i]='A';
				case 'Č': captionasx[i]='C';
				case 'Ć': captionasx[i]='E';
				case 'Ë': captionasx[i]='E';
				case 'Á': captionasx[i]='I';
				case 'Đ': captionasx[i]='S';
				case 'Ř': captionasx[i]='U';
				case 'Ű': captionasx[i]='U';
				case 'Ţ': captionasx[i]='Z';
				default: captionasx[i]=captionas[i];
			}
		}
		return ShowPlayerDialog(playerid,dialogid,styles,captionasx,infoxx,button1sx,button2sx);
		
	}
	return ShowPlayerDialog(playerid,dialogid,styles,captionas,infox,button1s,button2s);
}
