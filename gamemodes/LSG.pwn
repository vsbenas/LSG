{
	SetCameraBehindPlayer(playerid);
	return 1;
}

public IsAdminCall(playerid)
{
	if(playerDB[playerid][admin]) return 1;
	return 0;
}



public Vagie(playerid, listid)
{
	if(!IsPlayerConnected(playerid)) return 1;
	if(!IsPlayerInAnyVehicle(playerid)) return 1;
	if(listid == 1)
	{
		SetPlayerCheckpoint(playerid,-1550.0287,122.9966,3.5547,6.0);
		vagia[playerid]=1;
	}
	if(listid == 2)
	{
		SetPlayerCheckpoint(playerid,-1858.9226,-1608.0735,21.3262,6.0);
		vagia[playerid]=2;
	}
	if(listid == 3)
	{
		SetPlayerCheckpoint(playerid,941.4507,2071.1697,10.3999,6.0);
		vagia[playerid]=3;
	}
	if(listid == 4)
	{
		SetPlayerCheckpoint(playerid,-2258.8398,2386.1414,4.8071,6.0);
		vagia[playerid]=4;
	}
	new PA = random(10);
	new vehicleid = GetPlayerVehicleID(playerid);
	if(PA==2)
	{
		SendInfoMessage(playerid,"Sekmingai atjungete automobilio apsauga ir uzkurete varikli.");
		GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
		SetVehicleParamsEx(vehicleid,true,true,false,-1,VehVars[4],VehVars[5],VehVars[6]);
	}
	else
	{
		GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
		SetVehicleParamsEx(vehicleid,true,true,true,-1,VehVars[4],VehVars[5],VehVars[6]);
		new Float:coo[3];
		GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
		new name[24];
		GetPlayerName(playerid,name,24);
		new msghg[128];
		format(msghg,sizeof(msghg)," [racija] Operatorë: %s pavogë automobilá! Rađykite /imti kad priimti iđkvietimŕ.",name);
		SendMessageToTeisesauga(ORANGE,msghg);
		kvieciapd=playerid;
		GetPlayerPos(playerid,kvieciapdcord[0],kvieciapdcord[1],kvieciapdcord[2]);
	}
	SetTimerEx("NoAlarm",5000,false,"i",vehicleid);
	if(vehicleDB[vehicleid][gas] < 2) vehicleDB[vehicleid][gas]=50;
	MLog(playerid,"Pavoge Masina","i",listid);
	return 1;
}

forward SetPlayerPosRemote(playerid,Float:x,Float:y,Float:z, int, vw, freeze);
public SetPlayerPosRemote(playerid,Float:x,Float:y,Float:z, int, vw, freeze)
{
	return SetPlayerPoz(playerid,x,y,z,int,vw,freeze);
}
stock SetPlayerPoz(playerid,Float:x,Float:y,Float:z,int=-1,vw=-1, freeze = 1) // 100 ms default
{
	// before teleporting

	new place = GetPlace(playerid);
	if(place != PLACE_NONE)
	{
		if(place == PLACE_BIZ)
		{
			new i = GetPlayerVirtualWorld(playerid) - MAX_HOUSES*2;
			if(BusinessInfo[i][bRadio] && !playerDB[playerid][klausoimtuvo])
			{
				StopAudioStreamForPlayer(playerid);
				/*
				Audio_Stop(playerid,playerDB[playerid][radija]);
				playerDB[playerid][radija] = -1;*/
				playerDB[playerid][klausosi] = 0;		
			}
		}
		else if(place == PLACE_HOUSE)
		{
			new i = GetPlayerHouseID(playerid);
			if(hInfo[i][hRadio] && !playerDB[playerid][klausoimtuvo])
			{
				StopAudioStreamForPlayer(playerid);
				/*
				Audio_Stop(playerid,playerDB[playerid][radija]);
				playerDB[playerid][radija] = -1;*/
				playerDB[playerid][klausosi] = 0;		
			}
		}
	}
	new items[25];
	new num_items = Streamer_GetNearbyItems(x,y,z, STREAMER_TYPE_OBJECT, items,sizeof(items), 50.0);
	if(num_items < 20) // can be adjusted
	{
		freeze = 0;
	}
	new ping = GetPlayerPing(playerid);
	new time = 100 + ping*20;
	if(playerDB[playerid][ikalintas]) 
		time += 2000;

	// teleporting magic

	playerDB[playerid][pSetPos][0]=x;
    playerDB[playerid][pSetPos][1]=y;
    playerDB[playerid][pSetPos][2]=z;

	if(playerDB[playerid][ant] || playerDB[playerid][suristas] || playerDB[playerid][pila] || PFreezed[playerid])
		freeze=0; // dont freeze because this will unfreeze automatically

	if(int != -1)
		SetPlayerInterior(playerid, int);
	if(vw != -1)
		SetPlayerVirtualWorld(playerid, vw);
	Streamer_UpdateEx(playerid, x, y, z, vw, int, _, time, freeze); // does SetPlayerPos automatically

	// additional checks

	CancelEdit(playerid);
	PlayerEnterTime[playerid]-=221;
	NoCheckTP[playerid]=4;
	//SetCameraBehindPlayer(playerid);
	if(FPS[playerid])  
		AttachCameraToObject(playerid, FirstPersonObject[playerid]);
	if(BallHolder == playerid)
	    RecreateBall();
	return 1;
}
stock Stop(playerid)
{
	new Float:coo[3];
	GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
	SetPlayerPos(playerid,coo[0],coo[1],coo[2]);
}

stock SetVehiclePoz(vehicleid,Float:x,Float:y,Float:z)
{

	foreach(Player, i)
	{
		if(IsPlayerInVehicle(i,vehicleid) || GetPlayerSurfingVehicleID(i) == vehicleid)
		{
			playerDB[i][pSetPos][0]=x;
			playerDB[i][pSetPos][1]=y;
			playerDB[i][pSetPos][2]=z;
			new time = 500 + GetPlayerPing(i)*20;
			if(playerDB[i][ikalintas]) 
				time += 2000;
			Streamer_UpdateEx(i, x, y, z, _, _, _);
			Streamer_ToggleItemUpdate(i,STREAMER_TYPE_OBJECT , false);
			SetTimerEx("ReenableItems", time, false, "i", i);
			NoCheckTP[i]=3;
		}
	}
	vehicleDB[vehicleid][lastpos][0]=x;
	vehicleDB[vehicleid][lastpos][1]=y;
	vehicleDB[vehicleid][lastpos][2]=z;
	SetVehiclePos(vehicleid,x,y,z);
	return 1;
}
PUB:ReenableItems(playerid)
{
	Streamer_ToggleItemUpdate(playerid, STREAMER_TYPE_OBJECT, true);
}
public Taisykla(veh,playerid)
{
	if(!IsPlayerInRangeOfPointEx(5, playerid, 1526.4025,1642.5685,11.7228)){ KillTimer(taisyklaz[playerid]); taisyklaz[playerid]=-1; return 1; }
	new Float:HP;
	GetVehicleHealth(veh,HP);
	if(HP+50 <1000)
	{
		SetVehicleHealth(veh,HP+50);
		SendInfoMessage(playerid,"Taisomas masinos variklis.....");
		return 1;
	}
	else { RepairVehicle(veh); SendInfoMessage(playerid,"Taisoma isorine bukle......"); }
	SendInfoMessage(playerid,"Pilami degalai....");
	if(vehicleDB[veh][gas] < 95 ) {vehicleDB[veh][gas]+=5;}
	else SendInfoMessage(playerid,"Jusu automobilis visiskai pataisytas!");
	return 1;
}

