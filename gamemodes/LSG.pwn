stock CallLiftas(playerid,did,aukstas)
{
	if(Daugiabuciai[did][dLiftU])
		return SendInfoMessage(playerid,"Liftas jau naudojamas!");
	if(aukstas == Daugiabuciai[did][dLift])
	{
		MenuLift(playerid,did,aukstas);
	}
	else
	{
		GameTextForPlayer(playerid,"~y~Liftas iskviestas",3000,3);
		new time = abs(aukstas-Daugiabuciai[did][dLift])*1500;
		
		SetTimerEx("GetLift",time,0,"iii",playerid,did,aukstas);
		//Daugiabuciai[did][dLift]=1;
		Daugiabuciai[did][dLiftU]=true; 
	}
	return 1;
}
forward GetLift(playerid,did,aukstas);
public GetLift(playerid,did,aukstas)
{
	Daugiabuciai[did][dLiftU]=false; 
	Daugiabuciai[did][dLift]=aukstas;
	if(IsPlayerInRangeOfPointEx(3.0,playerid,VLiftoDurys[aukstas][0],VLiftoDurys[aukstas][1],VLiftoDurys[aukstas][2])) MenuLift(playerid,did,aukstas);
	return 1;
}

stock MenuLift(playerid,did,aukstas) 
{
	if(Daugiabuciai[did][dLiftU]) return SendInfoMessage(playerid,"~r~Liftas jau naudojamas!");
	if(Daugiabuciai[did][dLift] != aukstas) return SendInfoMessage(playerid,"~r~Liftas jau nuvaziavo i kita auksta!");
	new string[512];
	for(new i;i<sizeof(VLiftoDurys);i++)
	{
		if(i!= aukstas) format(string,sizeof(string),"%s{FFFFFF}%i\n",string,i+1);
		else format(string,sizeof(string),"%s{FF0000}%i\n",string,i+1);
	}
	ShowPlayerDialog(playerid,5379,DIALOG_STYLE_LIST,"Liftas",string,"Gerai","Atgal");
	return 1;
}
