stock GetHouseStats(playerid, hid)
{
	/*if(playerDB[playerid][specialybe] == 34 && vezainama[playerid]==hid)
	{
		SendInfoMessage(playerid,"Dekojame jums uz apsilankyma. Gaunate "#MONEYP_TURTO_AGENTAS"€ premija.");
		GivePlayerMoneyA(playerid, MONEYP_TURTO_AGENTAS);
		new msg[128];
		vezainama[playerid] = Iter_Random(Houses);
		format(msg,sizeof(msg)," * Vaziuokite prie namo Nr.%i",vezainama[playerid]);
		SendClientMessage(playerid,-1,msg);
	}*/
	for(new i;i<10;i++)
	{
		if(playerDB[playerid][pastas][i]==hid)
		{
			GivePlayerMoneyA(playerid, MONEY_PASTAS);
			ProcessAchievement(playerid,30);
			SendInfoMessage(playerid,"Dekojame jums uz apsilankyma. Gaunate "#MONEY_PASTAS"EUR premija.");
			playerDB[playerid][pastas][i]=0;
			new fail=false;
			//new array[10];
			new msg[256];
			format(msg,sizeof(msg),"Tau liko isvezioti laiskus i siuos namus:");
			for(new x;x<10;x++)
			{
				if(playerDB[playerid][pastas][x])
				{
					if(!fail)
						format(msg,sizeof(msg),"%s %i",msg,playerDB[playerid][pastas][x]);
					else
						format(msg,sizeof(msg),"%s,%i",msg,playerDB[playerid][pastas][x]);
					fail=true;
				}
			}
			if(fail)
			{
				SendClientMessage(playerid,YELLOW,msg);
				
			}
			else
			{
				if(IsPlayerAttachedObjectSlotUsed(playerid, SLOT_LAGAMINAS))
				{
					RemovePlayerAttachedObject(playerid, SLOT_LAGAMINAS);
				}
				SendClientMessage(playerid,YELLOW," * Isveziojai visus laiskus!");
			}
			break;
		}
		//=0;
	}
	new str2[1024];
	if(strcmp(hInfo[hid][Name],"Nera",true)==0)
	{
		//SendClientMessage(playerid, c_y, "Sis namas parduodamas");
		//SendClientMessage(playerid, c_y, "Noredami pirkti, rasykite /pirktinama");
		format(str2,sizeof(str2),"~p~Namas parduodamas!~n~~w~Noredami pirkti rasykite: /pirktinama~n~~w~Kaina: ~y~%i ~w~EUR",hInfo[hid][Cost]);
		if(playerDB[playerid][specialybe] ==34)
		{
			new msg[128];
			format(msg,sizeof(msg),"Kaina NTA agentui: %iEUR",hInfo[hid][Cost]/2);
			SendInfoMessage(playerid,msg);
			//format(str2,sizeof(str2),"%s~n~~w~Kaina NTA: ~y~%i ~w~€",str2);
		}
		//SendClientMessage(playerid, c_y, str2);
		//return 1;
	}
	else
	{
		if(hInfo[hid][islauztos])
		{
			format(str2, sizeof(str2), "~w~ Namas Priklauso ~y~ %s ~n~ ~w~ Namas yra ~y~ islauztas", hInfo[hid][Name]);
		}
		else if(hInfo[hid][Locked]==1)
		{
			format(str2, sizeof(str2), "~w~ Namas Priklauso ~y~ %s ~n~ ~w~ Namas yra ~r~ uzrakintas", hInfo[hid][Name]);
			//SendClientMessage(playerid, c_y, "Namas yra uzrakintas.");
		}
		else
		{
			format(str2, sizeof(str2), "~w~ Namas Priklauso ~y~ %s ~n~ ~w~ Namas yra ~g~ atrakintas", hInfo[hid][Name]);
			//SendClientMessage(playerid, c_y, "Noredami ieit spauskite ENTER arba F");
		}
		if(strcmp(hInfo[hid][Renter],"ForRent",true))
		{
			format(str2, sizeof(str2), "%s~n~~w~Nuomojasi ~y~%s",str2, hInfo[hid][Renter]);
			//SendClientMessage(playerid, c_y, str2);
			
		}
		//SendClientMessage(playerid, c_y, "Namu komandos /namai");
	}
	format(str2,sizeof(str2),"%s~n~~b~/namai",str2);
	GameTextForPlayer(playerid,str2,3000,3);
	if(hInfo[hid][polyId] != -1)
	{
		if(hInfo[hid][hRadio] && (hInfo[hid][hRadio]-1 < sizeof(RADIO_PLUGIN)) && (playerDB[playerid][stotis] != hInfo[hid][hRadio]-1 || GetPVarInt(playerid, "KlausosiRadijos") == 0) && !playerDB[playerid][klausoimtuvo])
		{
			/*
			Audio_Stop(playerid,playerDB[playerid][radija]);*/
			StopAudioStreamForPlayer(playerid);
			PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[hInfo[hid][hRadio]-1][RADIO_URL],hInfo[hid][iconx],hInfo[hid][icony],hInfo[hid][iconz],50.0,true);
			playerDB[playerid][stotis] = hInfo[hid][hRadio]-1;
			playerDB[playerid][klausosi] = 0;		
		}
	}
	return 1;
}

public OnPlayerCommandText(playerid, cmdtext[])
{

    if(strcmp(cmdtext,"/:",true,2)==0)
	{
	    if(!playerDB[playerid][telon]) return SendInfoMessage(playerid,"Jusu telefonas yra isjungtas. Naudokite /telon .");
	    if(playerDB[playerid][ikalintas]) return SendInfoMessage(playerid,"Policija ateme jusu telefona. Prasome naudotis taksofonu.");
		if(cmdtext[2]==0) {SendInfoMessage(playerid,"Greitai atrasyti /: [zinute]"); return 1;}

        new vardas[MAX_PLAYER_NAME],vardas2[MAX_PLAYER_NAME],texts[128];
		if(playerDB[playerid][mobsas] < 2)
		{
			SendInfoMessage(playerid,"Jums nepakanka saskaitos! Pasipildykite ja spaudos kioske.");
			return 1;
		}

        new recieverid = parase[playerid];
        
        if(recieverid == INVALID_PLAYER_ID)
        {
            SendInfoMessage(playerid,"Tau dar niekas neparase.");
			return 1;
		}
        if(playerDB[recieverid][ikalintas]) return SendInfoMessage(playerid,"Telefonas yra uz rysio zonos ribu.");
		if(!playerDB[recieverid][telon]) return SendInfoMessage(playerid,"Gavejo telefonas yra isjungtas.");


		strmid(texts,GetArgument(1, cmdtext,true),0,sizeof(texts));
		if(0==strcmp(texts,"0",true))
		{
		    SendInfoMessage(playerid,"Zinutes be teksto issiusti negalima ");
			return 1;
		}

   		GetPlayerName(playerid,vardas2,sizeof(vardas2));
		GetPlayerName(recieverid,vardas,sizeof(vardas));

		if(!playerDB[playerid][admin]) playerDB[playerid][mobsas]-=2;

		new tex[128];
		if(recieverid != INVALID_PLAYER_ID)
		{
			format(tex,sizeof(tex),"SMS: [%s >> %s ]:",vardas2,vardas);
			SendClientMessage(recieverid,TEXTCOL_SILVER,tex);
			SendClientMessage(recieverid,TEXTCOL_RED,texts);
		}

		if(playerid!=INVALID_PLAYER_ID)
		{
			if(IsPlayerAfk(recieverid)) 
				format(tex,sizeof(tex),"SMS: [%s >> %s {FFFFFF}[AFK]{98B134} ]:",vardas2,vardas);
			else
				format(tex,sizeof(tex),"SMS: [%s >> %s ]:",vardas2,vardas);
			SendClientMessage(playerid,TEXTCOL_GREEN,tex);
			SendClientMessage(playerid,TEXTCOL_RED,texts);
		}
		ProcessAchievement(playerid, 82);
		parase[recieverid]=playerid;
		PlayerPlaySound(recieverid, 1138, 0.0, 0.0, 0.0); // SMS
		return 1;
	}
	if(strcmp(cmdtext,"/.",true,2)==0)
	{
	    if(!playerDB[playerid][admin]) return SendInfoMessage(playerid,"Si komanda tik administratoriams");
		if(cmdtext[2]==0) {SendInfoMessage(playerid,"Greitai atrasyti /. [zinute]"); return 1;}

        new vardas[MAX_PLAYER_NAME],vardas2[MAX_PLAYER_NAME],texts[128];

        new recieverid = lastiadmin;
        
        if(recieverid == -1)
        {
            SendInfoMessage(playerid,"Tau dar niekas neparase.");
			return 1;
		}
        //if(playerDB[recieverid][ikalintas]) return SendInfoMessage(playerid,"Telefonas yra uz rysio zonos ribu.");
		//if(!playerDB[recieverid][telon]) return SendInfoMessage(playerid,"Gavejo telefonas yra isjungtas.");


		strmid(texts,GetArgument(1, cmdtext,true),0,sizeof(texts));
		if(0==strcmp(texts,"0",true))
		{
		    SendInfoMessage(playerid,"Zinutes be teksto issiusti negalima ");
			return 1;
		}

   		GetPlayerName(playerid,vardas2,sizeof(vardas2));
		GetPlayerName(recieverid,vardas,sizeof(vardas));

		new tex[128];
		if(recieverid != INVALID_PLAYER_ID)
		{
			format(tex,sizeof(tex),"SMS: [%s >> %s ]:",vardas2,vardas);
			SendClientMessage(recieverid,TEXTCOL_SILVER,tex);
			SendClientMessage(recieverid,TEXTCOL_RED,texts);
		}

		if(playerid!=INVALID_PLAYER_ID)
		{
			if(IsPlayerAfk(recieverid)) 
				format(tex,sizeof(tex),"SMS: [%s >> %s {FFFFFF}[AFK]{98B134} ]:",vardas2,vardas);
			else
				format(tex,sizeof(tex),"SMS: [%s >> %s ]:",vardas2,vardas);
			SendClientMessage(playerid,TEXTCOL_GREEN,tex);
			SendClientMessage(playerid,TEXTCOL_RED,texts);
		}
		ProcessAchievement(playerid, 82);
		parase[recieverid]=playerid;
		PlayerPlaySound(recieverid, 1138, 0.0, 0.0, 0.0); // SMS
		return 1;
	}
    if(strcmp(cmdtext, "//", true,2)==0)
	{
	        if(!playerDB[playerid][admin]) return 1;
			if(strlen(cmdtext) < 3) {SendInfoMessage(playerid,"Admin chato zinute: // [zinute]"); return 1;}
			new zin[128],vardas[MAX_PLAYER_NAME];
			GetPlayerName(playerid,vardas,MAX_PLAYER_NAME);
			format(zin,sizeof(zin),"%s: %s",vardas,cmdtext[3]);

			foreach (Player, i)
			{
				if(playerDB[i][admin] && BitFlag_Get(PConfig[i],PCFG_SHOWACHAT))
				{
					SendClientMessage(i,0xD9E916FF,zin);
				}
			}
			return 1;
	}
	if (strcmp("/'", cmdtext, true,2)==0)
	{
		if(playerDB[playerid][pgang] != -1)
		{
			if(strlen(cmdtext) < 3) return SendClientMessage(playerid,COLOR,"* Kalbeti su gauja: /' [tekstas]");

			new msg[128],pname[MAX_PLAYER_NAME];
			GetPlayerName(playerid,pname,sizeof(pname));
			format(msg,sizeof(msg),"[gauja] %s: %s",pname,cmdtext[3]);
			SendMessageToFamily(playerDB[playerid][pgang],COLOR,msg);
			return 1;
		}
	}
	if(strcmp("/e-mail",cmdtext,true)==0)
	{
		cmd_email(playerid,"");
		return 1;
	}
	return SendInfoMessage(playerid,"Tokios komandos nera.~n~Visos komandos /Pagalba");
}




