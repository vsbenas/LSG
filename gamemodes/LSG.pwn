				SendInfoMessage(playerid,"Jus nesate kunigas, todel negalite vairuoti sio transporto.");
				Stop(playerid);
				return 1;
			}
			case 519,577:
			{
				if(playerDB[playerid][admin] || spec == 45)
				{
					SendInfoMessage(playerid,"Skraidydami gausite "#MONEY_PILOTAS"EUR/min + "#MONEYP_PILOTAS"EUR uz aplankytus miestus.~n~ Gero vejo.");
					new Float:LOL;
					new idx = ClosestPlaneStop(playerid,LOL);
					new id = UpdateJobText(playerid,2,idx);
					if(id==0) SetPlayerRaceCheckpoint(playerid,4,PILOTAI_SF[0][0],PILOTAI_SF[0][1],PILOTAI_SF[0][2],PILOTAI_SF[1][0],PILOTAI_SF[1][1],PILOTAI_SF[1][2],20.0);
					else if(id==1) SetPlayerRaceCheckpoint(playerid,4,PILOTAI_LV[0][0],PILOTAI_LV[0][1],PILOTAI_LV[0][2],PILOTAI_LV[1][0],PILOTAI_LV[1][1],PILOTAI_LV[1][2],20.0);
					else if(id==2) SetPlayerRaceCheckpoint(playerid,4,PILOTAI_LS[0][0],PILOTAI_LS[0][1],PILOTAI_LS[0][2],PILOTAI_LS[1][0],PILOTAI_LS[1][1],PILOTAI_LS[1][2],20.0);
					return 1;
				}
				SendInfoMessage(playerid,"Jus nesate lakunas, todel negalite pilotuoti sio lektuvo.");
				Stop(playerid);
				return 1;
			}
			case 481:
			{
				if(vehicleid == PlayerCar[playerid])
				{
					if(playerDB[playerid][admin] || spec == 36)
					{
						SendInfoMessage(playerid,"Vazinedami musu transportu gausite "#MONEY_BMX"EUR/min + "#MONEYP_BMX"EUR uz stuntus.~n~Parodyk ka sugebi zmonems.");
						if(bmx[playerid] == -1)
						{
							new cp=random(sizeof(BMXCP));
							if(cp == bmx[playerid]) cp=random(sizeof(BMXCP));
							bmx[playerid]=cp;
						}
						SetPlayerCheckpoint(playerid,BMXCP[bmx[playerid]][0],BMXCP[bmx[playerid]][1],BMXCP[bmx[playerid]][2],2.0);
						SendClientMessage(playerid,YELLOW," * Zemelapyje pazymeta vieta i kuria turite uzsokti! Noredami pakeisti vieta rasykite /stunt !");
						return 1;
					}
					SendInfoMessage(playerid,"Jus nesate BMX'eris!");
					Stop(playerid);
					return 1;
				}
			}
			case 409:
			{
				if(playerDB[playerid][admin] || spec == 20)
				{
					UzdarbioZinute(playerid, MONEY_LIMUZINAI);
					return 1; 
				}
				SendInfoMessage(playerid,"Negalite vairuoti sio transporto. Jis skirtas Limuzino centro darbuotojams!");
				Stop(playerid);
				return 1;
			}
			case 514,515,403:
			{
				if(playerDB[playerid][admin] || spec == 41)
				{
					UzdarbioZinute(playerid, MONEY_FURISTAI);
					//ShowPlayerDialog(playerid,102,DIALOG_STYLE_LIST,"Vietos","Pilti kura\nIspilti kura\nPakrauti paletes\nIskrauti paletes\nPakrauti TV\nIskrauti TV","Rinktis","Iseiti");
					LoadFuruMission(playerid);
					return 1;
				}
				SendInfoMessage(playerid,"Negalite vairuoti sio transporto. Jis skirtas Furistam!");
				Stop(playerid);
				return 1;
			}
			case 400:
			{
				if(playerDB[playerid][admin] || spec == 42)
				{
					SendInfoMessage(playerid,"Vazinedami musu transportu gausite "#MONEY_PASIENIETIS"EUR/min, tiesiai i banka.~n~Atsakingai atidarinekite vartus /apasienis uz 100EUR.");
					return 1;
				}
				SendInfoMessage(playerid,"Jus nesate pasienietis, todel negalite vairuoti sio transporto.");
				Stop(playerid);
				return 1;
			}
			case 453:
			{
				if(0==strcmp(vehicleDB[vehicleid][nuomuoja],"no",false))
				{
					if(GetPlayerMoneyA(playerid) < COST_LAIVONUOMA)
					{
						Stop(playerid);
						SendInfoMessage(playerid,"~r~Laivo nuoma kainuoja "#COST_LAIVONUOMA"EUR!");
						return 1;
					}
					GivePlayerMoneyA(playerid, -COST_LAIVONUOMA);
					SendInfoMessage(playerid,"Issinuomavote laiva uz "#COST_LAIVONUOMA"EUR! Zvejoti galite parase /zvejoti");
					format(vehicleDB[vehicleid][nuomuoja], 24, ReturnName(playerid));
					//SetTimerEx("Nuoma",10*60*1000,0,"i",vehicleid);
					return 1;
				}
				else if(strcmp(vehicleDB[vehicleid][nuomuoja],ReturnName(playerid),false))
				{
					Stop(playerid);
					return SendInfoMessage(playerid,"Laivas jau isnuomotas!");
				}
			}
		}
//Klasiu tikrinimas
    	if(vehicleid == Carlist[playerid][Carid] || vehicleid == Carlist2[playerid][Carid] || vehicleid == Carlist3[playerid][Carid] )
		{
			SendInfoMessage(playerid,"Ilipote i savo automobili.~n~Noredami uzrakinti ar atrakinti ji, spauskite ~k~~TOGGLE_SUBMISSIONS~(+)");
		}
		else
		{
			new idx;
			new ida = GetPlayerFromCarlistID(vehicleid,idx);
			new time_lock = GetTickCount() - VehicleLocked[vehicleid][2];
			//GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
			switch(ida)
			{
				case 1: if(Carlist[idx][Lock] && !playerDB[playerid][admin] && !IsAPBike(vehicleid) && time_lock > 5000) return AC_Kick(playerid,"Carjack",1);
				case 2: if(Carlist2[idx][Lock] && !playerDB[playerid][admin] && !IsAPBike(vehicleid)&& time_lock > 5000) return AC_Kick(playerid,"Carjack",1);
				case 3: if(Carlist3[idx][Lock] && !playerDB[playerid][admin] && !IsAPBike(vehicleid)&& time_lock > 5000) return AC_Kick(playerid,"Carjack",1);
			}
			/*if(VehVars[3])// && !playerDB[playerid][admin]) // uzrakinta
			{
				AC_Kick(playerid,"Carjack");
				return 1;
			} */
		}
		if(model != BMX && model != MTBIKE && model != BIKE && model != 523 &&
		model != 497  && model != 463 && model != 461 && model != 581
		&& model != 522 && model != 521 && model != 460 && model != 519 && model != 487  &&
		model != 579  && model != 488 && model != 418 && !IsVairavimoMokyklosCar(vehicleid)) //Netaikomi dviraciams dalykai
		{
			if(!playerDB[playerid][teises]) SendClientMessage(playerid,0xF50A62FF,"* Jus neturite teisiu! Rekomenduojama Kreiptis i *Vairavimo Mokykla*");
			if(vehicleDB[vehicleid][gas]<1)
			{
				GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
				SetVehicleParamsEx(vehicleid,false,VehVars[1],VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
			}
		}

		if(model == 448 || model == 581 || model == 522 || model == 461 || model == 521 || model == 523 || model == 463 || model == 586 || model == 468)
		{
			if(!playerDB[playerid][teisesm]) SendClientMessage(playerid,0xF50A62FF,"* Jus neturite Motociklu teisiu! Rekomenduojama Kreiptis i *Vairavimo Mokykla*");
			if(vehicleDB[vehicleid][gas]<1)
			{
				GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
				SetVehicleParamsEx(vehicleid,false,VehVars[1],VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
			}
		}

		if(model == 497 || model == 460 || model == 519 || model == 487 || model == 577 || model == 488)
		{
			SendClientMessage(playerid,0xF50A62FF,"* Gero skrydzio! *");
			if(vehicleDB[vehicleid][gas]<1)
			{
				GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
				SetVehicleParamsEx(vehicleid,false,VehVars[1],VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
			}
		}

	}
	else if(newstate== PLAYER_STATE_PASSENGER)
	{
	    if(GetPlayerWeapon(playerid)==24 || GetPlayerWeapon(playerid)==27) SetPlayerArmedWeapon(playerid, 0); // no dgl!
		new vairuotojas = GetDriver(vehicleid);
		if(model == AMBULAN || model == 563 || model == 496 || model == 505 || model == 469)
		{
			if(vairuotojas == playerid) return 1;
			if(vairuotojas == INVALID_PLAYER_ID || (playerDB[vairuotojas][specialybe] != 2 && playerDB[vairuotojas][specialybe] != 93))
			{
				SendInfoMessage(playerid,"Nera mediko.");
				return 1;
			}
			new kaina = 0;
			if(GetPlayerScore(playerid) > 100)
				kaina = 120;
			if(GetPlayerScore(playerid) > 1000)
				kaina = 240;
			if(GetPlayerMoneyA(playerid) < kaina)
			{
				new msg[128];
				format(msg,128, "Pagydymas kainuoja %iEUR",kaina);
				SendInfoMessage(playerid,msg);
				return 1;
			}
			new Float:oldhp,Float:oldarmour;
			GetPlayerHealth(playerid,oldhp);
			GetPlayerArmour(playerid, oldarmour);
			if(oldhp <= 99 || oldarmour <= 99)
			{
				ProcessAchievement(vairuotojas,69);
				ProcessAchievement(playerid, 131);
			}
			if(oldarmour < 125)
				SetPlayerArmour(playerid,125);
			if(oldhp < 100)
				SetPlayerHealth(playerid,100);
			if(GetPlayerScore(playerid)> 100)
			{
				playerDB[vairuotojas][jobpts]++;
				Pelnas(vairuotojas,1,kaina * 3);
				GivePlayerMoneyA(playerid,-kaina);		
				GivePlayerMoneyA(vairuotojas,floatround(kaina*2.0/3.0));
			}
			else
			{
				SendInfoMessage(playerid,"Jus turite mazai patirties, todel gydymas jums nemokamas.");
			}
			//pelnas[1]+=50+random(10);
			return 1;
		}
		/*if(vairuotojas != playerid && vairuotojas != INVALID_PLAYER_ID)
		{
			if(playerDB[vairuotojas][klausosi] == vehicleid)
			{
				StopAudioStreamForPlayer(playerid);
				if(!playerDB[vairuotojas][stotis]) playerDB[vairuotojas][stotis]++;
				PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[playerDB[vairuotojas][stotis]-1][RADIO_URL]);
				playerDB[playerid][stotis] = playerDB[vairuotojas][stotis];
				playerDB[playerid][klausosi] = vehicleid;
			}
		}*/
		if(VehicleRadio[vehicleid] && !playerDB[playerid][klausoimtuvo])
		{
			StopAudioStreamForPlayer(playerid);
			PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[VehicleRadio[vehicleid]-1][RADIO_URL]);
			//playerDB[playerid][stotis] = playerDB[vairuotojas][stotis];
			playerDB[playerid][klausosi] = vehicleid;
		}


		if(model == 428) //bankininkas
		{
//			new vairuotojas = GetDriver(vehicleid);
			LoadOrderInka(playerid);
    		
			if(vairuotojas == playerid) return 1;
			if(vairuotojas == INVALID_PLAYER_ID)
			{
				SendInfoMessage(playerid,"Nera bankininko ar inkasatoriaus.");

				//Stop(playerid);
				return 1;
				//vairuotojas = playerid;
			}
			if(playerDB[playerid][dirtymoney])
			{
				if(playerDB[vairuotojas][specialybe] != 60)
				{
					return SendInfoMessage(playerid, "Vairuotojas turi dirbti inkasatoriumi!");
				}
				RemovePlayerAttachedObject(playerid, MESKERE_SLOT);
				LoadDirtyMoney(vairuotojas,playerid);
			}
			if(GetPlayerScore(playerid) < 100) return 1;
			if(GetPlayerMoneyA(playerid) < 80)
			{
				SendInfoMessage(playerid,"Banko paslaugos kainuoja 80EUR");
				Stop(playerid);
				return 1;
			}
			SendInfoMessage(playerid,"Komandos: /padet /paimt /balansas");
			GivePlayerMoneyA(playerid,-80);
			GivePlayerMoneyA(vairuotojas,80);
			new tick = GetTickCount();
			if(tick - LastPjovimas[vairuotojas] > 15*60*1000)
			{
				LastPjovimas[vairuotojas]=tick;
				playerDB[vairuotojas][jobpts]++;
			}
			return 1;
		}

		if(model == 418)
		{
//			new vairuotojas = GetDriver(vehicleid);
			if(vairuotojas == playerid) return 1;
			if(vairuotojas == INVALID_PLAYER_ID)
			{
				SendInfoMessage(playerid,"Nera Vairuotojo.");
				return 1;
			}
			if(GetPlayerMoneyA(playerid) < 10)
			{
				SendInfoMessage(playerid,"Bilietas kainuoja 10EUR");
				Stop(playerid);
				return 1;
			}
			SendInfoMessage(playerid,"Linkime geros keliones musu transportu.");
			GivePlayerMoneyA(playerid,-10);
			if(GetPlayerScore(playerid) > 100)
				GivePlayerMoneyA(vairuotojas,10);
			ProcessAchievement(playerid,4);
			return 1;
		}


		if(model == 437 || model == 431)
		{
//			new vairuotojas = GetDriver(vehicleid);
			if(vairuotojas != INVALID_PLAYER_ID)
			{
				new kaina = random(15);
				if(GetPlayerMoneyA(playerid) >= kaina)
				{
					SendInfoMessage(playerid,"Pardavete bilieta!");
					SendInfoMessage(playerid,"Nusipirkote bilieta!");
					if(GetPlayerScore(playerid) > 100)
						GivePlayerMoneyA(vairuotojas,kaina);
					GivePlayerMoneyA(playerid,-kaina);
					ProcessAchievement(playerid,4);
				}
			}
		}
		if(model == TAXI || model == 477 || model == 409 || model == 438)
		{
//			new vairuotojas = GetDriver(vehicleid);
			if(vairuotojas == INVALID_PLAYER_ID) return 1; // Nera vairuotojo, kam testi?
			if(playerDB[vairuotojas][specialybe]!=3 && playerDB[vairuotojas][specialybe]!=20 && playerDB[vairuotojas][specialybe]!=39 ) return 1; //Vairuotojas ne taxistas

//Gerai, tu - keleivis, paruoskime taxi scriptus
			//GetPlayerPos(playerid,taxiDB[playerid][Start][0],taxiDB[playerid][Start][1],taxiDB[playerid][Start][2]);
			new keleiviai = 0;
			foreach(Player, i)
			{
				if(taxiDB[i][taksistas] == vairuotojas)
					keleiviai ++;
			}
			if(keleiviai >= 3) // iki 3 keleiviu leidziam
			{
				return 1;
			}
			taxiDB[playerid][Start]=GetTickCount();
			taxiDB[playerid][taksistas]=vairuotojas;
			keleivis[vairuotojas]=playerid;
			new msg[256];
			format(msg,sizeof(msg),"Ilipo keleivis (%sXP), imti pinigus? Rasykite ~g~Taip~w~ arba ~r~Ne",FormatNumber(GetPlayerScore(playerid)));
			SendInfoMessage(vairuotojas,msg);
			playerDB[vairuotojas][textas]=3;
			return 1;
		}

	}
	return 1;

}
stock IsSeatTaken(vehicleid, seatid)
{
    foreach(Player,i)
    {
        if(GetPlayerVehicleID(i) == vehicleid && GetPlayerVehicleSeat(i) == seatid) return 1;
    }
    return 0;
}
forward ReturnGuns(playerid);
public ReturnGuns(playerid)
{
	for(new slot=0; slot<12; slot++) if(playerDB[playerid][spdata][slot])
	{
		GivePlayerWeaponEx(playerid,playerDB[playerid][spdata][slot],playerDB[playerid][spdata][12+slot]);
		playerDB[playerid][spdata][slot]=0;
	}
}
public Parasiutas(playerid)
{
	SetPVarInt(playerid, "PSpectating", 0);
	UpdateWeapons(playerid, -1);
	SetPlayerHealth(playerid,playerDB[playerid][shealth][0]);
	SetPlayerArmour(playerid,playerDB[playerid][shealth][1]);
	if(playerDB[playerid][spdata][29] != 0 && playerDB[playerid][spdata][29] != INVALID_VEHICLE_ID) // if he was in vehicle
	{
		if(GetVehicleModel(playerDB[playerid][spdata][29]))
		{
			PlayerEnterTime[playerid] -=221;
			if(!IsSeatTaken(playerDB[playerid][spdata][29],playerDB[playerid][spdata][30]))
				PutPlayerInVehicle(playerid,playerDB[playerid][spdata][29],playerDB[playerid][spdata][30]);
		}
	}
	else if(playerDB[playerid][spdata][28] != INVALID_VEHICLE_ID && playerDB[playerid][spdata][28] != 0) // if he was on vehicle
	{
		if(GetVehicleModel(playerDB[playerid][spdata][28]))
		{
			new Float:coo[3];
			GetVehicleRoof(playerDB[playerid][spdata][28],coo[0],coo[1],coo[2]);
			SetPlayerPoz(playerid,coo[0],coo[1],coo[2], _, _, 0);
			SetTimerEx("FixSurf",1000,false,"ii",playerid,playerDB[playerid][spdata][28]);
		}
	}
	playerDB[playerid][spdata][28]=INVALID_VEHICLE_ID;
	playerDB[playerid][spdata][29]=INVALID_VEHICLE_ID;
	playerDB[playerid][spdata][30]=0;
	galikast[playerid]=true;
	playerDB[playerid][lektuvas]=-1;
}

stock StartSpectate(playerid, id)
{
	new mess[64],rec[MAX_PLAYER_NAME];
	GetPlayerName(id,rec,sizeof(rec));
	format(mess,sizeof(mess),"Priziurite %s!",rec);
	SendInfoMessage(playerid,mess);
	Zuvyte[playerid]=CreatePlayerObject(playerid,1600,0.0,0.0,-10.0,0.0,0.0,0.0,100.0);
	
	new msg[128];
	if(playerDB[id][pgang] == -1)
	{
		format(msg,sizeof(msg)," * %s nepriklauso jokiai gaujai.",rec);
	}
	else
	{
		format(msg,sizeof(msg)," * %s priklauso \"%s\" gaujai.",rec,FamilyInfo[playerDB[id][pgang]][FamilyName]);
	}
	SendClientMessage(playerid,COLOR,msg);
	if(Uzimineja[id])
	{
		format(msg,sizeof(msg)," * %s uzimineja sandeli.", rec);
		SendClientMessage(playerid,-1,msg);
	}
	if(IsPlayerInWorld(id))
	{
		format(msg,sizeof(msg)," * %s yra kitame pasaulyje.", rec);
		SendClientMessage(playerid,-1,msg);
	}

	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER)
		UpdateGunData(playerid);

	playerDB[playerid][spdata][24]=GetPlayerSkin(playerid);
	GetPlayerPos(playerid,playerDB[playerid][spos][0],playerDB[playerid][spos][1],playerDB[playerid][spos][2]);
	GetPlayerHealth(playerid,playerDB[playerid][shealth][0]);
	GetPlayerArmour(playerid,playerDB[playerid][shealth][1]);
	playerDB[playerid][spdata][25]=GetPlayerWantedLevel(playerid);
	playerDB[playerid][spdata][26]=GetPlayerInterior(playerid);
	playerDB[playerid][spdata][27]=GetPlayerVirtualWorld(playerid);
	
	playerDB[playerid][spdata][28]=GetPlayerSurfingVehicleID(playerid);
	playerDB[playerid][spdata][29]=GetPlayerVehicleID(playerid);
	playerDB[playerid][spdata][30]=GetPlayerVehicleSeat(playerid);
	/*PlayerSpectated[id]=playerid;
	SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(id));
	SetPlayerInterior(playerid,GetPlayerInterior(id));
	PlayerEnterTime[playerid]-=221;*/
	TogglePlayerSpectating(playerid,true);
	SetPVarInt(playerid, "PSpectating", 2);
	SetPVarInt(playerid, "PSpectateId", id);
	PlayerSpectated[id] = playerid;
	UpdateSpectate(playerid, /* force= */ true); 
}
stock UpdateSpectate(playerid, force = false) 
{
	if(GetPVarInt(playerid, "PSpectating") != 2)
		return 0; 
	new id = GetPVarInt(playerid, "PSpectateId");
	if(!IsPlayerConnected(id))
	{
		EndSpectate(playerid);
		return 0;
	}
	SetPlayerVirtualWorld(playerid,GetPlayerVirtualWorld(id));
	SetPlayerInterior(playerid,GetPlayerInterior(id));
	new distas = GetDistanceBetweenPlayers(playerid, id);
	if(distas > 50 || force)
	{
		TogglePlayerSpectating(playerid,true);
		new vehid=GetPlayerVehicleID(id);
		if(!vehid) 
			PlayerSpectatePlayer(playerid,id);
		else 
			PlayerSpectateVehicle(playerid, vehid);
	}
	return 1;
}
stock EndSpectate(playerid)
{
	if(GetPVarInt(playerid, "PSpectating") != 2)
		return 0; 
	new id = GetPVarInt(playerid, "PSpectateId");

	TextDrawHideForPlayer(playerid,Spectate[id]);
	PlayerSpectated[id]=-1;

	SetPVarInt(playerid, "SpectateExiting", 1);
	TogglePlayerSpectating(playerid,false);
	SetPlayerSkin(playerid,playerDB[playerid][spdata][24]);
	SetPlayerPoz(playerid,playerDB[playerid][spos][0],playerDB[playerid][spos][1],playerDB[playerid][spos][2], _, _, 0);
	SetPlayerWantedLevel(playerid,playerDB[playerid][spdata][25]);
	SetPlayerInterior(playerid,playerDB[playerid][spdata][26]);
	SetPlayerVirtualWorld(playerid,playerDB[playerid][spdata][27]);
	NoCheck[playerid]=3;
	SetTimerEx("Parasiutas",500,false,"i",playerid);
	galikast[playerid]=false;
	SetPVarInt(playerid, "PSpectating", 0);
	DestroyPlayerObject(playerid,Zuvyte[playerid]);
	Zuvyte[playerid] = -1;
	return 1;
}

public TimerFall(playerid)  ApplyAnimation(playerid, "CRACK", "crckdeth2", 4.0, 1, 0, 0, 0, 0, 1);
stock CheckZone(playerid)
{
	//if(!IsPlayerConnected(playerid)) return 0;
	for(new i;i<MAX_NARKO;i++)
	{
		if(IsPlayerInDynamicArea(playerid,GangArea[i])) return 1;
	}
	if(PiniguSandelis(playerid))
		return 1;
	return 0;
}
stock PiniguSandelis(playerid)
{
	if(IsPlayerInRangeOfPoint(playerid, 200.0, PINIGU_FABRIKAS) && GetPlayerInterior(playerid) == 2)
		return 1;
	return 0;
}
stock InParking(veh)
{
	new Float:Xx,Float:Yy,Float:Zz;
	GetVehiclePos(veh,Xx,Yy,Zz);
	for(new i;i<sizeof(parkings);i++)
	{
		if(IsPointInDynamicArea(parkings[i], Xx, Yy, Zz))
			return 1;
	}
	return 0;
}
stock SafeArea(playerid)
{
	if(!IsPlayerConnected(playerid)) return 0;
	if(IsPlayerInWorldSafeArea(playerid))
	{
		return 1;
	}
	if(!IsPlayerInAnyDynamicArea(playerid))
		return 0;
	for(new i;i<sizeof(SafeZone);i++)
	{
		if(IsPlayerInDynamicArea(playerid,SafeZone[i]))
		{
			return 1 + i;
		}
	}
	// kaledu
	//if(IsPlayerInRangeOfPointEx(55,playerid, 396.5, -1545, 31.0)) 
	//	return 1;
	return 0;
}
stock RenkasiParduotuve(playerid,newkeys) {
	if(playerDB[playerid][aksesuaras] == 1)
	{
		new skin=GetPlayerSkin(playerid);
		SetPlayerAttachedObject(playerid, AKINIU_SLOT, CommonRed+playerDB[playerid][issirinkoak]-1, 2, AkiniuOffSet[skin][0], AkiniuOffSet[skin][1], AkiniuOffSet[skin][2], AkiniuOffSet[skin][3], AkiniuOffSet[skin][4], AkiniuOffSet[skin][5],AkiniuOffSet[skin][6]);
		if(newkeys & KEY_FIRE)
		{
			playerDB[playerid][issirinkoak]++;
			if(playerDB[playerid][issirinkoak]==35)
			{
				playerDB[playerid][issirinkoak]=1;
			}
			SetPlayerAttachedObject(playerid, AKINIU_SLOT, CommonRed+playerDB[playerid][issirinkoak]-1, 2, AkiniuOffSet[skin][0], AkiniuOffSet[skin][1], AkiniuOffSet[skin][2], AkiniuOffSet[skin][3], AkiniuOffSet[skin][4], AkiniuOffSet[skin][5],AkiniuOffSet[skin][6]);
			return 1;
		}
		else if(newkeys & KEY_HANDBRAKE)
		{
			playerDB[playerid][issirinkoak]--;
			if(playerDB[playerid][issirinkoak]==0)
			{
				playerDB[playerid][issirinkoak]=34;
			}
			SetPlayerAttachedObject(playerid, AKINIU_SLOT, CommonRed+playerDB[playerid][issirinkoak]-1, 2, AkiniuOffSet[skin][0], AkiniuOffSet[skin][1], AkiniuOffSet[skin][2], AkiniuOffSet[skin][3], AkiniuOffSet[skin][4], AkiniuOffSet[skin][5],AkiniuOffSet[skin][6]);
			return 1;
		}
		else if(newkeys & KEY_SPRINT)
		{
			if(GetPlayerMoneyA(playerid) < COST_AKINIAI) return SendInfoMessage(playerid,"~r~Neuztenka pinigu!");
			playerDB[playerid][akiniai]=playerDB[playerid][issirinkoak];
			SetPlayerAttachedObject(playerid, AKINIU_SLOT, CommonRed+playerDB[playerid][akiniai]-1, 2, AkiniuOffSet[skin][0], AkiniuOffSet[skin][1], AkiniuOffSet[skin][2], AkiniuOffSet[skin][3], AkiniuOffSet[skin][4], AkiniuOffSet[skin][5],AkiniuOffSet[skin][6]);
			playerDB[playerid][issirinkoak]=0;
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			GameTextForPlayer(playerid," ",3000,3);
			SendInfoMessage(playerid,"Gero nesiojimo!");
			GivePlayerMoneyA(playerid, -COST_AKINIAI);
			BitFlag_On(PConfig[playerid],PCFG_AKINIAI);
			ActorServe(playerid); BusinessMoney(COST_AKINIAI);
			return 1;
		}
		else if(newkeys & KEY_SECONDARY_ATTACK)
		{
			if(playerDB[playerid][akiniai]) SetPlayerAttachedObject(playerid, AKINIU_SLOT, CommonRed+playerDB[playerid][akiniai]-1, 2, AkiniuOffSet[skin][0], AkiniuOffSet[skin][1], AkiniuOffSet[skin][2], AkiniuOffSet[skin][3], AkiniuOffSet[skin][4], AkiniuOffSet[skin][5],AkiniuOffSet[skin][6]);
			else RemovePlayerAttachedObject(playerid, AKINIU_SLOT);
			playerDB[playerid][issirinkoak]=0;
			GameTextForPlayer(playerid," ",3000,3);
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			SendInfoMessage(playerid,"Uzsukite kita karta!");
			return 1;
		}		
	}
	else if(playerDB[playerid][aksesuaras] == 2)
	{
		UzdetiSalma(playerid,Salmai[playerDB[playerid][issirinkoak]-1]);
		
		if(newkeys & KEY_FIRE)
		{
			playerDB[playerid][issirinkoak]++;
			if(playerDB[playerid][issirinkoak]==sizeof(Salmai)+1)
			{
				playerDB[playerid][issirinkoak]=1;
			}
			
			UzdetiSalma(playerid,Salmai[playerDB[playerid][issirinkoak]-1]);
			return 1;
		}
		else if(newkeys & KEY_HANDBRAKE)
		{
			playerDB[playerid][issirinkoak]--;
			if(playerDB[playerid][issirinkoak]==0)
			{
				playerDB[playerid][issirinkoak]=sizeof(Salmai);
			}
			
			UzdetiSalma(playerid,Salmai[playerDB[playerid][issirinkoak]-1]);
			return 1;
		}
		else if(newkeys & KEY_SPRINT)
		{
			if(GetPlayerMoneyA(playerid) < COST_SALMAI) return SendInfoMessage(playerid,"~r~Neuztenka pinigu!");
			RemovePlayerAttachedObject(playerid, SALMO_SLOT);
			playerDB[playerid][salmas]=playerDB[playerid][issirinkoak];
			playerDB[playerid][issirinkoak]=0;
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			GameTextForPlayer(playerid," ",3000,3);
			SendInfoMessage(playerid,"Saugios keliones!");
			//BitFlag_On(PConfig[playerid],PCFG_KEPURE);
			GivePlayerMoneyA(playerid, -COST_SALMAI);
			ProcessAchievement(playerid, 86);
