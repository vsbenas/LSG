			if(GetPlayerScore(playerid)<XP_PICU_ISVEZIOTOJAS)
			{
				SendInfoMessage(playerid,"Atsiprasome, taciau jus nepakankamai patyres dirbti picu isveziotoju, reikia: xp>"#XP_PICU_ISVEZIOTOJAS);
				return 1;
			}
			MLog(playerid,"Isidarbino","i",7);CheckIsidarbinimoAch(playerid);
			SendInfoMessage(playerid,"Sveikiname prisijungus prie picu isveziotoju!");
			SendClientMessage(playerid,0x808080FF,"* Jűsř darbas tiekti ir pardavinëti picas pagal uţsakymus. Iđ jűsř picŕ galima ásigyti panaudojus komandŕ [/pirkti_pica].");
			if(playerDB[playerid][lytis]==1)
			{
				SetPlayerSkin(playerid,155);
				playerDB[playerid][uniforma]=155;
				ApplyAnimation(playerid,"PLAYIDLES","stretch",4.1,0,0,0,0,0);
			}else{
				SetPlayerSkin(playerid,205);
				playerDB[playerid][uniforma]=205;
				ApplyAnimation(playerid,"PLAYIDLES","stretch",4.1,0,0,0,0,0);
			}
			playerDB[playerid][uniformd]=true;
			autoDB[playerid][CPnumber]=0;vezaivieta[playerid]=0;
			playerDB[playerid][specialybe]=37;
		}else{
			SendInfoMessage(playerid,"Atsiprasome, taciau jus negalite dirbti dvieju darbu, palikite senaji.");
		}
		return 1;
	}

////////////////
	if(pickupid > pickups[0][bankomatas]-1 && pickupid < pickups[1][bankomatas]+1)
	{
		if(!playerDB[playerid][kortele]) return SendClientMessage(playerid,GREEN,"* Demesio! Jus neturite banko korteles! Isigykite ja artimiausiame banke.");
		new zinute[128];
		format(zinute,sizeof(zinute),"{FFFFFF}Jűsř sŕskaitos balansas:{33FF33} %i€.\n{FFFFFF}Ar norite paimti pinigus?",playerDB[playerid][banke]);
		ShowPlayerDialog(playerid,588,DIALOG_STYLE_MSGBOX,"Bankomatas",zinute,"Taip","Ne");
		return 1;
	}
//////////////////////////////////////////////////////////////////////////////////////////////////////// SPL */ ///////////////////////////////////////////////////
	if(pickupid == pickups[0][stadionas])
	{
		SendInfoMessage(playerid,"Sveiki atvyke i Los Santos Stadiona!");
		//SetPlayerInterior(playerid,15);
		SetPlayerPosFade(playerid,20,-1446.8335,938.8027,1036.5743,15);
		//SetPlayerPoz(playerid,-1446.8335,938.8027,1036.5743);
		return 1;
	}

	if(pickupid == pickups[1][stadionas])
	{
		//SetPlayerInterior(playerid,0);
		//SetPlayerPoz(playerid,2691.7229,-1698.3318,10.4788);
		SetPlayerPosFade(playerid,20,2691.7229,-1698.3318,10.4788,0);
		return 1;
	}

	if(pickupid == pickups[0][stadgalai])
	{
		if(playerDB[playerid][masina]==-1)
		{
			SendInfoMessage(playerid,"Jus neturite masinos, tad nera kam ir pilti degalu.");
			return 1;
		}
		if(GetVehicleModel(playerDB[playerid][masina]) != 504) return SendClientMessage(playerid,RED," * Niekuo jums padet negaliu!");
		vehicleDB[playerDB[playerid][masina]][gas]=50;
		SendInfoMessage(playerid,"Degalu lygis jusu masinoje optimizuotas buliu kautynems!");
		return 1;
	}
///////////////////////////////////

	if(pickupid == pickups[0][loterija])
	{
		if(LoadOrderInka(playerid))
			return 1;
		if(GetPlayerScore(playerid) < 100)
			return SendInfoMessage(playerid,"~r~Loterijoje gali zaisti tik nuo 100 xp");
		/*SendClientMessage(playerid,COLOR,"* ======= TELELOTO =======");
		if(playerDB[playerid][bilietas])
		{
			playerDB[playerid][bilietas]=false;
			switch(random(10000))
			{
			    case 3505:
				{
					SendClientMessage(playerid,COLOR,"* Jusu bilietas laimingas! Laimejote 100 000 €!!!");
					GivePlayerMoneyA(playerid,100000);
					ProcessAchievement(playerid,95);
					return 1;
				}
				case 1500..2000:
				{
					SendClientMessage(playerid,COLOR,"* Jusu bilietas laimingas! Uzbraukete istrizaine!");
					GivePlayerMoneyA(playerid,15);
					return 1;
				}
				case 2001..2500:
				{
					SendClientMessage(playerid,COLOR,"* Jusu bilietas laimingas! Uzbraukete visus keturis kampus!");
					GivePlayerMoneyA(playerid,10);
					return 1;
				}
				default : SendClientMessage(playerid,COLOR,"* Prapisai.");
			
			
			}
			return 1;
		}
		if(GetPlayerMoneyA(playerid) < 5) return SendInfoMessage(playerid,"~r~Nepakanka pinigu!");
		SendClientMessage(playerid,COLOR,"* Pagrindinis prizas 1 milijonas LITU ir 100XP!");
		SendClientMessage(playerid,COLOR,"* ========================");
		SendClientMessage(playerid,COLOR,"* Nusipirkote TELELOTO Bilieta! (Kaina 5€)");
		SendClientMessage(playerid,COLOR,"* Patikrinti bilieta galesite cia pat, po keliu min.");
		GivePlayerMoneyA(playerid,-5);
		//BusinessInfo[GetPlayerVirtualWorld(playerid)-MAX_HOUSES*2][bEarning]+=3;
		BusinessMoney(6);
		playerDB[playerid][bilietas]=true;*/
		if(GetPVarInt(playerid,"statymas"))
			return SendInfoMessage(playerid,"Tu jau padarei statyma. Palauk zaidimo pabaigos.");
		if(!GaliStatyti())
			return SendInfoMessage(playerid,"Losimas jau vyksta! Palauk zaidimo pabaigos.");

		if(!GetPVarInt(playerid,"statymo_suma"))
			SetPVarInt(playerid, "statymo_suma", 100);
		LosimuGui(playerid,0);
		return 1;
	}
	if(pickupid == pickups[0][baldu_verslas])
	{
		ShowBaldaiCat(playerid,0);
		return 1;
	}
	if(pickupid == pickups[0][elektr_verslas])
	{
		ShowBaldaiCat(playerid,1);
		return 1;
	}
	if(pickupid==pickups[0][interjer_verslas])
	{
		ShowBaldaiCat(playerid,2);
	}
	if(pickupid == pickups[0][valgis] || pickupid == pickups[1][valgis])
	{
		ClearAnimations(playerid);
		ApplyAnimation(playerid,"VENDING","vend_eat1_P",4.1,0,0,0,0,0);
		Valgymas(playerid,20.0);
		new sir = random(5);
		if(sir == 0) SendInfoMessage(playerid,"Valgote keptu bulvyciu.");
		else if(sir == 1) SendInfoMessage(playerid,"Valgote kepta vista.");
		else if(sir == 2) SendInfoMessage(playerid,"Valgote bandele.");
		else if(sir == 3) SendInfoMessage(playerid,"Valgote didele pica.");
		else SendInfoMessage(playerid,"Valgote ryziu salotu.");

		new Float:hp;
		GetPlayerHealth(playerid,hp);
		if(hp<120) SetPlayerHealth(playerid,hp+30);
		return 1;
	}

	if (pickupid == iejimas)
	{
		//SetPlayerPoz(playerid, 3216.251465, -974.502441, 283.492065);//
		SetPlayerPosFade(playerid,10,1862.4465,-1702.9535,3203.0859);
	}
	if(pickupid == isejimas)
	{
		if(playerDB[playerid][ikalintas]) return SetPlayerHealth(playerid,0.0);
		SetPlayerPosFade(playerid,10,3085.9692,-784.9335,11.5190);
	}
	if (pickupid == laukas)
	{
		SetPlayerPosFade(playerid,10,3105.1443,-822.8339,11.5755);
	}
	if (pickupid == lauke)
	{
		SetPlayerPosFade(playerid,10,1850.3074,-1732.7581,3203.0859);
	}
	if(pickupid == entersp)
	{
		SetPlayerPosFade(playerid,10,559.4380,-2092.8203,2.67120);
	}
	if(pickupid == exitsp)
	{
		SetPlayerPosFade(playerid,10,561.7214,-2033.8285,16.1670);
	}
	if(pickupid == entersauna)
	{
		SetPlayerPosFade(playerid,10,527.8544,-2082.4460,17.2253);
	}
	if(pickupid == exitsauna)
	{
		SetPlayerPosFade(playerid,10,570.3227,-2093.3599,2.6448);
	}
	if(pickupid == bigjump)
	{
		SetPlayerPosFade(playerid,10,578.5896,-2194.7065,7.1380);
	}
	if(pickupid == anima)
	{
		ApplyAnimation(playerid,"DAM_JUMP","DAM_LAUNCH",2,0,1,1,0,0);
	}
	return 1;
}
