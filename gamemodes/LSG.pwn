stock ClearStreamInfo(playerid) 
{
	for(new i;i<MAX_PLAYERS;i++) 
	{
		ShowPlayerNameTagForPlayer(playerid, i, false);
		StreamedPlayers[playerid][sNameShown][i]=0;
		StreamedPlayers[playerid][sList][i]=0;
	}
	StreamedPlayers[playerid][sCount]=0;

}


