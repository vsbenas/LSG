stock AddSniego(playerid,longer=0)
{

	new Float:Coo[3];
	GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
	Sniegas[playerid]=CreatePlayerObject(playerid,18864,Coo[0],Coo[1],Coo[2]-2.0,0.0,0.0,0.0,20.0);
	SniegoTimer[playerid]=SetTimerEx("UpdateSniegas",500,true,"i",playerid);
	SetTimerEx("UzteksMirgalo",30000 + longer * 150000,false,"i",playerid); // -> 60000

}

public UpdateSniegas(playerid)
