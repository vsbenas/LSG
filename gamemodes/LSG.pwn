stock TikrinamDalyvius()
{
 	new DalyviaiInCp =0;
	foreach(Player, i) // 
		if(IsPlayerInRaceCheckpoint(i) && KDalyvis[i][Dalyvauja] && KDalyvis[i][DabartinisCPs]==Keliones[DabartinisCP] && GetPlayerState(i) == PLAYER_STATE_DRIVER && AutoKluboMasina(i))
			DalyviaiInCp++;
	if(Keliones[Dalyviai] < 2) // cant start with less than 2
		 return 0;
	if(Keliones[paskutinisCP])
	{
		if(DalyviaiInCp == Keliones[Dalyviai]) return 1;
		else return 0; 
	}
	else
	{
		if(DalyviaiInCp == Keliones[Dalyviai]) return 2;
		else if(DalyviaiInCp >= (floatround((Keliones[Dalyviai]/3)*2))) return 3;
		else return 0;
	}
}

stock Float:GetAutokluboBonus()
{
	new unique = 0;
	new modelUsed[1000];
	foreach(Player, i)
	{
		if(KDalyvis[i][Dalyvauja])
		{
			new model = GetVehicleModel(GetPlayerVehicleID(i));
			if(model)
			{
				if(!modelUsed[model])
				{
					modelUsed[model]=1;
					unique++;
				}
			}
		}
	}
	if(unique > 6)
		unique = 6;
	new Float:modelBonus = 1.0 + (0.5 * unique/6.0); // 4 autoklubo cars and 2 bikes
	return modelBonus; // max 1.5
}

stock GetAutokluboReward() 
{
	return floatround(Keliones[Dalyviai]*120*GetAutokluboBonus());
}
stock Float:GetTuneMultipler(playerid)
{
	return (1.0 + (0.5 * PlayerTuneBonus[playerid] / 10.0)); // PlayerTuneBonus <= 10, so max tune multiplier is 1.5
}

stock SetPlayerTuneBonus(playerid, tunebonus)
{
	if(tunebonus == 0)
		return;
	new vehicleid = GetPlayerVehicleID(playerid);
	if(vehicleid != PlayerCar[playerid])
		return;
	new model = GetVehicleModel(vehicleid);
	new bool:found = false;
	for(new x;x<MAX_DARBINES_CAR;x++)
	{
		if(DarbinesCar[70][x][DCmodel]==model || DarbinesCar[73][x][DCmodel]==model) // automanai ir motomanai
		{
			found = true;
		}
	}
	if(!found)
		return;
	if(tunebonus > 10)
		tunebonus = 10;
	PlayerTuneBonus[playerid] = tunebonus;
	new msg[256];
	format(msg,256, " * Tavo autoklubo tune bonusas {FF0000}+%.1f%s{FFFFFF}!", (GetTuneMultipler(playerid) - 1)*100, "%%"); // max 50%
	SendClientMessage(playerid, -1, msg);
}

public NaujasCP()
{
	Keliones[Atlygis] += GetAutokluboReward();
	Keliones[NaujasCPs]=false;
	Keliones[DabartinisCP]++;
	foreach(Player, i)
	{
		if(KDalyvis[i][Dalyvauja])
		{
			if(Keliones[DabartinisCP]-1==KDalyvis[i][DabartinisCPs])
			{
				SetCPS(i,Keliones[DabartinisCP],Keliones[Paskutinysis]);
				//CallRemoteFunction("SetCPS", "iii", i,Keliones[DabartinisCP],Keliones[Paskutinysis]);
				if(Keliones[DabartinisCP]==Keliones[Paskutinysis])
				{
					Keliones[paskutinisCP]=true;
					SetPlayerRaceCheckpoint(i,1,KelionesKurimas[Keliones[DabartinisCP]][koordx], KelionesKurimas[Keliones[DabartinisCP]][koordy],KelionesKurimas[Keliones[DabartinisCP]][koordz],KelionesKurimas[Keliones[DabartinisCP]+1][koordx], KelionesKurimas[Keliones[DabartinisCP]+1][koordy],KelionesKurimas[Keliones[DabartinisCP]+1][koordz],18);
				}
				else
					SetPlayerRaceCheckpoint(i,0,KelionesKurimas[Keliones[DabartinisCP]][koordx], KelionesKurimas[Keliones[DabartinisCP]][koordy],KelionesKurimas[Keliones[DabartinisCP]][koordz],KelionesKurimas[Keliones[DabartinisCP]+1][koordx], KelionesKurimas[Keliones[DabartinisCP]+1][koordy],KelionesKurimas[Keliones[DabartinisCP]+1][koordz],18);
				GivePlayerMoneyA(i,floatround(20*GetAutokluboBonus()*GetTuneMultipler(i)));
			}
			else
			{
				SendInfoMessage(i,"Jus buvote pasalintas is keliones, nes nespejote paskui kitus.");
				KDalyvis[i][Dalyvauja]=false;
				KDalyvis[i][DabartinisCPs]=0;
				Keliones[Dalyviai]--;
				DisablePlayerRaceCheckpoint(i);
				HideCPS(i);
			}
			
		}
	}
	/*new msg[128];
	format(msg,sizeof(msg),"CP :%i",Keliones[DabartinisCP]);
	SendClientMessageToAll(COLOR,msg); */
}


public SkaiciuojamAtlygi()
{
	if(Keliones[Dalyviai]==0) 
		return;
	new msg[256];
	format(msg,sizeof(msg),"[racija] Operatore: Kelione %s baigta! Autoklubo pelnas uzaugo %i€! Autoklubo bonusas: {FF0000}%i%s{FFFFFF}!",Keliones[KelionesPavadinimas],Keliones[Atlygis], floatround(GetAutokluboBonus()*100 - 100), "%%");
    SendMessageToKlubai(0xFFFFFF30,msg);

	Keliones[Ijungta]=false;
	Keliones[Dalyviai]=0;
	
	Keliones[Atlygis] += GetAutokluboReward();
	//Keliones[Atlygis] = Keliones[Dalyviai]*120*(Keliones[Paskutinysis]+1);
	
	//pelnas[69]+=Keliones[Atlygis];
	Pelnas(-1,69,Keliones[Atlygis]);
	Keliones[Atlygis]=0;
	foreach(Player, i) if(KDalyvis[i][Dalyvauja])
	{
		HideCPS(i); 
		ProcessAchievement(i,77);
		playerDB[i][jobpts]++;
		KDalyvis[i][Dalyvauja]=false;
		KDalyvis[i][DabartinisCPs]=0;
		KDalyvis[i][DabartinisCPs]=0;
		//Keliones[Dalyviai]--;
		DisablePlayerRaceCheckpoint(i);
	}
}




forward GasPilot(playerid,vehicleid,model);
public GasPilot(playerid,vehicleid,model)
{
	TogglePlayerControllable(playerid,true);
	RepairVehicle(vehicleid);
	GameTextForPlayer(playerid,"~w~Galite Vaziuoti.",3000,3);
	vehicleDB[vehicleid][gas]=aBakai[model-400]-0.5;
	return 1;
}
public OnPlayerEnterRaceCheckpoint(playerid)
{
	if(NotSpawned[playerid]) return 0;
	if(YRace_OnPlayerEnterRaceCP(playerid))
		return 1;
    PlayerPlaySound(playerid, 1139,0.0,0.0,0.0); // Muzika
	if(KaleduRaceCP(playerid))
		return 1;
	new vehicleid = GetPlayerVehicleID(playerid);
//	new string[128];
	new model = GetVehicleModel(vehicleid);
	if(model == 593) // dodo kaledu event
	{
		if(RogesActive[playerid])
		{
			if(IsInRace(playerid) > 0)
				return 1;
			if(RogesActive[playerid] == 1) // start timer
			{
				SetProgressBarMaxValue(Veiksmai, sizeof(KaleduRace));
				ShowProgressBarForPlayer(playerid, Veiksmai);
				StartVeiksmas(playerid,"Kaledu Event");
				RogesTime[playerid]=GetTickCount();
			}
			SetProgressBarValue(Veiksmai,RogesActive[playerid]);

			ShowProgressBarForPlayer(playerid, Veiksmai);

			if(RogesActive[playerid] == sizeof(KaleduRace))
			{
				new taimas = GetTickCount() - RogesTime[playerid];
				new msg[256];
				format(msg,sizeof(msg),"{00FF00}Kalëdř event 2019\n{FFFFFF}Sveikinu! Tu trasŕ pabaigei per {00FF00}%02d:%02d.%02d{FFFFFF}!\nDabar keliauk pas Kalëdř Senelá jei dar neatsiëmei dovanos.",(taimas / 60000),((taimas / 1000) % 60),(taimas % 1000) / 10);
				ShowPlayerDialog(playerid, 4859, DIALOG_STYLE_MSGBOX, "Kalëdos", msg, "Gerai","");
				SetPVarInt(playerid,"IsdalinoDovanas",1);
				DestroyRoges(playerid);
				//format(msg,sizeof(msg),"Update `Kaledos17` SET Time = CASE WHEN Time IS NULL THEN %i ELSE LEAST(Time,%i) END, `Dovana` = CASE WHEN Dovana = 0 THEN 1 ELSE Dovana END WHERE Vardas='%s'",taimas,taimas,ReturnName(playerid));
				//mysql_function_query(SQL, msg, true, "SQL_UpdatedTime", "i", playerid);

			}
			if(RogesActive[playerid]==sizeof(KaleduRace)-1)
			{
				new id = RogesActive[playerid];
				SetPlayerRaceCheckpoint(playerid, 4, KaleduRace[id][0],KaleduRace[id][1],KaleduRace[id][2],0.0,0.0,0.0,18.0);
			}
			else
			{
				new id = RogesActive[playerid];
				SetPlayerRaceCheckpoint(playerid, 4, KaleduRace[id][0],KaleduRace[id][1],KaleduRace[id][2],KaleduRace[id+1][0],KaleduRace[id+1][1],KaleduRace[id+1][2],18.0);
				KrentaDovana(playerid);
			}
			RogesActive[playerid]++;

		}
	}
	if(model == 509 && ChristmasEvent[playerid])
	{
		DisablePlayerRaceCheckpoint(playerid);
		ChristmasEvent[playerid]++;
		if(ChristmasEvent[playerid] == 13) // go to santa
		{
			SendClientMessage(playerid,GREEN," * Isdalinai visas dovanas! Grizk pas kaledu seneli ir pasiimk savo dovana!");
		}
		else
		{
			new oldid = CurrentEventCP[playerid];
			new cpid = random(sizeof(EventCps));
			if(oldid == cpid) cpid = (oldid+1) % (sizeof(EventCps));
			SetPlayerRaceCheckpoint(playerid,0,EventCps[cpid][0],EventCps[cpid][1],EventCps[cpid][2],EventCps[cpid][0],EventCps[cpid][1],0.00,2.0);
			CurrentEventCP[playerid]=cpid;
			new msgas[127];
			SendClientMessage(playerid,WHITE," * Imetei dovana i kamina!");
			format(msgas,127," * Saunu! Tu jau isveziojai %i is 12 dovanu.",ChristmasEvent[playerid]-1);
			SendClientMessage(playerid,RED,msgas);
			new obj = CreateObject(19055,EventCps[oldid][0],EventCps[oldid][1],EventCps[oldid][2]+5.0,0.0,0.0,0.0,100.0);
			MoveObject(obj,EventCps[oldid][0],EventCps[oldid][1],0.0,5.0);
			SetTimerEx("DovanaKrenta",5000,false,"i",obj);
		}
		new queryz[256];
		new IP[24];
		GetPlayerIp(playerid,IP,24);
		format(queryz,sizeof(queryz),"UPDATE `Kaledos11` SET `Cps`=%i WHERE `Vardas`='%s' OR `Ip`='%s'",ChristmasEvent[playerid]-1,ReturnName(playerid),IP);
		mysql_query(queryz);
		return 1;
	}
	if(model == 519 || model == 577)
	{
		new Float:LOL;
