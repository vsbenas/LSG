	{
		format(msg,sizeof(msg),"Skraidydami musu transportu, firmai jus uzdirbsite %iEUR/min.", uzdarbis);
	}
	SendInfoMessage(playerid, msg);
}
forward FixBot();
public FixBot()
{
	new bot = -1;
  	for(new i=0;i<MAX_PLAYERS;i++) if(IsPlayerConnected(i) && IsPlayerNPC(i)) {
  		bot = i;
  		break;
  	} 
  	if(bot == -1)
  		ConnectNPC("Bus_Driver","mat_test");
	else if (GetPlayerVehicleID(bot) != Busikas)
	{
		PutPlayerInVehicle(bot,Busikas,0);
	}
}
