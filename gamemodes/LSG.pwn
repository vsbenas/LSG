#define BitFlag_Get(%0,%1)            ((%0) & (%1))   // Returns zero (false) if the flag isn't set.
#define BitFlag_On(%0,%1)             ((%0) |= (%1))  // Turn on a flag.
#define BitFlag_Off(%0,%1)            ((%0) &= ~(%1)) // Turn off a flag.
#define BitFlag_Toggle(%0,%1)         ((%0) ^= (%1))  // Toggle a flag (swap true/false).
//BitFlag_Get(PConfig[playerid],PCFG_);
enum PCFG:(<<= 1) {
    // It's important that you don't forget to put "= 1" on the first flag. If you don't, all flags will be 0.
    
    PCFG_SPARTIEJI = 1,        // 0b00000000000000000000000000000001
    PCFG_SHOWGCHAT,            // 0b00000000000000000000000000000010
    PCFG_SHOWVCHAT,  		   // 0b00000000000000000000000000000100
    PCFG_SHOWVIPCHAT,          // 0b00000000000000000000000000001000
    PCFG_SHOWNAMES,            // 0b00000000000000000000000000010000
    PCFG_SHOWTIME,             // 0b00000000000000000000000000100000
    PCFG_SHOWACHAT,            // 0b00000000000000000000000001000000
    PCFG_AKINIAI,              // 0b00000000000000000000000010000000
    PCFG_SALMAS,               // 0b00000000000000000000000100000000
    PCFG_KEPURE,               // 0b00000000000000000000001000000000
    PCFG_SHOWSPEEDO,           // 0b00000000000000000000010000000000
    PCFG_SHOWANIMATIONS,       // 0b00000000000000000000100000000000
    PCFG_SHOWJOBTEXT,          // 0b00000000000000000001000000000000
    PCFG_SHOWALKIS,            // 0b00000000000000000010000000000000
    PCFG_RAIDES,          // 0b00000000000000000100000000000000
    PCFG_HITSOUND,          // 0b00000000000000001000000000000000
    PCFG_PASISLEPES,          // 0b00000000000000010000000000000000
    PCFG_MONETA,          // 0b00000000000000100000000000000000
    PLAYER_BLABLA_16,          // 0b00000000000001000000000000000000
    PLAYER_BLABLA_17,          // 0b00000000000010000000000000000000
    PLAYER_BLABLA_18,          // 0b00000000000100000000000000000000
    PLAYER_BLABLA_19,          // 0b00000000001000000000000000000000
    PLAYER_BLABLA_20,          // 0b00000000010000000000000000000000
    PLAYER_BLABLA_21,          // 0b00000000100000000000000000000000
    PLAYER_BLABLA_22           // 0b00000001000000000000000000000000
}; // INV_AKINIAI, INV_SALMAS,INV_KEPURE

new
    // Create an array with the same tag as the enum
    PCFG:PConfig[MAX_PLAYERS];

#include <YSI\y_iterate>
