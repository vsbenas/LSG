stock UpdateChaseMeter(playerid)
{
	new speed = GetSpeed(playerid);
	if(!speed) speed=1;
	new cops;
	new bool:hide=false;
	new CopArray[MAX_PLAYERS];
	new totalplus;
	foreach(Player, i)
	{
		if(i!= playerid && (playerDB[i][specialybe]==80 || playerDB[i][specialybe]==81 || playerDB[i][specialybe]==82 || playerDB[i][specialybe]==83 || playerDB[i][specialybe]==84))
		{
			new Float:Dist = GetDistanceBetweenPlayers(playerid, i);
			if(Dist < 150)
			{
				CopArray[cops]=i;
				cops++;
			}
			if(Dist < 10)
			{
				new Float:speedbonus=speed/10.0;
				if(speedbonus < 1) speedbonus=1;
				totalplus+=floatround((20.0-Dist)*10.0/speedbonus);
			}
		}
	}
	if(!cops)
	{ 
		ChaseMeter[playerid]-=50;
		if(ChaseMeter[playerid] < 0)
		{
			ChaseMeter[playerid]=0;
		}
	}
	else
	{
		ChaseMeter[playerid]+=totalplus;
		if(ChaseMeter[playerid] >= 1000)
		{
			ChaseMeter[playerid]=0;
			/*new id=playerid;
			new msg[128],police[MAX_PLAYER_NAME];
			GetPlayerName(playerid,police,sizeof(police));
			GetPlayerName(id,vardas,sizeof(vardas));
			//if(playerDB[playerid][ant]) return SendInfoMessage(playerid,"Jus esate surakintas!");
			if(!playerDB[id][ant])
			{
				playerDB[id][ant]=true;
				TogglePlayerControllable(id,false);

				format(msg,sizeof(msg),"~r~Surakinote %s.",vardas);
				SendInfoMessage(playerid,msg);
				format(msg,sizeof(msg),"Surakinote %s.",vardas);
				SendClientMessage(playerid,RED,msg);

				format(msg,sizeof(msg),"~r~Jus surakino %s.",police);
				SendInfoMessage(id,msg);
				format(msg,sizeof(msg),"Jus surakino %s.",police);
				SendClientMessage(id,RED,msg);
				SetPlayerAttachedObject(id, CUFF_SLOT, 19418, 6, -0.011000, 0.028000, -0.022000, -15.600012, -33.699977, -81.700035, 0.891999, 1.000000, 1.168000);
				if(GetPlayerScore(id) < 11000) SendClientMessage(id,-1,"Jei atsijungsite busite uzbanintas.");
				if(!IsPlayerInAnyVehicle(id))
				{

					SetPlayerSpecialAction(id, 24); // SPECIAL_ACTION_CUFFED
				}
			}*/
			HideProgressBarForPlayer(playerid,Chase);
			hide=true;
		}
	}
	if(hide)
	{
		for(new i;i<cops;i++)
		{
			new id=CopArray[i];
			//SetPlayerMarkerForPlayer(id, playerid, 0xFF0000FF );
			HideProgressBarForPlayer(id, Chase);
		}
	}
	else
	{
		new thecolor=floatround(((ChaseMeter[playerid]/10)*12)/100);
		SetProgressBarColor(Chase, ChaseArray[thecolor]);
		SetProgressBarValue(Chase, ChaseMeter[playerid]);
		for(new i;i<cops;i++)
		{
			new id=CopArray[i];
			ShowProgressBarForPlayer(id, Chase);
		}
		ShowProgressBarForPlayer(playerid, Chase);
	}
	return 1;
}


