forward Rukymas(playerid);
public Rukymas(playerid)
{
	if(playerDB[playerid][ruko]==0) return 1;
	new Float:giv;
	GetPlayerHealth(playerid, giv);
	if(giv+1.0 <= 200) SetPlayerHealth(playerid, giv + 1.0);
	if(playerDB[playerid][sotumas] < 50.0) playerDB[playerid][sotumas]=playerDB[playerid][sotumas]+0.5;
	SetProgressBarMaxValue(Veiksmai, 10);
	SetProgressBarValue(Veiksmai,playerDB[playerid][ruko]);
	
	ShowProgressBarForPlayer(playerid, Veiksmai);
	StartVeiksmas(playerid,"Cigarete");
	if(playerDB[playerid][ruko] == 5)
		playerDB[playerid][parukes]=true;
	if(playerDB[playerid][ruko] == 10)
	{
		playerDB[playerid][parukes]=true;
		playerDB[playerid][ruko]=0;
		SetTimerEx("NebeParukes",60000,false,"i",playerid);
		HideProgressBarForPlayer(playerid,Veiksmai);
		EndVeiksmas(playerid);
		SetPlayerSpecialAction(playerid, SPECIAL_ACTION_NONE);
	}
	/*Invul[playerid]=true;
	SetTimerEx("NoInvul",1000,false,"i",playerid);*/
	return 1;
}
forward NebeParukes(playerid);
