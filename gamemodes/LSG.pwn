stock DestroyRoges(playerid)
{
	if(RogesActive[playerid]) {
		HideProgressBarForPlayer(playerid,Veiksmai);
		EndVeiksmas(playerid);
		DisablePlayerRaceCheckpoint(playerid);
		for(new i;i<32;i++) 
			DestroyDynamicObject(RogesObj[playerid][i]);
		DestroyVehicle(RogesVehicle[playerid]);
		PlayerCar[playerid]=-1;
		RogesActive[playerid]=0;
		StopAudioStreamForPlayer(playerid);
		return 1;
	}

	return 0;
}
stock KrentaDovana(playerid)
{
	new Float:c[3];
	GetPlayerPos(playerid,c[0],c[1],c[2]);
	GetXYBehindPlayer(playerid, c[0],c[1], 2.0);
	
	SendClientMessage(playerid,WHITE," **** Iđmetei dovanŕ! ****");
	new obj = CreateObject(19054+random(5),c[0],c[1],c[2]-4.0,0.0,0.0,0.0,100.0);
	MapAndreas_FindZ_For2DCoord(c[0],c[1],c[2]);
	MoveObject(obj,c[0],c[1],c[2]+0.5,9.0);
	SetTimerEx("DovanaKrenta",20000,false,"i",obj);
}

stock CreateMiskoGaisras(id) {

	MiskoGaisrai[fCenter][0] = GaisruCoord[id][0];
	MiskoGaisrai[fCenter][1] = GaisruCoord[id][1];
	MiskoGaisrai[fCenter][2] = GaisruCoord[id][2];

	MiskoGaisrai[inProgress]=true;
	MiskoGaisrai[fLeft] = 0;
	new Float:Xg = MiskoGaisrai[fCenter][0] - 5.0*10;
	new Float:Yg = MiskoGaisrai[fCenter][1] - 5.0*10;
	new slot = 0;
	new Float:Fz;
	for(new x; x < 10; x ++)
	{
		for(new y; y < 10; y++) 
		{
			MiskoGaisrai[fLeft]++;
			new Float:Ztemp;
			MapAndreas_FindZ_For2DCoord(Xg + 10*x, Yg + 10*y, Ztemp);
			new Float:Diff = GaisruCoord[id][2]-Ztemp;
			if(random(3) == 0)
				Fz = Ztemp;
			else
				Fz = GaisruCoord[id][2]-10.0-(random(floatround(Diff/2)));
			MiskoGaisrai[fObjects][slot] = CreateDynamicObject(18691, Xg + 10*x, Yg + 10*y, Fz, 0.0,0.0,0.0,-1,-1,-1,300.0,300.0);
			MiskoGaisrai[fIcons][slot] = CreateDynamicMapIcon(Xg + 10*x, Yg + 10*y, MiskoGaisrai[fCenter][2]+20.0, 0, ORANGE, -1, -1 ,-1, 100.0);
			slot++;
		}

	}
	MiskoGaisrai[fTimer] = SetTimer("Explosions", 2000, true);

}
forward Explosions();
public Explosions() {
	new Float:Coo[3];
	for(new r; r<2;r++) {
		new id = random(MiskoGaisrai[fLeft]);
		GetDynamicObjectPos(MiskoGaisrai[fObjects][id], Coo[0],Coo[1],Coo[2]);
		new Float:Ztemp;
		MapAndreas_FindZ_For2DCoord(Coo[0],Coo[1], Ztemp);
		if(Ztemp + 5.0 < Coo[2]) // not on the ground
		{
			if(random(3) == 0)
				CreateExplosion(Coo[0],Coo[1],Coo[2], 6, 50.0); // 6
			else 
				CreateExplosion(Coo[0],Coo[1],Coo[2], 2, 50.0); // 2
		}
		else
			CreateExplosion(Coo[0],Coo[1],Coo[2], 2, 50.0); // 2
	}
	foreach(Player, i) 
	{
		if(IsPlayerInRangeOfPointEx(100.0, i, MiskoGaisrai[fCenter][0],MiskoGaisrai[fCenter][1],MiskoGaisrai[fCenter][2])) 
		{
			if(GetVehicleModel(GetPlayerVehicleID(i))==563) // rainddance
			{
				if(CarLights[i]) // water on
				{
					new Float:Fpos[3];
					new Float:Ppos[3];
					GetVehiclePos(GetPlayerVehicleID(i),Ppos[0],Ppos[1],Ppos[2]);
					new found = 0;
					for(new fireid;fireid < MiskoGaisrai[fLeft] && found < 5; fireid++)
					{
						GetDynamicObjectPos(MiskoGaisrai[fObjects][fireid], Fpos[0],Fpos[1],Fpos[2]);
						if(floatabs(Fpos[0] - Ppos[0]) < 10.0 && floatabs(Fpos[1] - Ppos[1]) < 10.0)
						{
							found ++;
							ExtinguishFire(fireid);
						}
					}
					if(found > 0 && MiskoGaisrai[fLeft] > 0) {
						SetProgressBarMaxValue(Veiksmai, 400);
						SetProgressBarValue(Veiksmai,MiskoGaisrai[fLeft]+10);
						SetTimerEx("DelayedCik", 500, false, "i",i);
						ShowProgressBarForPlayer(i, Veiksmai);
						StartVeiksmas(i,"Misko gaisras");
					}
				}
			}
		}
	}

}
forward DelayedCik(playerid);
public DelayedCik(playerid)
{
	PlayerPlaySound(playerid, 1139,0.0,0.0,0.0);
}
stock ExtinguishFire(fireid) // < 400
{
	DestroyDynamicObject(MiskoGaisrai[fObjects][fireid]);
	DestroyDynamicMapIcon(MiskoGaisrai[fIcons][fireid]);
	MiskoGaisrai[fLeft]--;
	new left = MiskoGaisrai[fLeft];
	if(MiskoGaisrai[fLeft] > 0) {
		MiskoGaisrai[fObjects][fireid] = MiskoGaisrai[fObjects][left];
		MiskoGaisrai[fIcons][fireid] = MiskoGaisrai[fIcons][left];
		MiskoGaisrai[fIcons][left] = 0;
		MiskoGaisrai[fObjects][left] = 0;
	}
	else {
		SendMessageToGaisras(ORANGE,"[racija] Operatore: Misko gaisras uzgesintas!");
		Pelnas(-1,65,floatround(MONEYP_GAISRININKAI*18));

		foreach(Player, i)
		{
			if(GetVehicleModel(GetPlayerVehicleID(i))==563 && GetPlayerState(i) == PLAYER_STATE_DRIVER) // rainddance
			{
				ProcessAchievement(i,97);
				EndVeiksmas(i);
				HideProgressBarForPlayer(i,Veiksmai);
				if(IsPlayerInRangeOfPointEx(200.0, i, MiskoGaisrai[fCenter][0],MiskoGaisrai[fCenter][1],MiskoGaisrai[fCenter][2])) 
				{
					GivePlayerMoneyA(i,floatround(MONEYP_GAISRININKAI*6));
					playerDB[i][jobpts]++;
				}
			}
		}
		
		MiskoGaisrai[inProgress]=false;
		KillTimer(MiskoGaisrai[fTimer]);
	}
}
new MoneyVan=-1;

stock CheckMoneySpray() 
{
	if(MoneyVan != -1)
		SprayMoney(MoneyVan);
}
stock ThrowMoney(playerid)
{
	new veh = GetPlayerVehicleID(playerid);
	new speed = GetSpeedEx(veh);
	if(speed < 45)
		speed = 45;
	speed = speed/20;
	new Float:a;
	GetVehicleZAngle( veh, a ); // priekis

	new Float:Coo[3];
	GetVehiclePos(veh, Coo[0], Coo[1], Coo[2]);
	GetXYBehindVehicle(veh,Coo[0],Coo[1],3.5,0);
	new Float:Zcord;
	MapAndreas_FindZ_For2DCoord(Coo[0],Coo[1],Zcord);
	//for(new i;i<1;i++) 
	{

		new Float:sin,Float:cos;
		
		new obj = CreateObject(1550, Coo[0], Coo[1], Coo[2]+1.0, 0, 0, 0);

		new offset = 80; // - random(20);// - random(20);
		a -= 180+offset;
		if(a < 0)
			a+=360.0;
		sin = floatsin( -a, degrees );
		cos = floatcos( -a, degrees );

		PHY_InitObject(obj);
		PHY_SetObjectVelocity(obj, speed*sin, speed*cos, speed+5);

		PHY_SetObjectFriction(obj, 100); // This will stop the object when it touchs the ground.
		PHY_SetObjectGravity(obj, GRAVITY);
		PHY_SetObjectZBound(obj, Zcord+0.5, _, 0.0);
		PHY_SetObjectGhost(obj);

	}
}
stock SprayMoney(veh)
{

	if(GetVehicleModel(veh) != 428) 
		return;
	new speed = GetSpeedEx(veh);
	if(speed > 45) 
	{
		speed = speed/20;
		new Float:a;
		GetVehicleZAngle( veh, a );
		new Float:Coo[3];
		GetVehiclePos(veh, Coo[0], Coo[1], Coo[2]);
		GetXYBehindVehicle(veh,Coo[0],Coo[1],3.5,0);
		new Float:Zcord;
		MapAndreas_FindZ_For2DCoord(Coo[0],Coo[1],Zcord);
		//for(new i;i<1;i++) 
		{

			new Float:sin,Float:cos;
			
			new obj = CreateObject(1212, Coo[0], Coo[1], Coo[2]+1.0, 0, 0, 0);

			new offset = 90 - random(180);
			a += offset;
			if(a >= 360.0)
				a-=360.0;
			sin = floatsin( -a, degrees );
			cos = floatcos( -a, degrees );

			PHY_InitObject(obj);
			PHY_SetObjectVelocity(obj, speed*sin, speed*cos, speed+5);

			PHY_SetObjectFriction(obj, 100); // This will stop the object when it touchs the ground.
			PHY_SetObjectGravity(obj, GRAVITY);
			PHY_SetObjectZBound(obj, Zcord, _, 0.0);
			PHY_SetObjectGhost(obj);

		}
	}
}
forward MakeActor(actorid,Float:Xx,Float:Yy,Float:Zz,Float:Rr,vworld);
public MakeActor(actorid,Float:Xx,Float:Yy,Float:Zz,Float:Rr,vworld)
{
	SetActorPos(actorid, Xx, Yy, Zz);
	SetActorFacingAngle(actorid, Rr);
	SetActorVirtualWorld(actorid, vworld);
}


stock _animLibExist(_LoadAnin[])
{
    if(_LoadAnin[0] == '\0')
        return 0;
 
    for(new i = 0; i < sizeof(_AnimsEnum); i ++)
    {
        if(!strcmp(_LoadAnin, _AnimsEnum[i], true))
        {
            return 1;
        }
    }
    return 0;
}  


stock ShowPlayerKiausai(playerid)
{
	new query[128];
	format(query,128,"SELECT k1,k2,k3,k4,k5 From `Easter18` WHERE `Vardas`='%s'",ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_ShowKiausai", "i", playerid);
}

stock PadetiKiausini(playerid,kiausinis)
{
	new query[128];
	format(query,128,"SELECT k1,k2,k3,k4,k5 From `Easter18` WHERE `Vardas`='%s'",ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_PadetiKiausai", "ii", playerid,kiausinis);
}

stock GetPresent(playerid)
{
	new query[128];
	format(query,128,"SELECT k1,k2,k3,k4,k5,prizas From `Easter18` WHERE `Vardas`='%s'",ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_CheckPrize", "i", playerid);
}

stock ShowUzsakymai(playerid,type)
{
	new query[256];
	format(query,256,"SELECT * FROM Orders Where `type`=%i and `status`<>2 ORDER BY `date` ASC ",type);
	mysql_function_query(SQL, query, true, "SQL_ShowOrders", "ii", playerid,type);
}

stock NewUzsakymas(playerid,type,forid,amount)
{
	new query[256];
	format(query,256,"SELECT * FROM Orders Where `type`=%i and `forid`=%i and `status`<>2",type,forid);
	mysql_function_query(SQL, query, true, "SQL_CheckOrder", "iiii", playerid,type,forid,amount);
}

stock CreateOrder(playerid,type,forid,amount)
{
	new query[256];
	SendMessageToInka(TEXTCOL_GOLD,"[racija] Operatore: Naujas uzsakymas musu firmoje!");
	format(query,sizeof(query), "INSERT INTO Orders(`from`,`type`,`forid`,`amount`,`status`,`date`) VALUES ('%s',%i,%i,%i,0,NOW())",ReturnName(playerid),type,forid,amount);
	mysql_query(query);
	SendClientMessage(playerid, TEXTCOL_GOLD, " * Inkasatoriai *");
	SendClientMessage(playerid, WHITE, " * Uţsakymas priimtas. Ačiű, kad naudojates műsř paslaugomis!");
	//SendMessageToInka(TEXTCOL_GOLD,"[racija] Operatore: Naujas uzsakymas musu firmoje!");
	if(playerDB[playerid][specialybe] == 60)
	{
		ShowPlayerDialog(playerid,17000,DIALOG_STYLE_LIST,"Inkasatoriai","Padaryti uţsakymŕ\nPriimti uţsakymŕ","Gerai","Atsaukti");
	}
	else
	{
		ShowPlayerDialog(playerid,17000,DIALOG_STYLE_LIST,"Inkasatoriai","Padaryti uţsakymŕ","Gerai","Atsaukti");
	}
}

stock StartUzsakymas(playerid,idas)
{
	new query[256];
	format(query,256,"SELECT * FROM Orders Where `type`=0 and `status`<>2 ORDER BY `date` ASC ");
	mysql_function_query(SQL, query, true, "SQL_StartOrder", "ii", playerid,idas);
}

stock LoadOrderInka(playerid)
{

	if(playerDB[playerid][specialybe] != 60)
		return 0;
	new veh = GetPlayerVehicleID(playerid);
	if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	{
		if(GetVehicleModel(veh) != 428) 
			return 0;
		if(InkaUzsakymai[playerid][utype] == 0)
		{
			if(InkaUzsakymai[playerid][ustatus] == 1) // is verslo i banka
			{
				new idx = InkaUzsakymai[playerid][uforid];
				SetPlayerCheckpoint(playerid, BusinessInfo[idx][bEnterX],BusinessInfo[idx][bEnterY],BusinessInfo[idx][bEnterZ],5.0);
				SendClientMessage(playerid, COLOR, " * Verslo, is kurio turite pervezti pinigus, checkpointas pazymetas zemelapyje.");
				SendClientMessage(playerid, COLOR, " * Informavome pardavejus, kad perduotu jums pinigus.");
			}
			else if(InkaUzsakymai[playerid][ustatus] == 2) // paemem saibas, nesam i automobili
			{
				SendClientMessage(playerid, COLOR, " * Privalote padeti pinigus i automobilio saugykla.");
				RemovePlayerFromVehicle(playerid);
			}
			else if(InkaUzsakymai[playerid][ustatus] == 3) // vezam i banka
			{
				SendClientMessage(playerid, COLOR, " * Pagrindinio banko saugykla pazymeta zemelapyje.");
				SendClientMessage(playerid, COLOR, " * Atvaziave ten pasiimkite pinigus is automobilio ir nuneskite juos i seifa.");
				SetPlayerCheckpoint(playerid,1480.8185,-1825.6321,13.5469,5.0);
			}
			else if(InkaUzsakymai[playerid][ustatus] == 4)
			{
				SendClientMessage(playerid, COLOR, " * Neskite pinigus i banko seifa.");
				RemovePlayerFromVehicle(playerid);
			}
		}
		else if(InkaUzsakymai[playerid][utype] == 1)
		{
			new idx = InkaUzsakymai[playerid][uforid];
			if(InkaUzsakymai[playerid][uamount] == 5)
			{
				SendClientMessage(playerid, COLOR, " * Visi pinigai tavo masinoje svarus! Dabar uzlipk ant gaujos pickupo.");
				MoneyVan=-1;
				SetPlayerAttachedObject(playerid, MESKERE_SLOT, 1550, 1, 0.1, -0.3, 0, 0, 40, 0, 1, 1, 1);

			}
			else if(IsPlayerInRangeOfPointEx(35.0, playerid, BusinessInfo[idx][bEnterX],BusinessInfo[idx][bEnterY],BusinessInfo[idx][bEnterZ]))
			{
				ThrowMoney(playerid);
				SendClientMessage(playerid, COLOR, " * Isplovei viena pinigu maisa!");
				SendMessageToTeisesauga(YELLOW,"[racija] Operatore: Los Santos mieste yra plaunami pinigai! Ieskokite inkasatoriaus su padirbtais pinigais!");
				InkaUzsakymai[playerid][uamount]++;
				if(InkaUzsakymai[playerid][uamount] == 5)
				{
					return LoadOrderInka(playerid);
				}
				else
				{
					new lastbiz = idx;
					new verslas = Iter_Random(Businesses);
					if(verslas == 4 || verslas == lastbiz)
					{
						verslas++;
						if(verslas > 100)
							verslas = 0;
					}

					InkaUzsakymai[playerid][uforid]=verslas;
					new kelintas = InkaUzsakymai[playerid][uamount];
					new keli[24];
					if(kelintas == 0)
						keli = "Pirmasis";
					else if(kelintas == 1)
						keli = "Antrasis";
					else if(kelintas == 2)
						keli = "Treciasis";
					else if(kelintas == 3)
						keli = "Ketvirtasis";
					else if(kelintas == 4)
						keli = "Paskutinysis";
					new msg[128];
					
					format(msg,sizeof(msg)," * %s verslas yra '%s' (%s), jis pazymetas zemelapyje.",keli,BusinessInfo[verslas][bName],GetBussinessType(BusinessInfo[verslas][bType]));
					SendClientMessage(playerid, COLOR, " * Tavo darbas yra praplauti pinigus 5 Los Santos versluose, ir tuomet pristatyti i gaujos baze.");
					SendClientMessage(playerid, TEXTCOL_GOLD, msg);
					SetPlayerCheckpoint(playerid,BusinessInfo[verslas][bEnterX],BusinessInfo[verslas][bEnterY],BusinessInfo[verslas][bEnterZ],30.0);
					return 1;
				}
			}
			else
			{
				new kelintas = InkaUzsakymai[playerid][uamount];
				new keli[24];
				if(kelintas == 0)
					keli = "Pirmasis";
				else if(kelintas == 1)
					keli = "Antrasis";
				else if(kelintas == 2)
					keli = "Treciasis";
				else if(kelintas == 3)
					keli = "Ketvirtasis";
				else if(kelintas == 4)
					keli = "Paskutinysis";
				new msg[128];
				
				format(msg,sizeof(msg)," * %s verslas yra '%s' (%s), jis pazymetas zemelapyje.",keli,BusinessInfo[idx][bName],GetBussinessType(BusinessInfo[idx][bType]));
				SendClientMessage(playerid, COLOR, " * Tavo darbas yra praplauti pinigus 5 Los Santos versluose, ir tuomet pristatyti i gaujos baze.");
				SendClientMessage(playerid, TEXTCOL_GOLD, msg);
				SetPlayerCheckpoint(playerid,BusinessInfo[idx][bEnterX],BusinessInfo[idx][bEnterY],BusinessInfo[idx][bEnterZ],30.0);
			}

		}
	}
	else if(GetPlayerState(playerid) == PLAYER_STATE_PASSENGER)
	{
		if(GetVehicleModel(veh) != 428) 
			return 0;
		if(InkaUzsakymai[playerid][utype] == 0)
		{
			if(InkaUzsakymai[playerid][ustatus] == 2)
			{
				new vid = GetPlayerVehicleID(playerid);
				if(vid != PlayerCar[playerid])
				{
					SendClientMessage(playerid, COLOR, " * Tai ne tavo darbinis automobilis.");
				}
				else
				{
					new iSeat = GetPlayerVehicleSeat(playerid);
		    		if(iSeat != 2 && iSeat != 3)
		    		{
		    			SendClientMessage(playerid, COLOR, " * Turi padeti pinigus i saugykla (galines durys).");
		    			RemovePlayerFromVehicle(playerid);
		    		}
		    		else
		    		{
		    			RemovePlayerAttachedObject(playerid, MESKERE_SLOT);
		    			InkaUzsakymai[playerid][ustatus]++;
		    			SendClientMessage(playerid, COLOR, " * Padejai pinigus i saugykla.");
		    		}
				}
			}
			else if(InkaUzsakymai[playerid][ustatus] == 3)
			{
				if(!IsPlayerInRangeOfPointEx(10.0,playerid, 1480.8185,-1825.6321,13.5469))
				{
					SendClientMessage(playerid, COLOR, " * Tu per toli nuo banko seifo!");
					RemovePlayerFromVehicle(playerid);
				}
				else
				{
					new iSeat = GetPlayerVehicleSeat(playerid);
		    		if(iSeat != 2 && iSeat != 3)
		    		{
		    			SendClientMessage(playerid, COLOR, " * Turi paimti pinigus is automobilio saugyklos.");
		    			RemovePlayerFromVehicle(playerid);
		    		}
		    		else
		    		{
						SetPlayerAttachedObject(playerid, MESKERE_SLOT, 1550, 1, 0.1, -0.3, 0, 0, 40, 0, 1, 1, 1);
						InkaUzsakymai[playerid][ustatus]++;
						SendClientMessage(playerid, COLOR, " * Paemei pinigu maisa! Nunesk ji i seifa.");
					}
				}
			}

		}
	}
	else if(InkaUzsakymai[playerid][ustatus])
	{
		if(IsInBiz(playerid))
		{
			new idx=(GetPlayerVirtualWorld(playerid)-MAX_HOUSES*2);
			if(idx == InkaUzsakymai[playerid][uforid] && InkaUzsakymai[playerid][ustatus] == 1)
			{

				SetPlayerAttachedObject(playerid, MESKERE_SLOT, 1550, 1, 0.1, -0.3, 0, 0, 40, 0, 1, 1, 1);
				InkaUzsakymai[playerid][ustatus]++;
				ApplyAnimation(playerid, "MISC", "pickup_box", 4.000000, 0, 0, 0, 0, -1);
				SendClientMessage(playerid, COLOR, " * Paemei pinigu maisa! Pasidek ji i automobilio saugykla.");
				return 1;
			}
		}
		else if(IsPlayerInRangeOfPointEx(5.0, playerid,2141.2041,1633.2432,993.5761))
		{
			if(InkaUzsakymai[playerid][ustatus] == 4)
			{
				SendClientMessage(playerid, COLOR, " * Uzsakymas ivykdytas!");
				new amount = InkaUzsakymai[playerid][uamount];
				new uzstatas = amount/10;

				new msg[512];

				format(msg,sizeof(msg), " * Atgavai %i€ uţstatŕ.",uzstatas);
				SendClientMessage(playerid, TEXTCOL_GOLD, msg);
				GivePlayerMoneyA(playerid, uzstatas);
				new atlygis = amount/20;
				if(atlygis < 1000)
					atlygis = 1000;
				new ipelna = (atlygis * 3) / 4;
				format(msg,sizeof(msg), " * Uţdirbai %i€ á rankas ir %i€ á pelnŕ.",atlygis,ipelna);
				GivePlayerMoneyA(playerid,atlygis);
				Pelnas(playerid,59,ipelna);
				SendClientMessage(playerid, TEXTCOL_GOLD, msg);
				InkaUzsakymai[playerid][ustatus]=0;
				InkaUzsakymai[playerid][uamount]=0;
				new forid = InkaUzsakymai[playerid][uforid];
				InkaUzsakymai[playerid][uforid]=0;
				playerDB[playerid][jobpts]++;
				RemovePlayerAttachedObject(playerid, MESKERE_SLOT);
				new query[256];
				format(query,256,"UPDATE Orders Set `status`=2 WHERE `type`=0 and `forid`=%i and `takenby`='%s'",forid,ReturnName(playerid));
				mysql_query(query);
				new Alga = amount;
				format(msg,sizeof(msg),"Inkasatorius %s pristate Jusu verslo '%s' pelna i banka.~Pajamos: %iEUR.~Pervedimo mokestis: 0EUR.",ReturnName(playerid),BusinessInfo[forid][bName],amount);
				EAtaskaita("Inkasatoriai",BusinessInfo[forid][bOwner],"Pinigai pristatyti",msg);
				new forplayerid = GetIdForAlgos(BusinessInfo[forid][bOwner]);
				if(forplayerid == INVALID_PLAYER_ID || playerDB[forplayerid][authstate]!=4)
				{
					new queryz[256];
					format(queryz,sizeof(queryz),"UPDATE `Account` SET `Money.Bank`=(`Money.Bank`+%i) WHERE `Name` = '%s'",Alga,BusinessInfo[forid][bOwner]);
					mysql_query(queryz);
				}
				else
				{
					format(msg,sizeof(msg)," * Jums buvo pristatytas %i€ pelnas is verslo '%s'.",Alga,BusinessInfo[forid][bName]);
					SendClientMessage(forplayerid,ORANGE,msg);
					playerDB[forplayerid][banke]+=Alga;
					SavePlayerData(forplayerid,true);
				}
				BusinessInfo[forid][bEarning]-=amount;
				return 1;
			}
			
		}
	}
	return 0;
}
stock PrapisoPinigus(playerid,withcar)
{
	if(!withcar)
	{
		SendClientMessage(playerid, RED, " * Prapisai pinigu maisa! Deja, uzstato firma nekompensuos...");
		InkaUzsakymai[playerid][ustatus]=0;
		InkaUzsakymai[playerid][uamount]=0;
		new forid = InkaUzsakymai[playerid][uforid];
		InkaUzsakymai[playerid][uforid]=0;
		new query[256];
		format(query,256,"UPDATE Orders Set `status`=0 WHERE `type`=0 and `status`=1 and `forid`=%i",forid);
		mysql_query(query);
		RemovePlayerAttachedObject(playerid, MESKERE_SLOT);

	}
	else
	{
		SendClientMessage(playerid, RED, " * Sprogo tavo automobilis su pinigais! Deja, uzstato firma nekompensuos...");
		InkaUzsakymai[playerid][ustatus]=0;
		InkaUzsakymai[playerid][uamount]=0;
		new forid = InkaUzsakymai[playerid][uforid];
		InkaUzsakymai[playerid][uforid]=0;
		new query[256];
		format(query,256,"UPDATE Orders Set `status`=0 WHERE `type`=0 and `status`=1 and `forid`=%i",forid);
		mysql_query(query);
	}

}
stock LoadDirtyMoney(playerid,gangmember)
{
	MoneyVan=GetPlayerVehicleID(gangmember);
	SendClientMessage(gangmember, COLOR, " * Pakrovei pinigus i inkasatoriaus automobili! Dabar viskas priklauso nuo tavo vairuotojo...");
	new verslas = Iter_Random(Businesses);
	if(verslas == 4)
		verslas++;
	SendClientMessage(playerid, COLOR, " * Gavai pinigu pervezimo uzsakyma!");
	InkaUzsakymai[playerid][utype]=1;
	InkaUzsakymai[playerid][uforid]=verslas;
	InkaUzsakymai[playerid][uamount]=0;
	playerDB[gangmember][dirtymoney]=false;
	LoadOrderInka(playerid);
}

stock InkaUzsakymas() {
	new query[256];
	format(query,sizeof(query),"SELECT EnterWorld From Bizniai WHERE Earning > 5000");
	mysql_function_query(SQL, query, true, "SQL_PickInka", "");
}


stock SellNark(playerid, type, kiekis, price)
{
	new query[256];
	new idx = GetPlayerVirtualWorld(playerid) - MAX_HOUSES*2;
	format(query,256,"SELECT * From NarkTrade Where busid=%i AND type=%i",idx,type);
	mysql_function_query(SQL, query, true, "SQL_CheckNarkSell","iiii",playerid, type, kiekis, price);
}

stock BuyNark(playerid, type, kiek, price)
{
	if(GetPlayerMoneyA(playerid) < kiek*price)
		return SendInfoMessage(playerid,"~r~Neturi tiek pinigu!");
	if(!IsInBiz(playerid))
	{
		return 0;
	}
	new idx=(GetPlayerVirtualWorld(playerid)-MAX_HOUSES*2);
	new biztype = BusinessInfo[idx][bType];
	if(biztype != 4)
		return 0;
	new query[256];
	format(query,256,"SELECT amount From NarkTrade Where busid=%i AND type=%i",idx,type);
	mysql_function_query(SQL, query, true, "SQL_CheckNarkBuy","iiiii",playerid, type, kiek, price,idx);
	/*if(type == 0 && playerDB[playerid][zole] +kiek > 10)
		return SendInfoMessage(playerid,"~r~Tu tiek nepatempsi!");
	if(type == 1 && playerDB[playerid][lsd] +kiek > 10)
		return SendInfoMessage(playerid,"~r~Tu tiek nepatempsi!");
	if(type == 2 && playerDB[playerid][ratai] +kiek > 10)
		return SendInfoMessage(playerid,"~r~Tu tiek nepatempsi!");
	if(type == 3 && playerDB[playerid][amfetaminas] +kiek > 10)
		return SendInfoMessage(playerid,"~r~Tu tiek nepatempsi!");*/
	return 1;
}


stock KurMenu(playerid,itemx = -100)
{
	if(itemx != -100) {
		// check categories
		if(itemx == 0)
		{
			ShowPlayerDialog(playerid,012,DIALOG_STYLE_LIST,"Darbai",#TEXT_GREEN"• "#TEXT_WHITE"Mini darbai\n"#TEXT_GREEN"• "#TEXT_WHITE"Darbai be pakvietimo\n"#TEXT_GREEN"• "#TEXT_WHITE"Darbai su pakvietimu\n"#TEXT_GREEN"• "#TEXT_WHITE"Nelegalűs darbai\n \n"#TEXT_GREEN"• "#TEXT_WHITE"Apie darbus","Rinktis","Iseiti");			return 1;
		}
		if(itemx == -1)
		{
			ShowPlayerDialog(playerid,667,DIALOG_STYLE_INPUT,"Rasti zmogu","Norëdami surasti ţmogř, árađykite jo vardŕ.","Rasti","Iseiti");
			return 1;
		}
		if(itemx == -2)
		{
			ShowPlayerDialog(playerid,668,DIALOG_STYLE_INPUT,"Rasti nama","Norëdami surasti namŕ, árađykite jo numerá.","Rasti","Iseiti");
			return 1;
		}
		// now cats
		if(itemx < -2)
		 {
			new zinut[24];
			format(zinut,24,"expand_%i",itemx);
			SetPVarInt(playerid, zinut, 1 - GetPVarInt(playerid, zinut));
		}
		else if(itemx > 0) 
		{
			itemx--;
			if(KurVietos[itemx][v_x] != 0.0) {
				SetPlayerCheckpoint(playerid,KurVietos[itemx][v_x],KurVietos[itemx][v_y],KurVietos[itemx][v_z],6.0);
				new msgas[128];
				format(msgas,128,"Mini mape matote raudona taskeli, vazuokite link jo, ten rasite %s.",KurVietos[itemx][v_pav]);
				//SendInfoMessage(playerid,"Mini mape matote raudona taskeli, vazuokite link jo, ten rasite dazasvydi.");
				SendInfoMessage(playerid,msgas);
				return 1;
			}
			else {
				if(KurVietos[itemx][v_kat] == 3){ // darbiniai taisykla 
					//ShowPlayerDialog(playerid,670,DIALOG_STYLE_LIST,"Taisyklos","1\n2\n3","Rinktis","Atsaukti");
					new const Float:Taisykloz[][3]= {
						{1017.7556,-917.3123,42.4931},
						{ 1911.2146,-1775.0718,13.5318},
						{666.1385,-616.0114,16.3396},
						{2456.0039,-1460.7887,24.1489}
					};
					new tid = GetPVarInt(playerid, "closest_taisykla");
					SetPlayerCheckpoint(playerid,Taisykloz[tid][0],Taisykloz[tid][1],Taisykloz[tid][2],6.0);
					new msgas[128];
					format(msgas,128,"Mini mape matote raudona taskeli, vazuokite link jo, ten rasite taisykla nr.%i.",tid+1);
					//SendInfoMessage(playerid,"Mini mape matote raudona taskeli, vazuokite link jo, ten rasite dazasvydi.");
					SendInfoMessage(playerid,msgas);
					return 1;
					
				}
				else if(KurVietos[itemx][v_kat] == 4)
					return ShowPlayerDialog(playerid,669,DIALOG_STYLE_LIST,"Automobiliu turgus","Pigus automobiliai\nLowRiders\nSportiniai automobiliai ir Dviraciai\nLaivai","Gerai","Atsaukti");
			}
		}
	}
	for(new i;i<sizeof(KurKategorijos);i++)
	{
		new formatas[100];
		format(formatas,100,"expand_%i",-i);
		new expand = GetPVarInt(playerid, formatas);
		format(formatas,sizeof(formatas),#TEXT_GREEN"• "#TEXT_WHITE"%s\t ",KurKategorijos[i]);
		AddDListItem(playerid, formatas, -i);
		if(expand)
		{
			for(new x;x<sizeof(KurVietos);x++) 
			{
				if(KurVietos[x][v_kat] == i) 
				{
					new Float:distas = GetPlayerDistanceFromPoint(playerid, KurVietos[x][v_x],KurVietos[x][v_y],KurVietos[x][v_z])/300;
					if(KurVietos[x][v_x] == 0.0 && i==3) // taisykla
					{
						new Float:temp1 = GetPlayerDistanceFromPoint(playerid,  1017.7556,-917.3123,42.4931);
						new Float:temp2 = GetPlayerDistanceFromPoint(playerid, 1911.2146,-1775.0718,13.5318 );
						new Float:temp3 = GetPlayerDistanceFromPoint(playerid, 666.1385,-616.0114,16.3396);
						new Float:temp4 = GetPlayerDistanceFromPoint(playerid, 2456.0039,-1460.7887,24.1489);
						if(temp1 < temp2 && temp1 < temp3 && temp1 < temp4) {
							distas = temp1;
							SetPVarInt(playerid, "closest_taisykla", 0);
						}
						else if(temp2 < temp1 && temp2 < temp3 && temp2 < temp4) {
							distas = temp2;
							SetPVarInt(playerid, "closest_taisykla", 1);
						}
						else if(temp3 < temp1 && temp3 < temp2 && temp3 < temp4) {
							distas = temp3;
							SetPVarInt(playerid, "closest_taisykla", 2);
						}
						else {
							distas = temp4;
							SetPVarInt(playerid, "closest_taisykla", 3);
						}
						distas = distas / 300;
					}

					format(formatas,sizeof(formatas),"    "#TEXT_GREEN"• "#TEXT_WHITE"%s\t%.1fkm",KurVietos[x][v_pav],distas);
					AddDListItem(playerid, formatas, x+1);
				}
			}
		}
	}
	ShowPlayerDListHeader(playerid, 666, "Kur?", "Rinktis", "Iseiti","Vieta\tAtstumas");
	return 1;
}

stock ControlBalloon(playerid) 
{
	new id = fs_balloon_pl[playerid][1];
	new
			keys[3], Float:Coo[3];
	
	GetPlayerKeys(playerid, keys[0], keys[1], keys[2]);
	GetObjectPos(fs_balloon_set[id][0],Coo[0],Coo[1],Coo[2]);

	new Float:Zcord;
	MapAndreas_FindZ_For2DCoord(Coo[0],Coo[1],Zcord);
	new Float:height = Coo[2] - Zcord;

	new move = 0;
	if(keys[0] == KEY_JUMP)
	{
		if(Direction[playerid][0] < 1.0) 
			Direction[playerid][0] += 0.02;
		move = 1;
	}
	else if(keys[0] == KEY_SPRINT)
	{
		if(Direction[playerid][0] > -0.5)
			Direction[playerid][0] -= 0.02;
		move = 1;
	}
	else
	{
		if(height > 10 && Direction[playerid][0] > -0.5) {
			Direction[playerid][0] -= 0.01;
			move = 1;
		} 
	}
	if(keys[1] == KEY_UP)
	{
		if(Direction[playerid][1] < 1.0 && (height >= 30 || Direction[playerid][0] < -0.2 || Direction[playerid][0] > 0.4)) 
			Direction[playerid][1] += 0.02;
		move = 1;
	}
	else if(keys[1] == KEY_DOWN)
	{
		if(Direction[playerid][1] > 0) Direction[playerid][1] -= 0.02;
		move = 1;
	}
	else
	{
		if(Direction[playerid][1] > 0) {
			Direction[playerid][1] -= 0.01;
			move = 1;
		} 
	}
	if(keys[2] == KEY_LEFT)
	{

		Direction[playerid][2] += 5.0;
		if(Direction[playerid][2] >= 360)
			Direction[playerid][2] -= 360;
		SetPlayerFacingAngle(playerid, Direction[playerid][2]);
	}
	else if(keys[2] == KEY_RIGHT)
	{
		Direction[playerid][2] -= 5.0;
		if(Direction[playerid][2] < 0)
			Direction[playerid][2] += 360;
		SetPlayerFacingAngle(playerid, Direction[playerid][2]);
	}
	if(move) 
	{
		new Float:speedaz = floatsqroot(Direction[playerid][0]*Direction[playerid][0] + Direction[playerid][1]*Direction[playerid][1])*20/1.4142136; // div by sqrt(2)
		if(speedaz > 20.0)
			speedaz = 20.0;
	
		if(!IsPlayerInRangeOfPointEx(5.0, playerid, Coo[0], Coo[1], Coo[2]) && GetPlayerSurfingObjectID(playerid) == INVALID_OBJECT_ID) {
 			StopObject(fs_balloon_set[id][0]);
 			Direction[playerid][0]=0;
 			Direction[playerid][1]=0;
 			SetObjectPos(fs_balloon_set[id][0], Coo[0],Coo[1],Coo[2]);
			SetPlayerPoz(playerid,Coo[0],Coo[1],Coo[2]+1.0, _, _, 0);
			ApplyAnimation(playerid, "ped", "DRIVE_BOAT", 4.0, 1, 0, 0, 0, 0);
			return;
		}
		if(GetPlayerAnimationIndex(playerid) != 1093)
		{
			ApplyAnimation(playerid, "ped", "DRIVE_BOAT", 4.0, 1, 0, 0, 0, 0);
		}
		new Float:Zdir = Coo[2] + Direction[playerid][0]*10;

		if(Zdir < Zcord) {
			Zdir = Zcord; 
			Direction[playerid][0]=0;
			Direction[playerid][1]=0;
		}
		if(height >= 300) {
			if(Direction[playerid][0] > 0)
				Direction[playerid][0] -= 0.1;
		}
		if(height < 30 && (Direction[playerid][1] > 0.0 &&  -0.2 < Direction[playerid][0] < 0.4))
			Direction[playerid][1]=0.0;


		new Float:front = floatsqroot(Direction[playerid][1]*Direction[playerid][1])*20;
		Coo[0] += ( front * floatsin( -Direction[playerid][2], degrees ));
		Coo[1] += ( front * floatcos( -Direction[playerid][2], degrees ));



		new Float:FutureZ;
		MapAndreas_FindZ_For2DCoord(Coo[0],Coo[1],FutureZ);
		if(FutureZ > Zdir) {
			Direction[playerid][1]=0;
			return;
		}

		if(speedaz > 0.1)
			MoveObject(fs_balloon_set[id][0],Coo[0], Coo[1], Zdir,speedaz,0.0,0.0,Direction[playerid][2]);
		new
				string[128];
		new health = floatround((fs_balloon_set[id][4]*100.0)/MAX_BALLOON_HP);
		format(string, sizeof(string), "~n~~n~~n~~n~~n~~n~~n~~n~~n~~r~Greitis: ~w~%0.1f ~r~/ ~w~20.0~n~~r~Gyvybes: ~w~%i%%", speedaz,health);
		GameTextForPlayer(playerid, string, 1000, 3);
	}

}
stock CheckHitBalloon(hitid,weaponid)
{
	new found = -1;
	new id = -1;
	for(new i = 0; i < sizeof(fs_balloon_kor); i++)
	{
		if(fs_balloon_set[i][0] == hitid)
		{
			id = i;
			foreach(Player, x)
			{
				if(fs_balloon_pl[x][0] != 0) {
					if(fs_balloon_pl[x][1] == id)
						found=x;
				}
			}
		}
	}
	if(found == -1)
		return;

	new damg = floatround(GetWeaponDamage(weaponid));
	fs_balloon_set[id][4]-=damg;
	if(fs_balloon_set[id][4] <= 10)
	{
		new Float:Coo[3];
		GetObjectPos(fs_balloon_set[id][0],Coo[0],Coo[1],Coo[2]);
		CreateExplosion(Coo[0],Coo[1],Coo[2], 0, 5.0);
		DestroyBalloon(id);
		SpawnBalloon(id);
		foreach(Player, x)
		{
			if((fs_balloon_pl[x][0] != 0 && fs_balloon_pl[x][1] == id)|| GetPlayerSurfingObjectID(x) == hitid)
			{
				ClearAnimations(x);
				fs_balloon_pl[x][0] = 0;
				GivePlayerWeaponEx(x,46,1);
			}
		}
		
	}
}

forward StopMusic(playerid);
public StopMusic(playerid)
{
	PlayerPlaySound(playerid, 1186, 0.0, 0.0, 0.0); 
