stock CA_ContactTestEx(modelid, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz)	
{
	new Float:b;
	if(CA_GetModelBoundingSphere(modelid,b,b,b,b) == 0)
	{
		return 0;
	}
	else
	{
		return CA_ContactTest(modelid, x,y,z,rx,ry,rz);
	}

}
public OnPlayerEditDynamicObject(playerid, objectid, response, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz)
{	
	//printf("ok");
	if(DEBUG==true) printf("OnPlayerEditDynamicObject:%i",playerid);
	//printf("edit dynamic object id %i: %f,%f,%f,%f,%f,%f",objectid,x,y,z,rx,ry,rz);
	/*if(response==EDIT_RESPONSE_FINAL && IsPlayerAdmin(playerid))
	{
		SetDynamicObjectPos(objectid, x, y, z);
		SetDynamicObjectRot(objectid, rx, ry, rz);
		SendClientMessage(playerid, -1, "Done");
	}*/
	new houseid = GetPlayerHouseID(playerid);
	new polyid = GetPlayerPoly(playerid);

	if(GetPVarInt(playerid, "EditingID") != objectid)
	{
		CancelEdit(playerid);
		return 0;
	}
	if(GetPlace(playerid, /*houses= */ false) == PLACE_WORLD)
	{
		HandleWorldPlacing(playerid, objectid, response, x,y,z,rx,ry,rz);
		return 0;
	}
	if(polyid != GetPVarInt(playerid, "PlayerPoly") && !IsPlayerAdmin(playerid))
	{
		SetPlayerArmour(playerid, 0.0);
		SetPlayerHealth(playerid, 0.0);
		SendInfoMessage(playerid,"Iskritai is namo!");
		return 0;
	}

	if(response==EDIT_RESPONSE_FINAL || response==EDIT_RESPONSE_CANCEL)
	{
		if(polyid != -1)
		{
			new model = Streamer_GetIntData(STREAMER_TYPE_OBJECT,objectid,E_STREAMER_MODEL_ID);
			if(CA_ContactTestEx(model,x,y,z,rx,ry,rz) || !IsPointInPoly(polyid,x,y,z))
			{
				SendClientMessage(playerid, RED, " * Čia baldř statyti negali. Redagavimas atđauktas.");
				for(new i;i<MAX_BALDAI;i++)
				{
					if(BalduSistema[houseid][i][b_used] && BalduSistema[houseid][i][b_oid]==objectid)
					{	
						SetDynamicObjectPos(objectid, BalduSistema[houseid][i][b_x],BalduSistema[houseid][i][b_y],BalduSistema[houseid][i][b_z]);
						SetDynamicObjectRot(objectid, BalduSistema[houseid][i][b_rx],BalduSistema[houseid][i][b_ry],BalduSistema[houseid][i][b_rz]);
						return 0;
					}
				}
				return 0;
			}
		}
		

		SetDynamicObjectPos(objectid, x,y,z);
		SetDynamicObjectRot(objectid, rx, ry, rz);
		for(new i;i<MAX_BALDAI;i++)
		{
			if(BalduSistema[houseid][i][b_used] && BalduSistema[houseid][i][b_oid]==objectid)
			{	
				BalduSistema[houseid][i][b_x]=x;
				BalduSistema[houseid][i][b_y]=y;
				BalduSistema[houseid][i][b_z]=z;
				BalduSistema[houseid][i][b_rx]=rx;
				BalduSistema[houseid][i][b_ry]=ry;
				BalduSistema[houseid][i][b_rz]=rz;

		//DestroyDynamicObject(BalduSistema[houseid][i][b_oid]);
				//BalduSistema[houseid][i][b_oid]=CreateDynamicObject(BalduSistema[houseid][i][b_obj],BalduSistema[houseid][i][b_x],BalduSistema[houseid][i][b_y],BalduSistema[houseid][i][b_z],BalduSistema[houseid][i][b_rx],BalduSistema[houseid][i][b_ry],BalduSistema[houseid][i][b_rz],houseid);
				SendClientMessage(playerid, -1, " * Baldo pozicija iđsaugota!");
				if( GetPVarInt(playerid,"irengineja") == houseid)
					ShowPlayerDialog(playerid, 6883, DIALOG_STYLE_LIST, "Baldai", "Perstatyti","Gerai","Atsaukti");
				else
					ShowPlayerDialog(playerid, 6883, DIALOG_STYLE_LIST, "Baldai", "Perstatyti\nIđmesti\nPerveţti á kitŕ namŕ","Gerai","Atsaukti");
				SaveBaldai(houseid);
				break;
				
			}
		}
	}
	else
	{
		if(polyid != -1)
		{
			new model = Streamer_GetIntData(STREAMER_TYPE_OBJECT,objectid,E_STREAMER_MODEL_ID);
			if(CA_ContactTestEx(model,x,y,z,rx,ry,rz))
			{
				SendInfoMessage(playerid,"~r~Cia baldu statyti negali");
			}
			else if(!IsPointInPoly(polyid,x,y,z))
			{
				SendInfoMessage(playerid,"~r~Cia baldu statyti negali");
			}
			else
			{
				SendInfoMessage(playerid,"~g~Cia baldus statyti gali");
			}
		}
	}
	//CancelEdit(playerid);
	return 0;
}	


