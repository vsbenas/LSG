stock SaveBusinesses()
{
	//mysql_ntquery("Delete from `Bizniai`");
    foreach(Businesses,idx)
	{
	    if(!BusinessInfo[idx][bNumber]) continue;
        new coordsstring[1024];
	    format(coordsstring, sizeof(coordsstring), "REPLACE INTO `Bizniai`(Name,Owner,EnterX,EnterY,EnterZ,ExitX,ExitY,ExitZ,EnterInt,EnterWorld,Price,Number,Earning,Type,Owned,Radio,Mokesciai,Paeme) VALUES('%s','%s','%f','%f','%f','%f','%f','%f',%d,%d,%d,%d,%d,%d,%d,%d,%d,%d);",
		BusinessInfo[idx][bName],
		BusinessInfo[idx][bOwner],
		BusinessInfo[idx][bEnterX],
	    BusinessInfo[idx][bEnterY],
	    BusinessInfo[idx][bEnterZ],
	    BusinessInfo[idx][bExitX],
	    BusinessInfo[idx][bExitY],
	    BusinessInfo[idx][bExitZ],
	    BusinessInfo[idx][EnterInterior],
	    BusinessInfo[idx][EnterWorld],
	    BusinessInfo[idx][bPrice],
	    BusinessInfo[idx][bNumber],
	    BusinessInfo[idx][bEarning],
	    BusinessInfo[idx][bType],
	    BusinessInfo[idx][bOwned],
		BusinessInfo[idx][bRadio],
		BusinessInfo[idx][bMokesciai],
		BusinessInfo[idx][bPaeme]);
	    mysql_query(coordsstring);
	}
	return 1;
}
stock FindEmtyBizSlot()
{
	for(new i; i<MAX_BUSINESSES;i++) if(!BusinessInfo[i][bNumber]) return i;
	return -1;
}
