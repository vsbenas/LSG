stock RotateObject(objectid,Float:RX,Float:RY,Float:RZ,Float:Speed=1.0)
{
	new Float:PosX,Float:PosY,Float:PosZ;
	GetObjectPos(objectid,PosX,PosY,PosZ);
	new lol=random(2);
	if(!lol) lol=-1;
	return MoveObject(objectid,PosX,PosY,PosZ+(0.0002*lol),0.0001*Speed,RX,RY,RZ);
}
new LastFreezed[MAX_PLAYERS];
new PFreezed[MAX_PLAYERS];
stock TogglePlayerControllableEx(playerid,toggle)
