new NocheckInvul[MAX_PLAYERS];
public Chekas()
{	
	//if(FALSE==false) return 1;
    new
		Float:Coo[3],
		Float:VHP,
		Float:PARMOUR,
		Float:PHEAEURH,
		string[20],
		veh,
		hour,minute,
		statz,
		gun,
		ammo,
		speed,
		anim,
		insafearea,
		var,
		surfing,
		surfingveh,
		totalvmtest=0,
		tick
		;
	//new gWeaponData[13][2];
	gettime(hour,minute);
	tick = GetTickCount();
	//SetWorldTime(hour);
	new bool:changetime=false;
	if(minute != gTime)
	{
		gTime=minute;
		changetime=true;
		if(minute < 10) format(string, sizeof(string), "%d:0%d", hour, minute);
		else format(string, sizeof(string), "%d:%d", hour, minute);
		TextDrawSetString(Text:TextdrawTime, string);
		OnTimeChange(hour,minute);

	}
	if(Server[EventTime]) 
		Server[EventTime]--;
	else 
		Server[EventON]=false;
	UpdateDazai();
	UpdateLosimai();
	for(new id;id<MAX_POKER_GAMES;id++)
	{
		if(Poker[id][GameUsed])
		{
			if(Poker[id][Eile] != -1)
			{
				if(Poker[id][players][Poker[id][Eile]] != -1)
				{
					Poker[id][TimeLeft]--;
					format(string,sizeof(string),"Laukiama...%i",Poker[id][TimeLeft]);
					TextDrawSetString(Poker[id][PokerAction][Poker[id][Eile]],string);
					if(Poker[id][TimeLeft] == 0)
					{
						LeaveGame(Poker[id][players][Poker[id][Eile]],id,Poker[id][Eile]);
					}
		
				}
			}
			//TextDrawShowForPlayer(ppid,Poker[id][PokerAction][Poker[id][Eile]]);
		}
	}
	foreach (Player, playerid)
	{
		if(playerDB[playerid][authstate]==0)
		{
			if(tick - LoginStart[playerid] > 90000) // 1.5min
			{
				AC_Kick(playerid,"Per ilgas prisijungimas");
			}
			else if(MsgCount[playerid] > 6)
			{
				Kick(playerid);
			}
		}
		else if(MsgCount[playerid] > 6)
		{
			AC_Ban(playerid,"Spam");
		}
		UpdateSpectate(playerid);
		//if(Lrapid_countsec[playerid]) Lrapid_countsec[playerid]=0;
		new drunk = GetPlayerDrunkLevel(playerid);
		if(drunk < 300)
		{
			SetPlayerDrunkLevel(playerid, 1900);
			drunk=1900;
		}
		MsgCount[playerid]=0;
		if(RapidWarnings[playerid])
			RapidWarnings[playerid]=0;
		// name tag security
		PlayerTeleportedSameCar[playerid][1]=0;
		PlayerTeleportedSameCar[playerid][0]=0;
		UpdateMedikaiMission(playerid);
		UpdateWorlds(playerid);
		if(!playerDB[playerid][SpawnDance])
		{
			MoveCamera(playerid);
		}
		if(ChaseMeter[playerid] > 0) 
		{
			UpdateChaseMeter(playerid);
		}
		if(playerDB[playerid][pjauna])
		{
			Pjovimas(playerid);
		}
		if(playerDB[playerid][montuoja])
		{
			Montavimas(playerid);
		}
		if(playerDB[playerid][minuoja])
		{
			Minavimas(playerid);
		}
		if(GetPVarInt(playerid, "selfie") == 1)
		{
			if(!IsPlayerInRangeOfPointEx(1.0, playerid, SelfiePos[playerid][0], SelfiePos[playerid][1], SelfiePos[playerid][2]))
			{
				cmd_selfie(playerid,"");
			}
		}
		if(SaudyklosStats[playerid][s_id])
			SaudyklosInfo(playerid);
		if(Uzimineja[playerid])
		{
			if(hour == 19) Uzimineja[playerid]=0;
		}
		new left = (NarkTaimas[playerid] - GetTickCount())/1000;
		if(left <= 0 && changetime) SetPlayerTime(playerid,hour,minute);

		if(IsPlayerInRangeOfPointEx(10.0,playerid,1810.9484,-1890.2935,13.4071)) totalvmtest++; // prie vm vartu
		if(playerDB[playerid][ikalintas]) LikoSedeti(playerid);
		if(playerDB[playerid][banned]) TogglePlayerControllable(playerid, false);
		if(GetPVarInt(playerid, "PriemeIskvietima") != -1)
			UpdateJobText(playerid,100,GetPVarInt(playerid, "PriemeIskvietima"));// 100 rodom darbuotojui
		else if(GetPVarInt(playerid, "PriemeKlienta") != -1)
			UpdateJobText(playerid,99,GetPVarInt(playerid, "PriemeKlienta"));// 99 rodom klientui
		if(taxiDB[playerid][imti])
		{
			new kaina;
			new Float:Ex;
			Ex = ((GetTickCount() - taxiDB[playerid][Start])/60000.0);
			//printf("%f/%f/%i",Ex,Ex*MONEYP_TAKSISTAI,floatround(Ex*MONEYP_TAKSISTAI));
			if(playerDB[taxiDB[playerid][taksistas]][specialybe] == 3) kaina = floatround(Ex*MONEYP_TAKSISTAI);
			else if(GetVehicleModel(GetPlayerVehicleID(playerid)) == 409) kaina = floatround(Ex*MONEYP_LIMUZINAI);
			else if(playerDB[taxiDB[playerid][taksistas]][specialybe] == 20) kaina = floatround(Ex*MONEYP_TRANSPORTERIAI);			
			UpdateJobText(playerid,6,kaina);
			UpdateJobText(taxiDB[playerid][taksistas],6,kaina);
		}
		
		insafearea = SafeArea(playerid);
		if(insafearea)
		{
			if(SafeTDShown[playerid] == 0)
			{
				SafeTDShown[playerid]=1;
				TextDrawShowForPlayer(playerid, SafeTD);
				if(playerDB[playerid][specialybe]!=80 && playerDB[playerid][specialybe] != 82 && playerDB[playerid][specialybe]!=81 && playerDB[playerid][specialybe]!=83 && playerDB[playerid][specialybe]!=84)
				{
					SetPlayerTeam(playerid, 1);
				}
			}
		}
		else if(SafeTDShown[playerid] == 1)
		{
			SafeTDShown[playerid]=0;
			TextDrawHideForPlayer(playerid, SafeTD);
			if(playerDB[playerid][specialybe]!=80 && playerDB[playerid][specialybe] != 82 && playerDB[playerid][specialybe]!=81 && playerDB[playerid][specialybe]!=83 && playerDB[playerid][specialybe]!=84)
			{
				SetPlayerTeam(playerid, NO_TEAM);
			}
		}
		veh=GetPlayerVehicleID(playerid);
		if(veh)
		{
			SetCap(playerid,veh);
			KiausasSpray(playerid,veh);
			if(!VNoCheck[veh])
			{
				GetVehicleHealth(veh,VHP);
				if(VHP > VHealth[veh]+10.0 && !vehicleDB[veh][dega])
				{
					new bool:found=false;
					for(new x;x<sizeof(CarFixai);x++)
					{
						if(IsPlayerInRangeOfPointEx (15.0,playerid,CarFixai[x][0],CarFixai[x][1],CarFixai[x][2])){ found=true; }
					}
						
					if(!found && ac_InPayNSpray(playerid) == 0)
						AC_Warn(playerid,"Car Repair");
					//printf("%f > %f",HP,VHealth[veh]);
				}
				VHealth[veh]=VHP;
			}
			else VNoCheck[veh]--;
		}
		new target_actor = GetPlayerTargetActor(playerid);
		UpdateStars( playerid );
		if (s_TargetActor[playerid] != target_actor)
		{
			CallLocalFunction("OnPlayerTargetActor", "iii", playerid, target_actor, s_TargetActor[playerid]);
		
			s_TargetActor[playerid] = target_actor;
		}
		gun = GetPlayerWeapon(playerid);
		LastWeaponEx[playerid]=gun;
		//if(!playerDB[playerid][admin])
		{
			if((playerDB[playerid][authstate]==4 || playerDB[playerid][authstate]==1 || playerDB[playerid][authstate]==3 ) && playerDB[playerid][pospawn])
			{
				GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
				surfingveh = GetPlayerSurfingVehicleID (playerid);
				if(!IsPlayerAfkEx(playerid,tick))
				{
					/* ANTI-NAMETAG.. turns 200 into 40000 iterations
					not worth it
					if(!!BitFlag_Get(PConfig[playerid],PCFG_SHOWNAMES))
					{
						foreach(Player, i)
						{
							if(IsPlayerStreamedIn(i,playerid) && IsPlayerInRangeOfPointEx(25.0,i,Coo[0],Coo[1],Coo[2]))
							{
								if(!IsNameShown[playerid][i])
								{
									ShowPlayerNameTagForPlayer(playerid,i,true);
									IsNameShown[playerid][i]=true;
								}
		
							}
							else if(IsNameShown[playerid][i])
							{
								ShowPlayerNameTagForPlayer(playerid,i,false);
								IsNameShown[playerid][i]=false;
							}
						}
					} 
					*/
					// improving to 200*nearbyplayers
					statz = GetPlayerState(playerid);
					if(!!BitFlag_Get(PConfig[playerid],PCFG_SHOWNAMES)) 
					{
						for(new p;p<StreamedPlayers[playerid][sCount];p++) 
						{
							new pid = StreamedPlayers[playerid][sList][p];

							new Float:dists = GetPlayerDistanceFromPoint(pid,Coo[0],Coo[1],Coo[2]);
							if(dists <= 40.0 || (statz == PLAYER_STATE_SPECTATING && playerDB[playerid][admin])) 
							{
								if(StreamedPlayers[playerid][sNameShown][pid] == 0) {
									ShowPlayerNameTagForPlayer(playerid, pid, true);
									StreamedPlayers[playerid][sNameShown][pid]=1;
								}	
							}
							else
							{
								if(StreamedPlayers[playerid][sNameShown][pid] == 1) {
									ShowPlayerNameTagForPlayer(playerid, pid, false);
									StreamedPlayers[playerid][sNameShown][pid]=0;
								}	
							}

						}
					}

					
					if(tick - HealthAC[playerid][a_tick] > 5000)
					{
						GetPlayerHealth(playerid, PHEAEURH);
						GetPlayerArmour(playerid, PARMOUR);
						if(PARMOUR > HealthAC[playerid][set_armour])
						{
							AC_Warn(playerid,"Armour hack");
						}
						if(PHEAEURH > HealthAC[playerid][set_health] && ac_NearVendingMachine(playerid, GetPlayerInterior(playerid)) == 0 && playerDB[playerid][sotumas] > 10.0)
						{
							AC_Warn(playerid,"Health hack");
						}
						HealthAC[playerid][set_armour]=PARMOUR;
						HealthAC[playerid][set_health]=PHEAEURH;
					}

					
					if(veh != playerDB[playerid][pCar] && !playerDB[playerid][ant] && !playerDB[playerid][suristas] && statz==PLAYER_STATE_DRIVER)
					{
						AC_Warn(playerid,"Carjack ");

						new idx;
						new ida = GetPlayerFromCarlistID(veh,idx);
						if(idx != playerid && !IsAPBike(veh) && !playerDB[playerid][admin])
						{
							new kick = 0;
							//GetVehicleParamsEx(veh,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
							switch(ida)
							{
								case 1: if(Carlist[idx][Lock]) {kick = 1;}
								case 2: if(Carlist2[idx][Lock]) {kick = 1;}
								case 3: if(Carlist3[idx][Lock]) {kick = 1;}// return AC_Kick(playerid,"Carjack",1);
								default: {kick = 0;}
							}
							if(kick == 1)
							{
								AC_Kick(playerid,"Carjack",1);
							}
						}
						playerDB[playerid][pCar]=veh;
					}
					new surfingobj =  GetPlayerSurfingObjectID (playerid);
					surfing = (surfingveh != INVALID_VEHICLE_ID || surfingobj != INVALID_OBJECT_ID);
					
					if(playerDB[playerid][pAirbreaking]>=3)
						playerDB[playerid][pAirbreaking]=0;

					speed = JB_GetPlayerSpeed(playerid,true);
					if(statz == PLAYER_STATE_SPECTATING)
					{
						if(!playerDB[playerid][admin])
						{
							if(!playerDB[playerid][ikalintas] && playerDB[playerid][lektuvas] == -1)
							{
								AC_Kick(playerid,"Spectator mode");
							}
						}
					}
					if(statz==PLAYER_STATE_ONFOOT || ( statz==PLAYER_STATE_DRIVER && speed <10 ))
					{
						var=(floatround((GetPlayerDistanceFromPoint(playerid,playerDB[playerid][pCurrentPos][0],playerDB[playerid][pCurrentPos][1],playerDB[playerid][pCurrentPos][2])*3600)/(tick-playerDB[playerid][pLastCheck])));
						if(!NoCheckTP[playerid] && var>=500 && var<=1500 && !surfing)
						{
							playerDB[playerid][pAirbreaking]++;
							if(playerDB[playerid][pAirbreaking]==3)
							{
								playerDB[playerid][airbrk]++;
								if(playerDB[playerid][airbrk]<3)
								{
									new reason[128];
									format(reason,sizeof(reason),"AirBreak (aukstis: %.2f, greitis ~%d m/s)",Coo[2],var);
									AC_Warn(playerid,reason);
								}
								else
								{
									AC_Ban(playerid,"AirBreak");
									break;
								}
							}
						}
						else
							playerDB[playerid][pAirbreaking]=0;
					}
					anim = GetPlayerAnimationIndex(playerid);
					if ((Coo[2] < 900.0) == (playerDB[playerid][pCurrentPos][2] < 900.0))//Prevent kick when entering buildings.
					{
						if(!NoCheckTP[playerid])
						{
							if (statz != PLAYER_STATE_PASSENGER && statz != PLAYER_STATE_SPECTATING && !IsPlayerInRangeOfPointEx (350.0,playerid, playerDB[playerid][pCurrentPos][0], playerDB[playerid][pCurrentPos][1], playerDB[playerid][pCurrentPos][2]))
							{
								new surfwarn = 0;
								if(Surfing[playerid] != INVALID_VEHICLE_ID)
								{
									new Float:cooz[3];
									GetVehiclePos(Surfing[playerid],cooz[0],cooz[1],cooz[2]);
									if(IsPlayerInRangeOfPointEx (100.0,playerid, cooz[0],cooz[1],cooz[2]))
										surfwarn = 1;
								}
								if (surfwarn != 1 && !IsPlayerInRangeOfPointEx (5.0,playerid, playerDB[playerid][pSetPos][0], playerDB[playerid][pSetPos][1], playerDB[playerid][pSetPos][2]))
								{
									TeleportWarnings[playerid]++;
									printf("%s TP %f,%f,%f -> %f,%f,%f",ReturnName(playerid),playerDB[playerid][pCurrentPos][0], playerDB[playerid][pCurrentPos][1], playerDB[playerid][pCurrentPos][2],Coo[0],Coo[1],Coo[2]);
									if (IsCheatPosition (playerid)) // 1
									{
										AC_Ban(playerid,"Teleport(Cheat Pos)");
										break;
									}
									else if (TeleportWarnings[playerid] >= 3) // 3
									{
										AC_Ban(playerid,"Teleport");
										break;
									}
									else
									{
										new reason[128];
										new zona=Get2DZone(playerid);
										if(zona==26)
										{
					  						SetPlayerPoz(playerid,playerDB[playerid][pCurrentPos][0], playerDB[playerid][pCurrentPos][1], playerDB[playerid][pCurrentPos][2], _, _, 0);
											TeleportWarnings[playerid]--;
										}
										format(reason,sizeof(reason),"Teleport(Vieta: %s)",JB_gSAZones[zona][JB_SAZONE_NAME]);
										AC_Warn(playerid,reason);
									}
								}
							}
						}
						else 
						{
							if(anim == 1130) // save falling after entering building
							{
								if(IsPlayerInRangeOfPointEx (20.0,playerid, playerDB[playerid][pSetPos][0], playerDB[playerid][pSetPos][1], playerDB[playerid][pSetPos][2]))
									SetPlayerPos(playerid,playerDB[playerid][pSetPos][0],playerDB[playerid][pSetPos][1],playerDB[playerid][pSetPos][2]);
							}
							NoCheckTP[playerid]--;
						}
					}
					// invul
					if(DamageInbalance[playerid] >= 150.0)
					{
						AC_Warn(playerid,"Invulnerable");
						CheckInvul(playerid);
						warntime[playerid]=0;
						InvulWarnings[playerid]++;
						DamageInbalance[playerid]=0.0;
						/*if(InvulWarnings[playerid] == 3)
							AC_Kick(playerid,"Invulnerable"); */
					
					}
					if(NocheckInvul[playerid] == 0)
					{
						CheckInvul(playerid);
						NocheckInvul[playerid]=10;
					}
					else
						NocheckInvul[playerid]--;
					//Invisible?
					/*
					new Float:pX,Float:pY,Float:pZ,Float:wZ;
					GetPlayerPos(playerid,pX, pY, pZ);
					GetPointZPos(pX, pY, wZ);
					if(GetPlayerVirtualWorld(playerid) == 0 && pZ<wZ && !InvisDelay[playerid])
					{
						AC_Warn(playerid,"Invisible");
						SetTimerEx("InvisibleTimer",300000,0,"i",playerid);
						InvisDelay[playerid]=true;
					}
					*/
					
					if(statz == PLAYER_STATE_ONFOOT)
					{
						if(GetPlayerSpeed(playerid) > 3000)
						{
							AC_Ban(playerid, "Speedhack");
							return 1;
						}
						new skin = GetPlayerSkin(playerid);
						if (anim == 1231 && !ParaStatus[playerid])
						{
							if(!IsInvalidSkin(skin) && gun != 46 && !playerDB[playerid][admin])
							{
								AC_Kick(playerid, "Cheats detected 2");
								break;
							}
						}
						if(skin == 92 || skin == 99)
						{
							if(gun > 3 && gun < 42)
							{
								SetPlayerArmedWeapon(playerid, 0);
								SendInfoMessage(playerid,"~y~Negali naudotis ginklais ant rieduciu");
							}
						}
					}
					switch(gun)
					{
						case WEAPON_MINIGUN,WEAPON_UZI,WEAPON_HEATSEEKER,32:
						{
							if((!playerDB[playerid][admin] && !playerDB[playerid][psratasvydis]) || (playerDB[playerid][psratasvydis] && GetPlayerVirtualWorld(playerid) != 20001))
							{
								AC_Kick(playerid,"Neleistini ginklai");
								break;
							}
						}
						case 46:
						{
							ParaStatus[playerid]=200;
							
						}
						default:
						{
							if(ParaStatus[playerid]) 
								ParaStatus[playerid]--;
						}
						/*case 34:
						{
							if(playerDB[playerid][specialybe] != 83)
							{
								DeletePlayerWeapon(playerid, 34);
							}
						}*/
					}
					if(gun != 0 && gun != 40 && gun != 46 && gun != -1 && !playerDB[playerid][mire] && statz == PLAYER_STATE_ONFOOT )
					{
						
						if(!NoCheck[playerid])
						{
							new slotz = GetWeaponsSlot(gun);
							ammo = GetPlayerAmmo(playerid);
							if(GunData[playerid][slotz][0] != gun)
							{
								new gunpickup = IsNearGunPickup(playerid, gun);
								if(gunpickup)
								{
									OnPlayerPickUpPickup(playerid, gunpickup);
								}
								else
								{
									if(!playerDB[playerid][gunk][gun])
										AC_Ban(playerid,"Ginklai");
									else
									{
										DeletePlayerWeapon(playerid,gun);
										AC_Warn(playerid,"Ginklai");
									}	
								}
								continue;
							}							
							if(GunData[playerid][slotz][1] < ammo && ammo > 0 && gun != 42  || ammo == -100 && 0 <= GunData[playerid][slotz][1] <= 9999)
							{
								//AC_Kick(playerid,"Ginklai 2");
								if(GetPVarInt(playerid, "WarnedForKulkos") == 0)
									AC_Warn(playerid,"Kulku gamyba");
								SetPVarInt(playerid, "WarnedForKulkos", 1);
								printf("ammo %i data %i gunid %i",ammo,GunData[playerid][slotz][1],gun);
								new setammo = (GunData[playerid][slotz][1] == -100) ? (100000) : (GunData[playerid][slotz][1]);
								SetPlayerAmmo(playerid, gun, setammo);
								NoCheck[playerid]=3;
								//rintf("%i < %i weapon %i slot %i",GunData[playerid][slotz][1], ammo,GetPlayerWeapon(playerid),slotz);
							}
							if(0 < ammo < GunData[playerid][slotz][1] && 0 <= GunData[playerid][slotz][1] <= 9999)
							{
								GunData[playerid][slotz][1] = ammo; // uppdate it
							}
						}
						else 
							NoCheck[playerid]--;

						if(gun > 3 && gun < 42 && gun != 14)
						{
							if(insafearea && statz != PLAYER_STATE_DRIVER && statz != PLAYER_STATE_PASSENGER && !playerDB[playerid][admin])
							{
								SetPlayerArmedWeapon(playerid, 0), gun=0;
								SendInfoMessage(playerid,"~y~Sioje vietoje negalima naudotis ginklais");
							}
							
						}
						if(PiniguSandelis(playerid) && (gun == 41 || gun == 42 || gun == WEAPON_FLAMETHROWER)) //41 <= gun <= 42)
						{
							new keys,ud,lr;
							GetPlayerKeys(playerid, keys, ud, lr);
							if(keys & KEY_FIRE || keys & KEY_HANDBRAKE)
							{
								SetPlayerArmedWeapon(playerid, 0);
								SetPVarInt(playerid, "GesintuvoWarns", GetPVarInt(playerid, "GesintuvoWarns")+1);
								SendInfoMessage(playerid,"~y~Sioje vietoje negalima naudoti sio ginklo");
								if(GetPVarInt(playerid, "GesintuvoWarns") == 5)
								{
									SendInfoMessage(playerid,"~y~Prapisai savo ginkla");
									DeletePlayerWeapon(playerid,gun);
									SetPVarInt(playerid, "GesintuvoWarns", 0);
								}
								gun = 0;
							}
							
						}
						
					}
					/*if(gun != 0 && gun != 40 && gun != 46 && gun != -1 && !playerDB[playerid][mire] && (!playerDB[playerid][admin]))
					{
						if(!playerDB[playerid][gunk][gun])
						{
							AC_Ban(playerid,"Ginklai");
							break;
						}
						
						if(!NoCheck[playerid])
						{
							//GetPlayerWeaponData(playerid,GetWeaponsSlot(gun),gun,ammo);
							if(ammo > 0 && gun >= 16 && gun <= 39 && ammo > 0 && playerDB[playerid][ammok][gun] >= 0)
							{
								if(playerDB[playerid][ammok][gun] > ammo)
								{
									// update current ammo
									playerDB[playerid][ammok][gun] = ammo;
								}
								if(ammo > playerDB[playerid][ammok][gun])
								{
									if(WarnedForAmmo[playerid]==2)
									{
										printf("%s Pasidare kulku ginklui : %i kulkos: %i > %i",ReturnName(playerid),gun,ammo,playerDB[playerid][ammok][gun]);
										//SetPlayerArmedWeapon(playerid, 0);
										MLog(playerid,"Itariamas kulku gamyba","isisi",gun,"ginklas",ammo,">",playerDB[playerid][ammok][gun]);
										//DeletePlayerWeapon(playerid, gun);
										for(new i; i != sizeof(gWeaponData); ++i)
										{
											GetPlayerWeaponData(playerid, i, gWeaponData[i][0], gWeaponData[i][1]);
											if(gWeaponData[i][0] == gun) gWeaponData[i][1]=playerDB[playerid][ammok][gun];
											//gWeaponData[i][1] = gWeaponData[i][1] < 0 ? -gWeaponData[i][1] : gWeaponData[i][1];
											if(playerDB[playerid][ammok][gWeaponData[i][0]] < gWeaponData[i][1])
											{
												gWeaponData[i][1] = playerDB[playerid][ammok][gWeaponData[i][0]];
											}
											if(gWeaponData[i][1] == -100 && playerDB[playerid][ammok][gWeaponData[i][0]] != -100) gWeaponData[i][1]=playerDB[playerid][ammok][gWeaponData[i][0]];
										}
										ResetPlayerWeapons(playerid);

										for(new i; i != sizeof(gWeaponData); ++i) if(gWeaponData[i][0])
										{
											//if(gWeaponData[i][1] < playerDB[playerid][ammok][gun])
											GivePlayerWeaponEx(playerid, gWeaponData[i][0], gWeaponData[i][1]);
											//else
											//GivePlayerWeaponEx(playerid, gWeaponData[i][0], playerDB[playerid][ammok][gun]);
										}
									}
									else if(WarnedForAmmo[playerid] == 3)
									{
										AC_Kick(playerid,"Ginklai 2");
									}
									WarnedForAmmo[playerid]++;
								}
								else WarnedForAmmo[playerid]=0;

							}
							else WarnedForAmmo[playerid]=0;
						}
						else NoCheck[playerid]--;
						
					}
					*/
					if (speed > 45 && Coo[2] > 12.0 && (anim == 1543 || anim == 1538 || anim == 1539))
					{
						AC_Ban(playerid,"FlyHack");
						break;
					}
					var = GetPlayerPing(playerid);
					if(var > 500 && (!playerDB[playerid][admin]))
					{
						if(PingWarn[playerid] >=3)
						{
							new zinute[128],name[MAX_PLAYER_NAME];
							GetPlayerName(playerid,name,sizeof(name));
							format(zinute,128," * LSG Anti-Cheat : %s iđmestas dël didelio ping. Didţiausias leistinas: 500.",name);
							SendClientMessageToAll(RED,zinute);
							Kick(playerid);
							break;
						}
						else
							PingWarn[playerid]++;
					}
					if(playerDB[playerid][ikalintas])
					{
						new animlib[32];
						new animname[32];
						GetAnimationName(GetPlayerAnimationIndex(playerid),animlib,32,animname,32);
						if(!isnull(animlib) && strcmp(animlib, "SWIM", true) == 0)
						{
							SetPlayerHealth(playerid, 0.0);
							continue;
						}
					}
					if(GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK)
					{
						if((!playerDB[playerid][admin]) && !playerDB[playerid][psratasvydis] && GetPlace(playerid, /* houses= */ false) != PLACE_WORLD)
							SetPlayerSpecialAction(playerid,SPECIAL_ACTION_NONE);
						//AC_Kick(playerid,"Jetpack");
						//break;
					}
					/*else if(fs_balloon_pl[playerid][0] == 1)
					{
						DestroyBalloon(fs_balloon_pl[playerid][1]);
						SpawnBalloon(fs_balloon_pl[playerid][1]);
						fs_balloon_pl[playerid][0] = 0;
						SendClientMessage(playerid,-1," * Aciu kad naudojates balionu nuoma!");
					}*/
					if(0 < playerDB[playerid][klausosi] < 2000 && veh == playerDB[playerid][klausosi])
					{
						var = playerDB[playerid][klausosi];
						if(vehicleDB[var][energy] < 0.1)
						{
							vehicleDB[var][energy]=0;
						}
						else
							vehicleDB[var][energy]-=0.01;
					}
					/*	if(GetPlayerVehicleID(playerid)==0)
						{
							new Float:Coo2[3];
							GetVehiclePos(playerDB[playerid][klausosi],Coo2[0],Coo2[1],Coo2[2]);
							//Audio_Set3DPosition(playerid,playerDB[playerid][radija],Coo2[0],Coo2[1],Coo2[2],20);
							StopAudioStreamForPlayer(playerid);
							PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[playerDB[playerid][stotis]-1][RADIO_URL],Coo2[0],Coo2[1],Coo2[2],20.0,true);
						}
						*/
					if(PlayerAfk[playerid])
					{
						DestroyDynamic3DTextLabel(PlayerLabel[playerid]);
						
						PlayerAfk[playerid]=false;
						if(surfingveh == INVALID_VEHICLE_ID && Surfing[playerid] != INVALID_VEHICLE_ID && GetVehicleModel(Surfing[playerid]) == SurfingModel[playerid])
						{
							//new Float:coo[3];
							//GetVehicleRoof(Surfing[playerid],coo[0],coo[1],coo[2]);
							//SetPlayerPoz(playerid,coo[0],coo[1],coo[2]);
							SetTimerEx("FixSurf",1000,false,"ii",playerid,Surfing[playerid]);
							Surfing[playerid] = INVALID_VEHICLE_ID;
							
						}
					}
				}
				else
				{
					DamageInbalance[playerid]=0.0;
					if(!PlayerAfk[playerid])
					{
						Surfing[playerid]=surfingveh;
						SurfingModel[playerid] = GetVehicleModel(surfingveh);
						PlayerLabel[playerid] = CreateDynamic3DTextLabel("AFK", COLOR_INDIGO, 0.0,0.0,0.0, 10.0, playerid);
						PlayerAfk[playerid]=true;
					}
				}
				playerDB[playerid][pLastCheck]=tick;
				if( Coo[0] >= 99999.0 || Coo[1] >= 99999.0 || Coo[2] >= 99999.0 || Coo[0] <= -99999.0 || Coo[1] <= -99999.0 || Coo[2] <= -99999.0 ) {
  					SendClientMessage( playerid, 0xa9c4e4ff, "Demesio! Tu iskritai is zemelapio, todel grazinome tave i sena pozicija." );
					SetPlayerPoz( playerid, playerDB[playerid][pCurrentPos][0],playerDB[playerid][pCurrentPos][1],playerDB[playerid][pCurrentPos][2], _, _, 0);
				}
				playerDB[playerid][pCurrentPos][0]=Coo[0];
				playerDB[playerid][pCurrentPos][1]=Coo[1];
				playerDB[playerid][pCurrentPos][2]=Coo[2];
			}
		}
		if(g_RadioON)
		{
			if(IsPlayerInRangeOfPointEx(50.0,playerid,g_RadioCord[0],g_RadioCord[1],g_RadioCord[2]))
			{
				if(!playerDB[playerid][klausoisadmin])
				{
					StopAudioStreamForPlayer(playerid);
					PlayAudioStreamForPlayer(playerid,g_RadioURL,g_RadioCord[0],g_RadioCord[1],g_RadioCord[2],80.0,true);
					playerDB[playerid][klausoisadmin]=1;
				}
			}
			else if(playerDB[playerid][klausoisadmin]) 
			{
				playerDB[playerid][klausoisadmin]=0;
				StopAudioStreamForPlayer(playerid);
			}
			
		}
		/*if(statz == PLAYER_STATE_ONFOOT)
		{
			new vehicleid = GetClosestVehicleid(playerid,10.0);
			if(!vehicleid || vehicleid == INVALID_VEHICLE_ID)
				return 0;
			GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
			if(VehVars[5] == VEHICLE_PARAMS_ON)
			{
		}*/
	}
	/*
	AddStaticVehicle(431,3077.7688,-775.2222,11.1495,359.2314,75,59); // prie vartu
	AddStaticVehicle(431,3104.2659,-741.9261,11.1283,268.5011,75,59); // prie star
	AddStaticVehicle(431,3074.7358,-757.6441,11.1244,180.3775,75,59); // prie vartu 2
	AddStaticVehicle(431,1535.9420,-1672.7292,13.4828,180.7490,75,59); // pr pd
	*/
	if((IsVehicleInRangeOfPoint(Busikas,5.0,3077.7688,-775.2222,11.1495) || IsVehicleInRangeOfPoint(Busikas,5.0,3074.7358,-757.6441,11.1244)) && !JailGateOpen)
	{
		JailGateOpen=true;
		RotateObject(iwaziavimas,0,0,0);
		SetTimerEx("Varteliai",13000,0,"i",10);
	}
	if(totalvmtest)
	{
		if(!VMVartaiOpen)
		{
			RotateObject(vmvartai,0, 10 ,270);
			VMVartaiOpen=true;
		}
	}
	else
	{
		if(VMVartaiOpen)
		{
			RotateObject(vmvartai,0, 90 ,270);
			VMVartaiOpen=false;
		}
	}
	if(IsVehicleInRangeOfPoint(Busikas,7.0,3104.2659,-741.9261,11.1283)) // JAIL
	{
		if(!BusasAtvaziavo)
		{
			BusasAtvaziavo=true;
			BusAtPlace(1);
		}
	}
	else if(IsVehicleInRangeOfPoint(Busikas,12.0,1535.8585,-1675.4337,13.3828)) // PD
	{
		if(!BusasAtvaziavo)
		{
			BusasAtvaziavo=true;
			BusAtPlace(0);
		}
	}
	else if(BusasAtvaziavo) BusasAtvaziavo=false;
	return 1;
}
