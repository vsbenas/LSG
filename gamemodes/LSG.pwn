public Uzvedimas(vehicleid,playerid)
{
	vehicleDB[vehicleid][uzvedineja]=false;
	if(!IsPlayerInVehicle(playerid,vehicleid)) return 0;
	new Float:energijos = 5.0+random(5);
	new Float:HP,randomas;
	GetVehicleHealth(vehicleid,HP);
	if(HP > 900) randomas = 10;
	else if(HP > 800) randomas = 11;
	else if(HP > 700) randomas = 12;
	else if(HP > 600) randomas = 13;
	else if(HP > 500) randomas = 14;
	else if(HP > 400) randomas = 15;
	else if(HP > 300) randomas = 16;
	else randomas = 20;
	if(vehicleDB[vehicleid][rankinis]) return SendInfoMessage(playerid,"Rankinis stabdis uztrauktas! Spausk [SPACE], kad ji atleistum!");
	if(floatround(random(randomas)/AdjustByRida(vehicleid,RIDA_UZVEDIMO_TIKIMYBE)) > 8)
	{
		SendInfoMessage(playerid,"Variklis neuzsikure.");
		return 1;
	}
	else
	{
	    if(vehicleDB[vehicleid][energy] < energijos) return SendInfoMessage(playerid,"Issikrove akumuliatorius!");
		if(playerDB[playerid][ant] || playerDB[playerid][suristas]) return 1;
		if(vehicleDB[vehicleid][gas] < 2)
		{
			ProcessAchievement(playerid,33);
			return SendInfoMessage(playerid,"Nera degalu!");
		}
		if(vehicleDB[vehicleid][dega]) return SendInfoMessage(playerid,"Automobilis dega!");
		SendInfoMessage(playerid,"Variklis: ~g~Ijungtas~n~~y~MOUSE1+SPACE");
	    vehicleDB[vehicleid][gas]=vehicleDB[vehicleid][gas]-1.0;
	    vehicleDB[vehicleid][energy]=vehicleDB[vehicleid][energy]-energijos;
		GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
		SetVehicleParamsEx(vehicleid,true,true,VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
		return 1;
	}
}
public Atfreezint(playerid)
{
	if(!playerDB[playerid][ant] && !playerDB[playerid][suristas])
		TogglePlayerControllable(playerid,true);
    Atfreezinti[playerid] = 0;
	return 1;
}

public Isjungimas(vehicleid,playerid)
{
	vehicleDB[vehicleid][uzvedineja]=false;
	if(!IsPlayerInVehicle(playerid,vehicleid)) return 0;
	if(playerDB[playerid][ant] || playerDB[playerid][suristas]) return 1;
	SendInfoMessage(playerid,"Variklis: ~r~Isjungtas~n~~y~MOUSE1");
	galikast[playerid]=false;
	SetTimerEx("GaliKast",1500,0,"i",playerid);
//	TogglePlayerControllable(playerid,false);
	GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
	SetVehicleParamsEx(vehicleid,false,false,VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
	return 1;
}
public OnEnterExitModShop(playerid, enterexit, interiorid)
{
	HandleChristmasEnterExitModShop(playerid, enterexit, interiorid);
	//SendClientMessage(playerid,COLOR," * Ilindai i tiuningykla!");
	new vehicleid=GetPlayerVehicleID(playerid); 
	GetVehiclePos(vehicleid,vehicleDB[vehicleid][lastpos][0],vehicleDB[vehicleid][lastpos][1],vehicleDB[vehicleid][lastpos][2]);
	GetVehicleZAngle(vehicleid,vehicleDB[vehicleid][lastpos][3]);
	if(enterexit) playerDB[playerid][tiuningykloj]=true;
	else playerDB[playerid][tiuningykloj]=false;
	if(playerDB[playerid][ant]) TogglePlayerControllable(playerid,false);
	return 1;
}

