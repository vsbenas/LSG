public rentfee()
{
	InkaUzsakymas();
	//KaleduEvent();
	//NarkoPildymas();
	new pname[24];
//	for(new houseid=0;houseid<MAX_HOUSES;houseid++)
	foreach (Houses, houseid)
	{
		if(strcmp(hInfo[houseid][Renter], "ForRent", true))
		{
			foreach (Player, ii)
			{
					GetPlayerName(ii, pname, 24);
					if(strcmp(hInfo[houseid][Renter], pname, true)==0)
					{
						new query[128];
						format(query,sizeof(query),"SELECT `RentPay`+%i FROM `Namai` WHERE `ID`=%i",hInfo[houseid][Rentcost],houseid);
						mysql_function_query(SQL, query, true, "SQL_ReikiaMoketi", "ii", ii,houseid);
						
						format(query,sizeof(query),"UPDATE `Namai` SET `RentPay`=`RentPay`+%i WHERE `ID`=%i",hInfo[houseid][Rentcost],houseid);
						mysql_query(query);
						hInfo[houseid][Rentfee]=1;
					}
			}
			if(hInfo[houseid][Rentfee]==0)
			{
				if(strcmp(hInfo[houseid][Renter],"ForRent"))
				{
					new query[128];
					format(query,sizeof(query),"UPDATE `Namai` SET `RentPay`=`RentPay`+%i WHERE `ID`=%i",hInfo[houseid][Rentcost],houseid);
					mysql_query(query);
				}
			}
			hInfo[houseid][Rentfee]=0;
		}
	} 
}




stock GetHouseID(playerid)
{
	new vw = GetPlayerVirtualWorld(playerid);
	foreach (Houses, i)
	{
		if(IsPlayerInRangeOfPointEx(MAX_DISTANCE_TO_PROP, playerid, hInfo[i][iconx], hInfo[i][icony], hInfo[i][iconz]))
		{
			if(hInfo[i][daugiabutis] && vw != (MAX_HOUSES*2+MAX_BUSINESSES+hInfo[i][daugiabutis]-1)) continue;
			
			return i;
		}
	}
	return -255;
}


stock IsNearLastHouse(playerid)
{
	if(LastHouse[playerid]==-1)
		return -1;
	new hid = LastHouse[playerid];
	if(IsPlayerInRangeOfPointEx(MAX_DISTANCE_TO_PROP, playerid, hInfo[hid][iconx], hInfo[hid][icony], hInfo[hid][iconz]))
	{
		new vw = GetPlayerVirtualWorld(playerid);
		if(hInfo[hid][daugiabutis] && vw != (MAX_HOUSES*2+MAX_BUSINESSES+hInfo[hid][daugiabutis]-1))
			return -1;
		return hid;
	}
	LastHouse[playerid]=-1;
	return -1;
}



