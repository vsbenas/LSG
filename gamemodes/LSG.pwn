stock LoadRandomPlace(playerid,place)
{
	new BusinessArray[MAX_BUSINESSES],
		TotalBiz,
		BusinessType[6];
	switch(place)
	{
		case 0: BusinessType = { 6, 8, 9, -1, -1, -1 };
		case 1: BusinessType = { 1, 2, 8, 9, 13, 16 };
		case 2: BusinessType = { 7, 14, 15, 17, -1, -1 };
		case 3: BusinessType = { 3, 4, -1, -1, -1, -1 };
		case 4: BusinessType = { 5, 10, 11 , 12, -1, -1 };
		case 5: BusinessType = { 4, 11, -1, -1, -1, -1}; 
		default: return printf("Place: %i. Tokios vietos ner :/");
	}
	foreach(Businesses, i) if(i != 4)
	{
		for(new x;x<sizeof(BusinessType);x++)
		{
			if(BusinessInfo[i][bType] == BusinessType[x])
			{
				BusinessArray[TotalBiz]=i;
				TotalBiz++;
			}
		}
	}
	new randbiz = BusinessArray[random(TotalBiz)];
	vpakrauta[GetPlayerVehicleID(playerid)]=randbiz+1;
	return 1;
}

