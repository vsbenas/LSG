forward GetPlayerMoneyA(playerid);
forward GivePlayerMoneyA(playerid,money);

public GetPlayerMoneyA(playerid) return playerDB[playerid][pinigai];
stock ResetPlayerMoneyA(playerid)
{
	playerDB[playerid][pinigai]=0;
	ResetPlayerMoney(playerid);
}
public GivePlayerMoneyA(playerid,money)
{
	if(!NoCheck2[playerid])
	{
		new rmoney = GetPlayerMoney(playerid);
		if( rmoney < playerDB[playerid][pinigai] && rmoney > 0 ) playerDB[playerid][pinigai]=rmoney;
	}
	playerDB[playerid][pinigai]+=money;
	RefreshClientMoney(playerid);
	new zin[256];
	//format(zin,)
	new sum = money;
	if(sum < 0)
		format(zin,sizeof(zin),"~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~w~-%sEUR",FormatNumber(-sum));
	else
		format(zin,sizeof(zin),"~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~w~+%sEUR",FormatNumber(sum));
	GameTextForPlayer(playerid,zin, 2000, 3 );//€
	printf("[PINIGAI] %s: %i",ReturnName(playerid),money);

	NoCheck2[playerid]=1;
}

stock RefreshClientMoney(playerid)
{
	ResetPlayerMoney(playerid);
	GivePlayerMoney(playerid,playerDB[playerid][pinigai]);
}


