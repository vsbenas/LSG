stock GetNamuLimit(playerid)
{
	if(Pareigos(playerid,"Aukcionai"))
		return 10;
	return 2;
}

stock OpenHouseMenu(playerid)
{
	if(playerDB[playerid][ant] || playerDB[playerid][suristas]) 
	{
		return 1;
	}
	AddDListItem(playerid, "{6799f0}Pasauliai", 0);
	new housenumber = GetPlayerHouseID(playerid);
	new pname[24];
	GetPlayerName(playerid, pname, 24);
	if(!housenumber) 
	{
		return 1;
	}
	if(strcmp(hInfo[housenumber][Name],pname,false)==0 || strcmp(hInfo[housenumber][Renter],pname,false)==0)
	{
		AddDListItem(playerid, "Saugoti ţaidimŕ", 1);
		if(hInfo[housenumber][Locked] == 1 && !hInfo[housenumber][islauztos])
		{
			AddDListItem(playerid, "Atrakinti duris", 2);
		}
		else if(hInfo[housenumber][Locked] == 0 && !hInfo[housenumber][islauztos])
		{
			AddDListItem(playerid, "Uţrakinti duris", 2);
		}
		
		AddDListItem(playerid, "Pavalgyti", 3);
	}
	if(strcmp(hInfo[housenumber][Name],pname,false)==0)
	{
		AddDListItem(playerid, "Paimti", 4);
		AddDListItem(playerid, "Padëti", 5);
		AddDListItem(playerid, "Baldai", 6);
		AddDListItem(playerid, "Radija", 7);
		AddDListItem(playerid, "Remontuoti", 8);
		AddDListItem(playerid, "Daţyti", 9);
		AddDListItem(playerid, "Leisti árengti namŕ", 10);
		AddDListItem(playerid, "Augalai", 11);
	}
	ShowPlayerDList(playerid, 2790, "Namas", "Rinktis", "Atsaukti");
	return 1;
}

stock UzdarbioZinute(playerid, uzdarbis)
{
	new msg[128];
	if(playerDB[playerid][plead] && IsDyrKoefEnabled())
	{
		format(msg,sizeof(msg),"Vazinedami musu transportu, firmai jus uzdirbsite ~r~%i~w~EUR/min.", uzdarbis * 2);
	}
	else
	{
		format(msg,sizeof(msg),"Vazinedami musu transportu, firmai jus uzdirbsite %iEUR/min.", uzdarbis);
	}
	SendInfoMessage(playerid, msg);
}
stock UzdarbioZinuteSkraid(playerid, uzdarbis)
{
	new msg[128];
	if(playerDB[playerid][plead] && IsDyrKoefEnabled())
	{
		format(msg,sizeof(msg),"Skraidydami musu transportu, firmai jus uzdirbsite ~r~%i~w~EUR/min.", uzdarbis * 2);
