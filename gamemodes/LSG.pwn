}
stock GetIdForAlgos(name[])
{
	if(isnull(name)) return INVALID_PLAYER_ID;
	foreach(Player, i)
	{
		if(strcmp(name,ReturnName(i),true)==0)
			return i;
	}
	return INVALID_PLAYER_ID;
}

stock SekiojantiKarve(playerid)
{
	//SendClientMessage(playerid,COLOR,"Karvute");
	new Float:Pos[4];
	if(IsPlayerInAnyVehicle(playerid)) GetVehiclePos(GetPlayerVehicleID(playerid), Pos[0], Pos[1], Pos[2]);
	else GetPlayerPos(playerid, Pos[0], Pos[1], Pos[2]);
	Pos[0] += float(random(30) - 15);
	Pos[1] += float(random(30) - 15);
	new id;
	new randas = random(3);
	if(randas == 0) id = 16442;
	else if(randas == 1) id = 1609;
	else if(randas == 2) id = 1608;
	PlayerCow[playerid]=CreatePlayerObject(playerid,id, 0, 0, 0, 0, 0, 0);
	StopPlayerObject(playerid,PlayerCow[playerid]);
	SetPlayerObjectPos(playerid,PlayerCow[playerid], Pos[0], Pos[1], Pos[2] - 7.5);
	MovePlayerObject(playerid,PlayerCow[playerid], Pos[0], Pos[1], Pos[2], 5.0);
	CowTimer[playerid]=SetTimerEx("Sekioja",800,true,"i",playerid);
	SetTimerEx("UzteksKarviu",20000+random(10000),false,"i",playerid); // 10000 -> 60000
}

public UzteksKarviu(playerid)
{
	KillTimer(CowTimer[playerid]);
	DestroyPlayerObject(playerid,PlayerCow[playerid]);
	CowTimer[playerid]=-1;
	PlayerCow[playerid]=-1;
}

stock Float:GetSpeedForCow(playerid)
{
	new Float:x,Float:y,Float:z;
 	if(IsPlayerInAnyVehicle(playerid)) GetVehicleVelocity(GetPlayerVehicleID(playerid),x,y,z);
	else GetPlayerVelocity(playerid,x,y,z);
	return floatsqroot(x*x+y*y+z*z) * 48.5;
}


public Sekioja(playerid)
{
	if(!IsPlayerConnected(playerid))
	{
		DestroyPlayerObject(playerid,PlayerCow[playerid]);
		KillTimer(CowTimer[playerid]);
		PlayerCow[playerid]=-1;
		CowTimer[playerid]=-1;
		return 1;
	}
	new Float:Pos[7];
	GetPlayerObjectPos(playerid,PlayerCow[playerid], Pos[0], Pos[1], Pos[2]);
	if(!KarveToPlayer(playerid, 5.0, Pos[0], Pos[1], Pos[2]))
	{
		if(IsPlayerInAnyVehicle(playerid)) GetVehiclePos(GetPlayerVehicleID(playerid), Pos[3], Pos[4], Pos[5]);
		else GetPlayerPos(playerid, Pos[3], Pos[4], Pos[5]);
		Pos[3] += float(random(10) - 5);
		Pos[4] += float(random(10) - 5);
		Pos[6] = atan( floatdiv(abs(Pos[4] - Pos[1]), abs(Pos[3] - Pos[0])) );

		if(Pos[3] < Pos[0] && Pos[4] < Pos[1])  Pos[6] += 180;
		else if(!(Pos[3] > Pos[0] && Pos[4] > Pos[1]))
		{
			Pos[6] *= float(-1);
			Pos[6] += float((Pos[3] > Pos[0] && Pos[4] < Pos[1]) ? (90) : (270));
			Pos[6] -= float(90);
		}
		SetPlayerObjectRot(playerid,PlayerCow[playerid], 0, 0, Pos[6]);
		MovePlayerObject(playerid,PlayerCow[playerid], Pos[3]-1.5, Pos[4]+1.5 , Pos[5] + 1.2, GetSpeedForCow(playerid) + 7.8);
	}
	return 1;
}

