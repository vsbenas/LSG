public Uzemimas(playerid,pickupi)
{
	if(playerDB[playerid][banned]) return 0;
	if(!IsPlayerConnected(playerid))
	{
		Uzimineja[playerid]=0;
		return 1;
	}
	if(Uzimineja[playerid] == -1)
	{
		Uzimineja[playerid]=0;
		return 1;
	}
	if(IsPlayerAfk(playerid))
	{
		if(playerDB[playerid][mire])
		{
			Uzimineja[playerid]=0;
			PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
			HideProgressBarForPlayer(playerid,Veiksmai);
			EndVeiksmas(playerid);
		}
		else
			AC_Kick(playerid,"AFK Uziminejant sandeli");
		return 1;
	}
	if(GetPlayerVirtualWorld(playerid) != 0 || (pickupi == pickups[0][piniguvieta] && GetPlayerInterior(playerid) != 2) || (pickupi != pickups[0][piniguvieta] && GetPlayerInterior(playerid) != 0)) 
	{
		SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
		Uzimineja[playerid]=0;
		PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
		HideProgressBarForPlayer(playerid,Veiksmai);
		EndVeiksmas(playerid);
		return 1;
	}
	new synced,unsynced;
	new Float:Coo[3];
	GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
	foreach(Player,i) if(i != playerid)
	{
		if(IsPlayerInRangeOfPointEx(30.0,i,Coo[0],Coo[1],Coo[2]) && GetPlayerInterior(i)==0 && GetPlayerVirtualWorld(i)==0)
		{
			if(IsPlayerStreamedIn(playerid,i)) synced++;
			else unsynced++;
		
		}
	}
	if((synced+unsynced) >= 3 && unsynced >= synced)
	{
		AC_Warn(playerid,"Invisible.cs sandelyje");
		SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
		Uzimineja[playerid]=0;
		PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
		HideProgressBarForPlayer(playerid,Veiksmai);

		return 1;
	}
	if(IsPlayerInRangeOfPointEx(50.0,playerid,-60.7811,48.0869,3.1103)) // lsd
	{
		if(Coo[2] < 2.6) // lsd po zeme
		{
			AC_Warn(playerid,"Sandelyje po zeme");
			SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
			Uzimineja[playerid]=0;
			PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
			HideProgressBarForPlayer(playerid,Veiksmai);
			return 1;
		}
	}
	else if(IsPlayerInRangeOfPointEx(50.0,playerid,2318.0364,38.2342,26.4844)) // ratai
	{
		if(Coo[2] < 26.0)
		{
			AC_Warn(playerid,"Sandelyje po zeme");
			SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
			Uzimineja[playerid]=0;
			PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
			HideProgressBarForPlayer(playerid,Veiksmai);
			return 1;
		}
	}
	else if(IsPlayerInRangeOfPointEx(50.0,playerid,-365.9257,-1423.4869,25.7266)) // seklos
	{
		if(Coo[2] < 25.0)
		{
			AC_Warn(playerid,"Sandelyje po zeme");
			SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
			Uzimineja[playerid]=0;
			PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
			HideProgressBarForPlayer(playerid,Veiksmai);
			return 1;
		}
	}
	else if(IsPlayerInRangeOfPointEx(50.0,playerid,213.6279,1867.3140,13.1406)) // ginklai
	{
		if(Coo[2] < 12.5)
		{
			AC_Warn(playerid,"Sandelyje po zeme");
			SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
			Uzimineja[playerid]=0;
			PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
			HideProgressBarForPlayer(playerid,Veiksmai);
			return 1;
		}
	}
	else if(IsPlayerInRangeOfPointEx(50.0,playerid,-1309.4672,501.9740,11.1953)) // laivas
	{
		if(Coo[2] < 10.5)
		{
			AC_Warn(playerid,"Sandelyje po zeme");
			SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
			Uzimineja[playerid]=0;
			PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
			HideProgressBarForPlayer(playerid,Veiksmai);
			return 1;
		}
	}
	new hour,minute,second;
	gettime(hour,minute,second);
	new WeekDay=GetWeekDay();
	new KasOwnina,KuriVieta;
	if(pickupi==pickups[0][seklos])
		KuriVieta=0;
	else if(pickupi == pickups[0][lsdvieta])
		KuriVieta=1;
	else if(pickupi == pickups[0][ratuvieta])
		KuriVieta=2;
	else if(pickupi == pickups[0][pdvieta])
		KuriVieta=3;
	else if(pickupi == pickups[0][piniguvieta])
		KuriVieta=4;
	else if(pickupi == pickups[0][m4vieta])
		KuriVieta=5;
	new vietele[24];
	switch(KuriVieta)
	{
		case 0: vietele="Seklu";
		case 1: vietele="LSD";
		case 2: vietele="Ratu";
		case 3: vietele="Ginklu";
		case 4: vietele="Pinigu";
		case 5: vietele="Laivo";
	}
	new str[128];
	format(str,sizeof(str),"%s_sandelis~n~~n~~n~~n~",vietele);
	new bool:WedSat = KuriVieta < 4 && (WeekDay == 0 || WeekDay == 4);
	new bool:ThuSun = KuriVieta >= 4 && (WeekDay == 1 || WeekDay == 5);

	if( ( WedSat || ThuSun ) && (hour == 18 && minute > 30))
	{
		PlayerTextDrawSetString(playerid,VeiksmuTD[playerid],str);
		PlayerTextDrawShow(playerid,VeiksmuTD[playerid]);
		KasOwnina = PlaceOwnedBy[KuriVieta];
		if(KuriVieta==3 || KuriVieta == 5)
		{
			if(KasOwnina==-1 && (playerDB[playerid][specialybe]==80 || playerDB[playerid][specialybe] == 82 || playerDB[playerid][specialybe]==81 || playerDB[playerid][specialybe]==83 || playerDB[playerid][specialybe]==84))
			{
				Uzimineja[playerid]=0;
				HideProgressBarForPlayer(playerid,Veiksmai);
				SendInfoMessage(playerid,"~y~Sis sandelis jau priklauso teisesaugai!");
				PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
				return 1;
			}
			else if(KasOwnina==playerDB[playerid][pgang] && KasOwnina != -1)
			{
				Uzimineja[playerid]=0;
				HideProgressBarForPlayer(playerid,Veiksmai);
				SendInfoMessage(playerid,"~y~Sis sandelis jau priklauso jusu gaujai!");
				PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
				return 1;
			}	
			if(!IsPlayerInRangeOfPointEx(5.0,playerid,PickupIDs[pickupi][0],PickupIDs[pickupi][1],PickupIDs[pickupi][2]))
			{
				SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
				Uzimineja[playerid]=0;
				HideProgressBarForPlayer(playerid,Veiksmai);
				PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
				return 1;
			}
			if(Uzimineja[playerid] >= 24)
			{					
				ProcessAchievement(playerid,65);
				HideProgressBarForPlayer(playerid,Veiksmai);
				PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
				if(KasOwnina==-1)
				{
					new name[50];
					switch(playerDB[playerid][pgang])
					{
						case 0:
						{
							name = "The Ballas";
						}
						case 1:
						{
							name = "Varios Los Aztecas";
						}
						case 2:
						{
							name = "Grove Street Families";
						}
						case 3:
						{
							name = "Los Santos Vagos";
						}
						case 4:
						{
							name = "The Mafia";
						}
						case 5:
						{
							name = "Da Nang Boys";
						}
					}
					new msg[128];
					Uzimineja[playerid]=0;
					format(msg,128,"[gauja] %s uzeme %s sandeli!",ReturnName(playerid),vietele);
					PlaceOwnedBy[KuriVieta]=playerDB[playerid][pgang];
					SaveNarko(KuriVieta);
					SendMessageToFamily(playerDB[playerid][pgang],ORANGE,msg);
					GangZoneSpalva[KuriVieta]=FamilyInfo[playerDB[playerid][pgang]][FamilyZone][1];
					GangZoneHideForAll(GangZone[KuriVieta]);
					GangZoneShowForAll(GangZone[KuriVieta],GangZoneSpalva[KuriVieta]);
					format(msg,128,"[racija] %s(%s) Uzeme jusu %s sandeli!",ReturnName(playerid),name,vietele);
					SendMessageToTeisesauga(YELLOW,msg);
					return 1;
				}
				else if(PlaceOwnedBy[KuriVieta]!=playerDB[playerid][pgang])
				{
					new msg[128],name[50];
					switch(playerDB[playerid][pgang])
					{
						case 0:
						{
							name = "The Ballas";
						}
						case 1:
						{
							name = "Varios Los Aztecas";
						}
						case 2:
						{
							name = "Grove Street Families";
						}
						case 3:
						{
							name = "Los Santos Vagos";
						}
						case 4:
						{
							name = "The Mafia";
						}
						case 5:
						{
							name = "Da Nang Boys";
						}
					}
					if(playerDB[playerid][pgang]==-1) name="Teisesauga";
					Uzimineja[playerid]=0;
					format(msg,128,"[gauja] %s(%s) Uzeme jusu %s sandeli!",ReturnName(playerid),name,vietele);
					PlaceOwnedBy[KuriVieta]=playerDB[playerid][pgang];
					SaveNarko(KuriVieta);
					SendMessageToFamily(KasOwnina,RED,msg);
					if(PlaceOwnedBy[KuriVieta]==-1)
					{
						format(msg,128,"[racija] %s Pereme %s sandeli!",ReturnName(playerid),vietele);
						SendMessageToTeisesauga(YELLOW,msg);
					}
					else
					{
						format(msg,128,"[gauja] %s Pereme %s sandeli!",ReturnName(playerid),vietele);
						SendMessageToFamily(PlaceOwnedBy[KuriVieta],ORANGE,msg);
					}
					if(PlaceOwnedBy[KuriVieta]==-1)
						GangZoneSpalva[KuriVieta]=0x00F2FFAB;
					else
						GangZoneSpalva[KuriVieta]=FamilyInfo[playerDB[playerid][pgang]][FamilyZone][1];
					GangZoneHideForAll(GangZone[KuriVieta]);
					GangZoneShowForAll(GangZone[KuriVieta],GangZoneSpalva[KuriVieta]);
					return 1;
				}
				else 
				{	
					SendInfoMessage(playerid,"~y~Sandelis jau priklauso jusu gaujai!");
					Uzimineja[playerid]=0;
					return 1;
				}
			}
			else
			{
				Uzimineja[playerid]++;
				SetProgressBarValue(Veiksmai, Uzimineja[playerid]);
				SetProgressBarMaxValue(Veiksmai,25);
				ShowProgressBarForPlayer(playerid, Veiksmai);
				SetTimerEx("Uzemimas",5000,false,"ii",playerid,pickupi);
				return 1;
			}
		
		}
		else
		{
			if(KasOwnina==playerDB[playerid][pgang])
			{
				Uzimineja[playerid]=0;
				HideProgressBarForPlayer(playerid,Veiksmai);
				PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
				SendInfoMessage(playerid,"~y~Sis sandelis jau priklauso jusu gaujai!");
				return 1;
			}

			if(!IsPlayerInRangeOfPointEx(5.0,playerid,PickupIDs[pickupi][0],PickupIDs[pickupi][1],PickupIDs[pickupi][2]))
			{
				SendInfoMessage(playerid,"~r~Jus nuejote per toli nuo pickupo!");
				Uzimineja[playerid]=0;
				HideProgressBarForPlayer(playerid,Veiksmai);
				PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
				return 1;
			}
			if(Uzimineja[playerid] >= 24)
			{			
				ProcessAchievement(playerid,65);			
				HideProgressBarForPlayer(playerid,Veiksmai);
				PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
				if(KasOwnina==-1)
				{
					new msg[128];
					Uzimineja[playerid]=0;
					format(msg,128,"[gauja] %s uzeme %s sandeli!",ReturnName(playerid),vietele);
					PlaceOwnedBy[KuriVieta]=playerDB[playerid][pgang];
					SaveNarko(KuriVieta);
					SendMessageToFamily(playerDB[playerid][pgang],ORANGE,msg);
					GangZoneSpalva[KuriVieta]=FamilyInfo[playerDB[playerid][pgang]][FamilyZone][1];
					GangZoneHideForAll(GangZone[KuriVieta]);
					GangZoneShowForAll(GangZone[KuriVieta],GangZoneSpalva[KuriVieta]);
					return 1;
				}
				else if(PlaceOwnedBy[KuriVieta]!=playerDB[playerid][pgang])
				{
					new msg[128],name[50];
					switch(playerDB[playerid][pgang])
					{
						case 0:
						{
							name = "The Ballas";
						}
						case 1:
						{
							name = "Varios Los Aztecas";
						}
						case 2:
						{
							name = "Grove Street Families";
						}
						case 3:
						{
							name = "Los Santos Vagos";
						}
						case 4:
						{
							name = "The Mafia";
						}
						case 5:
						{
							name = "Da Nang Boys";
						}
					}
					Uzimineja[playerid]=0;
					format(msg,128,"[gauja] %s(%s) Uzeme jusu %s sandeli!",ReturnName(playerid),name,vietele);
					PlaceOwnedBy[KuriVieta]=playerDB[playerid][pgang];
					SaveNarko(KuriVieta);
					SendMessageToFamily(KasOwnina,RED,msg);
					format(msg,128,"[gauja] %s Pereme %s sandeli!",ReturnName(playerid),vietele);
					SendMessageToFamily(PlaceOwnedBy[KuriVieta],ORANGE,msg);
					GangZoneSpalva[KuriVieta]=FamilyInfo[playerDB[playerid][pgang]][FamilyZone][1];
					GangZoneHideForAll(GangZone[KuriVieta]);
					GangZoneShowForAll(GangZone[KuriVieta],GangZoneSpalva[KuriVieta]);
					return 1;
				}
				else 
				{	
					SendInfoMessage(playerid,"~y~Sandelis jau priklauso jusu gaujai!");
					Uzimineja[playerid]=0;
					return 1;
				}
			}
			else
			{
				Uzimineja[playerid]++;
				SetProgressBarValue(Veiksmai, Uzimineja[playerid]);
				SetProgressBarMaxValue(Veiksmai,25);
				ShowProgressBarForPlayer(playerid, Veiksmai);
				SetTimerEx("Uzemimas",5000,false,"ii",playerid,pickupi);
				return 1;
			}
		}
	}
	else
	{
		for(new i;i<MAX_PLAYERS;i++)
		{
			if(Uzimineja[i]!= 0 )
			{
				HideProgressBarForPlayer(playerid,Veiksmai);
				PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
				Uzimineja[i]=0;
			}
		}
	}
	return 1;
}
stock NarkoVietos(playerid,pickupid)
{
	if(GetPlayerVirtualWorld(playerid)) return 0;
	if(Uzimineja[playerid])
	{
		AC_Warn(playerid,"Bando uzimt sandeli su pickuphack");
		return 0;
	}
	if(GetPlayerSurfingVehicleID(playerid) != INVALID_PLAYER_ID)
	{
		AC_Warn(playerid,"Bando uzimti sandeli su invisible hack");
		return 0;
	}

	new hour,minute,second;
	gettime(hour,minute,second);
	new WeekDay=GetWeekDay();
	new KasOwnina,KuriVieta;
	if(pickupid==pickups[0][seklos])
		KasOwnina = PlaceOwnedBy[0],KuriVieta=0;
	else if(pickupid == pickups[0][lsdvieta])
		KasOwnina = PlaceOwnedBy[1],KuriVieta=1;
	else if(pickupid == pickups[0][ratuvieta])
		KasOwnina = PlaceOwnedBy[2],KuriVieta=2;
	else if(pickupid == pickups[0][pdvieta])
		KasOwnina = PlaceOwnedBy[3],KuriVieta=3;
	else if(pickupid == pickups[0][piniguvieta])
		KasOwnina = PlaceOwnedBy[4],KuriVieta=4;
	else if(pickupid == pickups[0][m4vieta])
		KasOwnina = PlaceOwnedBy[5],KuriVieta=5;
	new day,year,month;
	getdate(year,month,day);
	/*if(month == 5 && day == 15) {
		if(KuriVieta == 0) // seklos
			PickupKiausas(playerid, 1);
		else if(KuriVieta == 1)
			PickupKiausas(playerid, 0);
		else if(KuriVieta == 2)
			PickupKiausas(playerid, 2);
		else if(KuriVieta == 3)
			PickupKiausas(playerid, 3);
		else if(KuriVieta == 4)
			PickupKiausas(playerid, 4);
	}*/
	new bool:WedSat = KuriVieta < 4 && (WeekDay == 0 || WeekDay == 4);
	new bool:ThuSun = KuriVieta >= 4 && (WeekDay == 1 || WeekDay == 5);

	if(  WedSat || ThuSun  )
	{
		if(hour == 18 && minute > 30)
		{
			if ( WedSat )
			    BombaYra[3]=1;
			if(playerDB[playerid][specialybe]==80 || playerDB[playerid][specialybe] == 82 || playerDB[playerid][specialybe]==81 || playerDB[playerid][specialybe]==83 || playerDB[playerid][specialybe]==84)
			{
				if(KuriVieta!=3 && KuriVieta != 5) return SendInfoMessage(playerid,"Tu neturi gaujos!");
				if(KasOwnina==-1)
				{
					return SendInfoMessage(playerid,"Jus jau uzeme pozicija!");
				}
				else if(PlaceOwnedBy[KuriVieta]!=-1)
				{

					Uzimineja[playerid]=1;
					SendInfoMessage(playerid,"Uzimineji sandeli.");
					SetTimerEx("Uzemimas",5000,false,"ii",playerid,pickupid);
					return 1;
				}	
				return 1;
			}

			if(playerDB[playerid][pgang] == -1) return SendInfoMessage(playerid,"Tu neturi gaujos!");
			if(KasOwnina==playerDB[playerid][pgang]) return SendInfoMessage(playerid,"Jus jau uzeme pozicija!");
			if(FamilyInfo[playerDB[playerid][pgang]][FamilyIspejimai] == 2)
			{
				SendInfoMessage(playerid, "Jusu gauja atimta!");
				return 1;
			}
			
			if(KasOwnina==-1)
			{
				Uzimineja[playerid]=1;
				SendInfoMessage(playerid,"Uzimineji sandeli.");
				SetTimerEx("Uzemimas",5000,false,"ii",playerid,pickupid);
				return 1;
			}
			else if(PlaceOwnedBy[KuriVieta]!=playerDB[playerid][pgang])
			{
				Uzimineja[playerid]=1;
				SendInfoMessage(playerid,"Uzimineji sandeli.");
				SetTimerEx("Uzemimas",5000,false,"ii",playerid,pickupid);
				return 1;
			}	
			else return SendInfoMessage(playerid,"Sandelis jau priklauso jusu gaujai!");
		}
	}
	new string[256];

	if(pickupid == pickups[0][seklos])
	{
		KasOwnina = PlaceOwnedBy[0];
		if(playerDB[playerid][pgang] == -1 || playerDB[playerid][pgang] != KasOwnina)
		{
			format(string,sizeof(string),"Sis sandelis priklauso %s gaujai!",FamilyInfo[KasOwnina][FamilyName]);
			SendInfoMessage(playerid,string);
			return 0;
		}
		ShowSandelioDialog(playerid, pickupid);
		
	}
	else if(pickupid == pickups[0][lsdvieta])
	{
		KasOwnina = PlaceOwnedBy[1];
		if(playerDB[playerid][pgang] == -1 || playerDB[playerid][pgang] != KasOwnina)
		{
			format(string,sizeof(string),"Sis sandelis priklauso %s gaujai!",FamilyInfo[KasOwnina][FamilyName]);
			SendInfoMessage(playerid,string);
			return 0;
		}
		ShowSandelioDialog(playerid, pickupid);
	}
	else if(pickupid == pickups[0][ratuvieta])
	{
		KasOwnina = PlaceOwnedBy[2];
		if(playerDB[playerid][pgang] == -1 || playerDB[playerid][pgang] != KasOwnina)
		{
			format(string,sizeof(string),"Sis sandelis priklauso %s gaujai!",FamilyInfo[KasOwnina][FamilyName]);
			SendInfoMessage(playerid,string);
			return 0;
		}
		ShowSandelioDialog(playerid, pickupid);
	}
	else if(pickupid == pickups[0][pdvieta])
	{
		KasOwnina = PlaceOwnedBy[3];
		if(KasOwnina == -1)
		{
			return SendInfoMessage(playerid,"Sveikiname teisesauga issaugojus ginklu sandeli!");
		}
		else
		{
			if(playerDB[playerid][pgang] == -1 || playerDB[playerid][pgang] != KasOwnina)
			{
				format(string,sizeof(string),"Sis sandelis priklauso %s gaujai!",FamilyInfo[KasOwnina][FamilyName]);
				SendInfoMessage(playerid,string);
				return 0;
			}
			
			if(strcmp(FamilyInfo[KasOwnina][FamilyLeader],ReturnName(playerid),true) == 0 || strcmp(FamilyInfo[KasOwnina][FamilySubstitute],ReturnName(playerid),true) == 0)
			{
				//format(string,sizeof(string),"Turime %i apkabu combat sg.\nKiek norite pirkti?\nVieneto kaina: "#COST_COMBAT"€",KiekYra[3]);
				//ShowPlayerDialog(playerid,7603,DIALOG_STYLE_INPUT,"Combat SG",string,"Gerai","Iki");
				format(string,sizeof(string),"Combat SG: %i apkabu(vnt. kaina: "#COST_COMBAT"€)\nArea 51 bomba [%s]",KiekYra[3],((BombaYra[3])?("Yra"):("Nera")));
				ShowPlayerDialog(playerid,7604,DIALOG_STYLE_LIST,"Area 51",string,"Gerai","Iki");
			}
			else
			{
				//format(string,sizeof(string),"Turime %i apkabu combat sg.\nKiek norite pirkti?\nVieneto kaina: "#COST_COMBAT"€",KiekYra[3]);
				//ShowPlayerDialog(playerid,7603,DIALOG_STYLE_INPUT,"Combat SG",string,"Gerai","Ataskaita");
				return SendClientMessage(playerid,WHITE," * Sandelis priklauso jusu gaujai, taciau is jo pirkti gali tik gaujos vadas");//format(string,sizeof(string),"Turime %i vnt. ekstazio.\nKiek norite pirkti?\nVieneto kaina: "#COST_RATAI"€\n{00FF00}Gal norite gauti ataskaita?",KiekYra[2]);
				//ShowPlayerDialog(playerid,7602,DIALOG_STYLE_INPUT,"Ratai",string,"Gerai","Ataskaita");
			}
		}
	}
	else if(pickupid == pickups[0][piniguvieta]) 
	{
		KasOwnina = PlaceOwnedBy[4];
		if(KasOwnina == -1)
		{
			return SendInfoMessage(playerid,"Sis dandelis dar nepriklauso niekam!");
		}
		else
		{
			if(playerDB[playerid][pgang] == -1 || playerDB[playerid][pgang] != KasOwnina)
			{
				format(string,sizeof(string),"Sis sandelis priklauso %s gaujai!",FamilyInfo[KasOwnina][FamilyName]);
				SendInfoMessage(playerid,string);
				return 0;
			}
			
			if(strcmp(FamilyInfo[KasOwnina][FamilyLeader],ReturnName(playerid),true) == 0 || strcmp(FamilyInfo[KasOwnina][FamilySubstitute],ReturnName(playerid),true) == 0)
			{
				//format(string,sizeof(string),"Turime %i apkabu combat sg.\nKiek norite pirkti?\nVieneto kaina: "#COST_COMBAT"€",KiekYra[3]);
				//ShowPlayerDialog(playerid,7603,DIALOG_STYLE_INPUT,"Combat SG",string,"Gerai","Iki");
				SendClientMessage(playerid, RED, " * Demesio! Pries paimdami pinigus pasisamdykite inkasatoriu. Jis turetu jusu laukti prie sandelio.");
				format(string,sizeof(string),"Sandelyje atspausdinta %i€\nPaimti pinigus (reikia 100.000€)",KiekYra[4]);
				ShowPlayerDialog(playerid,7704,DIALOG_STYLE_LIST,"Pinigu fabrikas",string,"Gerai","Iki");
			}
			else
			{
				//format(string,sizeof(string),"Turime %i apkabu combat sg.\nKiek norite pirkti?\nVieneto kaina: "#COST_COMBAT"€",KiekYra[3]);
				//ShowPlayerDialog(playerid,7603,DIALOG_STYLE_INPUT,"Combat SG",string,"Gerai","Ataskaita");
				format(string,sizeof(string),"Sandelyje atspausdinta %i€",KiekYra[4]);
				ShowPlayerDialog(playerid,7704,DIALOG_STYLE_LIST,"Pinigu fabrikas",string,"Gerai","Iki");
				return SendClientMessage(playerid,WHITE," * Sandelis priklauso jusu gaujai, taciau is jo pinigus imti gali tik gaujos vadas.");//format(string,sizeof(string),"Turime %i vnt. ekstazio.\nKiek norite pirkti?\nVieneto kaina: "#COST_RATAI"€\n{00FF00}Gal norite gauti ataskaita?",KiekYra[2]);
				//ShowPlayerDialog(playerid,7602,DIALOG_STYLE_INPUT,"Ratai",string,"Gerai","Ataskaita");
			}
		}
	}
	else if(pickupid == pickups[0][m4vieta])
	{
		KasOwnina = PlaceOwnedBy[5];
		if(KasOwnina == -1)
		{
			return SendInfoMessage(playerid,"Sveikiname teisesauga issaugojus laivo sandeli!");
		}
		else
		{
			if(playerDB[playerid][pgang] == -1 || playerDB[playerid][pgang] != KasOwnina)
			{
				format(string,sizeof(string),"Sis sandelis priklauso %s gaujai!",FamilyInfo[KasOwnina][FamilyName]);
				SendInfoMessage(playerid,string);
				return 0;
			}
			
			if(strcmp(FamilyInfo[KasOwnina][FamilyLeader],ReturnName(playerid),true) == 0 || strcmp(FamilyInfo[KasOwnina][FamilySubstitute],ReturnName(playerid),true) == 0)
			{
				//format(string,sizeof(string),"Turime %i apkabu combat sg.\nKiek norite pirkti?\nVieneto kaina: "#COST_COMBAT"€",KiekYra[3]);
				//ShowPlayerDialog(playerid,7603,DIALOG_STYLE_INPUT,"Combat SG",string,"Gerai","Iki");
				format(string,sizeof(string),"M4: %i apkabu(vnt. kaina: "#COST_M4"€)",KiekYra[5]);
				ShowPlayerDialog(playerid,7605,DIALOG_STYLE_LIST,"Laivo sandelis",string,"Gerai","Iki");
			}
			else
			{
				//format(string,sizeof(string),"Turime %i apkabu combat sg.\nKiek norite pirkti?\nVieneto kaina: "#COST_COMBAT"€",KiekYra[3]);
				//ShowPlayerDialog(playerid,7603,DIALOG_STYLE_INPUT,"Combat SG",string,"Gerai","Ataskaita");
				return SendClientMessage(playerid,WHITE," * Sandelis priklauso jusu gaujai, taciau is jo pirkti gali tik gaujos vadas");//format(string,sizeof(string),"Turime %i vnt. ekstazio.\nKiek norite pirkti?\nVieneto kaina: "#COST_RATAI"€\n{00FF00}Gal norite gauti ataskaita?",KiekYra[2]);
				//ShowPlayerDialog(playerid,7602,DIALOG_STYLE_INPUT,"Ratai",string,"Gerai","Ataskaita");
			}
		}
	}
	return 1;
}
new cycle = 0;
NarkoPildymas()
{
	cycle ++;
	for(new i;i<MAX_NARKO;i++)
	{
		if(PlaceOwnedBy[i]!= -1)
		{
			if(i == 3) // csg
			{
				if(KiekYra[i] < 99)
					KiekYra[i]+=2;
			}
			else if(i == 4)
			{
				KiekYra[i]+=1050;
				if(KiekYra[i] > 100000)
					KiekYra[i]=100000;
			}
			else if(i==5) // m4
			{
				if(KiekYra[i] < 50 && cycle % 2 == 0)
					KiekYra[i]+=1;
			}
			else
			{
				if(KiekYra[i] < 50)
					KiekYra[i]+=1;
			}
		}
	}
}

