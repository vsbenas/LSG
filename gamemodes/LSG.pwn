	else*/
	new Float:step = 2.8;
	new taimux = 1250;
	InterpolateCameraPos(playerid,CAMERA_X - 3 * floatsin(-(playerDB[playerid][SpawnAngle]-step), degrees),
		CAMERA_Y - 3 * floatcos(-(playerDB[playerid][SpawnAngle]-step), degrees),
		CAMERA_Z,CAMERA_X - 3 * floatsin(-playerDB[playerid][SpawnAngle], degrees),
		CAMERA_Y - 3 * floatcos(-playerDB[playerid][SpawnAngle], degrees),
