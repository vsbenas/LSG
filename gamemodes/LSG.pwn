					AddDListItem(playerid, "Dvigubas mësainis \t{33FF33}"#COST_DVIGUBAS_MESAINIS"€", 14);
				else
					AddDListItem(playerid, #TEXT_RED"Dvigubas mësainis \t{33FF33}"#COST_DVIGUBAS_MESAINIS"€", 14);


				if(HPas + COST_BIGMAC < 200)
					AddDListItem(playerid, "BigMac \t{33FF33}"#COST_BIGMAC"€", 15);
				else
					AddDListItem(playerid, #TEXT_RED"BigMac \t{33FF33}"#COST_BIGMAC"€", 15);

				AddDListItem(playerid, "Maistas Iđsineđimui \t{33FF33}"#COST_MAISTAS"€", 22);
				header = 1;
			}
			case 11:
			{
				if(HPas + COST_MAZA_PICA < 200)
					AddDListItem(playerid, "Maţa pica \t{33FF33}"#COST_MAZA_PICA"€", 4);
				else
					AddDListItem(playerid, #TEXT_RED"Maţa pica \t{33FF33}"#COST_MAZA_PICA"€", 4);

				if(HPas + COST_VIDUTINE_PICA < 200)
					AddDListItem(playerid, "Vidutinë pica \t{33FF33}"#COST_VIDUTINE_PICA"€",5);
				else
					AddDListItem(playerid, #TEXT_RED"Vidutinë pica \t{33FF33}"#COST_VIDUTINE_PICA"€", 5);

				if(HPas + COST_DIDELE_PICA < 200)
					AddDListItem(playerid, "Didelë pica \t{33FF33}"#COST_DIDELE_PICA"€", 6);
				else
					AddDListItem(playerid, #TEXT_RED"Didelë pica \t{33FF33}"#COST_DIDELE_PICA"€", 6);

				if(HPas + COST_SALOTOS < 200)
					AddDListItem(playerid, "Salotos \t{33FF33}"#COST_SALOTOS"€", 7);
				else
					AddDListItem(playerid, #TEXT_RED"Salotos \t{33FF33}"#COST_SALOTOS"€", 7);
				AddDListItem(playerid, "Maistas Iđsineđimui \t{33FF33}"#COST_MAISTAS"€", 22);
				header = 1;
			}
			case 12:
			{
				if(HPas + COST_KEKSAS < 200)
					AddDListItem(playerid, "Keksas \t{33FF33}"#COST_KEKSAS"€", 16);
				else
					AddDListItem(playerid, #TEXT_RED"Keksas \t{33FF33}"#COST_KEKSAS"€", 16);

				if(HPas + COST_SPURGA < 200)
					AddDListItem(playerid, "Spurga \t{33FF33}"#COST_SPURGA"€", 17);
				else
					AddDListItem(playerid, #TEXT_RED"Spurga \t{33FF33}"#COST_SPURGA"€", 17);

				if(HPas + COST_DIDELE_SPURGA < 200)
					AddDListItem(playerid, "Didelë spurga \t{33FF33}"#COST_DIDELE_SPURGA"€", 18);
				else
					AddDListItem(playerid, #TEXT_RED"Didelë spurga \t{33FF33}"#COST_DIDELE_SPURGA"€", 18);

				AddDListItem(playerid, "Maistas Iđsinesimui \t{33FF33}"#COST_MAISTAS"€", 22);
				header = 1;
			}
			case 13:
			{
				AddDListItem(playerid, "Aksesuarai", 19);
			}
			case 14:
			{
				AddDListItem(playerid, "Gyvybës draudimas", 20);
				AddDListItem(playerid, "Automobilio draudimas",24);
			}
			case 15:
			{
				SendInfoMessage(playerid,"Nusipirkti bilieta galite uzlipe ant dolerio ikonos!");
				return 1;
			}
			case 16:
			{
				SendInfoMessage(playerid,"Issaugoti zaidima galite uzlipe ant kasetes!");
				return 1;
			}
			case 17:
			{
				SendInfoMessage(playerid,"Kortele nusipirkti galite uzlipe ant jos zenklo!");
				return 1;
			}
			case 18,19,20:
			{
				ShowBaldaiCat(playerid);
				return 1;
			}
			case 21:
			{
				AddDListItem(playerid, "Maisto prekës", 27);
				AddDListItem(playerid, "Automobiliř prekës", 26);
			}
		}
		if(header)
			ShowPlayerDListHeader(playerid, 1111, "Paslaugos", "Rinktis", "Iđeiti","Prekë\tKaina");
		else
			ShowPlayerDListTab(playerid, 1111, "Paslaugos", "Rinktis", "Iđeiti");
	}
	else
	{
		for(new i;i<3;i++)
		{
			if(checkpointid == drillid[i])
			{
				if(SecEntrances[i][s_boom]!=2)
				{
					return SendInfoMessage(playerid,"Uzgrobimas nevyksta!");
				}
				if(drilltimer[i] == 0)
				{
					if(playerDB[playerid][pgang] != -1)
					{
						SendInfoMessage(playerid,"Montuoji grazta");
						SetProgressBarMaxValue(Veiksmai, 30);
						playerDB[playerid][montuoja]=1;
						SetProgressBarValue(Veiksmai,playerDB[playerid][montuoja]);
						ShowProgressBarForPlayer(playerid, Veiksmai);
						StartVeiksmas(playerid,"Montavimas");
						//TogglePlayerControllable(playerid,false);
						ClearAnimations(playerid);
						ApplyAnimation(playerid, "BOMBER", "BOM_Plant_Loop", 4.0, 1, 0, 0, 1, 0,0); //Sedeti
						drilltimer[i]=1;
						
					
					}
					else
						return SendInfoMessage(playerid,"Graztas nesumontuotas.");
				}
				else
				{
					if(drilltimer[i]==1)
						return SendInfoMessage(playerid,"Graztas dar montuojamas.");
					else if(drilltimer[i]> 1)
					{
						if(playerDB[playerid][pgang] != -1)
						{

							return SendInfoMessage(playerid,"Graztas dirba.");
						}
						else if(playerDB[playerid][specialybe]==81 || playerDB[playerid][specialybe]==83)
						{

							SendInfoMessage(playerid,"Pradejai isjungineti grazta");
							SetProgressBarMaxValue(Veiksmai, 30);
							playerDB[playerid][minuoja]=10000;
							SetProgressBarValue(Veiksmai,playerDB[playerid][minuoja]-10000);
							ShowProgressBarForPlayer(playerid, Veiksmai);
							StartVeiksmas(playerid,"Atjungimas");
							ClearAnimations(playerid);
							ApplyAnimation(playerid, "BOMBER", "BOM_Plant_Loop", 4.0, 1, 0, 0, 1, 0,0); //Sedeti
			
						}
						else
							return SendInfoMessage(playerid,"TU nemoki isminuoti grazto, reikia SWAT arba KAREIVIO!");
					}
					else if(drilltimer[i]==-1 && playerDB[playerid][pgang] != -1)
					{
						SecEntrances[i][s_boom]=1;
						drilltimer[i]=0;
						new msg[128];
						format(msg,sizeof(msg),"[racija] Operatore: %s pavoge pinigu maisa! Turite ji nusauti ir paimti pinigu maisa.",ReturnName(playerid));
						SendMessageToTeisesauga(YELLOW,msg);
						SendClientMessage(playerid,YELLOW," * Sekmingai paemei pinigus, skubek juos nuvezti i savo gaujos baze."); 
						SetPlayerAttachedObject(playerid, MESKERE_SLOT, 1550, 1, 0.1, -0.3, 0, 0, 40, 0, 1, 1, 1);
						playerDB[playerid][hasmoney]=1;
						// 1550 money bag
						
					}
					/*
					new Float:Coo[3];
					GetObjectPos(Bombike[id],Coo[0],Coo[1],Coo[2]);
					BombikeTimer[id] = Create3DTextLabel("300s",RED,Coo[0],Coo[1],Coo[2],40.0,0);
					SetTimerEx("BombTimer",1000,false,"ii",300,id);
					*/
				
				
				}
			
			}
		}
	
	}
	return 1;
}

stock UpdateMap()
{
	for(new i = 0; i < 5; i++)
	{
		new Float:vehx, Float:vehy, Float:vehz;
		new Float:nvehx, Float:nvehy, Float:nvehz;
		GetVehiclePos(bus[i], vehx, vehy, vehz);
		GetMiniMapCoord(vehx,vehy,nvehx,nvehy,nvehz);
		
		MoveDynamicObject(point[i], nvehx, nvehy, nvehz, 0.1, 90.0, 0.0, 0.0);
	}
}

stock GetMiniMapCoord(Float:x,Float:y,&Float:nx,&Float:ny,&Float:nz)
{
	nx = x/2000;
	nz = y/2000;
	ny = POS_Y;
	nx+=POS_X;
	nz+=POS_Z;
}

stock AddToPokerWaitQue(playerid, table, suma)
{
	/*
	#define MAX_POKER_WAITING 25
	new PlayerPokerWaitQue[MAX_PLAYERS] = -1
	new PokerWaitQue[MAX_POKER_GAMES][MAX_POKER_WAITING];
	new PokerWaitQueSuma[MAX_POKER_GAMES][MAX_POKER_WAITING];

	*/
	if(table < 0 || table >= MAX_POKER_GAMES)
		return 0;
	if(playerDB[playerid][playingpoker])
		return 0;

	for(new i;i<MAX_POKER_WAITING;i++)
	{
		if(PokerWaitQueSuma[table][i] == 0)
		{
			PokerWaitQue[table][i] = playerid;
			PokerWaitQueSuma[table][i] = suma;
			TogglePlayerControllable(playerid, false);
			PlayerPokerWaitQue[playerid] = table;
			return i+1;
		}
	}
	return 0;
}
stock GetPlayerFromPokerWaitQue(table)
{
	if(table < 0 || table >= MAX_POKER_GAMES)
		return -1;

	if(PokerWaitQueSuma[table][0] == 0)
		return -1;

	new playerid = PokerWaitQue[table][0];

	if(!IsPlayerConnected(playerid) || GetPlayerMoneyA(playerid) < PokerWaitQueSuma[table][0] || !IsPlayerInRangeOfPointEx(10.0,playerid,PokerTables[table][0],PokerTables[table][1],PokerTables[table][2]))
	{
		RemovePlayerFromPokerWaitQue(playerid, table);
		if(GetPlayerMoneyA(playerid) < PokerWaitQueSuma[table][0])
			SendInfoMessage(playerid, "Nebeturi pinigu pokeriui!");
		else
			SendInfoMessage(playerid, "Palikai pokerio eile!");

		return GetPlayerFromPokerWaitQue(table);
	}

	return playerid;
}
stock AddPokerQuePlayer(table)
{
	if(table < 0 || table >= MAX_POKER_GAMES)
		return 0;

	new playerid = GetPlayerFromPokerWaitQue(table);

	if(playerid == -1)
		return 0;

	new suma = PokerWaitQueSuma[table][0];

	RemovePlayerFromPokerWaitQue(playerid, table);

	
	if(Poker[table][GameUsed])
	{
		new found=-1;
		for(new x;x<6;x++)
		{
			if(Poker[table][players][x] == -1)
			{
				found = x;
				break;
			}
		}
		if(found == -1)
		{
			SendInfoMessage(playerid,"Ivyko klaida!");
			return 0;
		}
		GivePlayerMoneyA(playerid, -suma);
		Poker[table][PFondas][found]=suma;
		Poker[table][players][found]=playerid;
		Poker[table][Playing][found]=0;
		SetPlayerPos(playerid,SeatCoords[table][found][0],SeatCoords[table][found][1],SeatCoords[table][found][2]);
		SetPlayerFacingAngle(playerid,SeatCoords[table][found][3]);
		ApplyAnimation(playerid,"INT_OFFICE", "FF_Dam_Fwd",4.0,0,0,0,1,0,1);
		playerDB[playerid][playingpoker]=1;
		if(Poker[table][TheStep]>=0)	
			for(new x;x<3;x++)
			{
				TextDrawShowForPlayer(playerid,Poker[table][TableKorta][x]);
				//TextDrawDestroy(TableKorta[i]);
			}
		if(Poker[table][TheStep] >=1)
			TextDrawShowForPlayer(playerid,Poker[table][TableKorta][3]);
		if(Poker[table][TheStep] >=2)
			TextDrawShowForPlayer(playerid,Poker[table][TableKorta][4]);
		//TextDrawDestroy(JusuKortos);
		TextDrawShowForPlayer(playerid,Poker[table][BankTD]);
		CreatePlayerTextDraws(playerid);
		for(new y;y<6;y++)
		{
			if(Poker[table][players][y] != -1)
			{
				TextDrawShowForPlayer(playerid,Poker[table][PokerAction][y]);
				TextDrawShowForPlayer(playerid,Poker[table][PokerMoney][y]);
				TextDrawShowForPlayer(playerid,Poker[table][PokerName][y]);
				for(new x;x<2;x++)
				{
					PlayerTextDrawShow(playerid,Korta[playerid][y][x]);
				}
			}
			
		}
		for(new x;x<5;x++)
		{
			PlayerTextDrawHide(playerid,Mygtukas[x][playerid]);
		}
		SetPlayerCameraPos(playerid,PokerCameras[table][0],PokerCameras[table][1],PokerCameras[table][2]);
		SetPlayerCameraLookAt(playerid,PokerCameras[table][3],PokerCameras[table][4],PokerCameras[table][5], CAMERA_MOVE);
		SendClientMessage(playerid,-1,"Norëdami iđeiti spauskite ESC!");
		SelectTextDraw(playerid, 0xACCBF1FF);
	}
	else
	{
		AddToPokerQue(playerid,table,suma);
	}
	return 1;
}
stock RemovePlayerFromPokerWaitQue(playerid, table)
{
	if(table < 0 || table >= MAX_POKER_GAMES)
		return 0;
	for(new i;i<MAX_POKER_WAITING;i++)
	{
		if(PokerWaitQue[table][i] == playerid)
		{
			PokerWaitQue[table][i] = 0;
			PokerWaitQueSuma[table][i] = 0;
			UpdatePokerWaitQue(table);
			PlayerPokerWaitQue[playerid] = -1;
			if(IsPlayerConnected(playerid))
			{
				if(!playerDB[playerid][ant] && !playerDB[playerid][suristas])
					TogglePlayerControllable(playerid, true);
				//SendInfoMessage(playerid, "Palikai pokerio eile!");
			}
			return 1;
		}
	}
	return 0;
}
stock UpdatePokerWaitQue(table)
{
	if(table < 0 || table >= MAX_POKER_GAMES)
		return 0;
	new pos = -1;
	for(new i;i<MAX_POKER_WAITING;i++)
	{
		if(PokerWaitQueSuma[table][i] == 0)
		{
			pos = i;
			break;
		}
	}
	if(pos == -1)
		return 0;
	for(new x = pos + 1; x < MAX_POKER_WAITING; x++) // shift all records from pos left
	{
		if(PokerWaitQueSuma[table][x] == 0)
		{
			break;
		}
		new playerid = PokerWaitQue[table][x];
		new queId = x;
		PokerWaitQueSuma[table][x-1] = PokerWaitQueSuma[table][x];
		PokerWaitQue[table][x-1] = PokerWaitQue[table][x];

		PokerWaitQueSuma[table][x] = 0;
		PokerWaitQue[table][x] = 0;

		if(IsPlayerConnected(playerid) && PlayerPokerWaitQue[playerid] != -1)
		{
			new msg[256];
			format(msg,256,"Jusu vieta pokerio eileje: ~r~%i~n~~w~Noredami iseiti spauskite [H]",queId);
			SendInfoMessage(playerid, msg);
		}

	}

	return 1;

	
}


stock AddToPokerQue(playerid,id,suma)
{
	if(PokerQueUsed[id][0] && playerid != PokerQue[id][0])
	{
		if(!IsPlayerConnected(PokerQue[id][0]))
		{
			PokerQueUsed[id][0]=0;
			AddToPokerQue(playerid,id,suma);
			return;
		}
		if(GetPlayerMoneyA(PokerQue[id][0]) < PokerQueSuma[id][0])
		{
			SendInfoMessage(PokerQue[id][0],"Jus nebeturite pinigu!");
			ClearAnimations(PokerQue[id][0]);
			SetCameraBehindPlayer(PokerQue[id][0]);
			if(FPS[playerid])  AttachCameraToObject(playerid, FirstPersonObject[playerid]);
			PokerQueUsed[id][0]=0;
			AddToPokerQue(playerid,id,suma);
			return;
		}
		SendInfoMessage(PokerQue[id][0],"Zaidimas prasideda!");
		playerDB[playerid][playingpoker]=1;
		GivePlayerMoneyA(playerid, -suma);
		Poker[id][PFondas][1]=suma;
		GivePlayerMoneyA(PokerQue[id][0], -PokerQueSuma[id][0]);
		Poker[id][PFondas][0]=PokerQueSuma[id][0];
		SendClientMessage(playerid,-1,"Noredami iseiti spauskite ESC!");
		//Poker[i][players][1]=playerid;
		//InitPokerGame(
		SetPlayerPos(playerid,SeatCoords[id][1][0],SeatCoords[id][1][1],SeatCoords[id][1][2]);
		SetPlayerPos(playerid,SeatCoords[id][1][0],SeatCoords[id][1][1],SeatCoords[id][1][2]);
		SetPlayerFacingAngle(playerid,SeatCoords[id][1][3]);
		SetPlayerFacingAngle(playerid,SeatCoords[id][1][3]);
		ApplyAnimation(playerid,"INT_OFFICE", "FF_Dam_Fwd",4.0,0,0,0,1,0,1);
		ApplyAnimation(playerid,"INT_OFFICE", "FF_Dam_Fwd",4.0,0,0,0,1,0,1);
		InitPokerGame(id,PokerBlinds[id][0],PokerBlinds[id][1],PokerQue[id][0],playerid);
		SetPlayerCameraPos(playerid,PokerCameras[id][0],PokerCameras[id][1],PokerCameras[id][2]);
		SetPlayerCameraLookAt(playerid,PokerCameras[id][3],PokerCameras[id][4],PokerCameras[id][5], CAMERA_MOVE);
		SetPlayerCameraPos(PokerQue[id][0],PokerCameras[id][0],PokerCameras[id][1],PokerCameras[id][2]);
		SetPlayerCameraLookAt(PokerQue[id][0],PokerCameras[id][3],PokerCameras[id][4],PokerCameras[id][5], CAMERA_MOVE);
		SelectTextDraw(playerid, 0xACCBF1FF);
		SelectTextDraw(PokerQue[id][0], 0xACCBF1FF);
		for(new x;x<2;x++)
		{
				
			PokerQueSuma[id][x]=0;
			PokerQueUsed[id][x]=0;
			PokerQue[id][x]=0;
		}
	}
	else
	{
		new found=0;
		//GivePlayerMoneyA(playerid, -suma);
		//Poker[i][PFondas][found]=suma;
		//Poker[i][players][found]=playerid;
		SetPlayerPos(playerid,SeatCoords[id][found][0],SeatCoords[id][found][1],SeatCoords[id][found][2]);
		SetPlayerPos(playerid,SeatCoords[id][found][0],SeatCoords[id][found][1],SeatCoords[id][found][2]);
		SetPlayerFacingAngle(playerid,SeatCoords[id][found][3]);
		SetPlayerFacingAngle(playerid,SeatCoords[id][found][3]);
		ApplyAnimation(playerid,"INT_OFFICE", "FF_Dam_Fwd",4.0,0,0,0,1,0,1);
		ApplyAnimation(playerid,"INT_OFFICE", "FF_Dam_Fwd",4.0,0,0,0,1,0,1);
		playerDB[playerid][playingpoker]=1;
		SendInfoMessage(playerid,"Laukite kito zaidejo!");
		SendClientMessage(playerid,-1,"Noredami iseiti spauskite ESC!");
		PokerQue[id][0]=playerid;
		PokerQueUsed[id][0]=1;
		PokerQueSuma[id][0]=suma;
		SelectTextDraw(playerid, 0xACCBF1FF);
	}
}

PUB:KickDelay(playerid)
{
	return Kick(playerid);
}

stock KickEx(playerid,time=300)
{
	if(BeingKicked[playerid]) return Kick(playerid);
	BeingKicked[playerid]=1,SetTimerEx("KickDelay",time,false,"i",playerid);
	return 1;
} 

stock CreateGangZoneAroundPos(Float:x,Float:y,Float:range)
{
	new Float:minx,Float:miny,Float:maxx,Float:maxy;
	minx=x-range;
	maxx=x+range;
	miny=y-range;
	maxy=y+range;
	return GangZoneCreate(minx,miny,maxx,maxy);
}
stock CreateDynamicAreaAroundPos(Float:x,Float:y,Float:range)
{
	new Float:minx,Float:miny,Float:maxx,Float:maxy;
	minx=x-range;
	maxx=x+range;
	miny=y-range;
	maxy=y+range;
	return CreateDynamicRectangle(minx,miny,maxx,maxy);
}

stock LoadPatruliavimas(playerid,id)
{
	if(Patruliai[id][pplin] == Patruliai[id][pplmax] && playerDB[playerid][plead] != 80) return SendClientMessage(playerid,YELLOW," * Nera vietos sioje zonoje!");
	GangZoneShowForPlayer(playerid,Patruliai[id][gangz],0xFFFF0099);
	Patruliavimas[playerid]=id;
	Patruliai[id][pplin]++;
	//new names[24];
	new msg[256];
	format(msg,sizeof(msg),"Siuo metu cia patruliuoja");
	new x;
	foreach(Player,i)
	{
		if(Patruliavimas[i]==id && i != playerid)
		{
			x++;
			if(x!=1)
				format(msg,sizeof(msg),"%s, %s",msg,ReturnName(i));
			else
				format(msg,sizeof(msg),"%s %s",msg,ReturnName(i));
		}
	}
	SendClientMessage(playerid,YELLOW," * Prisijungei i patruliavima, vaziuok i nurodyta vieta(zemelapyje ji geltona). Noredamas atsaukti rasyk /patruliavimas");
	SendClientMessage(playerid,YELLOW," * Patruliuojant kils minutes net jei busi ne automobilyje.");
	SendClientMessageEx(playerid,RED,msg);
	return 1;
}
stock CreatePatruliavimoZone(playerid,pname[],maxp,Float:x,Float:y,Float:range)
{
	if(range < 50 || range > 200) return SendClientMessage(playerid,YELLOW," * Atstumas nuo 50 iki 200m!");
	if(maxp < 2 || maxp > 6) return SendClientMessage(playerid,YELLOW," * Daugiausia zmoniu nuo 2 iki 6!");
	new id=-1;
	for(new i;i<MAX_PATRULIU;i++)
	{
		if(Patruliai[i][used])
		{
			if(IsPointInDynamicArea(Patruliai[i][dynamicarea],x,y,0.0))
			{
				return SendClientMessage(playerid,YELLOW," * Jus jau patruliavimo zonoje!");
			}
		}
		else if(id==-1)
		{
			id=i;
		}
	}
	if(id==-1) return SendClientMessage(playerid,YELLOW," * Nera vietos naujoms zonoms!");
	Patruliai[id][used]=1;
	Patruliai[id][gangz] = CreateGangZoneAroundPos(x,y,range);
	Patruliai[id][dynamicarea] = CreateDynamicAreaAroundPos(x,y,range);
	format(Patruliai[id][pavv],12,pname);
	Patruliai[id][possx]=x;
	Patruliai[id][possy]=y;
	Patruliai[id][rangee]=range;
	Patruliai[id][pplmax]=maxp;
	Patruliai[id][pplin]=0;
	return 1;
}
stock LoadPatruliai()
{
	mysql_function_query(SQL, "SELECT * From `Patruliai`", true, "SQL_Patruliai", "");
}

stock ShowPatruliavimoDialog(playerid)
{
	new text[2048];
	new places;
	for(new i;i<MAX_PATRULIU;i++)
	{
		if(Patruliai[i][used])
		{
			places++;
			format(text,sizeof(text),"%s{FFFFFF}%i. {FF0000}%s {FFFFFF}(%i/%i)\n",text,places,Patruliai[i][pavv],Patruliai[i][pplin],Patruliai[i][pplmax]);
		}
	}
	if(playerDB[playerid][plead]==80 || playerDB[playerid][admin])
	{
		if(places < 20)
		{
			format(text,sizeof(text),"%sKurti nauja zona",text);
			places ++;
		}
	}
	if(!places)
		return SendInfoMessage(playerid,"Direktorius nesukure patruliavimo vietu!");
	ShowPlayerDialog(playerid,1122,DIALOG_STYLE_LIST,"Patruliavimas",text,"Gerai","Atsaukti");
	return 1;
}

stock SetupKiausas()
{
	SendMessageToDazaiThird(TEXTCOL_GOLD,"DAŢASVYDIS: Atsirado naujas LSG Kiauđinis! Skubëkite já suđaudyti!");
	DestroyObject(Kiausas);
	DestroyDynamic3DTextLabel(KiausoText);
	for(new i;i<5;i++)
	{
		DestroyObject(KiausasDrop[i]);
		PHY_DeleteObject(KiausasDrop[i]);
		KiausasDrop[i]=-1;
	}
	Kiausas = CreateObject(19341, -952.6806,1900.1826,15.0245,0,0,0); //, Float:DrawDistance = 0.0)
	KiausoHP=1000;
	new bars = KiausoHP/50; // 20 bars
	new msg[155];
	format(msg,sizeof(msg),"{45e62f}LSG kiauđinis\n{FFFFFF}[{3e3ec4}%s{FFFFFF}%s]",str_repeat("|",bars),str_repeat("|",20-bars));
	KiausoText = CreateDynamic3DTextLabel(msg, -1, -952.6806,1900.1826,15.5245, 20.0);
}
stock SendMessageToDazaiThird(coloras,textass[])
{
	foreach(Player,i)
	{
		if(playerDB[i][psratasvydis])
			SendClientMessage(i, coloras, textass);
	}

}
stock UpdateKiausas()
{
	KiausoHP--;
	new msg[155];
	new bars = KiausoHP/50;
	format(msg,sizeof(msg),"{45e62f}LSG kiauđinis\n{FFFFFF}[{3e3ec4}%s{FFFFFF}%s]",str_repeat("|",bars),str_repeat("|",20-bars));
	UpdateDynamic3DTextLabelText(KiausoText, -1, msg);
	if(KiausoHP == 0)
	{
		SendMessageToDazaiThird(TEXTCOL_GOLD,"DAŢASVYDIS: Sprogo LSG Kiauđinis! Skubëkite pasiimti dovanas!");
		DestroyObject(Kiausas);
		Kiausas=-1;
		DestroyDynamic3DTextLabel(KiausoText);
		KiausoText = Text3D:INVALID_3DTEXT_ID;
		CreateExplosion(-952.6806,1900.1826,15.5245, 1, 10.0);
		for(new i; i < 5; i++)
		{
			new Float:sin,Float:cos;
			new speed = 4;
			new obj = CreateObject(19341 + i, -952.6806,1900.1826,15.5245, 0, 0, 0);
			KiausasDrop[i]=obj;
			new Float:a = i * (360.0 / 5);
			sin = floatsin( -a, degrees );
			cos = floatcos( -a, degrees );

			PHY_InitObject(obj);
			PHY_SetObjectVelocity(obj, speed*sin, speed*cos, speed);

			PHY_SetObjectFriction(obj, 100); // This will stop the object when it touchs the ground.
			PHY_SetObjectGravity(obj, GRAVITY);
			PHY_SetObjectZBound(obj, 8.5, _, 0.0);
			PHY_SetObjectGhost(obj);
		}
	}
}
stock PickupItem(playerid)
{
	new Float:Coo[3];
	for(new i;i<5;i++)
	{
		if(KiausasDrop[i] != -1)
		{
			GetObjectPos(KiausasDrop[i], Coo[0], Coo[1], Coo[2]);
			if(IsPlayerInRangeOfPointEx(2.0,playerid, Coo[0], Coo[1], Coo[2]))
			{
				if(!galikast[playerid])
					return;
				galikast[playerid]=false;
				SetTimerEx("GaliKast",1000,0,"i",playerid);

				//PickupKiausas(playerid,i);
				return;
			}

		}
	}
}

stock Sratasvydziosetup(playerid)
{
	//SetupKiausas();
	//ResetPlayerWeapons(playerid);
	ResetGunData(playerid);
	if(SratsvydzioGuns[playerid][0] != 0 && SratsvydzioGuns[playerid][1] != 0 && SratsvydzioGuns[playerid][2] != 0)
	{
		GivePlayerWeaponEx(playerid,SratsvydzioGuns[playerid][0],100000); // dgl-sg
		GivePlayerWeaponEx(playerid,SratsvydzioGuns[playerid][1],100000); // mp5-ak47
		GivePlayerWeaponEx(playerid,SratsvydzioGuns[playerid][2],100000); // rifle-awp
		SendClientMessage(playerid,-1," * Ginklus gali pasikeisti parases /ginklai");
	}
	else
	{
		ShowPlayerDialog(playerid,4780,DIALOG_STYLE_LIST,"Pasirinkite pirma ginkla:","Colt\nSilenced Colt\nDesert Eagle","Gerai","");
	}
	
	//SetPlayerSkinEx(playerid, 260);
	{
		TextDrawShowForPlayer(playerid,dazugui[0]);
		TextDrawShowForPlayer(playerid,dazugui[1]);
		TextDrawShowForPlayer(playerid,dazugui[2]);
		TextDrawShowForPlayer(playerid,dazugui[3]);
		TextDrawShowForPlayer(playerid,dazugui[4]);
	}	
	new offset = (playerDB[playerid][psratasvydis]+1) % 2;
	SetPlayerSkin(playerid,143+offset);
	SetPlayerHealth(playerid,100.0);
	SetPlayerArmour(playerid,100.0);
	SendInfoMessage(playerid,"Sekmes!");
	//new randpos = random(sizeof(sratasvpos));
	//SetPlayerPoz(playerid,sratasvpos[randpos][0],sratasvpos[randpos][1],sratasvpos[randpos][2]);
	new id=2*dazumap + playerDB[playerid][psratasvydis]-1;

	SetPlayerPoz(playerid,sratasvpos[id][0],sratasvpos[id][1],sratasvpos[id][2]);
	//SetTimerEx("Freeze",100,false,"i",playerid);
	//TogglePlayerControllable(playerid,false);
	SetPlayerTeam(playerid,id+1);
	SetPlayerVirtualWorld(playerid,20001);
	Invul[playerid]=true;
	SetTimerEx("NoInvul",1000,false,"i",playerid);
	SetPlayerInterior(playerid,dazuinterjerai[dazumap]); //(playerDB[playerid][psratasvydis] < 5) ? 10 : 17);
	SendClientMessage(playerid,YELLOW," * Noredamas iseiti is dazasvydzio grizk ant pickup.");
	return 1;
}

public OnPlayerModelSelectionEx(playerid, response, extraid, modelid, order)
{
    if(extraid == GUI_MYSKINS)
    {
		if(response)
		{
			if(galikast[playerid])
			{
				if(GetPlayerState(playerid) != PLAYER_STATE_ONFOOT) return SendInfoMessage(playerid,"Islipk is masinos!"); 
				if(GetPlayerSpecialAction(playerid) != SPECIAL_ACTION_NONE)
				{
					SetPlayerSpecialAction(playerid, SPECIAL_ACTION_NONE);
					return SendInfoMessage(playerid,"Dabar skino keisti negali. Bandyk dar karta.");
				}
				// SendClientMessage(playerid, 0xFF0000FF, "Uzsidejai skina");
				new msg[128];
				format(msg,sizeof(msg)," * Uzsidejai skin nr.%i",modelid);
				SendClientMessage(playerid,0xFF0000FF,msg);
				playerDB[playerid][drabuziai]=modelid;
				SetPlayerSkin(playerid,modelid);
				format(msg,sizeof(msg),"UPDATE Spinta Set LastUsed=NOW() Where Vardas='%s' AND Skin=%i",ReturnName(playerid),modelid);
				mysql_query(msg);
				//new Float:pos[3]; GetPlayerPos(playerid, pos[0], pos[1], pos[2]);
				//CreateVehicle(modelid, pos[0] + 2.5, pos[1], pos[2] + 2.5, 0.0, random(128), random(128), -1);
			}
			else ShowRubai(playerid);
		}

        //else //SendClientMessage(playerid, 0xFF0000FF, "Atsaukei");
        return 1;
    }
    if(extraid == GUI_BUYSKINS)
    {
    	if(response)
    	{
			new skinid=modelid;
			if(modelid == 0 || modelid == 74)
				return 0;
			
			if(playerDB[playerid][kreditai]<10) 
				return SendClientMessage(playerid, RED, " * Neturi pakankamai kreditu!");
			if(IsInvalidSkin(skinid) || skinid > 311) return SendClientMessage(playerid, RED, " * Netinkamas skinas!");

			SetPVarInt(playerid, "perkaskin", modelid);
			new msg[256];
			format(msg,256,#TEXT_WHITE"Ar tikrai norite pirkti skin Nr. "#TEXT_BLUE"%i{FFFFFF}?\n\nKaina: 10 kreditř.",modelid);

			ShowPlayerDialog(playerid, 1991, DIALOG_STYLE_MSGBOX, "Skin pirkimas", msg, "Taip","Ne");
		}
		return 1;
				
    }
    if(extraid == GUI_CHOOSESKIN)
    {
    	if(response)
    	{
			new msg[256];
			format(msg,256,#TEXT_WHITE"Uzsidejai skin Nr. "#TEXT_BLUE"%i",modelid);
			SendClientMessage(playerid, -1, msg);
			SetPlayerSkin(playerid, modelid);
		}
		return 1;
				
    }
	if(extraid >= GUI_BALDAI && extraid < GUI_BALDAI+100)
	{
		if(response)
		{
			
			new query[256];
			format(query,sizeof(query),"SELECT kaina FROM `baldai_id` WHERE `obj`='%i' LIMIT 1",modelid);
			mysql_function_query(SQL, query, true, "SQL_SelectedBaldai", "ii",playerid,modelid);
			PlayerLastCat[playerid]=extraid-GUI_BALDAI;
			//ShowPlayerDialog(playerid,6878,DIALOG_STYLE_MSGBOX,"Ar norite pirkti?",msg,"Gerai","Atsaukti");
			return 1;
		}
		else 
			ShowBaldaiCat(playerid);
	}
	if(extraid >= GUI_BALDAI2 && extraid < GUI_BALDAI2+100)
	{
		if(GetPlace(playerid) != PLACE_HOUSE)
			return SendInfoMessage(playerid,"Privalote buti namie!");
		
		new houseid=GetPlayerHouseID(playerid);
		if ( strcmp(hInfo[houseid][Name],ReturnName(playerid),false) != 0 && GetPVarInt(playerid,"irengineja") != houseid && !IsPlayerAdmin(playerid))
		{
			return SendInfoMessage(playerid,"Sis namas nepriklauso jums!");
		} 
		if(response)
		{
			new items = 0;
			for(new i;i<MAX_BALDAI;i++)
			{
				if(BalduSistema[houseid][i][b_used] && BalduSistema[houseid][i][b_cat]==PlayerLastCat[playerid])
				{
					//list[items]=BalduSistema[houseid][i][b_oid];
					if(items == order)
					{
						SetPVarInt(playerid, "EditingBaldas", i);
					}
					items++;
				}
			}
			if( GetPVarInt(playerid,"irengineja") == houseid)
				ShowPlayerDialog(playerid, 6883, DIALOG_STYLE_LIST, "Baldai", "Perstatyti","Gerai","Atsaukti");
			else
				ShowPlayerDialog(playerid, 6883, DIALOG_STYLE_LIST, "Baldai", "Perstatyti\nIđmesti\nPerveţti á kitŕ namŕ","Gerai","Atsaukti");
			return 1;
		}
		else 
		{
			mysql_function_query(SQL,"SELECT * From `baldai_cat` order by pav asc",true,"SQL_SelectMoveBaldai","ii",playerid,houseid);
			return 1;
		}
	}
	if(extraid == GUI_OBJEKTAI)
	{
		if(!response)
		{
			HandleInWorldDialog(playerid, 2799, 0);
			return 1;
		}
		HandlePlaceObject(playerid, modelid);
	}
    return 1;
}


stock DeliverBaldai(playerid,objectid)
{
	#pragma unused objectid
	new msg[256];
	new hid1=-1,
	    hid2=-1,
		name[MAX_PLAYER_NAME];
	GetPlayerName(playerid,name,sizeof(name));
	foreach(Houses,i)
	{
	    if(0==strcmp(name,hInfo[i][Name],false))
	    {
	        if(hid1==-1)
	        {
	            hid1=i;
	            continue;
	        }
	        else
	        {
	            hid2=i;
	            break;
	        }
	    }
	}
	if(hid1 == -1) return 0;
	new valid[5];
	new totalh;
	for(new i;i<MAX_BALDAI;i++)
	{
		if(!BalduSistema[hid1][i][b_used])
		{
			valid[totalh]=hid1;
			totalh++;
			break;
		}
	}
	if(hid2 != -1)
	{
		for(new i;i<MAX_BALDAI;i++)
		{
			if(!BalduSistema[hid2][i][b_used])
			{
				valid[totalh]=hid2;
				totalh++;
				break;
			}
		}
	}
	if(GetPVarInt(playerid,"irengineja") != 0)
	{
		valid[totalh] = GetPVarInt(playerid,"irengineja");
		totalh++;
	}
	if(!totalh) return 0;
	for(new i;i<totalh;i++)
	{
		format(msg,sizeof(msg),"%sNr.%i\n",msg,valid[i]);
	}
	ShowPlayerDialog(playerid,6870,DIALOG_STYLE_LIST,"Pasirinkite nama",msg,"Gerai","");
	return 1;
}

stock ShowBaldaiCat(playerid,type=-1)
{
	if(type == -1)
	{
		type=GetBaldaiType(playerid);
		if(type == -1) return 1;
	}
	new query[126];
	format(query,sizeof(query),"SELECT * From `baldai_cat` WHERE rusis='%i'",type);
	mysql_function_query(SQL,query,true,"SQL_ShowCat","i",playerid);
	return 1;
}


stock GetBaldaiType(playerid)
{
	if(!IsInBiz(playerid)) return -1;
	//if(GetPlayerScore(playerid) < 100) return SendInfoMessage(playerid,"Sia komanda galite naudotis tik nuo 100 XP.~n~Pavalgyti galite is siuksliu konteineriu.");
	new idx=(GetPlayerVirtualWorld(playerid)-MAX_HOUSES*2);
	new type = BusinessInfo[idx][bType];
	if(type == 1)
		return 3; // dovanos sporto klube
	if(type < 18) return -1;
	if(type > 20) return -1;

	return (type-18);
	//return 0; // temp
}

stock ShowBaldaiShope(playerid,cat)
{
	if(cat == 13) // Dovanos
	{
		//KaleduShopas(playerid);
		return 1;
	}
	new query[128];
	format(query,sizeof(query),"SELECT `obj` FROM `baldai_id` Where cat='%i' ORDER by `kaina` ASC",cat);
	mysql_function_query(SQL, query, true, "SQL_BaldaiShope", "ii",playerid,cat);
	return 1;
}


stock SaveBaldai(houseid)
{
	//RestartCheck();
	new query[512];
	format(query,sizeof(query),"DELETE FROM baldai WHERE houseid='%i'",houseid);
	mysql_query(query);
	for(new i;i<MAX_BALDAI;i++) 
	{
		if(BalduSistema[houseid][i][b_used])
		{
			format(query,sizeof(query),"INSERT INTO `baldai`(`houseid`,`obj`,`x`,`y`,`z`,`rotx`,`roty`,`rotz`,`cat`) VALUES('%i','%i','%f','%f','%f','%f','%f','%f',%i)",houseid,BalduSistema[houseid][i][b_obj],BalduSistema[houseid][i][b_x],BalduSistema[houseid][i][b_y],BalduSistema[houseid][i][b_z],BalduSistema[houseid][i][b_rx],BalduSistema[houseid][i][b_ry],BalduSistema[houseid][i][b_rz],BalduSistema[houseid][i][b_cat]);
			mysql_query(query);
		}
	}
}
stock LoadBaldai(houseid,destroy=0)
{
	if(destroy)
	{
		for(new i;i<MAX_BALDAI;i++)
		{
			if(BalduSistema[houseid][i][b_used])
			{
				BalduSistema[houseid][i][b_used]=0;
				DestroyDynamicObject(BalduSistema[houseid][i][b_oid]);
				BalduSistema[houseid][i][b_oid]=-1;
			}
		}
	}
	new query[512];
	format(query,sizeof(query),"SELECT * FROM baldai WHERE houseid='%i'",houseid);
	//mysql_query("SELECT * FROM `Sandeliai`");
	mysql_function_query(SQL, query, true, "SQL_BalduQuery", "i",houseid);

	return 1;
}

