public ZolesKokybe()
{
	AutokluboKelione();
	print("ZolesKokybe");
//	for(new i=0; i<MAX_HOUSES; i++)
	foreach (Houses, i)
	{
		if(hInfo[i][krumeliai] > 0)
		{
			hInfo[i][amzius] ++;
			if(hInfo[i][dregme] > 0)
			{
				hInfo[i][dregme] -= 4;
			}
			if(hInfo[i][dregme] > 200){hInfo[i][krumeliai] = 0;}
			if(hInfo[i][bukle] > 0)
			{
				new balansas;
				balansas = 90 - hInfo[i][dregme];
				if(balansas < 0){ balansas = balansas * -1;}
				if(balansas >= 0 && balansas <= 10)
				{
					if(hInfo[i][bukle] < 117){	hInfo[i][bukle] +=4;}
					else{ hInfo[i][bukle] -=1;}
				}
				else if(balansas > 10 && balansas <= 30){ hInfo[i][bukle] -= 0;}
				else if(balansas > 30 && balansas <= 50){ hInfo[i][bukle] -= 1;}
				else if(balansas > 50 && balansas <= 70){ hInfo[i][bukle] -= 2;}
				else if(balansas > 70 && balansas <= 90){ hInfo[i][bukle] -= 2;}
				else{hInfo[i][bukle] -= 2;}
			}
			else{hInfo[i][krumeliai] = 0;}
		}
		new query[256];
		format(query,sizeof(query),"UPDATE `Namai` SET `Locked`=%i, `Krumeliai`=%i,`Dregme`=%i,`Bukle`=%i,`Amzius`=%i WHERE `ID`=%i",hInfo[i][Locked],hInfo[i][krumeliai],hInfo[i][dregme],hInfo[i][bukle],hInfo[i][amzius],i);
		mysql_query(query);
	}
	return 1;
}
new warntime[MAX_PLAYERS];
stock AC_Warn(playerid, reason[],bool:insert=true)
{
	if(!IsPlayerConnected(playerid)) 
		return 1;
	if(warntime[playerid] + 3000 > GetTickCount()) // ignore
		return 1;
	warntime[playerid] = GetTickCount();

	new reasonas[150];
	format(reasonas,sizeof(reasonas)," * LSG Anti-Cheatas perspëja administratorius: %s átariamas %s",ReturnName(playerid),reason);
	if(insert) MLog(playerid,"WarnCheat","s", reason);
	printf(formatwithoutLT(reasonas));
	SendMessageToAdmin(reasonas);
	return 1;
}
stock AC_Ban(playerid, reason[],nodelay=0, nokick=0)
{
	if(!IsPlayerConnected(playerid)) return 1;
	SendClientMessage(playerid,RED," * DEMESIO!");
	SendClientMessage(playerid,RED," * Jus itariamas nelegaliu programu naudojimu(cheat/bug).");
	SendClientMessage(playerid,RED," * Jei manote, kad jus nekaltas - sukurkite tema Lsgyvenimas.lt forume, skyriuje BAN APELIACIJOS.");
	SendClientMessage(playerid,RED," * Spauskite F8, kad padaryt FOTO irodyma. Jis atsiras My Documents/Gta San Andreas User Files/SA-MP/screens.");
	new zinute[128],
		name[MAX_PLAYER_NAME],
		plrIP[16],
		query[512];
	GetPlayerName(playerid,name,sizeof(name));
	format(zinute,128," * LSG Anti-cheat : %s uzblokuotas uz cheat ( %s )",name,reason);
	SendClientMessageToAll(RED,zinute);
	TogglePlayerControllable(playerid,false);
	GetPlayerIp(playerid, plrIP, sizeof(plrIP));
	new gangas = playerDB[playerid][pgang];
	format(query,sizeof(query),"INSERT INTO BANS (Vardas,IP,Priezastis,Adminas,Date,Gauja) VALUES ('%s','%s','%s','LSG Anti-Cheat',NOW(),%i)",name,plrIP,reason, gangas);
	mysql_query(query);
	printf(zinute);
	
	if(nokick == 0)
	{
		if(nodelay) 
			Kick(playerid);
		else
			KickEx(playerid);
	}
	MLog(playerid,"AC_Ban","s", reason);
	return 1;
}

new LastKickMessage[128];

stock AC_Kick(playerid,reason[],nodelay=0,onlyuser=0)
{
	if(!IsPlayerConnected(playerid)) return 1;
	new zinute[128],
		name[MAX_PLAYER_NAME];
	Stop(playerid);
	TogglePlayerControllable(playerid,false);
	SendClientMessage(playerid,RED," * DEMESIO!");
	SendClientMessage(playerid,RED," * Jus itariamas nelegaliu programu naudojimu(cheat/bug).");
	SendClientMessage(playerid,RED," * Jus buvote ispetas.");
	SendClientMessage(playerid,RED," * Jei manote, kad jus nekaltas - tiesiog ignoruokite sita pranesima ir prisijunkite is naujo.");
	GetPlayerName(playerid,name,sizeof(name));
	printf("[AC_KICK] %s uz %s",ReturnName(playerid),reason);
	format(zinute,128," * LSG Anti-Cheat : %s iđmestas ( %s ).",name,reason);
	if(onlyuser || strlen(LastKickMessage) > 1 && strcmp(LastKickMessage, zinute, false) == 0)
	{
		printf("AC kick protection");
		SendClientMessage(playerid, RED, zinute);
	}
	else
	{
		SendClientMessageToAll(RED,zinute);
	}
	format(LastKickMessage, 128, "%s", zinute);
	if(nodelay) 
		Kick(playerid);
	else
		KickEx(playerid);
	
	MLog(playerid,"AC_Kick","s", reason);
	NotSpawned[playerid]=true;
	return 1;
}
