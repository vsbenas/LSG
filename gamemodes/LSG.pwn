		Light[4][playerid] = CreateDynamicObject(354,FRX[playerid]+(0+(random(10))),FRY[playerid]-(0+(random(10))),FRZ[playerid]-5, 0, 0,0);
		Light[5][playerid] = CreateDynamicObject(354,FRX[playerid]+(0+(random(10))),FRY[playerid]+(0+(random(10))),FRZ[playerid]-5, 0, 0,0);
		Light[6][playerid] = CreateDynamicObject(354,FRX[playerid]+(0+(random(10))),FRY[playerid],FRZ[playerid]-5, 0, 0,0);
		Light[7][playerid] = CreateDynamicObject(354,FRX[playerid],FRY[playerid]-(0+(random(10))),FRZ[playerid]-5, 0, 0,0);
		Light[8][playerid] = CreateDynamicObject(354,FRX[playerid],FRY[playerid]+(0+(random(10))),FRZ[playerid]-5, 0, 0,0);
		new Float:xla,Float:yla,Float:zla;
		GetDynamicObjectPos(Light[1][playerid], xla, yla, zla);
		MoveDynamicObject(Light[1][playerid], xla-6, yla-6, zla-20, 4);
		GetDynamicObjectPos(Light[2][playerid], xla, yla, zla);
		MoveDynamicObject(Light[2][playerid], xla-6, yla+6, zla-20, 4);
		GetDynamicObjectPos(Light[3][playerid], xla, yla, zla);
		MoveDynamicObject(Light[3][playerid], xla-6, yla, zla-20, 4);
		GetDynamicObjectPos(Light[4][playerid], xla, yla, zla);
		MoveDynamicObject(Light[4][playerid], xla+6, yla-6, zla-20, 4);
		GetDynamicObjectPos(Light[5][playerid], xla, yla, zla);
		MoveDynamicObject(Light[5][playerid], xla+6, yla+6, zla-20, 4);
		GetDynamicObjectPos(Light[6][playerid], xla, yla, zla);
		MoveDynamicObject(Light[6][playerid], xla+6, yla, zla-20, 4);
		GetDynamicObjectPos(Light[7][playerid], xla, yla, zla);
		MoveDynamicObject(Light[7][playerid], xla, yla-6, zla-20, 4);
		GetDynamicObjectPos(Light[8][playerid], xla, yla, zla);
		MoveDynamicObject(Light[8][playerid], xla, yla+6, zla-20, 4);
		SetTimerEx("splittime3", 3000, 0, "i", playerid);
		DestroyDynamicObject(Firerocket[playerid]);
		DestroyDynamicObject(rocketsmoke[playerid]);
		UpdateStreamerFW(xla,yla,zla);
		return 1;
	}
	return 1;
}

public splittime3(playerid)
{
