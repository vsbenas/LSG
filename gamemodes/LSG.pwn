	PlayerTextDrawBackgroundColor(playerid, Receive, 255);
	PlayerTextDrawFont(playerid, Receive, 1);
	PlayerTextDrawLetterSize(playerid, Receive, 0.500000, 1.000000);
	PlayerTextDrawColor(playerid, Receive, -1);
	PlayerTextDrawSetOutline(playerid, Receive, 0);
	PlayerTextDrawSetProportional(playerid, Receive, 1);
	PlayerTextDrawSetShadow(playerid, Receive, 1);
	PlayerTextDrawUseBox(playerid, Receive, 1);
	PlayerTextDrawBoxColor(playerid, Receive, -2004318055);
	PlayerTextDrawTextSize(playerid, Receive, 540.000000, 0.000000);
	PlayerTextDrawShow(playerid, Receive);
	return Receive;
}

//PlayerText:CreateLineForMainai(

stock AddItemToMainai(playerid,itemid,count)
{
	if(TradingWith[playerid] == -1) return SendInfoMessage(playerid,"Tu nebesimainai!");
	new n=0;
	for(new i;i<MAX_ITEMS;i++)
	{
		if(ItemType[i]{playerid}==itemid)
		{
			if(ItemType[i]{playerid} == 1 || ItemType[i]{playerid} == 2)
			{
				ItemType[i]{playerid}=0;
				ItemCount[i][playerid]=0;
			}
			else
			{
				if(ItemCount[i][playerid] == count)
				{
					n=2;
					break;
				}
			}
		}
		if(ItemType[i]{playerid}==0)
		{
			ItemType[i]{playerid}=itemid;
			ItemCount[i][playerid]=count;
			n=1;
			break;
		}
	}
	PlayerTextDrawDestroy(playerid,MainuTD[7][playerid]);
	PlayerTextDrawDestroy(TradingWith[playerid],MainuTD[8][playerid]);
	MainuTD[7][playerid] = CreateOfferTextDraw(playerid,CreateTheText(playerid)); 
	MainuTD[8][TradingWith[playerid]] = CreateReceiveTextDraw(TradingWith[playerid],CreateTheText(playerid)); 
	//Sutinka{TradingWith[playerid]}=false;
	galikast[TradingWith[playerid]]=false;
	SetTimerEx("GaliKast",4000,0,"i",TradingWith[playerid]);
	galikast[playerid]=false;
	SetTimerEx("GaliKast",4000,0,"i",playerid);
	SendClientMessage(TradingWith[playerid],RED," * Zaidejas pakeite savo pasiulyma! Palaukite pora sekundziu.");
	if(Sutinka{TradingWith[playerid]})
	{
		//SendInfoMessage(playerid,"Nesutinka!");
		PlayerPlaySound(playerid, 1085, 0.0, 0.0, 0.0);
		PlayerTextDrawColor(playerid, MainuTD[3][playerid], 0x4A5A6BFF);
		PlayerTextDrawShow(playerid, MainuTD[3][playerid]);
		if(IsPlayerConnected(TradingWith[playerid]))
		{
			Sutinka{TradingWith[playerid]}=false;
			
			SendInfoMessage(TradingWith[playerid],"Nesutinkate!");
			PlayerPlaySound(TradingWith[playerid], 1085, 0.0, 0.0, 0.0);
			PlayerTextDrawColor(TradingWith[playerid], MainuTD[6][playerid], 0x4A5A6BFF);
			PlayerTextDrawShow(TradingWith[playerid], MainuTD[6][playerid]);
			SelectTextDraw(playerid, 0xACCBF1FF);
		}
		else
		{
			CancelSelectTextDraw(playerid);
			SetPVarInt(playerid,"MainaiIvyko",1);
			SendInfoMessage(playerid,"~r~Zaidejas su jumis nebenori mainytis!");
			DestroySelectionMenu(playerid);
			TradingWith[playerid]=-1;
		}
	}
	return n;
}
stock CreateTheText(playerid)
{
	new string[1024],n;
	for(new i;i<MAX_ITEMS;i++)
	{
		n++;
		if(ItemType[i]{playerid}==0) break;
		format(string,sizeof(string),"%s%i. %s~n~",string,n,GetItemName(playerid,ItemType[i]{playerid},ItemCount[i][playerid]));
		
	}
	if(isnull(string)) format(string,sizeof(string),"-");
	return string;
}
stock Float:GetAutoRida(playerid,carid)
{
	if(carid==1) return Carlist[playerid][Rida];
	else if(carid==2) return Carlist2[playerid][Rida];
	else if(carid==3) return Carlist3[playerid][Rida];
	else return 0.0;
}
stock GetItemName(playerid,itemid,count)
{
	new string[50];
	switch(itemid)
	{
		case 1: format(string,sizeof(string),"%sEUR",FormatNumber(count)); // pinigai
		case 2: format(string,sizeof(string),"%ikred.",count); // kreditai
		case 3: format(string,sizeof(string),"%s (%s,%.1fkm)",aVehicleNames[GetAutoName(playerid,count)][Name],((GetAutoStatus(playerid,count))?("Sveikas"):("Sproges")),GetAutoRida(playerid,count)); // automobiliai
		case 4: format(string,sizeof(string),"Verslas \"%s\"(%s)",BusinessInfo[count][bName],GetBussinessType(BusinessInfo[count][bType])); // verslai
		case 5: format(string,sizeof(string),"Namas Nr.%i",count); // namai
		default: format(string,sizeof(string),"Nieko");
	}
	return string;
}

stock GetAutoName(playerid,carid)
{
	if(carid==1) return Carlist[playerid][Typ];
	else if(carid==2) return Carlist2[playerid][Typ];
	else if(carid==3) return Carlist3[playerid][Typ];
	return 0;
	//else return str;
}

stock GetAutoStatus(playerid,carid)
{
	if(carid==1) return Carlist[playerid][Status];
	else if(carid==2) return Carlist2[playerid][Status];
	else if(carid==3) return Carlist3[playerid][Status];
	else return 1;
}

stock MakeTrade(playerid,playerid2)
{//-1 not connected -2 not connected other -3 not trading -4 has 2 much cars -5 has 2 much cars other -6 has 2 much houses -7 has 2 much houses other
	if(!IsPlayerConnected(playerid)) return -1;
	if(!IsPlayerConnected(playerid2)) return -2;
	if(TradingWith[playerid]!=playerid2 || TradingWith[playerid2]!=playerid) return -3;
	new moneybalance,kredbalance;
	new CarArray[3][ahCar],
		CarArrayUsed[3],
		GivesCars[2],
		GivenCarID[2][3],
		GivesHouses[2],
		HousesID[2][2],
		GivesBusinesses[2],
		BusID[2][10];
	for(new i;i<MAX_ITEMS;i++)
	{
		if(ItemType[i]{playerid}==1) moneybalance+=ItemCount[i][playerid];
		if(ItemType[i]{playerid2}==1) moneybalance-=ItemCount[i][playerid2];
		if(ItemType[i]{playerid}==2) kredbalance+=ItemCount[i][playerid];
		if(ItemType[i]{playerid2}==2) kredbalance-=ItemCount[i][playerid2];
		if(ItemType[i]{playerid}==3)
		{
			GivenCarID[0][GivesCars[0]]=ItemCount[i][playerid];
			GivesCars[0]++;
		}
		if(ItemType[i]{playerid2}==3)
		{
			GivenCarID[1][GivesCars[1]]=ItemCount[i][playerid2];
			GivesCars[1]++;
		}
		if(ItemType[i]{playerid}==4)
		{
			BusID[0][GivesBusinesses[0]]=ItemCount[i][playerid];
			GivesBusinesses[0]++;
		}
		if(ItemType[i]{playerid2}==4)
		{
			BusID[1][GivesBusinesses[1]]=ItemCount[i][playerid2];
			GivesBusinesses[1]++;
		}
		if(ItemType[i]{playerid}==5)
		{
			HousesID[0][GivesHouses[0]]=ItemCount[i][playerid];
			GivesHouses[0]++;
		}
		if(ItemType[i]{playerid2}==5)
		{
			HousesID[1][GivesHouses[1]]=ItemCount[i][playerid2];
			GivesHouses[1]++;
		}
	}
	if(GivesCars[0] || GivesCars[1])
	{
		new HowMuch[2];
		if(Carlist[playerid][Typ]!=-1) HowMuch[0]++;
		if(Carlist2[playerid][Typ]!=-1) HowMuch[0]++;
		if(Carlist3[playerid][Typ]!=-1) HowMuch[0]++;
		
		if(Carlist[playerid2][Typ]!=-1) HowMuch[1]++;
		if(Carlist2[playerid2][Typ]!=-1) HowMuch[1]++;
		if(Carlist3[playerid2][Typ]!=-1) HowMuch[1]++;
		
		if(HowMuch[0] - GivesCars[0] + GivesCars[1] > 3) return -4;
		if(HowMuch[1] - GivesCars[1] + GivesCars[0] > 3) return -5;
	}
	if(GivesHouses[0] || GivesHouses[1])
	{
		if((playerDB[playerid][namu]-GivesHouses[0]+GivesHouses[1]) > GetNamuLimit(playerid)) return -6;
		if((playerDB[playerid2][namu]-GivesHouses[1]+GivesHouses[0]) > GetNamuLimit(playerid2)) return -7;
	}
	if(moneybalance != 0)
	{
		if(GetPlayerMoneyA(playerid) < moneybalance) return -8;
		if(GetPlayerMoneyA(playerid2) < -moneybalance) return -9;
	}
	if(kredbalance != 0)
	{
		if(playerDB[playerid][kreditai] < kredbalance) return -8;
		if(playerDB[playerid2][kreditai] < -kredbalance) return -9;
	}
	if(GivesBusinesses[0] || GivesBusinesses[1]) 
	{
		if(VerslaiCount(playerid)-GivesBusinesses[0]+GivesBusinesses[1] > 10) return -10;
		if(VerslaiCount(playerid2)-GivesBusinesses[1]+GivesBusinesses[0] > 10) return -11;

	}
	// giving starts here
	if(moneybalance != 0)
	{
		GivePlayerMoneyA(playerid, -moneybalance);
		GivePlayerMoneyA(playerid2, moneybalance);
	}
	if(kredbalance != 0)
	{
		playerDB[playerid][kreditai]-=kredbalance;
		playerDB[playerid2][kreditai]+=kredbalance;
		new uzrasas[128];
		format(uzrasas,128,"UPDATE `Account` SET Kreditai =%i WHERE `Name` = '%s'",playerDB[playerid][kreditai],ReturnName(playerid));
		mysql_query(uzrasas);
		format(uzrasas,128,"UPDATE `Account` SET Kreditai =%i WHERE `Name` = '%s'",playerDB[playerid2][kreditai],ReturnName(playerid2));
		mysql_query(uzrasas);
	}
	if((GivesBusinesses[0] || GivesHouses[0] || GivesCars[0]) && (GivesBusinesses[1] || GivesHouses[1] || GivesCars[1]))
	{
		ProcessAchievement(playerid,70);
		ProcessAchievement(playerid2,70);
	}
	if(GivesBusinesses[0])
	{
		for(new x;x<GivesBusinesses[0];x++)
		{
			new i = BusID[0][x];
			new tname[24];
			GetPlayerName(playerid2,tname,24);
			if(0!=strcmp(BusinessInfo[i][bOwner],ReturnName(playerid),false)) continue;
			strmid(BusinessInfo[i][bOwner],tname,0,MAX_PLAYER_NAME,MAX_PLAYER_NAME);
			new string[128];
			new idx =i;
			format(string, sizeof(string), VERSLAS_NEPARDUODAMAS, BusinessInfo[idx][bName],BusinessInfo[idx][bOwner],GetBussinessType(BusinessInfo[idx][bType]));
			DestroyDynamic3DTextLabel(businesstext[idx]);
			businesstext[idx] = CreateDynamic3DTextLabel(string,0x00BC00FF,BusinessInfo[idx][bEnterX],BusinessInfo[idx][bEnterY],BusinessInfo[idx][bEnterZ],40.0, _,_, 1);
		}
	}
	if(GivesBusinesses[1])
	{
		for(new x;x<GivesBusinesses[1];x++)
		{
			new i = BusID[1][x];
			if(0!=strcmp(BusinessInfo[i][bOwner],ReturnName(playerid2),false)) continue;
			new tname[24];
			GetPlayerName(playerid,tname,24);
			strmid(BusinessInfo[i][bOwner],tname,0,MAX_PLAYER_NAME,MAX_PLAYER_NAME);
			new string[128];
			new idx =i;
			format(string, sizeof(string), VERSLAS_NEPARDUODAMAS, BusinessInfo[idx][bName],BusinessInfo[idx][bOwner],GetBussinessType(BusinessInfo[idx][bType]));
			DestroyDynamic3DTextLabel(businesstext[idx]);
			businesstext[idx] = CreateDynamic3DTextLabel(string,0x00BC00FF,BusinessInfo[idx][bEnterX],BusinessInfo[idx][bEnterY],BusinessInfo[idx][bEnterZ],40.0, _,_, 1);
		}	
	}
	if(GivesHouses[0])
	{
		for(new x;x<GivesHouses[0];x++)
		{

			new pname[24],parname[24];
			GetPlayerName(playerid2, pname, 24);
			GetPlayerName(playerid, parname, 24);
			new housenumber=HousesID[0][x];
			if(strcmp(hInfo[housenumber][Name],ReturnName(playerid),false)!=0) continue;
			MLog(playerid2,"Nusipirko nama is","is", housenumber,ReturnName(playerid));
			playerDB[playerid2][namu]++;
			playerDB[playerid][namu]--;

			//hInfo[housenumber][zole] = 0;
			//hInfo[housenumber][nark] = 0;
			//hInfo[housenumber][pinigai] = 0;
			new query[128];
			format(query,sizeof(query),"UPDATE `Namai` SET `Zole`=0,`Nark`=0,`Pinigai`=0 WHERE `ID`=%i",housenumber);
			mysql_query(query);
			for(new slot=0; slot<12; slot++)
			{
				hInfo[housenumber][gunas][slot]=0;
				hInfo[housenumber][kulkos][slot]=0;
				new kulkoz[50],gunz[50];
				format(kulkoz,sizeof(kulkoz),"Kulkos%i",slot);
				format(gunz,sizeof(gunz),"Ginklas%i",slot);

				format(query,sizeof(query),"UPDATE `Namai` SET `%s`=0,`%s`=0 WHERE `ID`=%i",kulkoz,gunz,housenumber);
				mysql_query(query);
			}
			format(query,sizeof(query),"UPDATE `Namai` SET `Name`='%s' WHERE `ID`=%i",pname,housenumber);
			mysql_query(query);
			hInfo[housenumber][Name]=pname;
			hInfo[housenumber][Locked] = 0;
			DestroyDynamic3DTextLabel(HouseText[housenumber]);
			new zinute[512];
			new vw;
			if(hInfo[housenumber][daugiabutis]) vw=(MAX_HOUSES*2+MAX_BUSINESSES+hInfo[housenumber][daugiabutis]-1);
			format(zinute,sizeof(zinute),"{FFFFFF}Namas Nr.: {FF0000}%i\n{FFFFFF}Savininkas: {FF0000}%s",housenumber,hInfo[housenumber][Name]);
			HouseText[housenumber] = CreateDynamic3DTextLabel(zinute, COLOR_WHITE, hInfo[housenumber][iconx], hInfo[housenumber][icony], hInfo[housenumber][iconz], 50, _,_, 1, vw);
			if(hInfo[housenumber][polyId] != -1)
			{
				ShowPlayerDialog(playerid2, 9530, DIALOG_STYLE_MSGBOX, "Apartamentai", "Sveikiname ásigyjus vienŕ prestiţiđkiausiř Los Santos apartamentř!\n\nJuo galite naudotis visiđkai kaip ir kitais namais, iđskyrus kelias smulkmenas:\n\
				• Negalite daţyti namo sienř ir durř.\n\
				• Negalite namo remontuoti.\n\
				• Galite uţrakinti lifto duris uţlipć ant đio pickup.\n\
				• Privalote baldus statyti tvarkingai. Uţ per sienas/lubas/grindis iđlindusius baldus iđ jűsř bus atimtas namas be jokio perspëjimo.\n\n\n\
				Linkime jaukaus ir patogaus gyvenimo jűsř naujŕjame name!", "Gerai","");
			}
		}
	}
	if(GivesHouses[1])
	{
		for(new x;x<GivesHouses[1];x++)
		{
			new pname[24],parname[24];
			GetPlayerName(playerid, pname, 24);
			GetPlayerName(playerid2, parname, 24);
			SendInfoMessage(playerid,"Jus nusipirkote nama!");
			new housenumber=HousesID[1][x];
			if(strcmp(hInfo[housenumber][Name],ReturnName(playerid2),false)!=0) continue;
			MLog(playerid2,"Nusipirko nama is","is", housenumber,ReturnName(playerid2));
			playerDB[playerid][namu]++;
			playerDB[playerid2][namu]--;
			
			//hInfo[housenumber][zole] = 0;
			//hInfo[housenumber][nark] = 0;
			//hInfo[housenumber][pinigai] = 0;
			new query[128];
			format(query,sizeof(query),"UPDATE `Namai` SET `Zole`=0,`Nark`=0,`Pinigai`=0 WHERE `ID`=%i",housenumber);
			mysql_query(query);
			for(new slot=0; slot<12; slot++)
			{
				hInfo[housenumber][gunas][slot]=0;
				hInfo[housenumber][kulkos][slot]=0;
				new kulkoz[50],gunz[50];
				format(kulkoz,sizeof(kulkoz),"Kulkos%i",slot);
				format(gunz,sizeof(gunz),"Ginklas%i",slot);

				format(query,sizeof(query),"UPDATE `Namai` SET `%s`=0,`%s`=0 WHERE `ID`=%i",kulkoz,gunz,housenumber);
				mysql_query(query);
			}
			format(query,sizeof(query),"UPDATE `Namai` SET `Name`='%s' WHERE `ID`=%i",pname,housenumber);
			mysql_query(query);
			hInfo[housenumber][Name]=pname;
			hInfo[housenumber][Locked] = 0;
			DestroyDynamic3DTextLabel(HouseText[housenumber]);
			new zinute[512];
			new vw;
			if(hInfo[housenumber][daugiabutis]) vw=(MAX_HOUSES*2+MAX_BUSINESSES+hInfo[housenumber][daugiabutis]-1);
			format(zinute,sizeof(zinute),"{FFFFFF}Namas Nr.: {FF0000}%i\n{FFFFFF}Savininkas: {FF0000}%s",housenumber,hInfo[housenumber][Name]);
			HouseText[housenumber] = CreateDynamic3DTextLabel(zinute, COLOR_WHITE, hInfo[housenumber][iconx], hInfo[housenumber][icony], hInfo[housenumber][iconz], 50, _,_, 1, vw);
			if(hInfo[housenumber][polyId] != -1)
			{
				ShowPlayerDialog(playerid, 9530, DIALOG_STYLE_MSGBOX, "Apartamentai", "Sveikiname ásigyjus vienŕ prestiţiđkiausiř Los Santos apartamentř!\n\nJuo galite naudotis visiđkai kaip ir kitais namais, iđskyrus kelias smulkmenas:\n\
				• Negalite daţyti namo sienř ir durř.\n\
				• Negalite namo remontuoti.\n\
				• Galite uţrakinti lifto duris uţlipć ant đio pickup.\n\
				• Privalote baldus statyti tvarkingai. Uţ per sienas/lubas/grindis iđlindusius baldus iđ jűsř bus atimtas namas be jokio perspëjimo.\n\n\nLinkime jaukaus ir patogaus gyvenimo jűsř naujŕjame name!", "Gerai","");
			}
		}
	}
	if(GivesCars[0])
	{
		for(new i;i<3;i++)
		{
			if(GivenCarID[0][i] == 1)
			{
				CarArray[i]=Carlist[playerid];
				CarArrayUsed[i]=1;
				ClearCarList(playerid,1);
			}
			else if(GivenCarID[0][i] == 2)
			{
				CarArray[i]=Carlist2[playerid];
				CarArrayUsed[i]=1;
				ClearCarList(playerid,2);
			}
			else if(GivenCarID[0][i] == 3)
			{
				CarArray[i]=Carlist3[playerid];
				CarArrayUsed[i]=1;
				ClearCarList(playerid,3);
			}
		}
	}
	if(GivesCars[1])
	{
		for(new i;i<3;i++)
		{
			if(GivenCarID[1][i] == 1)
			{
				if(Carlist[playerid][Typ]==-1)
				{
					Carlist[playerid]=Carlist[playerid2];
					ClearCarList(playerid2,1);
				}
				else if(Carlist2[playerid][Typ]==-1)
				{
					Carlist2[playerid]=Carlist[playerid2];
					ClearCarList(playerid2,1);
				}
				else if(Carlist3[playerid][Typ]==-1)
				{
					Carlist3[playerid]=Carlist[playerid2];
					ClearCarList(playerid2,1);
				}
			}
			else if(GivenCarID[1][i] == 2)
			{
				if(Carlist[playerid][Typ]==-1)
				{
					Carlist[playerid]=Carlist2[playerid2];
					ClearCarList(playerid2,2);
				}
				else if(Carlist2[playerid][Typ]==-1)
				{
					Carlist2[playerid]=Carlist2[playerid2];
					ClearCarList(playerid2,2);
				}
				else if(Carlist3[playerid][Typ]==-1)
				{
					Carlist3[playerid]=Carlist2[playerid2];
					ClearCarList(playerid2,2);
				}
			}
			else if(GivenCarID[1][i] == 3)
			{
				if(Carlist[playerid][Typ]==-1)
				{
					Carlist[playerid]=Carlist3[playerid2];
					ClearCarList(playerid2,3);
				}
				else if(Carlist2[playerid][Typ]==-1)
				{
					Carlist2[playerid]=Carlist3[playerid2];
					ClearCarList(playerid2,3);
				}
				else if(Carlist3[playerid][Typ]==-1)
				{
					Carlist3[playerid]=Carlist3[playerid2];
					ClearCarList(playerid2,3);
				}
			}
		}
	}
	if(GivesCars[0])
	{
		for(new i;i<3;i++)
		{
			if(CarArrayUsed[i]==1)
			{
				if(Carlist[playerid2][Typ]==-1)
				{
					Carlist[playerid2]=CarArray[i];
				}
				else if(Carlist2[playerid2][Typ]==-1)
				{
					Carlist2[playerid2]=CarArray[i];
				}
				else if(Carlist3[playerid2][Typ]==-1)
				{
					Carlist3[playerid2]=CarArray[i];
				}	
			}
		}
	}
	
	return 1;
}
CreateSelectionMenu(playerid)
{
	MainuTD[0][playerid] = CreatePlayerBackgroundTextDraw(playerid, DIALOG_BASE_X, DIALOG_BASE_Y + 20.0, DIALOG_WIDTH, DIALOG_HEIGHT);
	MainuTD[1][playerid] = CreatePlayerHeaderTextDraw(playerid, DIALOG_BASE_X, DIALOG_BASE_Y, "Mainai");
	MainuTD[2][playerid] = CreateCurrentPageTextDraw(playerid, DIALOG_WIDTH - 200.0, DIALOG_BASE_Y + 14.0); // zaidejo vardas
	MainuTD[3][playerid] = CreatePlayerDialogButton(playerid, DIALOG_BASE_X + 30.0, DIALOG_BASE_Y+DIALOG_HEIGHT+100.0, 50.0, 16.0, "Sutikti"); // sutinka
	MainuTD[4][playerid] = CreatePlayerDialogButton(playerid, DIALOG_BASE_X + 90.0, DIALOG_BASE_Y+DIALOG_HEIGHT+100.0, 50.0, 16.0, "Prideti");
	MainuTD[5][playerid] = CreatePlayerDialogButton(playerid, DIALOG_BASE_X + 150.0, DIALOG_BASE_Y+DIALOG_HEIGHT+100.0, 50.0, 16.0, "Atsaukti");
	MainuTD[6][playerid] = CreatePlayerDialogButton(playerid, DIALOG_WIDTH - 30.0, DIALOG_BASE_Y+DIALOG_HEIGHT+100.0, 50.0, 16.0, "Sutinka",0);
	MainuTD[7][playerid] = CreateOfferTextDraw(playerid,CreateTheText(playerid)); 
	MainuTD[8][playerid] = CreateReceiveTextDraw(playerid,CreateTheText(TradingWith[playerid]));
	PlayerTextDrawSetString(playerid, MainuTD[2][playerid], ReturnName(TradingWith[playerid]));
	TextDrawShowForPlayer(playerid,MainuLine);
	return 1;
}

//------------------------------------------------

DestroySelectionMenu(playerid)
{
	//ClearOffer(playerid);
	for(new i;i<9;i++) PlayerTextDrawDestroy(playerid,MainuTD[i][playerid]),MainuTD[i][playerid]=PlayerText:INVALID_TEXT_DRAW;
	TextDrawHideForPlayer(playerid,MainuLine);
	for(new i;i<MAX_ITEMS;i++)
	{
		ItemType[i]{playerid}=0;
		ItemCount[i]{playerid}=0;
	}
	return 1;
}
stock ClearOffer(playerid)
{
	if(TradingWith[playerid] == -1) return SendInfoMessage(playerid,"Tu nebesimainai!");
	for(new i;i<MAX_ITEMS;i++)
	{
		ItemType[i]{playerid}=0;
		ItemCount[i]{playerid}=0;
	}
	PlayerTextDrawDestroy(playerid,MainuTD[7][playerid]);
	PlayerTextDrawDestroy(TradingWith[playerid],MainuTD[8][playerid]);
	MainuTD[7][playerid] = CreateOfferTextDraw(playerid,CreateTheText(playerid)); 
	MainuTD[8][TradingWith[playerid]] = CreateReceiveTextDraw(TradingWith[playerid],CreateTheText(playerid)); 
	SendClientMessage(playerid,RED," * Isemete savo pasiulytus daiktus.");
	Sutinka{playerid}=false;
	if(Sutinka{TradingWith[playerid]})
	{
		SendInfoMessage(playerid,"Nesutinka!");
		Sutinka{TradingWith[playerid]}=false;
		PlayerPlaySound(playerid, 1085, 0.0, 0.0, 0.0);
		PlayerTextDrawColor(playerid, MainuTD[3][playerid], 0x4A5A6BFF);
		PlayerTextDrawShow(playerid, MainuTD[3][playerid]);
		if(IsPlayerConnected(TradingWith[playerid]) && TradingWith[TradingWith[playerid]]==playerid)
		{
			
		}
		else
		{
			CancelSelectTextDraw(playerid);
			SetPVarInt(playerid,"MainaiIvyko",1);
			SendInfoMessage(playerid,"~r~Zaidejas su jumis nebenori mainytis!");
			DestroySelectionMenu(playerid);
			TradingWith[playerid]=-1;
			return 1;
		}
	}
	galikast[TradingWith[playerid]]=false;
	SetTimerEx("GaliKast",4000,0,"i",TradingWith[playerid]);
	galikast[playerid]=false;
	SetTimerEx("GaliKast",4000,0,"i",playerid);
	
	SendClientMessage(TradingWith[playerid],RED," * Zaidejas pakeite savo pasiulyma! Palaukite pora sekundziu.");
	SendInfoMessage(TradingWith[playerid],"Nesutinka!");
	PlayerPlaySound(TradingWith[playerid], 1085, 0.0, 0.0, 0.0);
	PlayerTextDrawColor(TradingWith[playerid], MainuTD[6][playerid], 0x4A5A6BFF);
	PlayerTextDrawShow(TradingWith[playerid], MainuTD[6][playerid]);
	SelectTextDraw(playerid, 0xACCBF1FF);
	return 1;
}
public OnPlayerClickPlayerTextDraw(playerid, PlayerText:playertextid)
{
	if(DEBUG==true) printf("OnPlayerClickPlayerTextDraw:%i",playerid);
	if(OnPlayerClickPoker(playerid, playertextid)) return 1;
	if(OnClickLoto(playerid,playertextid))
		return 1;
	if(playertextid == MainuTD[4][playerid])
	{
		//new string[512];
		new pname[MAX_PLAYER_NAME];
		GetPlayerName(playerid,pname,MAX_PLAYER_NAME);
		AddDListItem(playerid, "Pinigai", 1);
		AddDListItem(playerid, "Kreditai", 2);
		if(Carlist[playerid][Typ]!=-1 || Carlist2[playerid][Typ] != -1 || Carlist3[playerid][Typ] != -1)
		{
			AddDListItem(playerid, "Automobilis", 3);
		}
		foreach(Businesses,i) if(BusinessInfo[i][bOwned] && 0==strcmp(BusinessInfo[i][bOwner],pname,false))
		{
			AddDListItem(playerid,"Verslas",4);
			break;
		}
		foreach(Houses,i)
		{
			if(0==strcmp(pname,hInfo[i][Name],false))
			{
				AddDListItem(playerid,"Namas", 5);
				break;
			}
		}
		AddDListItem(playerid,"{FF0000}Valyti prideta turta", 6);
		ShowPlayerDList(playerid, 6000, "Prideti...", "Rinktis", "Atsaukti");

		return 1;
	}
	if(playertextid == MainuTD[5][playerid])
	{
		SendInfoMessage(playerid,"Atsaukete!");
		DestroySelectionMenu(playerid);
		CancelSelectTextDraw(playerid);
		if(IsPlayerConnected(TradingWith[playerid]) && TradingWith[TradingWith[playerid]]==playerid)
		{
			DestroySelectionMenu(TradingWith[playerid]);
			CancelSelectTextDraw(TradingWith[playerid]);
			SendInfoMessage(TradingWith[playerid],"Kitas zmogus atsauke mainus!");
			PlayerTextDrawColor(playerid, MainuTD[6][playerid], 0xACCBF1FF);
			PlayerTextDrawShow(playerid, MainuTD[6][playerid]);
		}
		Sutinka{playerid}=false;
		Sutinka{TradingWith[playerid]}=false;
		TradingWith[TradingWith[playerid]]=-1;
		TradingWith[playerid]=-1;

		return 1;
	}
    if(playertextid == MainuTD[3][playerid]) // sutikti
    {
		if(!Sutinka{playerid})
		{
			if(!galikast[playerid]) return SendClientMessage(playerid,RED," * Zaidejas pakeite savo pasiulyma! Palaukite pora sekundziu.");
			Sutinka{playerid}=true;
			SendInfoMessage(playerid,"Sutinkate!");
			PlayerPlaySound(playerid, 1084, 0.0, 0.0, 0.0);
			PlayerTextDrawColor(playerid, MainuTD[3][playerid], 0xACCBF1FF);
			PlayerTextDrawShow(playerid, MainuTD[3][playerid]);
			SelectTextDraw(playerid, 0x4A5A6BFF);
			if(IsPlayerConnected(TradingWith[playerid]) && TradingWith[TradingWith[playerid]]==playerid)
			{
				SendInfoMessage(TradingWith[playerid],"Sutinka!");
				PlayerPlaySound(TradingWith[playerid], 1084, 0.0, 0.0, 0.0);
				PlayerTextDrawColor(TradingWith[playerid], MainuTD[6][playerid], 0xACCBF1FF);
				PlayerTextDrawShow(TradingWith[playerid], MainuTD[6][playerid]);
				if(Sutinka{TradingWith[playerid]})
				{
					SendInfoMessage(TradingWith[playerid],"Mainai Ivyko!");
					SendInfoMessage(playerid,"Mainai Ivyko!");
					//printf("%i",MakeTrade(playerid,TradingWith[playerid]));
					switch(MakeTrade(playerid,TradingWith[playerid]))
					{
						//-1 not connected -2 not connected other -3 not trading -4 has 2 much cars -5 has 2 much cars other -6 has 2 much houses -7 has 2 much houses other
						case -1: SendClientMessage(playerid,RED," * Jus Atsijunges");
						case -2: SendClientMessage(playerid,RED," * Kitas zaidejas Atsijunge");
						case -3: SendClientMessage(playerid,RED," * Jus nebesimainote, todel mainai neivyko.");
						case -4: SendClientMessage(TradingWith[playerid],RED," * Po mainu kitas zaidejas turetu daugiau nei 3 automobilius, todel mainai neivyko."),SendClientMessage(playerid,RED," * Po mainu jus turetumete daugiau nei 3 automobilius, todel mainai neivyko.");
						case -5: SendClientMessage(playerid,RED," * Po mainu kitas zaidejas turetu daugiau nei 3 automobilius, todel mainai neivyko."),SendClientMessage(TradingWith[playerid],RED," * Po mainu jus turetumete daugiau nei 3 automobilius, todel mainai neivyko.");
						case -6: SendClientMessage(TradingWith[playerid],RED," * Po mainu kitas zaidejas turetu daugiau nei 2 namus, todel mainai neivyko."),SendClientMessage(playerid,RED," * Po mainu jus turetumete daugiau nei 2 namus, todel mainai neivyko.");
						case -7: SendClientMessage(playerid,RED," * Po mainu kitas zaidejas turetu daugiau nei 2 namus, todel mainai neivyko."),SendClientMessage(TradingWith[playerid],RED," * Po mainu jus turetumete daugiau nei 2 namus, todel mainai neivyko.");
						case -8,-9: SendClientMessage(playerid,RED," * Nebeturite susitarto turto."),SendClientMessage(TradingWith[playerid],RED," * Nebeturite susitarto turto.");
						case -10: SendClientMessage(TradingWith[playerid],RED," * Po mainu kitas zaidejas turetu daugiau nei 10 verslu, todel mainai neivyko."),SendClientMessage(playerid,RED," * Po mainu kitas zaidejas turetu daugiau negu 10 verslu, todel mainai neivyko.");
						case -11: SendClientMessage(playerid,RED," * Po mainu kitas zaidejas turetu daugiau nei 10 verslu, todel mainai neivyko."),SendClientMessage(TradingWith[playerid],RED," * Po mainu jus turetumete daugiau nei 10 verslu, todel mainai neivyko.");

						default: {}
					}
					//AddMainuLog
					SetPVarInt(playerid,"MainaiIvyko",1);
					SetPVarInt(TradingWith[playerid],"MainaiIvyko",1);
					CancelSelectTextDraw(playerid);
					DestroySelectionMenu(playerid);
					if(IsPlayerConnected(TradingWith[playerid]) && TradingWith[TradingWith[playerid]]==playerid)
					{
						CancelSelectTextDraw(TradingWith[playerid]);
						DestroySelectionMenu(TradingWith[playerid]);
						PlayerTextDrawColor(playerid, MainuTD[6][playerid], 0xACCBF1FF);
						PlayerTextDrawShow(playerid, MainuTD[6][playerid]);
					}
					Sutinka{playerid}=false;
					Sutinka{TradingWith[playerid]}=false;
					TradingWith[TradingWith[playerid]]=-1;
					TradingWith[playerid]=-1;
					return 1;
				}
			}
			else
			{	
				CancelSelectTextDraw(playerid);
				SetPVarInt(playerid,"MainaiIvyko",1);
				SendInfoMessage(playerid,"~r~Zaidejas su jumis nebenori mainytis!");
				DestroySelectionMenu(playerid);
				TradingWith[playerid]=-1;
			}
			
		}
		else
		{
			Sutinka{playerid}=false;
			SendInfoMessage(playerid,"Nesutinkate!");
			PlayerPlaySound(playerid, 1085, 0.0, 0.0, 0.0);
			PlayerTextDrawColor(playerid, MainuTD[3][playerid], 0x4A5A6BFF);
			PlayerTextDrawShow(playerid, MainuTD[3][playerid]);
			SelectTextDraw(playerid, 0xACCBF1FF);
			if(IsPlayerConnected(TradingWith[playerid]) && TradingWith[TradingWith[playerid]]==playerid)
			{
				SendInfoMessage(TradingWith[playerid],"Nesutinka!");
				PlayerPlaySound(TradingWith[playerid], 1085, 0.0, 0.0, 0.0);
				PlayerTextDrawColor(TradingWith[playerid], MainuTD[6][playerid], 0x4A5A6BFF);
				PlayerTextDrawShow(TradingWith[playerid], MainuTD[6][playerid]);
			}
			else
			{
				CancelSelectTextDraw(playerid);
				SetPVarInt(playerid,"MainaiIvyko",1);
				SendInfoMessage(playerid,"~r~Zaidejas su jumis nebenori mainytis!");
				DestroySelectionMenu(playerid);
				TradingWith[playerid]=-1;
			}
		}
    }
    return 1;
}

stock SendEmailConfirmation(playerid,email[],code[])
{
	LoginStart[playerid]=GetTickCount();
	new text[2400];
	new slaptas[10];
	if(strlen(code) > 0)
		format(slaptas,sizeof(slaptas),code);
	else
		format(slaptas,sizeof(slaptas),RandomPw(5));
	new ip[25];
	GetPlayerIp(playerid,ip,25);
	format(text,sizeof(text),"Labas %s, sveikiname uzsiregistravus lsgyvenimas.lt serveryje! Jusu patvirtinimo kodas: %s",ReturnName(playerid),slaptas);
	for(new i; i < strlen(text); i ++)//Scan the text line to add some symbol because URL cant contain blank spaces
	{
		if(text[i] == ' ')
			text[i] = '-';
	}
	
	new msg[127];
	format(msg,sizeof(msg)," * Laiskas siunciamas adresu %s ....",email);
	SendClientMessage(playerid,COLOR,msg);
	new query[300];
	format(query,sizeof(query),"REPLACE INTO `Pastas`(`Vardas`,`Email`,`Confirmation`,`Confirmed`) VALUES('%s','%s','%s',0)",ReturnName(playerid),email,slaptas);
	mysql_query(query);
	if(EMAIL_CONFIRMATION_ENABLED)
	{
		new string[2500];
		format(string,2500,"lsgyvenimas.lt/scripts/passreminder.php?msg=%s&receiver=%s",text,email);//Format request URL to PHP file we made before
		//As you can see url contains code which is used later in PHP file we made
		HTTP(playerid, HTTP_GET,string, " ", "EmailConfirmation");//Sends a request to test.php file
		format(string,sizeof(string),"%s|%s", email, text);
		AddToTaskQueue(playerid, TaskType:SEND_EMAIL_VERIFICATION, string);
		
		SendClientMessage(playerid, COLOR, " * Patvirtinimo kodas issiustas! Prasome ivesti ji cia:");
		ShowPlayerDialog(playerid,1998,DIALOG_STYLE_INPUT,"Patvirtinimo kodas","I jusu el.pasto adresa issiunteme patvirtinimo koda. Turetumete ji gauti 10 min. begyje, taciau dazniausiai gausite ji is karto.\nPasitikrinkite ir SPAM kataloga.\nIveskite koda cia:","Gerai","Atsaukti");
	}
	else
	{
		// tiesiog patvirtinam...
		format(query,128,"Update Pastas Set Confirmed=1, Confirmation=NULL WHERE Vardas='%s'",ReturnName(playerid));
		mysql_query(query);
		SendClientMessage(playerid,GREEN," * Sekmingai patvirtinote savo el.pasto adresa. Sekmes zaidime!");
		SendClientMessage(playerid,WHITE," * Naudokites rodyklemis apacioje, kad issirinktumete savo apranga. Kai issirinksite spauskite \"SPAWN\"");
		ShowPlayerDialog(playerid,1996,DIALOG_STYLE_MSGBOX,"Lietuviskos raides","Ar taisyklingai matote zemiau parasyta zodi?\n\n"#HCOLOR"Ačiű"#DCOLOR"\n\nJei pasirinksite taip - zaidime matysite lietuviskus simbolius.\nJei pasirinksite ne - zaidime lietuviskos raides bus konvertuojamos i ju atitikmeni (be nosiniu, varneliu ir t.t.)\nLietuviskas raides visada galite isijungti per VVP (/p) paspaude Nustatymai.","Taip","Ne");
	}
}
forward EmailConfirmation(index, response_code, data[]); //forward response callback, so pawno doesnt say there is some undefinded symbol

public EmailConfirmation(index, response_code, data[])//data[] Will contain "Email delivered" see in PHP file
{
    if(response_code == 200)
    {
        SendClientMessage(index, COLOR, " * Patvirtinimo kodas issiustas! Prasome ivesti ji cia:");
		ShowPlayerDialog(index,1998,DIALOG_STYLE_INPUT,"Patvirtinimo kodas","I jusu el.pasto adresa issiunteme patvirtinimo koda. Turetumete ji gauti 10 min. begyje, taciau dazniausiai gausite ji is karto.\nPasitikrinkite ir SPAM kataloga.\nIveskite koda cia:","Gerai","Atsaukti");
    }
    else 
    {
		// tiesiog patvirtinam...
		new playerid = index;
		if(!IsPlayerConnected(index)) return 1;
		new query[128];
		format(query,128,"Update Pastas Set Confirmed=1, Confirmation=NULL WHERE Vardas='%s'",ReturnName(playerid));
		mysql_query(query);
		SendClientMessage(playerid,GREEN," * Sekmingai patvirtinote savo el.pasto adresa. Sekmes zaidime!");
		SendClientMessage(playerid,WHITE," * Naudokites rodyklemis apacioje, kad issirinktumete savo apranga. Kai issirinksite spauskite \"SPAWN\"");
		ShowPlayerDialog(playerid,1996,DIALOG_STYLE_MSGBOX,"Lietuviskos raides","Ar taisyklingai matote zemiau parasyta zodi?\n\n"#HCOLOR"Ačiű"#DCOLOR"\n\nJei pasirinksite taip - zaidime matysite lietuviskus simbolius.\nJei pasirinksite ne - zaidime lietuviskos raides bus konvertuojamos i ju atitikmeni (be nosiniu, varneliu ir t.t.)\nLietuviskas raides visada galite isijungti per VVP (/p) paspaude Nustatymai.","Taip","Ne");
		return 1;
    }
    return 1;
}
stock SendPassReminder(playerid,email[])
{
	new text[2400];
	new slaptas[100];
	format(slaptas,sizeof(slaptas),RandomPw(10));
	new ip[25];
	GetPlayerIp(playerid,ip,25);
	format(text,sizeof(text),"Sveiki, gavome prasyma priminti jusu akaunto %s slaptazodi lsgyvenimas.lt serveryje. Jusu naujas sugeneruotas slaptazodis: %s. Jis isigalios pirma kart juo prisijungus. Jeigu kazkas kitas uzsake slaptazodzio keitima(ip %s), galite tiesiog ignoruoti sia zinute.",ReturnName(playerid),slaptas,ip);
	for(new i; i < strlen(text); i ++)//Scan the text line to add some symbol because URL cant contain blank spaces
	{
		if(text[i] == ' ')
			text[i] = '-';
		/*
		
		if(strfind(text[i]," ", true) == 0)//If scan process found blank space its gets replaced with "-" in my case, you can use any other symbol
		{
			text[i] = '-';//Result is Hello-World-!
		}
		*/
	}
	new string[2500];
	format(string,2500,"lsgyvenimas.lt/scripts/passreminder.php?msg=%s&receiver=%s",text,email);//Format request URL to PHP file we made before
	new query[300];
	format(query,sizeof(query),"INSERT INTO `RemindPassword`(`Vardas`,`Kodas`,`Data`,`Ip`) VALUES('%s','%s',NOW(),'%s')",ReturnName(playerid),slaptas,ip);
	mysql_query(query);
	//As you can see url contains code which is used later in PHP file we made
	
	HTTP(playerid, HTTP_GET,string, " ", "EmailDelivered");//Sends a request to test.php file
	format(string,sizeof(string),"%s|%s", email, text);
	AddToTaskQueue(playerid, TaskType:SEND_EMAIL_REMINDER, string);
	new eta=-1;
	for(new i=1;i<60;i++)
	{
		if(eta == -1)
		{
			if(email[i]=='@')
				eta=i;
			else if(email[i+1] != '@')
			{
				email[i]='*';
			}
		}
		else break;
		
	}
	new msg[127];
	format(msg,sizeof(msg)," * Laiskas siunciamas adresu %s ....",email);
	SendClientMessage(playerid,COLOR,msg);
}
forward EmailIgnore(index, response_code, data[]);
public EmailIgnore(index, response_code, data[])
{
	printf("Response %i %s",response_code,data);
	return 1;
}
forward EmailDelivered(index, response_code, data[]); //forward response callback, so pawno doesnt say there is some undefinded symbol

public EmailDelivered(index, response_code, data[])//data[] Will contain "Email delivered" see in PHP file
{
    if(response_code == 200)
    {
        SendClientMessage(index, COLOR, " * Prasymas pakeisti slaptazodi issiustas. Butinai patikrinkite ir Spam kataloga.");
		//KickEx(index,300);
    }
    else
    {
		if(!IsPlayerConnected(index)) return 1;
		new buffer[128];
        format(buffer, sizeof(buffer), "Điuo metu negalime priminti tau slaptaţodţio, Klaida: %i", response_code);//Else will print error code, see reference
        SendClientMessage(index, COLOR, buffer);
		printf(buffer);
		new query[300];
		format(query,sizeof(query),"DELETE FROM `RemindPassword` WHERE `Vardas`='%s'",ReturnName(index));
		mysql_query(query);
		KickEx(index,300);
    }
    return 1;
}

public OnPlayerClickTextDraw(playerid, Text:clickedid)
{
	if(DEBUG==true) printf("OnPlayerClickTextDraw:%i",playerid);
	if(OnClickLoto(playerid,PlayerText:clickedid))
		return 1;
	//SendClientMessageToAll(-1,"OnPlayerClickPokerfail");
	// Handle: They cancelled (with ESC)
	//printf("%i",Text:clickedid);
	new id=-1,pid=-1;
	for(new i;i<MAX_POKER_GAMES;i++)
	{
		for(new x;x<6;x++)
		{
			if(Poker[i][players][x]==playerid)
			{
				id=i;
				pid=x;
				break;
			}
			if(Poker[i][watching] == playerid)
			{
				id=i;
			}
		}
	}
	if(TradingWith[playerid] != -1)
	{

		if(clickedid == Text:INVALID_TEXT_DRAW) 
		{
		
			if(GetPVarInt(playerid,"MainaiIvyko")) return SetPVarInt(playerid,"MainaiIvyko",0);
			SendInfoMessage(playerid,"Atsaukete!");
			DestroySelectionMenu(playerid);
			if(IsPlayerConnected(TradingWith[playerid]) && TradingWith[TradingWith[playerid]]==playerid)
			{
				DestroySelectionMenu(TradingWith[playerid]);
				CancelSelectTextDraw(TradingWith[playerid]);
				SendInfoMessage(TradingWith[playerid],"Nesutinka!");
				PlayerTextDrawColor(playerid, MainuTD[6][playerid], 0xACCBF1FF);
				PlayerTextDrawShow(playerid, MainuTD[6][playerid]);
			}
			Sutinka{playerid}=false;
			Sutinka{TradingWith[playerid]}=false;
			TradingWith[playerid]=-1;
			PlayerPlaySound(playerid, 1085, 0.0, 0.0, 0.0);
			return 1;
		}

	}
	else
	{
		if(clickedid == PassReminder)
		{
			PlayerPlaySound(playerid, 1085, 0.0, 0.0, 0.0);
			new query[256];
			format(query,sizeof(query),"SELECT Email From Pastas Where Vardas='%s'",ReturnName(playerid));
			//SendClientMessage(playerid,COLOR,"Click");
			mysql_function_query(SQL, query, true, "SQL_PastasCheck", "i", playerid);
			return 1;
		}
		if(clickedid == Text:INVALID_TEXT_DRAW && playerDB[playerid][playingpoker]) 
		{
			if(id != -1)
			{
				if(pid != -1)
					LeaveGame(playerid,id,pid,1);
				else
				{
					Poker[id][watching]=-1;
					playerDB[playerid][playingpoker] = 0;
					for(new i;i<5;i++)
					{
						TextDrawHideForPlayer(playerid,Poker[id][TableKorta][i]);
						//TextDrawDestroy(TableKorta[i]);
					}
					//TextDrawDestroy(JusuKortos);
					TextDrawHideForPlayer(playerid,Poker[id][BankTD]);
					TextDrawHideForPlayer(playerid,Poker[id][JusuEile]);
					for(new y;y<6;y++)
					{
						TextDrawHideForPlayer(playerid,Poker[id][PokerAction][y]);
						TextDrawHideForPlayer(playerid,Poker[id][PokerMoney][y]);
						TextDrawHideForPlayer(playerid,Poker[id][PokerName][y]);
						for(new z;z<2;z++)
						{
							PlayerTextDrawHide(playerid,Korta[playerid][y][z]);
							PlayerTextDrawDestroy(playerid,Korta[playerid][y][z]);
						}
					}
					for(new z;z<5;z++)
					{
						PlayerTextDrawHide(playerid,Mygtukas[z][playerid]);
						PlayerTextDrawDestroy(playerid,Mygtukas[z][playerid]);
					}
				
				}
			}
			else
			{
				for(new x;x<MAX_POKER_GAMES;x++)
				{
					if(PokerQue[x][0] == playerid)
					{
						ClearAnimations(playerid);
						SetCameraBehindPlayer(playerid);
						if(FPS[playerid])  AttachCameraToObject(playerid, FirstPersonObject[playerid]);
						PokerQue[x][0]=0;
						PokerQueUsed[x][0]=0;
						playerDB[playerid][playingpoker]=0;
					}
				}
			}
			//if(GetPVarInt(playerid,"MainaiIvyko")) return SetPVarInt(playerid,"MainaiIvyko",0);
			//SendClientMessageToAll(-1,"OnPlayerClickPokerfail2");
		}
	}
	return 0;
}
