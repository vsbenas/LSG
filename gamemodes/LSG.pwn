stock StopAudioStreamForPlayerEx(playerid)
{
	SetPVarInt(playerid, "KlausosiRadijos", 0);
	if(NuclearBlast[NukeInProgress] != 1)
	{
		return StopAudioStreamForPlayer(playerid);
	}
	return 1;
}
stock PlayAudioStreamForPlayerEx(playerid, url[], Float:posX = 0.0, Float:posY = 0.0, Float:posZ = 0.0, Float:distance = 50.0, usepos = 0)
{
	SetPVarInt(playerid, "KlausosiRadijos", 1);
	if(NuclearBlast[NukeInProgress] != 1)
	{
		return PlayAudioStreamForPlayer(playerid, url, posX, posY, posZ, distance, usepos);
	}
	return 1;
}
#define StopAudioStreamForPlayer(%0) StopAudioStreamForPlayerEx(%0)
#define PlayAudioStreamForPlayer(%0) PlayAudioStreamForPlayerEx(%0)
IsAutohausCar(carid)
{
	new i;
	for(i=0; i<sizeof(aVehicleNames); i++)
	{
		if(aVehicleNames[i][Carid]==carid) { return i; }
	}
	return -1;
}

stock GetPlayerFromCarlistID(carid, &playerid)
{
	playerid=-1;
	foreach(Player, i)
	{
		playerid=i;
		if(Carlist[i][Carid]==carid) return 1;
		else if(Carlist2[i][Carid]==carid) return 2;
		else if(Carlist3[i][Carid]==carid) return 3;
	}
	playerid=-1;
	return 0;
}
GetPlayerFromCarlistCar(carid)
{
	new i;
	for(i=0; i<sizeof(Carlist); i++)
	{
		if(Carlist[i][Carid]==carid) { return i; }
	}

	return -1;
}
GetPlayerFromCarlistCar2(carid)
{
	new i;
	for(i=0; i<sizeof(Carlist2); i++)
	{
		if(Carlist2[i][Carid]==carid) { return i; }
	}
	return -1;
}
GetPlayerFromCarlistCar3(carid)
{
	new i;
	for(i=0; i<sizeof(Carlist3); i++)
	{
		if(Carlist3[i][Carid]==carid) { return i; }
	}
	return -1;
}
