IsInvalidSkin(skinid)
{
    switch(skinid)
    {
        case 0, 74: return 1;
        case -1: return 1;
        default: return 0;
    }
    return 0;
}

stock DeletePlayerWeapon(playerid, weaponid)
{
    new slot = GetWeaponsSlot(weaponid);

    UpdateGunData(playerid);

	if(GunData[playerid][slot][0] == weaponid)
	{
		GunData[playerid][slot][0] = 0;
		GunData[playerid][slot][1] = 0;
	}
	ResetPlayerWeapons(playerid);
	if(UpdateWeaponsTimer[playerid] == -1) // if we dont have a timer add it
	{
		UpdateWeaponsTimer[playerid] = SetTimerEx("UpdateWeapons", 200+GetPlayerPing(playerid), false, "ii", playerid,weaponid);
	}
    return 1;
}
stock DeletePlayerWeaponsForJob(playerid)
{

	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER)
		UpdateGunData(playerid);

    for(new i; i != 13; ++i)
    {
        switch(GunData[playerid][i][0])
        {
			case 0,3,16,17,23,26,27,31,34,37,39: 
			{
				if(GunData[playerid][i][1] == -100 || GunData[playerid][i][0] == 3 || GunData[playerid][i][0] == 39) // only infinite weapons, police baton and satchel charges
				{
					GunData[playerid][i][0]=0;
					GunData[playerid][i][1]=0;
				}
			}
			//default: { GivePlayerWeaponEx(playerid, gWeaponData[i][0], gWeaponData[i][1]); }
        }
    }

	if(UpdateWeaponsTimer[playerid] == -1) // if we dont have a timer add it
	{
		ResetPlayerWeapons(playerid);
		UpdateWeaponsTimer[playerid] = SetTimerEx("UpdateWeapons", 200+GetPlayerPing(playerid), false, "ii", playerid,-1);
	}
	if(IsPlayerAttachedObjectSlotUsed(playerid,TAZER_SLOT))
	{
		RemovePlayerAttachedObject(playerid, TAZER_SLOT);
	}
	new Float: AP;
	GetPlayerArmour(playerid, AP);
	if(AP > 100.0) 
	{
		SetPlayerArmour(playerid, 100.0);
	}
    return 1;
}

public SplitRBSprinkle(lightobject, playerid)
{
	new Float:xla, Float:yla, Float:zla;
	GetDynamicObjectPos(RocketBoxSprinkle[RocketBoxTime[playerid]][playerid], xla, yla, zla);
	CreateExplosion(xla, yla, zla, 2, 0);
	DestroyDynamicObject(RocketBoxSprinkle[RocketBoxTime[playerid]][playerid]);
	RBLight[1][playerid] = CreateDynamicObject(lightobject, xla, yla, zla, 0, 0, 0);
	MoveDynamicObject(RBLight[1][playerid], (xla-(0+(random(8)))), (yla-(0+(random(8)))), (zla-25), (2+(random(4))));
	RBLight[2][playerid] = CreateDynamicObject(lightobject, xla, yla, zla, 0, 0, 0);
	MoveDynamicObject(RBLight[2][playerid], (xla+(0+(random(8)))), (yla+(0+(random(8)))), (zla-25), (2+(random(4))));
	RBLight[3][playerid] = CreateDynamicObject(lightobject, xla, yla, zla, 0, 0, 0);
	MoveDynamicObject(RBLight[3][playerid], (xla-(0+(random(8)))), (yla+(0+(random(8)))), (zla-25), (2+(random(4))));
	RBLight[4][playerid] = CreateDynamicObject(lightobject, xla, yla, zla, 0, 0, 0);
	MoveDynamicObject(RBLight[4][playerid], (xla+(0+(random(8)))), (yla-(0+(random(8)))), (zla-25), (2+(random(4))));
	SetTimerEx("DestroyRBLight", 2600, 0, "i", playerid);
	UpdateStreamerFW(xla,yla,zla);
	return 1;
}

public DestroyRBLight(playerid)
{
	DestroyDynamicObject(RBLight[1][playerid]);
	DestroyDynamicObject(RBLight[2][playerid]);
	DestroyDynamicObject(RBLight[3][playerid]);
	DestroyDynamicObject(RBLight[4][playerid]);
	RocketBoxTime[playerid] = RocketBoxTime[playerid]+1;
	RocketBoxTimer(playerid);
	return 1;
}

public RocketBoxTimer(playerid)
{
	if(RocketBoxTime[playerid] == 11)
	{
	    RocketBoxTime[playerid] = 0;
	    DestroyDynamicObject(RocketBox[playerid]);
	    DestroyDynamicObject(RocketBoxSmoke[playerid]);
	    UpdateStreamerFW(RBX[playerid], RBY[playerid], RBZ[playerid]);
	    return 1;
	}
	if(RocketBoxTime[playerid] >= 1)
	{
	    new LightObject;
	    switch(random(2))
		{
			case 0:
			{
				LightObject = 354;
			}
			case 1:
			{
				LightObject = 1213;
			}
		}
	    RocketBoxSprinkle[RocketBoxTime[playerid]][playerid] = CreateDynamicObject(LightObject, RBX[playerid], RBY[playerid], RBZ[playerid], 0, 0, 0);
		MoveDynamicObject(RocketBoxSprinkle[RocketBoxTime[playerid]][playerid], RBX[playerid], RBY[playerid], (RBZ[playerid]+35), 20);
		SetTimerEx("SplitRBSprinkle", 1500, 0, "ii",LightObject, playerid);
		UpdateStreamerFW(RBX[playerid], RBY[playerid], RBZ[playerid]);
		return 1;
	}
	return 1;
}

public Destroy1Sprinkle(playerid)
{
	if(DestroySprinkleID[playerid] >= 50)
	{
	    new x;
	    for (x=0;x<Sprinkleid;x++)
		{
			DestroyDynamicObject(FountainSprinkle[x][playerid]);
		}
		UpdateStreamerFW(FTX[playerid], FTY[playerid], FTZ[playerid]);
	    return 1;
	}
	if(DestroySprinkleID[playerid] >= 0)
	{
		DestroyDynamicObject(FountainSprinkle[DestroySprinkleID[playerid]][playerid]);
		DestroySprinkleID[playerid] = DestroySprinkleID[playerid]+1;
		UpdateStreamerFW(FTX[playerid], FTY[playerid], FTZ[playerid]);
		return 1;
	}
	return 1;
}

