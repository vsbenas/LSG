			{
				DestroyDynamic3DTextLabel(MiniDarbai[gTrailer]),MiniDarbai[gTrailer]=Text3D:-1;
			}
			foreach(Player,i)
			{
				if(PlayerCar[i]==gTrailer)
				{
					DestroyOldCar(i); 
					x=1;
					break;
				}
			}
			if(!x)
			{
				SetVehicleToRespawn(gTrailer);
			}
			if(gTrailer == LastNutempta[playerid]) return 1;

			GivePlayerMoneyA(playerid,MONEYP_MECHANIKAI);
			Pelnas(playerid,5,MONEYP_MECHANIKAI*3);
			LastNutempta[playerid]=gTrailer;
			
			vehicleDB[gTrailer][lastpos][0]=0;
			vehicleDB[gTrailer][lastpos][1]=0;
			vehicleDB[gTrailer][lastpos][2]=0;
