new Float:CPpos[MAX_PLAYERS][4];
stock SetPlayerCheckpointEx(playerid, Float:xx, Float:yy, Float:zz, Float:size) 
{
	new ret = SetPlayerCheckpoint(playerid, xx,yy,zz,size);
	CPpos[playerid][0]=xx;
	CPpos[playerid][1]=yy;
	CPpos[playerid][2]=zz;
	CPpos[playerid][3]=size;
	return ret;
}
#define SetPlayerCheckpoint SetPlayerCheckpointEx
stock SetPlayerArmourEx(playerid,Float:acamount) // for anticheat
{
	HealthAC[playerid][a_tick]=GetTickCount();
	HealthAC[playerid][set_armour]=acamount;

	return SetPlayerArmour(playerid,acamount);
}
stock SetPlayerHealthEx(playerid,Float:acamount)
{
	HealthAC[playerid][a_tick]=GetTickCount();
	HealthAC[playerid][set_health]=acamount;

	return SetPlayerHealth(playerid,acamount);
}


stock ac_InPayNSpray(playerid)
{
	for(new ac_i = sizeof(ac_PayNSpray) - 1; ac_i != -1; --ac_i)
	{
		if(IsPlayerInRangeOfPoint(playerid, 7.5, ac_PayNSpray[ac_i][0], ac_PayNSpray[ac_i][1], ac_PayNSpray[ac_i][2])) return 1;
	}
	return 0;
}
stock ac_NearVendingMachine(playerid, interiorid)
{
	new ac_i, ac_s;
	switch(interiorid)
	{
		case 0: ac_i = 44, ac_s = -1;
		case 1: ac_i = 51, ac_s = 44;
		case 2: ac_i = 52, ac_s = 51;
		case 3: ac_i = 58, ac_s = 52;
		case 6: ac_i = 60, ac_s = 58;
		case 7: ac_i = 61, ac_s = 60;
		case 15: ac_i = 62, ac_s = 61;
		case 16: ac_i = 65, ac_s = 62;
		case 17: ac_i = 72, ac_s = 65;
		case 18: ac_i = 74, ac_s = 72;
		default: return 0;
	}
	for(; ac_i != ac_s; --ac_i)
	{
		if(IsPlayerInRangeOfPoint(playerid, 4.0, ac_vMachines[ac_i][0], ac_vMachines[ac_i][1], ac_vMachines[ac_i][2])) return 1;
	}
	return 0;
}
