new PassWarnings[ MAX_PLAYERS ] = { 0, ... };

public OnRconLoginAttempt(ip[], password[], success)
{
	if(!success) //If the password was incorrect
	{
		new pip[16];
		foreach (Player, i)
		{
			GetPlayerIp(i, pip, sizeof(pip));
			if(0==strcmp(ip, pip, true)) //If a player's IP is the IP that failed the login
			{
				SendClientMessage(i, 0xFFFFFFFF, "Blogas SLAPTAZODIS! Nenorek BAN!"); //Send a message
				++PassWarnings[ i ];
				if( PassWarnings[ i ] == 3 )
				{
					PassWarnings[ i ] = 0;
					Kick(i);
				}
			}
		}
	}
	return 1;
}

public Unfi(i,id)
{
	fi[i][id] = false;
	return 1;
}
public CheckS(playerid)
{
	if(!IsPlayerConnected(playerid) || !aktivuotas[playerid])
		return 1;
	new anim = GetPlayerAnimationIndex(playerid);
	if(anim != 1153 || IsPlayerAfk(playerid))
	{
		SendInfoMessage(playerid,"Isjungei matuokli");
		aktivuotas[playerid]=false;
		ApplyAnimation(playerid, "CARRY", "crry_prtial", 1.0, 0, 0, 0, 0, 0);
		return 1;
	}
	new id = GetClosestPlayer(playerid,25.0),estr[128];
	if(id == INVALID_PLAYER_ID || !IsPlayerConnected(id))
	{
		return SetTimerEx("CheckS",333,0,"i",playerid);
	}
	if(fi[playerid][id] || GetPlayerState(id) != 2) 
	{
		return SetTimerEx("CheckS",333,0,"i",playerid);
	}
	new speedas = GetSpeed(id);
	fi[playerid][id] = true;
	SetTimerEx("Unfi",7*700,0,"ii",playerid,id);
	if(speedas > 100)
	{
		format(estr,128,"%s pravaziavo ~r~%d KM/H~w~ greiciu.",ReturnName(id),speedas);
	}
	else
		format(estr,128,"%s pravaziavo ~g~%d KM/H~w~ greiciu.",ReturnName(id),speedas);
	SendInfoMessage(playerid,estr);
	if(speedas > 100 && !IsPoliceCar(GetPlayerVehicleID(id)))
	{
		format(estr,128,"~r~Jus virsijote greiti!~n~~w~Leistinas greitis 100 KM/H o jusu buvo %d KM/H.",speedas);
		if(GetPlayerWantedLevel(id)+1 < 10) 
			SetPlayerWantedLevel(id,GetPlayerWantedLevel(id)+1);
		else 
			SetPlayerWantedLevel(id,10);
		SendInfoMessage(id,estr);
	}
	SetTimerEx("CheckS",333,0,"i",playerid);
	return 1;
}
stock IsPoliceCar(vehicleid)
{
	if(IsKobraCheetah(vehicleid)) return 1;
	switch(GetVehicleModel(vehicleid))
	{
		case 523,430,497,596,597,599,601,427,490,447,470,433,528: return 1; // policijos
		case 481,509,510: return 1;// baikai
		case 593,592,577,563,553,548,520,519,513,512,511,
        488,487,476,469,460,425,417,493,484,453: return 1; // skraidantys
		case 537,538: return 1;//traukiniai
		case 407,416,489,544: return 1; //  gaisrine,medikai

		default: return 0;
	}
	return 0;
}
//Float:GetPos(playerid,posid) { new Float:id[3]; if(IsPlayerInAnyVehicle(playerid)) GetVehiclePos(GetPlayerVehicleID(playerid),id[0],id[1],id[2]); else GetPlayerPos(playerid,id[0],id[1],id[2]); return id[posid-1]; }

stock GetSpeed(playerid)
{
	static 	
		Float:x,
		Float:y,
		Float:z;
	GetVehicleVelocity(GetPlayerVehicleID(playerid),x,y,z);
	return floatround(floatsqroot(x*x + y*y + z*z) * 161.48);
}
stock GetPlayerSpeed(playerid)
{
	static 	
		Float:x,
		Float:y,
		Float:z;
	GetPlayerVelocity(playerid,x,y,z);
	return floatround(floatsqroot(x*x + y*y + z*z) * 161.48);
}

#define GetSpeedExDefn(%0,%1); \
{ \
	new Float:velX,Float:velY,Float:velZ; \
	GetVehicleVelocity(%0, velX, velY, velZ); \
	%1 = floatround(floatsqroot(velX*velX + velY*velY + velZ*velZ) * 161.48); \
}


stock GetSpeedEx(vehicleid)
{
	new speed;
	GetSpeedExDefn(vehicleid,speed);
	return speed;
}
stock GetClosestPlayer(except,Float:radius = 99999.9999)
{
	new Float:dis[2],e[2];
	e[0] = INVALID_PLAYER_ID;
	dis[0] = radius;
	
	new Float:coo[6];
	GetPlayerPos(except,coo[0],coo[1],coo[2]);
	for (e[1]=0;e[1]<MAX_PLAYERS;e[1]++)	if(IsPlayerConnected(e[1]) && e[1] != except && !fi[except][e[1]])
	{
		GetPlayerPos(e[1],coo[3],coo[4],coo[5]);
		dis[1] = floatround(floatsqroot((coo[0]-coo[3])*(coo[0]-coo[3])+(coo[1]-coo[4])*(coo[1]-coo[4])+(coo[2]-coo[5])*(coo[2]-coo[5])));
		if(dis[1]< dis[0])
		{
			dis[0] = dis[1];
			e[0] = e[1];
		}
	}
	return e[0];
}

