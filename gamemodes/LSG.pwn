			new v = GetClosestVehicleid(playerid, 10.0,vehicleid);
			if(v != INVALID_VEHICLE_ID)
			{
				modelis=GetVehicleModel(v);
				if(modelis==610)
				{
					AttachTrailerToVehicle(v,vehicleid);
					if(!SlavejoCP[playerid]) 
					{
						SendInfoMessage(playerid,"~y~Puiku! Dabar vaziuokite i laukus!");
						//SlavejoCP[playerid]=0;
						SetPlayerCheckpoint(playerid,Traktoristu_CP[SlavejoCP[playerid]][0],Traktoristu_CP[SlavejoCP[playerid]][1],Traktoristu_CP[SlavejoCP[playerid]][2],5.0);
					}
					return 1;
				}
			
			}
			return 1;
		}	
		else if(modelis == 531 && IsTrailerAttachedToVehicle(vehicleid))
		{
			if(!SlavejoCP[playerid]) 
			{
				SendInfoMessage(playerid,"~y~Puiku! Dabar vaziuokite i laukus!");
				//SlavejoCP[playerid]=0;
				SetPlayerCheckpoint(playerid,Traktoristu_CP[SlavejoCP[playerid]][0],Traktoristu_CP[SlavejoCP[playerid]][1],Traktoristu_CP[SlavejoCP[playerid]][2],5.0);
			}
		}
		if(modelis == TOWTRUCK)
		{
			if(GetVehicleTrailer(GetPlayerVehicleID(playerid)) != 0) return 1;
			new v = GetClosestVehicleid(playerid, 10.0,vehicleid);
			if(v == INVALID_VEHICLE_ID)
				return SendInfoMessage(playerid,"~r~Tu per toli nuo automobilio!");
			new id;
			if(0 < v < 2000)
				id = GetPlayeridMid(vehicleDB[v][lastuser]);

			if(	!IsVagiuCar(v) && !IsVairavimoMokyklosCar(v) && !IsNuomosCar(v))
			{
				if(id != INVALID_PLAYER_ID && IsPlayerConnected(id) && (IsPlayerAfk(id))) 
				{
					new Float:Pos[3];
					GetPlayerPos(id,Pos[0],Pos[1],Pos[2]);
					if(IsPlayerInRangeOfPointEx(200.0, playerid, Pos[0], Pos[1], Pos[2]))
						return SendInfoMessage(playerid,"~r~Negali imti sio automobilio nes zaidejas afk!");
				}
				//if(InParking(v)) return SendInfoMessage(playerid,"~r~Negali imti automobilio is parkingo!");
				if(id == playerid) return SendInfoMessage(playerid,"~r~Negali imti savo automobilio!");
				if(GetPlayerFromCarlistCar(v)==-1 && GetPlayerFromCarlistCar2(v)==-1 && GetPlayerFromCarlistCar3(v)==-1 && vehicleid != v  && !JobCars[v][0] && IsAutohausCar(v) == -1) // && vehicleDB[v][lastpos][0]!=0.0
				{
					if(id != INVALID_PLAYER_ID ) // && playerDB[id][masina] == v
					{
						new tdelta = GetTickCount() - LeftCar[id];
						if(tdelta < 120*1000)
						{
							new laukti = 120*1000 - tdelta;
							new msgas[128];
							format(msgas,sizeof(msgas),"Sio automobilio negali tempti, nes jo vairuotojas neseniai ji paliko. Palauk %i sec.",floatround(laukti/1000));
							return SendInfoMessage(playerid,msgas);
						
						}
					}
					AttachTrailerToVehicle(v,GetPlayerVehicleID(playerid));
					SetPlayerCheckpoint(playerid,1523.8451,-1493.8091,13.5620,4.0);
					return 1;
				}
				else
					return SendInfoMessage(playerid,"~r~Sio automobilio imti negali!");
			}
			else
				return SendInfoMessage(playerid,"~r~Sio automobilio imti negali!!");
		}

		return 1;

	}
	
	
