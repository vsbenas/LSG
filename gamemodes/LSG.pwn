stock Minavimas(playerid) 
{
	if(playerDB[playerid][minuoja] >= 10000)
			{
				new vieta[40];
				new placeas=0;
				for(new i;i< sizeof(DRILL_CP);i++)
				{
					if (IsPlayerInRangeOfPointEx( 5.0,playerid, DRILL_CP[i][0],DRILL_CP[i][1],DRILL_CP[i][2] ))
					{
						placeas=i;
					}
				}
				switch(placeas)
				{
					case 0: vieta = "Sandelyje prie HP";
					case 1: vieta = "Savivaldybeje";
					case 2: vieta = "Pagr. banke";
				}
				playerDB[playerid][minuoja]++;
				if(playerDB[playerid][minuoja] == 10031)
				{
					SendInfoMessage(playerid,"Atjungei grazta!");
					HideProgressBarForPlayer(playerid,Veiksmai);
					EndVeiksmas(playerid);
					ClearAnimations(playerid);
					playerDB[playerid][minuoja]=0;
					new msg[128];
					format(msg,sizeof(msg),"[racija] Operatore: Pastatas buvo apgintas! Sveikiname %s isjungus grazta!",ReturnName(playerid));
					SecEntrances[placeas][s_boom]=1;
					for(new i;i<3;i++)
					{
						DestroyObject(drillobj[placeas][i]);
					}
					Delete3DTextLabel(BombikeTimer[placeas]);
					BombikeTimer[placeas]=Text3D:INVALID_3DTEXT_ID;
					drilltimer[placeas]=0;
					playerDB[playerid][jobpts]++;
					SendMessageToTeisesauga(YELLOW,msg);
				}
				else
				{
					if(IsPlayerInDynamicCP(playerid,drillid[placeas]))
					{
						SetProgressBarMaxValue(Veiksmai, 30);
						SetProgressBarValue(Veiksmai,playerDB[playerid][minuoja]-10000);
						ShowProgressBarForPlayer(playerid, Veiksmai);
						
						ClearAnimations(playerid);
						ApplyAnimation(playerid, "BOMBER", "BOM_Plant_Loop", 4.0, 1, 0, 0, 1, 0,0); //Sedeti
					}
					else
					{
						SendInfoMessage(playerid,"~r~Nuejai per toli nuo grazto!");
						HideProgressBarForPlayer(playerid,Veiksmai);
						EndVeiksmas(playerid);
						playerDB[playerid][minuoja]=0;
					}
				}
			}
			else
			{
				playerDB[playerid][minuoja]+= (10+random(11));
				SetProgressBarMaxValue(Veiksmai, 1000);
				SetProgressBarValue(Veiksmai,playerDB[playerid][minuoja]);
				ShowProgressBarForPlayer(playerid, Veiksmai);
				new placeas=-1;
				for(new i;i< sizeof(SecEntrances);i++)
				{
					if (IsPlayerInRangeOfPointEx( 5.0,playerid, SecEntrances[ i ][ se_x ], SecEntrances[ i ][ se_y ], SecEntrances[ i ][ se_z ] ))
					{
						placeas=i;
					}
				}
				if(placeas == -1)
				{
					SendInfoMessage(playerid,"Nuejai per toli nuo bombos!");
					HideProgressBarForPlayer(playerid,Veiksmai);
					EndVeiksmas(playerid);
					playerDB[playerid][minuoja]=0;
					//TogglePlayerControllable(playerid,true);
					ClearAnimations(playerid);
					return;
				}
				if(random(400+playerDB[playerid][jobpts])== 20)
				{
					new vieta[40];

					switch(placeas)
					{
						case 0: vieta = "Sandelyje prie HP";
						case 1: vieta = "Savivaldybeje";
						case 2: vieta = "Pagr. banke";
					}
					KillBomb(vieta,placeas);
					SendInfoMessage(playerid,"~r~Nukirpai ne ta laida!");
					HideProgressBarForPlayer(playerid,Veiksmai);
					EndVeiksmas(playerid);
					playerDB[playerid][minuoja]=0;
					//TogglePlayerControllable(playerid,true);
					ClearAnimations(playerid);
					SetPlayerHealth(playerid,0.0);
				}
				else if(playerDB[playerid][minuoja] >= 1000)
				{
					playerDB[playerid][minuoja]=0;
					HideProgressBarForPlayer(playerid,Veiksmai);
					EndVeiksmas(playerid);
					TogglePlayerControllable(playerid,true);
					ClearAnimations(playerid);
					SendInfoMessage(playerid,"~g~Isminavai!");
					new msg[128];
					format(msg,sizeof(msg),"[racija] Operatore: Pastatas buvo apgintas! Sveikiname %s isminavus bomba!",ReturnName(playerid));
					DestroyObject(Bombike[placeas]);
					Bombike[placeas]=-1;
					Delete3DTextLabel(BombikeTimer[placeas]);
					BombikeTimer[placeas]=Text3D:INVALID_3DTEXT_ID;
					playerDB[playerid][jobpts]++;
					SendMessageToTeisesauga(YELLOW,msg);
				}
			}

}
stock Pjovimas(playerid) 
{
	playerDB[playerid][pjauna]++;
	SetProgressBarMaxValue(Veiksmai, 20);
	SetProgressBarValue(Veiksmai,playerDB[playerid][pjauna]);
	ShowProgressBarForPlayer(playerid, Veiksmai);
	
	if(playerDB[playerid][pjauna]==20)
	{
		playerDB[playerid][pjauna]=0;
		HideProgressBarForPlayer(playerid,Veiksmai);
		EndVeiksmas(playerid);
		SendInfoMessage(playerid,"~g~Antrankiai nupjauti!");
		new tick = GetTickCount();
		if(tick - LastPjovimas[playerid] > 1000*60*15) {
			playerDB[playerid][jobpts]++;
			GivePlayerMoneyA(playerid,MONEYP_BAIKERIAI);
			Pelnas(playerid,97,(MONEYP_BAIKERIAI*2)); 
			SendClientMessage(playerid, WHITE, " * Uz nupjautus antrankius gavai 1000€ i rankas ir 2000€ i pelna!");
		}
		LastPjovimas[playerid]=tick;
		
		new atrakinam=-1;
		new vehicleid=GetPlayerVehicleID(playerid);
		foreach(Player,i) if(i!=playerid)
		{
			if(IsPlayerInVehicle(i,vehicleid))
			{
				atrakinam=i;
			}
		}
		if(atrakinam==-1) return;
		playerDB[atrakinam][ant]=false;
		TogglePlayerControllable(atrakinam,true);
		RemovePlayerAttachedObject(atrakinam,CUFF_SLOT);
		SetPlayerSpecialAction(atrakinam, SPECIAL_ACTION_NONE);
		SendInfoMessage(atrakinam,"~g~Antrankiai nupjauti!");
	}
}
stock CalculateBaimesFaktorius(playerid) 
{
	// from 100 to 300
	new bikersInRange = 0;
	new beSalmu = 0;
	new suristu = 0;
	new Float:Coo[3];
	GetPlayerPos(playerid, Coo[0],Coo[1],Coo[2]);
	foreach(Player, i)
	{
		if(IsPlayerInRangeOfPointEx(150.0, i, Coo[0],Coo[1],Coo[2]))
		{
			if(playerDB[i][specialybe]==71 && GetVehicleModel(GetPlayerVehicleID(i)) == 463 && bikersInRange < 5) // can be passenger too
			{
				bikersInRange++;
				if(!IsPlayerAttachedObjectSlotUsed(i,SALMO_SLOT))
				{
					beSalmu++;
				}
			}
			if(playerDB[i][specialybe] != 71 && playerDB[i][suristas] && suristu < 5)
			{
				suristu ++;
			}
		}
	}
	if(bikersInRange < 1)
		bikersInRange=1;
	// bikersInRange 1-5, suristu 0-5, beSalmu 0-5
	new koef = 100 + ((bikersInRange - 1) * 20) + (suristu * 20) + (beSalmu * 20);
	if(koef > 300)
		koef = 300;
	return koef;
}
stock ShowBaimesFaktorius(playerid, percent) 
{
	new msg[256];
	format(msg,256, "Baimes faktorius: ~r~%i%%",percent);
	SendInfoMessage(playerid, msg);
}
stock Montavimas(playerid)
{
	playerDB[playerid][montuoja]++;
	new placeas=-1;
	for(new i;i< sizeof(DRILL_CP);i++)
	{
		if (IsPlayerInRangeOfPointEx( 10.0,playerid, DRILL_CP[i][0], DRILL_CP[i][1], DRILL_CP[i][2]))
		{
			placeas=i;
		}
	}
	if(placeas == -1)
	{
		playerDB[playerid][montuoja]=0;
		ClearAnimations(playerid);
		HideProgressBarForPlayer(playerid,Veiksmai);
		EndVeiksmas(playerid);
		SendInfoMessage(playerid,"Nustojai montuoti grazta!");
		for(new i;i<sizeof(DRILL_CP);i++)
			drilltimer[i]=0;
	}
	if(playerDB[playerid][montuoja]==31)
	{
		playerDB[playerid][montuoja]=0;
		HideProgressBarForPlayer(playerid,Veiksmai);
		EndVeiksmas(playerid);
		ClearAnimations(playerid);
		drilltimer[placeas]=120;
		BombikeTimer[placeas] = Create3DTextLabel("120s",RED,DRILL_CP[placeas][0], DRILL_CP[placeas][1], DRILL_CP[placeas][2],40.0,0);
		drillobj[placeas][0]=CreateObject(18717, DRILL_CP[placeas][0], DRILL_CP[placeas][1], DRILL_CP[placeas][2]-2.2697,   0.00, 0.00, DRILL_CP[placeas][3]);
		drillobj[placeas][1]=CreateObject(951, DRILL_CP[placeas][0]+0.03, DRILL_CP[placeas][1]-0.17, DRILL_CP[placeas][2]-1.3697,   0.00, 0.00, DRILL_CP[placeas][3]+180.00);
		drillobj[placeas][2]=CreateObject(341, DRILL_CP[placeas][0]+0.04, DRILL_CP[placeas][1], DRILL_CP[placeas][2]-0.4797,   0.00, 30.00, DRILL_CP[placeas][3]+90.00);
		SendInfoMessage(playerid,"Padejai grazta!");
		SetTimerEx("DrillTimer",1000,false,"ii",120,placeas);
	}
	else
	{
		SetProgressBarMaxValue(Veiksmai, 30);
		SetProgressBarValue(Veiksmai,playerDB[playerid][montuoja]);
		ShowProgressBarForPlayer(playerid, Veiksmai);
		StartVeiksmas(playerid,"Montuoji grazta");
		ApplyAnimation(playerid, "BOMBER", "BOM_Plant_Loop", 4.0, 1, 0, 0, 1, 0,0); //Sedeti
		if(!IsPlayerInDynamicCP(playerid, drillid[placeas]))
		{
			playerDB[playerid][montuoja]=0;
			drilltimer[placeas]=0;
			ClearAnimations(playerid);
			HideProgressBarForPlayer(playerid,Veiksmai);
			EndVeiksmas(playerid);
			SendInfoMessage(playerid,"Nustojai montuoti grazta!");
		}
		
	}
}
