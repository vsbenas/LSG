				SetPlayerInterior(playerid,0);
				SendClientMessage(playerid, YELLOW," * Noredami baigti - spauskite [ENTER]");
				playerDB[playerid][specina]=true;
				SetPlayerPoz(playerid, 1535.5051,-1674.7971, -10.0, _, _, 0);
				return 1;
			}
			else if(IsPlayerInRangeOfPointEx(2.0, playerid, 1348.7961,521.3548,1067.7477)) // Banko kamera
			{
				GetPlayerPos(playerid,CameraCord[playerid][0],CameraCord[playerid][1],CameraCord[playerid][2]);
				TogglePlayerControllable(playerid,false);
				SetPlayerCameraPos(playerid,1468.7972,-1749.8865,30.0434);
				SetPlayerCameraLookAt(playerid, 1504.4750,-1733.9017,13.3828);
				SetPlayerInterior(playerid,0);
				playerDB[playerid][specina]=true;
				SetPlayerPoz(playerid, 1468.7972,-1749.8865, -10.0, _, _, 0);
				SendClientMessage(playerid, YELLOW," * Noredami baigti - spauskite [ENTER]");
				return 1;
			}
			/*
			new housenumber = GetHouseID(playerid);
			if(housenumber != -255) EnterNamas(playerid,housenumber);*/
			new vw = GetPlayerVirtualWorld(playerid);
			foreach (Houses, i)
			{
				if(IsPlayerInRangeOfPointEx(MAX_DISTANCE_TO_PROP, playerid, hInfo[i][iconx], hInfo[i][icony], hInfo[i][iconz]))
				{
					if(hInfo[i][daugiabutis] && vw != (MAX_HOUSES*2+MAX_BUSINESSES+hInfo[i][daugiabutis]-1)) continue;
					EnterNamas(playerid,i);
				}
				else if(hInfo[i][hKiemas] && IsPlayerInRangeOfPointEx(MAX_DISTANCE_TO_PROP, playerid, hInfo[i][kiemox], hInfo[i][kiemoy], hInfo[i][kiemoz]))
				{
					EnterNamas(playerid,i,1);
				}
			}
			
		}
		return 1;
	}

	return 1;
}

stock LockVehicle(playerid,vehicleid)
{
	if(Carlist[playerid][Carid]==vehicleid)
	{
		new Float:sx,Float:sy,Float:sz;
		GetVehiclePos(Carlist[playerid][Carid],sx,sy,sz);
		if(sy < -1483.6194 && sy > -1507.2380 && sx < 1546.4885 && sx > 1464.6373)
		{
			SendInfoMessage(playerid,"~y~Jus negalite atrakinti konfiskuotos masinos!");
		}
		else
		{
			if (Carlist[playerid][Lock]==0)
			{
				Carlist[playerid][Lock]=1;
				SetVehicleParamsForAll(Carlist[playerid][Carid],0,1);
				SetVehicleParamsForPlayerEx(Carlist[playerid][Carid],playerid,0,0);
				SendInfoMessage(playerid,"Jus ~r~uzrakinote~w~ savo masina.");
			}
			else
			{
				Carlist[playerid][Lock]=0;
				SetVehicleParamsForAll(Carlist[playerid][Carid],0,0);
				SendInfoMessage(playerid,"Jus ~g~atrakinote~w~ savo masina.");
			}
			return 1;
		}
	}
	else if(Carlist2[playerid][Carid]==vehicleid)
	{
		new Float:sx,Float:sy,Float:sz;
		GetVehiclePos(Carlist2[playerid][Carid],sx,sy,sz);
		if(sy < -1483.6194 && sy > -1507.2380 && sx < 1546.4885 && sx > 1464.6373)
		{
			SendInfoMessage(playerid,"~y~Jus negalite atrakinti konfiskuotos masinos!");
		}
		else
		{
			if (Carlist2[playerid][Lock]==0)
			{
				Carlist2[playerid][Lock]=1;
				SetVehicleParamsForAll(Carlist2[playerid][Carid],0,1);
				SetVehicleParamsForPlayerEx(Carlist2[playerid][Carid],playerid,0,0);
				SendInfoMessage(playerid,"Jus ~r~uzrakinote~w~ savo masina.");
			}
			else
			{
				Carlist2[playerid][Lock]=0;
				SetVehicleParamsForAll(Carlist2[playerid][Carid],0,0);
				SendInfoMessage(playerid,"Jus ~g~atrakinote~w~ savo masina.");
			}
			return 1;
		}
	}
	else if(Carlist3[playerid][Carid]==vehicleid)
	{
		new Float:sx,Float:sy,Float:sz;
		GetVehiclePos(Carlist3[playerid][Carid],sx,sy,sz);
		if(sy < -1483.6194 && sy > -1507.2380 && sx < 1546.4885 && sx > 1464.6373)
		{
			SendClientMessage(playerid, HOMER, "Jus negalite atrakinti konfiskuotos masinos!");
		}
		else
		{
			if (Carlist3[playerid][Lock]==0)
			{
				Carlist3[playerid][Lock]=1;
				SetVehicleParamsForAll(Carlist3[playerid][Carid],0,1);
				SetVehicleParamsForPlayerEx(Carlist3[playerid][Carid],playerid,0,0);
				SendInfoMessage(playerid,"Jus ~r~uzrakinote~w~ savo masina.");
			}
			else
			{
				Carlist3[playerid][Lock]=0;
				SetVehicleParamsForAll(Carlist3[playerid][Carid],0,0);
				SendInfoMessage(playerid,"Jus ~g~atrakinote~w~ savo masina.");
			}
			return 1;
		}
	}
	return 1;
}
stock GoToKiemas(playerid,houseid) 
{
	if(hInfo[houseid][hKiemas] == 0)
	{
		return SendInfoMessage(playerid," Sis namas neturi kiemo!");
	}

	CancelEdit(playerid);
	SetPlayerPosFade(playerid,20,hInfo[houseid][kiemox],hInfo[houseid][kiemoy],hInfo[houseid][kiemoz]+0.5,0,0);
	return 1;
}
stock LockHouseKiemas(playerid,housenumber)
{
	new pname[24];
