stock ShowMedikuCp(playerid)
{
	new car = playerDB[playerid][masina];
	if(IsPlayerInAnyVehicle(playerid))
		car = GetPlayerVehicleID(playerid);
	new model = GetVehicleModel(car);
	if(MedikuDB[med_carer] == playerid && MedikuDB[med_status] == 3)
	{
		if(model == 469 || model == 563) // heli
			SetPlayerCheckpoint(playerid, Hospitals[MedikuDB[med_hpid]][h_x], Hospitals[MedikuDB[med_hpid]][h_y], Hospitals[MedikuDB[med_hpid]][h_z], 10.0);
		else
			SetPlayerCheckpoint(playerid, Hospitals[MedikuDB[med_hpid]][v_x], Hospitals[MedikuDB[med_hpid]][v_y], Hospitals[MedikuDB[med_hpid]][v_z], 10.0);
	}
}


stock EndMedicMission()
{
	if(MedikuDB[med_pedid] != -1)
		DestroyActor(MedikuDB[med_pedid]);
	MedikuDB[med_pedid] = -1;
	MedikuDB[med_status]=0;
	MedikuDB[med_carer] = -1;
}

stock EndMedicMissionSuccess(playerid)
{
	new msg[256];
	format(msg,256, "[racija] Operatore: %s laiku atveţë pacientŕ á ligoninć ir iđgelbëjo jam gyvybć!", ReturnName(playerid));
	SendMessageToMedics(COLOR,msg);
	GivePlayerMoneyA(playerid, MONEYP_MEDIKAI);
	Pelnas(playerid,1,MONEYP_MEDIKAI * 4);
	MedikuDB[med_status]=0;
	MedikuDB[med_carer] = -1;
	HideProgressBarForPlayer(playerid, Veiksmai);
	EndVeiksmas(playerid);
}

forward MedikaiTime();
public MedikaiTime()
{
	new x=0,msg[128];
	foreach (Player, i)
	{
		if(playerDB[i][specialybe]==2 || playerDB[i][specialybe]==93) x++;
	}
	if(x==0) return 0;

	if(MedikuDB[med_status] == 1) // waiting
	{
		EndMedicMission();
		return 1;
	}
	else if(MedikuDB[med_status] == 2 || MedikuDB[med_status] == 3) // already in progress
	{
		return 1;
	}
	MedikuDB[med_status] = 1;
	new ped = random(sizeof(MedikaiPeds));
	new skin = random(312);
	if(skin == 74)
		skin = 1;
	new actor = CreateActor(skin, MedikaiPeds[ped][0], MedikaiPeds[ped][1], MedikaiPeds[ped][2], MedikaiPeds[ped][3]);
	if(actor == INVALID_ACTOR_ID)
		return 1;
	ApplyActorAnimation(actor, "CRACK", "crckdeth2", 4.0, 1, 1,1,1,0);
	MedikuDB[med_pedid] = actor;
	MedikuDB[med_pednr] = ped;
	kvieciamedikus=-100;
	GetActorPos(actor,kvieciamedikuscord[0],kvieciamedikuscord[1],kvieciamedikuscord[2]);
	format(msg,sizeof(msg),"[racija] Operatore: Smarkiai suţeistas pilietis %s! Rađykite /imti!",JB_gSAZones[Get2DZoneEx(kvieciamedikuscord[0],kvieciamedikuscord[1])][JB_SAZONE_NAME]);
	SendMessageToMedics(COLOR, msg);
	return 1;
}

stock StartMedikuMission(playerid)
{
	kvieciamedikus = -1;
	if(MedikuDB[med_status] != 1)
	{
		return SendInfoMessage(playerid,"Siuo metu iskvietimu nera.");
	}
	MedikuDB[med_status] = 2;
	MedikuDB[med_carer] = playerid;
	MedikuDB[med_bukle] = 1000;
	MedikuDB[med_hpid] = random(sizeof(Hospitals));
	SendInfoMessage(playerid,"Iskvietimas priimtas! Skubekite prie paciento ir spauskite [H]");
	new msg[256];
	SetPlayerCheckpoint(playerid,kvieciamedikuscord[0],kvieciamedikuscord[1],kvieciamedikuscord[2],20.0);
	format(msg,sizeof(msg),"[racija] Operatore: %s prieme iskvietima.",ReturnName(playerid));
	SendMessageToMedics(RED,msg);
	UpdateMedikaiMission(playerid);
	StartVeiksmas(playerid,"Paciento bukle");
	return 1;
}

stock UpdateMedikaiMission(playerid)
{
	if(MedikuDB[med_carer] != playerid)
		return;

	new ped = MedikuDB[med_pednr];
	SetActorPos(MedikuDB[med_pedid],  MedikaiPeds[ped][0], MedikaiPeds[ped][1], MedikaiPeds[ped][2]);
	if(MedikuDB[med_status] == 2)
	{
		if(!IsPlayerInAnyVehicle(playerid))
			MedikuDB[med_bukle] -= 10; // about 1.5 minutes
		else
			MedikuDB[med_bukle] -= 5; // about 3 minutes
	}
	if(MedikuDB[med_status] == 3)
	{
		new delta = 0;
		// hes in the car, adjust by speed
		if(IsPlayerInAnyVehicle(playerid))
		{
			new speed = GetSpeedEx(GetPlayerVehicleID(playerid));
			if (speed > 100)
			{
				if(MedikuDB[med_bukle] <= 450)
					delta = 5; // give him some health!
			}
			else if(speed < 60)
			{
				delta = -30;
			}
			else
			{
				delta = -20;
			}
		}
		else
		{
			delta = -40;
		}
		MedikuDB[med_bukle] += delta;
	}
	if(MedikuDB[med_bukle] > 1000)
		MedikuDB[med_bukle] = 1000;
	if(MedikuDB[med_bukle] <= 20)
	{
		SendMessageToMedics(COLOR,"[racija] Operatore: Pacientas numirë belaukdamas medikř pagalbos!");
		EndMedicMission();
		HideProgressBarForPlayer(playerid, Veiksmai);
		EndVeiksmas(playerid);
		return;
	}
	if(playerDB[playerid][action])
		return;
	SetProgressBarMaxValue(Veiksmai, 1000);
	SetProgressBarValue(Veiksmai,MedikuDB[med_bukle]);
	ShowProgressBarForPlayer(playerid, Veiksmai);
}
stock PickupMedikuPed(playerid)
{
	if(playerDB[playerid][specialybe] != 2 && playerDB[playerid][specialybe] != 93)
		return 0;
	if(MedikuDB[med_status] != 2)
		return 0;
	if(IsPlayerInAnyVehicle(playerid))
		return 0;

	new Float:Coo[3];
	GetActorPos(MedikuDB[med_pedid],Coo[0],Coo[1],Coo[2]);
	if(!IsPlayerInRangeOfPointEx(5.0, playerid, Coo[0],Coo[1],Coo[2]))
		return 0;

	new car = playerDB[playerid][masina];
	new Float:cpo[3];
	GetVehiclePos(car,cpo[0],cpo[1],cpo[2]);
	new model = GetVehicleModel(car);
	if(!IsPlayerInRangeOfPointEx(20.0,playerid,cpo[0],cpo[1],cpo[2]))
	{
		SendInfoMessage(playerid,"~r~Automobilis per toli");
		return 1;
	}
	if(model != 416 && model != 563 && model != 496 && model != 505 && model != 469)
	{
		SendInfoMessage(playerid,"~r~Netinkamas automobilis");
		return 1;
	}
	StartSomething(playerid,68,"Pirmoji pagalba.."); 
	OnePlayAnim(playerid,"MEDIC","CPR",4.0,0,0,0,0,0);
	return 1;
}

stock MedikaiPickedUp(playerid)
{
	if(MedikuDB[med_status]==0)
		return;
	MedikuDB[med_bukle] = floatround(MedikuDB[med_bukle] * 1.5 + 100);
	MedikuDB[med_status] = 3;
	if(MedikuDB[med_bukle] > 1000)
		MedikuDB[med_bukle] = 1000;

	new const operacijos[][] = {
		"Đirdies operacija",
		"Dirbtinë đirdis",
		"Izoliacija",
		"Kulkos pađalinimas",
		"Stuburo átvaras",
		"Kraujavimo sustabdymas",
		"Kraujo perpylimas",
		"Nuodř iđvalymas",
		"Gaivinimas elektrođoku",
		"Kepenř transplantacija",
		"Ađmenř iđtraukimas",
		"Ţaizdos uţsiuvimas",
		"Nudegimř gydymas",
		"Dirbtinis kvëpavimas",
		"Inkstř persodinimas"
	};
	new randop = random(sizeof(operacijos));
	new msg[256];
	if(randop <= 2)
	{
		format(msg,sizeof(msg)," * Piliečiui skubiai reikalinga {3275a8}%s{FFFFFF}! Skubëkite já nuveţti á {a8325b}%s{FFFFFF}!",operacijos[randop], Hospitals[MedikuDB[med_hpid]][v_pav]);
	}
	else
	{
		format(msg,sizeof(msg)," * Piliečiui skubiai reikalingas {3275a8}%s{FFFFFF}! Skubëkite já nuveţti á {a8325b}%s{FFFFFF}!",operacijos[randop], Hospitals[MedikuDB[med_hpid]][v_pav]);
	}
	SendClientMessage(playerid, -1, msg);
	ShowMedikuCp(playerid);
	DestroyActor(MedikuDB[med_pedid]);
	MedikuDB[med_pedid] = -1;

	StartVeiksmas(playerid,"Paciento bukle");
	SetProgressBarMaxValue(Veiksmai, 1000);
	SetProgressBarValue(Veiksmai,MedikuDB[med_bukle]);
	ShowProgressBarForPlayer(playerid, Veiksmai);
}

forward FireTime();
public FireTime()
{
	/*if(MiskoGaisrai[inProgress]) // if someone working on it then stop
	{
		new found = 0;
		foreach(Player, i) 
		{
			if(IsPlayerInRangeOfPointEx(100.0, i, MiskoGaisrai[fCenter][0],MiskoGaisrai[fCenter][1],MiskoGaisrai[fCenter][2])) 
			{
				if(GetVehicleModel(GetPlayerVehicleID(i))==563) // rainddance
				{
					if(CarLights[i]) // water on
					{
						return 1;
					}
				}
			}
		}
	}*/
	if(FireDB[inProgress])
	{
		FireDB[inProgress]=false;
		DestroyDynamicObject(FireDB[fObj]);
		if(kvieciagais == -100) kvieciagais=-1;
		//return 1;
	}
	new x=0,obja,msg[128];
	foreach (Player, i)
	{
		if(playerDB[i][specialybe]==66) x++;
	}
	if(x==0) return 0;
	x = random(4);
	
	if(x == 0)
	{
		new houseid = Iter_Random(Houses);
		while(hInfo[houseid][polyId] != -1 && houseid > 1)
		{
			houseid--;
		}
		if(strcmp(hInfo[houseid][Name],"Nera",true)!=0)
			x=random(2);
		if(x == 1)
		{
			FireDB[fCoo][0] = Gaisrai[ hInfo[houseid][vidus] ][ 0 ];
			FireDB[fCoo][1] = Gaisrai[ hInfo[houseid][vidus] ][ 1 ];
			FireDB[fCoo][2] = Gaisrai[ hInfo[houseid][vidus] ][ 2 ];
			FireDB[fVW] = houseid;
			FireDB[fInt] = Inter[ hInfo[houseid][vidus] ][ Int ];
			FireDB[fHealth] = 50;
			FireDB[fMaxHealth] = FireDB[fHealth];
			FireDB[fPlace] = 0;
			FireDB[fNumber] = houseid;
			obja=fire_med;
			format(msg,sizeof(msg),"[racija] Operatore: Gaisras namo Nr.%i viduje. Rasykite /imti!",houseid);
		}
		else 
		{
			FireDB[fCoo][0] = hInfo[houseid][iconx];
			FireDB[fCoo][1] = hInfo[houseid][icony];
			FireDB[fCoo][2] = hInfo[houseid][iconz];
			if(hInfo[houseid][daugiabutis])
			{
				FireDB[fVW] = MAX_HOUSES*2+MAX_BUSINESSES+ hInfo[houseid][daugiabutis]-1;
			}
			else FireDB[fVW] = 0;
			FireDB[fInt] = 0;
			FireDB[fHealth] = 100;
			FireDB[fMaxHealth] = FireDB[fHealth];
			FireDB[fPlace] = 1;
			FireDB[fNumber] = houseid;
			obja=fire_large;
			format(msg,sizeof(msg),"[racija] Operatore: Gaisras prie namo Nr.%i. Rasykite /imti!",houseid);
		}
	}
	else if(x == 1)
	{
		new world = Iter_Random(Businesses);
		FireDB[fCoo][0] = BusinessInfo[world][bEnterX];
		FireDB[fCoo][1] = BusinessInfo[world][bEnterY];
		FireDB[fCoo][2] = BusinessInfo[world][bEnterZ];
		FireDB[fVW] = 0;
		FireDB[fInt] = 0;
		FireDB[fHealth] = 100;
		FireDB[fMaxHealth] = FireDB[fHealth];
		obja=fire_large;
		FireDB[fPlace] = 2;
		FireDB[fNumber] = world;
		format(msg,sizeof(msg),"[racija] Operatore: Gaisras firmoje '%s'. Rasykite /imti!",BusinessInfo[world][bName]);
	}
	else if(x == 2)
	{
		new world = Iter_Random(Daugiabuciai);
		FireDB[fCoo][0] = Daugiabuciai[world][dX];
		FireDB[fCoo][1] = Daugiabuciai[world][dY];
		FireDB[fCoo][2] = Daugiabuciai[world][dZ];
		FireDB[fVW] = 0;
		FireDB[fInt] = 0;
		FireDB[fHealth] = 100;
		FireDB[fMaxHealth] = FireDB[fHealth];
		obja=fire_large;
		FireDB[fPlace] = 3;
		FireDB[fNumber] = world;
		format(msg,sizeof(msg),"[racija] Operatore: Gaisras daugiabutyje Nr.%i. Rasykite /imti!",world+1);
	}
	else if(x == 3) 
	{	
		if(MiskoGaisrai[inProgress])
		{
			for(new i;i<MiskoGaisrai[fLeft];i++) {
				DestroyDynamicObject(MiskoGaisrai[fObjects][i]);
				DestroyDynamicMapIcon(MiskoGaisrai[fIcons][i]);
			}
			KillTimer(MiskoGaisrai[fTimer]);
		}
		new miskas = random(sizeof(GaisruCoord)-1);
		CreateMiskoGaisras(miskas);
		format(msg,sizeof(msg),"[racija] Operatore: Gaisras miske Nr.%i! Rasykite /imti!",miskas+1);
		kvieciagais=-100;
		SendMessageToGaisras(COLOR,msg);
		return 1;
	}
	else 
		return 1;
	
	FireDB[inProgress]=true;
	FireDB[fObj] = CreateDynamicObject(obja,FireDB[fCoo][0],FireDB[fCoo][1],FireDB[fCoo][2]-1.5,0.0,0.0,0.0,FireDB[fVW],FireDB[fInt]);
	kvieciagais=-100;
	SendMessageToGaisras(COLOR,msg);
	return 1;
}

stock LoadKurjeriuMission(playerid,iskrove=0)
{
	new vehicleid = GetPlayerVehicleID(playerid);
	new krc=1;
	if(!vehicleid) vehicleid=PlayerCar[playerid];// return 1;
	if(vezaivieta[playerid])
	{
		if(vpakrauta[playerid]-1 >= MAX_BUSINESSES) vpakrauta[playerid]=0;
		if(vezaivieta[playerid]-1 >= sizeof(FURU_TEKSTAI)) vezaivieta[playerid]=0;
		else if(iskrove)
		{
			krc=2;
		}
		else if(vpakrauta[vehicleid])
		{
			new idx = vpakrauta[vehicleid]-1;
			SetPlayerCheckpoint(playerid,BusinessInfo[idx][bEnterX],BusinessInfo[idx][bEnterY],BusinessInfo[idx][bEnterZ],30.0);
			UpdateJobText(playerid,4,vezaivieta[playerid]-1,vpakrauta[vehicleid]-1);
			krc=0;
		}
		else
		{
			if(FURU_ATVEZTA[vezaivieta[playerid]-1] > 0)
			{
				SetPlayerCheckpoint(playerid,FURU_ISKROVIMAI[vezaivieta[playerid]-1][0],FURU_ISKROVIMAI[vezaivieta[playerid]-1][1],FURU_ISKROVIMAI[vezaivieta[playerid]-1][2],20.0);
				UpdateJobText(playerid,4,-1,vezaivieta[playerid]-1);
				krc=0;
			}
		}
	}
	if(krc)
	{
		new vezai = vpakrauta[playerid];
		vpakrauta[vehicleid]=0;
		new minimumas = 0;
		for(new i;i<sizeof(FURU_ATVEZTA)-2;i++)
		{
			if(FURU_ATVEZTA[i] > minimumas)
			{
				minimumas=FURU_ATVEZTA[i];
				vezaivieta[playerid]=i+1;
			}
		}
		if(!minimumas) return SendInfoMessage(playerid,"Baze tuscia! Nera ka vezti.");

		SetPlayerCheckpoint(playerid,FURU_ISKROVIMAI[vezaivieta[playerid]-1][0],FURU_ISKROVIMAI[vezaivieta[playerid]-1][1],FURU_ISKROVIMAI[vezaivieta[playerid]-1][2],20.0);
		if(krc == 1) UpdateJobText(playerid,4,-1,vezaivieta[playerid]-1);
		else if(krc == 2) UpdateJobText(playerid,4,vezai-1,vezaivieta[playerid]-1);
		
		new msg[128];
		format(msg,sizeof(msg),"~w~Reikia vezti ~y~%s~w~~n~Vaziuokite pasikrauti.",FURU_TEKSTAI[vezaivieta[playerid]-1]);
		SendInfoMessage(playerid,msg);
	}
	return 1;

}
stock LoadFuruMission(playerid,iskrove=0)
{
	new vehicleid = GetPlayerVehicleID(playerid);
	new krc=1;
	if(!vehicleid) return 1;
	if(vezaivieta[playerid])
	{
		if(vezaivieta[playerid]-1 >= sizeof(FURU_TEKSTAI)) vezaivieta[playerid]=0;
		else if(iskrove)
		{
			krc=2;
			
		}
		else if(vpakrauta[GetVehicleTrailer(vehicleid)])
		{
			SetPlayerCheckpoint(playerid,FURU_ISKROVIMAI[vezaivieta[playerid]-1][0],FURU_ISKROVIMAI[vezaivieta[playerid]-1][1],FURU_ISKROVIMAI[vezaivieta[playerid]-1][2],20.0);
			UpdateJobText(playerid,3,vezaivieta[playerid]-1);
			krc=0;
		}
		else
		{
			SetPlayerCheckpoint(playerid,FURU_PAKROVIMAI[vezaivieta[playerid]-1][0],FURU_PAKROVIMAI[vezaivieta[playerid]-1][1],FURU_PAKROVIMAI[vezaivieta[playerid]-1][2],20.0);
			UpdateJobText(playerid,3,vezaivieta[playerid]-1);
			krc=0;
		}
	}
	if(krc)
	{
		new vezai = vezaivieta[playerid];
		new minimumas = 999999;
		for(new i;i<sizeof(FURU_ATVEZTA);i++)
		{
			if(FURU_ATVEZTA[i] < minimumas)
			{
				minimumas=FURU_ATVEZTA[i];
				vezaivieta[playerid]=i+1;
			}
		}
		vezaivieta[playerid] = 1 + random(sizeof(FURU_ATVEZTA));
		SetPlayerCheckpoint(playerid,FURU_PAKROVIMAI[vezaivieta[playerid]-1][0],FURU_PAKROVIMAI[vezaivieta[playerid]-1][1],FURU_PAKROVIMAI[vezaivieta[playerid]-1][2],20.0);
		if(krc == 1) UpdateJobText(playerid,3,vezaivieta[playerid]-1);
		else if(krc == 2) UpdateJobText(playerid,3,vezai-1,vezaivieta[playerid]-1);
		new msg[128];
		format(msg,sizeof(msg),"~w~Musu firmoje truksta ~y~%s~w~~n~Vaziuokite pasikrauti.",FURU_TEKSTAI[vezaivieta[playerid]-1]);
		SendInfoMessage(playerid,msg);
	}
	return 1;
}
stock GetXYBehindVehicle(vehicleid, &Float:x, &Float:y, Float:distance,angle)
{
    new
        Float:a;
    GetVehiclePos( vehicleid, x, y, a );
    GetVehicleZAngle( vehicleid, a );
    new Float:sin = floatsin( -a, degrees );
    new Float:cos = floatcos( -a, degrees );
    a = (a + angle);
    if(a >= 360.0) 
    	a-=360.0;
    x -= ( distance * sin);
    y -= ( distance * cos);
}
#define Z_SPEED (4.0)
#define GRAVITY (13.0)
new ObjectPlayer[MAX_OBJECTS];

stock OnSomethingFinish(playerid, totaltime)
{
	playerDB[playerid][actionmax]=0;
	PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
	new vehicleid = GetPlayerVehicleID(playerid);
	SetPVarInt(playerid,"kurjeris_busy",0);
	if(totaltime  == 68)
	{
		MedikaiPickedUp(playerid);
		return 1;
	}
	if(vezaivieta[playerid])
	{
		if(totaltime == 187) // furu pakrovimas
		{
			if(!CheckPriekaba(playerid,vehicleid,vezaivieta[playerid]-1))
			{
				GivePlayerMoneyA(playerid, 4000);
				SendInfoMessage(playerid,"~r~Kur tavo priekaba?");
				TogglePlayerControllable(playerid, true);
				return 0;
			}
			vehicleid = GetVehicleTrailer(vehicleid);
			TogglePlayerControllable(playerid,true);
			if(!vehicleid)
			{
				GivePlayerMoneyA(playerid, 4000);
				SendInfoMessage(playerid,"~r~Kur tavo masina?");
				TogglePlayerControllable(playerid, true);
				return 1;
			}
			SendInfoMessage(playerid,"Krovinys pakrautas.~n~ Prasome nuvezti ji iskrauti.");
			vpakrauta[vehicleid]=1;
			LoadFuruMission(playerid);
		}
		else if(totaltime == 160) // iskrovimas
		{
			if(!CheckPriekaba(playerid,vehicleid,vezaivieta[playerid]-1)) 
			{
				TogglePlayerControllable(playerid, true);
				return 1;
			}
			vehicleid = GetVehicleTrailer(vehicleid);
			if(!vehicleid) return 0;
			if(!vpakrauta[vehicleid]) return 0;
			new msg[128];
//			new Float:Dist = GetPlayerDistanceFromPoint(playerid,FURU_PAKROVIMAI[vezaivieta[playerid]-1][0],FURU_PAKROVIMAI[vezaivieta[playerid]-1][1],FURU_PAKROVIMAI[vezaivieta[playerid]-1][2]);
			new cost = MONEYP_FURISTAI;
			format(msg,sizeof(msg)," * Krovinys iskrautas. Uzdirbai %i€.",cost);
			ProcessAchievement(playerid,76);
			playerDB[playerid][jobpts]++;
			SendClientMessage(playerid,-1,msg);
			TogglePlayerControllable(playerid,true);
			FURU_ATVEZTA[vezaivieta[playerid]-1]+=4;
			GivePlayerMoneyA(playerid, cost+4000);
			Pelnas(playerid,4,cost);
			vpakrauta[vehicleid]=0;
			LoadFuruMission(playerid,1);
		}
		else if(totaltime == 110) // kraunasi
		{
			//if(FURU_ATVEZTA[vezaivieta[playerid]-1] <= 0) return SendInfoMessage(playerid,"Sio krovinio neber.");
			SendInfoMessage(playerid,"Krovinys pakrautas.~n~ Prasome nuvezti ji iskrauti.");
			TogglePlayerControllable(playerid,true);
			//FURU_ATVEZTA[vezaivieta[playerid]-1]--;
			LoadRandomPlace(playerid,vezaivieta[playerid]-1);
			LoadKurjeriuMission(playerid);
		}
		else if(totaltime == 50) // iskrove
		{
			TogglePlayerControllable(playerid,true);
			vehicleid = PlayerCar[playerid];
			if(vehicleid)
			{
				if(vpakrauta[vehicleid])
				{
					ClearAnimations(playerid);
					Boxas(playerid,1);
					GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
					SetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],false,-1,VehVars[4],false,VehVars[6]);
					SendClientMessage(playerid, -1, " * Paemei krovini. Nuneđk já á verslŕ.");
				}
			}
		}
		else if(totaltime == 36)
		{
			TogglePlayerControllable(playerid,true);
			if(!vehicleid) return 0;
			if(!vpakrauta[vehicleid]) return 0;
			SendInfoMessage(playerid,"Cementas iskrautas!");
			vpakrauta[vehicleid]=0;
			GivePlayerMoneyA(playerid,MONEYP_STATYBININKAS);
			ProcessAchievement(playerid,76);
			SetPlayerCheckpoint(playerid,1273.0933,-1250.0557,14.2002,5.0);
		}
		else if(totaltime == 37)
		{
			TogglePlayerControllable(playerid,true);
			if(!vehicleid) return 0;
			if(vpakrauta[vehicleid]) return 0;
			SendInfoMessage(playerid,"Siuksles pakrautos!");
			vpakrauta[vehicleid]=1;
			//GivePlayerMoneyA(playerid,MONEYP_STATYBININKAS);
			//ProcessAchievement(playerid,76);
			SetPlayerCheckpoint(playerid,2128.4524,-1983.5947,15.0797,25.0);
		}
		else if(totaltime == 52)
		{
			TogglePlayerControllable(playerid,true);
			if(!vehicleid) return 0;
			SendInfoMessage(playerid,"Siuksles iskrautos! Vaziuokite surinkti siuksliu.");
			GivePlayerMoneyA(playerid,MONEYP_STATYBININKAS);
			vpakrauta[vehicleid]=0;
			if(!SetNextNukeCp(playerid, 2))
			{
				vezaivieta[playerid]=random(sizeof(STATYBININKAI))+1;
				SetPlayerCheckpoint(playerid,STATYBININKAI[vezaivieta[playerid]-1][0], STATYBININKAI[vezaivieta[playerid]-1][1],STATYBININKAI[vezaivieta[playerid]-1][2],5.0);
			}
		}
		else if(totaltime == 51)
		{
			TogglePlayerControllable(playerid,true);
			if(!vehicleid) return 0;
			SendInfoMessage(playerid,"Cementas pakrautas! Dabar vaziuokite statyti nama.");
			vpakrauta[vehicleid]=1;
			if(!SetNextNukeCp(playerid, 1))
			{
				vezaivieta[playerid]=random(sizeof(STATYBININKAI))+1;
				SetPlayerCheckpoint(playerid,STATYBININKAI[vezaivieta[playerid]-1][0], STATYBININKAI[vezaivieta[playerid]-1][1],STATYBININKAI[vezaivieta[playerid]-1][2],5.0);
			}
		}
		else if(totaltime == 191)
		{
			TogglePlayerControllable(playerid,true);
			if(!vehicleid || GetVehicleModel(vehicleid) != 524)
			{
				new model = GetVehicleModel(PlayerCar[playerid]);
				if(model != 524)
				{
					SendClientMessage(playerid, -1, "Privalote bűti cemento mađinos vairuotojas!");
					return 1;
				}
				vehicleid = PlayerCar[playerid];
			}
			new type = GetPVarInt(playerid, "NukeType");
			if(type == 0)
				return 0;
			else if(type == 1) // restore
			{
				new id = GetPVarInt(playerid, "NukeCP");
				if(IsPlayerInRangeOfPointEx(RemovedObjects[id][rfSize]+20 + 100, playerid,  RemovedObjects[id][rfX],RemovedObjects[id][rfY] ,RemovedObjects[id][rfZ]))
				{
					if(RemovedObjects[id][rActive] == 0)
					{
						SendClientMessage(playerid, -1, " * Đá pastatŕ jau atstatë kitas ţaidëjas! Ţemëlapyje tau paţymëtas kitas objektas.");
						SetPVarInt(playerid, "NukeType", 0);
						SetPVarInt(playerid, "NukeCP", 0);
						SetNextNukeCp(playerid, type);
					}
					else
					{
						RestoreNukeObject(id);
						SendClientMessage(playerid, -1, " * Atstatei đá pastatŕ ir gavai "#MONEYP_STATYBININKAS"EUR uţ atliktŕ darbŕ!");
						vpakrauta[vehicleid]=0;
						GivePlayerMoneyA(playerid, MONEYP_STATYBININKAS);
						SetPVarInt(playerid, "NukeType", 0);
						SetPVarInt(playerid, "NukeCP", 0);
						NuclearBlast[TotalObjectsRecovered] ++;
						SendClientMessage(playerid, -1, " * Dabar vaţiuok pasikrauti cemento.");
						SetPlayerCheckpoint(playerid,1273.0933,-1250.0557,14.2002,25.0);
						
					}
					return 1;
				}
				SendClientMessage(playerid, -1, "Tu per toli nuo objekto!");
			}
		}
		else if(totaltime == 192)
		{
			TogglePlayerControllable(playerid,true);
			if(!vehicleid || GetVehicleModel(vehicleid) != 406)
			{
				new model = GetVehicleModel(PlayerCar[playerid]);
				if(model != 406)
				{
					SendClientMessage(playerid, -1, "Privalote bűti Dumper vairuotojas!");
					return 1;
				}
				else
				{
					vehicleid = PlayerCar[playerid];
				}
			}
			new type = GetPVarInt(playerid, "NukeType");
			if(type == 0)
				return 0;
			else if(type == 2) // restore
			{
				new id = GetPVarInt(playerid, "NukeCP");
				if(IsPlayerInRangeOfPointEx(HelovynoObj[id][heSize]+20 + 100, playerid,  HelovynoObj[id][heX],HelovynoObj[id][heY] ,HelovynoObj[id][heZ]))
				{
					if(HelovynoObj[id][heStatus] == 0)
					{
						SendClientMessage(playerid, -1, " * Đá pastatŕ jau nugriovë kitas ţaidëjas!");
						SetPVarInt(playerid, "NukeType", 0);
						SetPVarInt(playerid, "NukeCP", 0);
						SetNextNukeCp(playerid, type);
					}
					else
					{
						DestroyDynamicObject(HelovynoObj[id][heObject]);
						HelovynoObj[id][heStatus] = 0;

						SendClientMessage(playerid, -1, " * Nugriovei đá objektŕ!");
						vpakrauta[vehicleid]=1;
						//GivePlayerMoneyA(playerid, MONEYP_STATYBININKAS);
						SetPVarInt(playerid, "NukeType", 0);
						SetPVarInt(playerid, "NukeCP", 0);
						NuclearBlast[TotalObjectsDestroyed] ++;
						SendClientMessage(playerid, -1, " * Dabar vaţiuok iđkrauti điukđles.");
						SetPlayerCheckpoint(playerid,2128.4524,-1983.5947,15.0797,25.0);
						
					}
					return 1;
				}
				SendClientMessage(playerid, -1, "Tu per toli nuo objekto!");
			}
		}
		
	}
	else if(totaltime == 30) // kobros spygliai
	{
		new veh = vehicleid;
		if(!veh) return 0;
		new speed = GetSpeedEx(veh);
		if(speed < 60)
			speed+=60;
		speed = speed/60;
		new Float:a;
		GetVehicleZAngle( veh, a );
		new Float:Coo[3];
		GetVehiclePos(veh, Coo[0], Coo[1], Coo[2]);
		GetXYBehindVehicle(veh,Coo[0],Coo[1],3.5,0);
		new Float:Zcord;
		MapAndreas_FindZ_For2DCoord(Coo[0],Coo[1],Zcord);

		new Float:sin,Float:cos;
		new obj = CreateObject(2899, Coo[0], Coo[1], Coo[2], 0, 0, a+90);
		ObjectPlayer[obj]=playerid;
		new offset = 90 - random(180);
		a += offset;
		if(a >= 360.0)
			a-=360.0;
		sin = floatsin( -a, degrees );
		cos = floatcos( -a, degrees );

		PHY_InitObject(obj);
		PHY_SetObjectVelocity(obj, speed*sin, speed*cos, speed);
		PHY_SetObjectGhost(obj);
		PHY_SetObjectFriction(obj, 100); // This will stop the object when it touchs the ground.
		PHY_SetObjectGravity(obj, GRAVITY);
		if(Zcord > Coo[2])
			Zcord = Coo[2]-1;
		PHY_SetObjectZBound(obj, Zcord+0.3, _, 0.0);
		GetVehicleParamsEx(veh,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
		SetVehicleParamsEx(veh,VehVars[0],VehVars[1],false,-1,VehVars[4],false,VehVars[6]);
	}
	return 1;
}

public PHY_OnObjectCollideWithZBound(objectid, lowhigh) // low bound = 0, high bound = 1
{
	// is it spygliai?
	//printf("Collide");
	if(lowhigh == 0)
	{
		/*new pataike = GetPVarInt(GniuztePlayer[objectid], "Pataike");
		if(pataike < 100) 
		{
			SetPVarInt(GniuztePlayer[objectid],"Pataike",pataike + 1);
			new msg[128];
			format(msg,128,"%i/100",pataike+1);
			SendInfoMessage(GniuztePlayer[objectid],msg);
		}*/
		if(objectid == kiausasobj)
		{
			KiausasDropped();
		}
		new model = GetObjectModel(objectid);
		if(model == 2899)
		{
			new playerid = ObjectPlayer[objectid];
			new Float:pos[3];
			GetObjectPos(objectid, pos[0], pos[1], pos[2]);
			new Float:rot[3];
			GetObjectRot(objectid, rot[0], rot[1], rot[2]);
			CreateSmallStinger(playerid,pos[0], pos[1],pos[2], rot[2], 0, 360000);
			PHY_DeleteObject(objectid);
			DestroyObject(objectid);
		}
		else if(model == 1212) // pinigai
		{
			SetTimerEx("DestroyMoney",3000,false,"i",objectid);
		}
		else if(model == 1550)
		{
			SetTimerEx("DestroyMoney",10000,false,"i",objectid);
		}
		else if(model == 1974) // gniuzte
		{
			PHY_DeleteObject(objectid);
			DestroyObject(objectid);
		}
		else if(model != 2114) // gibs
		//else
		{
			PHY_DeleteObject(objectid);
		}
	}

}
public PHY_OnObjectCollideWithPlayer(objectid,playerid) 
{
	new model = GetObjectModel(objectid);
	if(model == 1974)
	{
		PHY_DeleteObject(objectid);
		new Float:P[3];
		GetPlayerPos(playerid,P[0],P[1],P[2]);
		DestroyObject(objectid);
		if(!IsPlayerAfk(playerid))
		{
			/*new pataike = GetPVarInt(GniuztePlayer[objectid], "Pataike");
			if(pataike < 100) 
			{
				SetPVarInt(GniuztePlayer[objectid],"Pataike",pataike + 1);
				new msg[128];
				format(msg,128,"%i/100",pataike+1);
				SendInfoMessage(GniuztePlayer[objectid],msg);
			}*/

			PlayerPlaySound(GniuztePlayer[objectid], 1136, P[0],P[1],P[2]);
			PlayerPlaySound(playerid,1136, 0,0,0);
			if(random(2) == 0)
				ApplyAnimation(playerid, "ped", "KO_shot_face",4.0, 0,0,0,0,0); //, loop, lockx, locky, freeze, time)
			else
				ApplyAnimation(playerid, "ped", "KO_shot_stom",4.0, 0,0,0,0,0); 
			new Float:HP, Float: AP;
			GetPlayerHealth(playerid, HP);
			GetPlayerArmour(playerid, AP);
			if(AP > 0.0)
			{
				AP -= 5.0;
				if(AP < 0)
					AP=0;
				SetPlayerArmour(playerid,AP);
			}
			else
			{
				HP -= 5.0;
				SetPlayerHealth(playerid, HP);
			}
		}
		new effect;
		if(random(2) == 0)
			effect = CreateObject(18742,P[0],P[1],P[2]-2,0,0,0);
		else
			effect = CreateObject(18724,P[0],P[1],P[2]-10,0,0,0);
		SetTimerEx("DestroyMoney",1000, false, "i", effect);
	}
	return 1;
}
