}

public Varteliai(kurie)
{
	if(kurie == 0)
	{
//		MoveDynamicObject(policijaa,1540.195557, -1627.877563, 15.156204, 1.0001);
		RotateObject(policijaa,0, 90 ,90);
		//MoveObject(policijaa, Float:X, Float:Y, Float:Z, Float:Speed, Float:RotX = -1000.0, Float:RotY = -1000.0, Float:RotZ = -1000.0)
		return 1;
	}
/*	else if(kurie == 3)
	{
		MoveDynamicObject(bmxx, 1861.897217, -1380.626831, 15.324156, 1.0001);
		return 1;
	}*/
	else if(kurie == 1)
	{
		MoveObject(liftas,1569.856567, -1637.569091, 12.859857, 1.0001);
		return 1;
	}
/*	else if(kurie == 4)
	{
		MoveDynamicObject(mechanikai, 1647.9857177734, -1540.3292236328, 15.339853286743, 1.0001);
		return 1;
	} */
	else if(kurie == 2)
	{
		RotateObject(pasienis,0,90,84.98);
		return 1;
	}
	else if(kurie == 3)
	{
		RotateObject(pasienis2,0,90,265);
		return 1;
	}
	else if(kurie == 10)
	{
		RotateObject(iwaziavimas,0, 90 ,0);
		JailGateOpen=false;
		return 1;
	}
	else if(kurie == 13)
	{
	    RotateObject(valtys,0, 89,277);
		return 1;
	}
	else if(kurie==14)
	{
		MoveObject(angarovartai,-3.60795927,2472.71582031,22.53562927,1.0001);
		return 1;
	}
	else if(kurie == 20)
	{
		MoveDynamicObject(door1,1849.32995605,-1714.31005859,3201.54003906,0.50);
	}
	else if(kurie == 21)
	{
		MoveDynamicObject(door2,1847.31994629,-1722.56994629,3201.54003906,0.50);
	}
	else if(kurie == 22)
	{
		MoveDynamicObject(door3,1854.01953125,-1726.27343750,3201.54003906,0.50);
	}
	else if(kurie == 23)
	{
		MoveDynamicObject(door4,1862.02246094,-1710.91992188,3201.54003906,0.50);
	}
	return 1;
}

stock GetPlayerFirstName(playerid)
{
    new namestring[2][MAX_PLAYER_NAME];
    new name[MAX_PLAYER_NAME];
    GetPlayerName(playerid,name,MAX_PLAYER_NAME);
    split(name, namestring, '_');
    return namestring[0];
}
stock GetPlayerLastName(playerid)
{
    new namestring[2][MAX_PLAYER_NAME];
    new name[MAX_PLAYER_NAME];
    GetPlayerName(playerid,name,MAX_PLAYER_NAME);
    split(name, namestring, '_');
    return namestring[1];
}

public Bankininke(playerid)
{
	if(!IsPlayerConnected(playerid)) return 0;
	if(random(4) == 2) return SendInfoMessage(playerid,"Prisiskambint nepavyko. Prasome pabandyti veliau.");
    new msg[128];
    format(msg,sizeof(msg),"Bankininke: Jusu firmos pelnas yra %iEUR.",pelnas[playerDB[playerid][plead]-1]);
    SendInfoMessage(playerid,msg);
    return 1;
}



forward CountV(playerid);
public CountV(playerid)
{
	skaiciavimas--;
	switch(skaiciavimas)
	{
		case 2:
		{
			SetTimerEx("CountV",1000,0,"i",playerid);
			new Float:coo[3];
			new Float:Pos[3];
			GetPlayerPos(playerid,Pos[0],Pos[1],Pos[2]);
			//GameTextForAll("~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~g~-~y~ Du ~g~-",1000,3);
			foreach (Player, i)
			{
				if(IsPlayerInRangeOfPointEx(150.0,i,Pos[0],Pos[1],Pos[2]))
				{
					GetPlayerPos(i,coo[0],coo[1],coo[2]);
					PlayerPlaySound(i,1056,coo[0],coo[1],coo[2]);
					GameTextForPlayer(i,"~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~g~-~y~ Du ~g~-",1000,3);
				}
			}
		}
		case 1:
		{
			SetTimerEx("CountV",1000,0,"i",playerid);
			new Float:coo[3];
			new Float:Pos[3];
			GetPlayerPos(playerid,Pos[0],Pos[1],Pos[2]);
			//GameTextForAll("~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~g~-~y~ Vienas ~g~-",1000,3);
			foreach (Player, i)
			{
				if(IsPlayerInRangeOfPointEx(150.0,i,Pos[0],Pos[1],Pos[2]))
				{
					GetPlayerPos(i,coo[0],coo[1],coo[2]);
					PlayerPlaySound(i,1056,coo[0],coo[1],coo[2]);
					GameTextForPlayer(i,"~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~g~-~y~ Vienas ~g~-",1000,3);
				}
			}		
		}
		case 0:
		{
			SetTimerEx("CountV",3000,0,"i",playerid);
			new Float:coo[3];
			new Float:Pos[3];
			GetPlayerPos(playerid,Pos[0],Pos[1],Pos[2]);
			//GameTextForAll("~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~g~-~y~]~g~-~r~!!! GOOO !!!~g~-~y~]~g~-",1000,3);
			foreach (Player, i)
			{
				if(IsPlayerInRangeOfPointEx(150.0,i,Pos[0],Pos[1],Pos[2]))
				{
					GetPlayerPos(i,coo[0],coo[1],coo[2]);
					PlayerPlaySound(i,1057,coo[0],coo[1],coo[2]);
					GameTextForPlayer(i,"~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~n~~g~-~y~]~g~-~r~!!! GOOO !!!~g~-~y~]~g~-",1000,3);
				}
			}				
		}
		case -1:
			as=false;
	}
	return 1;
}	
