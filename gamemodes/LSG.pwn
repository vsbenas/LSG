public OnPlayerCleoDetected( playerid, cleoid )
{
	if(!playerDB[playerid][admin])
	{
		switch( cleoid )
		{
			case CLEO_FAKEKILL:
			{
				return 1;
			}
			case CLEO_CARWARP:
			{
				if(PlayerCar[playerid] == GetPlayerVehicleID(playerid)) return 1;
				AC_Ban(playerid,"Car Warp");
			}
			case CLEO_CARSWING:
			{
				AC_Ban(playerid,"Car Swing" );
			}
			case CLEO_CAR_PARTICLE_SPAM:
			{
				AC_Ban(playerid, "Car Particle Spam" );
			}
		}
	}
	else
		SendClientMessage(playerid,RED," * Tu itariamas cheatu naudojimu, bet bano negauni, nes esi administratorius!");
    return 1;
}



stock CheckForUnban(playerid)
{
	new query[1024];
	format(query,sizeof(query),"SELECT Variable From Logs WHERE UPPER(`Variable`)=UPPER(' %s') AND Veiksmas='Unban' LIMIT 1",ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_CheckUnbanAch", "i", playerid);
}



#define DIALOG_BASE_X   	75.0
#define DIALOG_BASE_Y   	130.0
#define DIALOG_WIDTH    	550.0
#define DIALOG_HEIGHT   	180.0


GetNumberOfPages()
{
	if((gTotalItems >= SELECTION_ITEMS) && (gTotalItems % SELECTION_ITEMS) == 0)
	{
		return (gTotalItems / SELECTION_ITEMS);
	}
	else return (gTotalItems / SELECTION_ITEMS) + 1;
}

