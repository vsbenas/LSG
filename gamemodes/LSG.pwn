stock OnTimeChange(hour,minute)
{
	#pragma unused hour,minute
	new ticks = GetServerTickRate();
	new playersin = Iter_Count(Player);
	printf("Tick rate: %i|%i",ticks,playersin);
	if(IsProdEnvironment())
	{
		LogMetricInt("tick_rate",ticks);
		LogMetricInt("player_count",playersin);
		LogMetricFloat("packet_loss",GetServerPacketLoss());
	}
	new WeekDay = GetWeekDay();
	new bool:WedSat = (WeekDay == 0 || WeekDay == 4);
	if(WedSat && hour == 19 && minute <= 1) // run twice in case somehow missed
	{
		CheckDrugKingAchievement();
	}
	new day,month,year;
	getdate(year,month,day);
	if(month == 10 && day == 31)
	{
		if(hour == 16)
		{
			if(minute == 0)
			{
				Halloween(0);
			}
			if(minute == 10)
			{
				Halloween(1);
			}
			if(minute == 20 || minute == 30)
			{
				Halloween(2);
			}
			if(minute == 40)
			{
				Halloween(3);
			}
			if(minute == 50)
			{
				Halloween(4);
			}
		}
		if(hour == 17)
		{
			if(minute == 0)
			{
				Halloween(5);
			}
			if(minute == 10)
			{
				Halloween(6);
			}
			if(minute == 20)
			{
				Halloween(6);
			}
			if(minute == 30)
			{
				Halloween(7); // begin shake and shake begins halloween 8
			}

		}
		/*else if(hour > 17 && minute == 0)
		{
			Halloween(10); // reminders
		}*/
	}
    else if(month == 11 && day == 1 && helovynas) {
        Halloween(13);
    }
	/*else if(month == 11 && day == 1)
	{
		if(hour == 5 && minute == 0)
		{
			Halloween(8); // start the event after rr
		}
		else if(hour < 21 && minute == 0)
		{
			Halloween(12); // reminders
		}
		if(hour == 21 && minute == 0)
		{
			Halloween(13); // stop event
		}
	}*/
	
}

forward Gniuzte(pl);
public Gniuzte(pl) 
{
	SetPVarInt(pl, "Gniuzte", 2);
	SetPlayerAttachedObject(pl, SLOT_KROVINYS, 1974, 6, 0.05, 0.05, 0, 0,0,0, 1,1,1,-1,-1);
				
	return 1;
}

forward Antigodmode(playerid,uni,skinid);
public Antigodmode(playerid,uni,skinid)
{
	if(GetPlayerSkin(playerid) == 20 && skinid != 20)
	{
		AC_Kick(playerid,"Ghostmode");
	}

}

stock DazuLentele(playerid)
{
	new msgas[512];
	new red,blue;
	foreach(Player, i)
	{
		if(playerDB[i][psratasvydis]==1) blue++;
		else if(playerDB[i][psratasvydis]==2) red++;	
	}


	format(msgas,sizeof(msgas),"{FFFFFF}Arena: "#TEXT_GREEN"%s\n{FFFFFF}Liko laiko: "#TEXT_GREEN"%02d:%02d\n{FFFFFF}Ţaidëjai: "#TEXT_RED"%i{FFFFFF} / "#TEXT_BLUE"%i\nPasirinkite komandŕ:\n    "#TEXT_GREEN"• "#TEXT_RED"Raudona\n    "#TEXT_GREEN"• "#TEXT_BLUE"Mëlyna",dazuarenos[dazumap],(dazutime/ 60), (dazutime % 60),red,blue);

	ShowPlayerDialog(playerid,565,DIALOG_STYLE_LIST,"LSG Daţai",msgas,"Rinktis","Atsaukti");

}


stock Texturize(hid,isdoor,matid,textureid)
{
	if(textureid >= 9065)
	{
		printf("Error textureid >= 9065");
		return;
	}
	if(matid < 0 || matid > 15)
	{
		printf("Error matid > 15");
		return;
	}
	if(isdoor == 0)
	{
		for(new i=0;i<100;i++) if(IsValidDynamicObject(hInfo[hid][intobj][i]) && hInfo[hid][intobj][i] != 0)
		{
			SetDynamicObjectMaterial(hInfo[hid][intobj][i], matid, GetTModel(textureid), GetTXDName(textureid), GetTextureName(textureid));
		}
		if(textureid != 8932)
			hInfo[hid][intobjid][matid] = textureid;
	}
	else
	{	
		for(new i=0;i<100;i++) if(IsValidDynamicObject(hInfo[hid][doorobj][i]) && hInfo[hid][doorobj][i] != 0)
		{
			SetDynamicObjectMaterial(hInfo[hid][doorobj][i], matid, GetTModel(textureid), GetTXDName(textureid), GetTextureName(textureid));
		}
	}
}

stock ResetTextures(hid,isdoor,matid,delete=0,pid=-1)
{
	for(new i=0;i<100;i++) 
	{
		if(IsValidDynamicObject(hInfo[hid][intobj][i]) && hInfo[hid][intobj][i] != 0)
		{
			DestroyDynamicObject(hInfo[hid][intobj][i]);
			hInfo[hid][intobj][i]=0;
		}
		if(IsValidDynamicObject(hInfo[hid][doorobj][i]) && hInfo[hid][doorobj][i] != 0)
		{
			DestroyDynamicObject(hInfo[hid][doorobj][i]);
			hInfo[hid][doorobj][i]=0;
		}
	}
	LoadInterior(hid);
	new query[512];
	if(delete == 1)
	{

		format(query,512,"DELETE FROM Textures WHERE houseid=%i AND isdoor=%i and matid=%i",hid,isdoor,matid);
		mysql_query(query);
	}
	foreach(Player, i) 
		if(GetPlayerHouseID(i) == hid)
			Streamer_Update(i);
	

	// now reload the ones we have

	format(query,512,"SELECT * FROM `Textures` WHERE `houseid`=%i",hid);
	mysql_function_query(SQL,query,true,"SQL_TextureLoad","i",pid);
}
stock SaveTexture(hid,isdoor,matid,textureid)
{
	new query[512];
	format(query,512,"REPLACE INTO Textures Values(%i,%i,%i,%i)",hid,isdoor,matid,textureid);
	mysql_query(query);
}
