	}
	if(Keliones[Ijungta] && KDalyvis[playerid][Dalyvauja] && GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
	{
		//if(!Keliones[DabartinisCP] && Keliones[Dalyviai] < 3)
