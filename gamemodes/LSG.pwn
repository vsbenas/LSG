stock VagiuHelper(playerid, vehicleid, listid)
{
	MLog(playerid,"Pridave Masina","i",vagia[playerid]);
	playerDB[playerid][jobpts]++;
	DestroyVehicle(vehicleid); //sunaikiname masina
	new msg[128];
	format(msg,sizeof(msg),"Uz sia masina gavai %iEUR.",MONEYP_VAGIS);
	GivePlayerMoneyA(playerid,MONEYP_VAGIS);
	SendInfoMessage(playerid,msg);
	vehicleDB[vehicleid][lastpos][0]=0;
	vehicleDB[vehicleid][lastpos][1]=0;
	vehicleDB[vehicleid][lastpos][2]=0;
	Pelnas(playerid,57,MONEYP_VAGIS);
	if(listid == 1)
	{
		SetPlayerCameraPos(playerid,-1534.6313,150.5789,3.5547);
		SetPlayerCameraLookAt(playerid,-1534.4789,153.5749,4.6031);
	}
	if(listid == 2)
	{
		SetPlayerCameraPos(playerid,-1861.8389,-1635.0841,23.1597);    //Camera
		SetPlayerCameraLookAt(playerid,-1866.3359,-1630.3333,22.9875); //Camera
	}
	if(listid == 3)
	{
		SetPlayerCameraPos(playerid,984.6781,2075.1016,12.0668);    //Camera
		SetPlayerCameraLookAt(playerid,979.9724,2078.5332,11.2861); //Camera
	}
	if(listid == 4)
	{
		SetPlayerCameraPos(playerid,-2258.0142,2358.6443,4.9752);    //Camera
		SetPlayerCameraLookAt(playerid,-2251.0286,2360.9070,5.5753); //Camera
	}
	SetTimerEx("excam",reset_time*1000, false, "i", playerid);
	PlayerPlaySound(playerid,1150,0.0,0.0,0.0);
}

public Buspay(playerid,Float:x,Float:y,Float:z)
{
	new model= GetVehicleModel(GetPlayerVehicleID(playerid));
	if(IsPlayerInRangeOfPointEx(20,playerid,x,y,z))
	{
		if(model==437 || model==431)
		{
			GivePlayerMoneyA(playerid,MONEYP_AUTOBUSO_VAIRUOTOJAS);
			GameTextForPlayer(playerid,"Galite vaziuoti",1000,5);
			//SetPlayerScore(playerid,GetPlayerScore(playerid)+1);
			//TogglePlayerControllable(playerid,true);
		}
		else if(model==418)
		{
			GivePlayerMoneyA(playerid,MONEYP_MIKRO_VAIRUOTOJAS);
			GameTextForPlayer(playerid,"Galite vaziuoti",1000,5);
			//SetPlayerScore(playerid,GetPlayerScore(playerid)+1);
			//TogglePlayerControllable(playerid,true);
		}
		else if(model==408)
		{
			if(Ispyle[playerid]==1)
			{
				siuksliuDB[playerid][CPskaicius]=0;
				//SetPlayerScore(playerid,GetPlayerScore(playerid)+3);
				GivePlayerMoneyA(playerid,MONEYP_SIUKSLIAVEZIS);
				ProcessAchievement(playerid,76);
				GameTextForPlayer(playerid,"Galite vazuoti rinkti siuksliu",1000,5);
				Ispyle[playerid]=-1;
			}
			else if(VazuojaPilt[playerid]==1)
			{
				//SetPlayerScore(playerid,GetPlayerScore(playerid)+2);
				GameTextForPlayer(playerid,"Jusu siuksleveze pilna.\n Vazuokite i baze, kad ispiltumete siuskles.",2000,5);
			}
			else
			{
				//SetPlayerScore(playerid,GetPlayerScore(playerid)+1);
				GameTextForPlayer(playerid,"Galite vazuoti prie kito konteinerio",1000,5);
			}
		}
		else if(model == 537 || model == 538)
		{
			if(GetSpeedEx(GetPlayerVehicleID(playerid)) < 10)
			{
				GivePlayerMoneyA(playerid, MONEYP_TRAUKINISTAS);

				GameTextForPlayer(playerid,"Galite vaziuoti",1000,5);
				vehicleDB[GetPlayerVehicleID(playerid)][gas]=40.0;
			}
			else GameTextForPlayer(playerid,"Jums nebuvo sumoketa nes nesustojote!",3000,5);
		}
	} 
	else GameTextForPlayer(playerid,"Jums nebuvo sumoketa nes nesustojote!",3000,5);
}

