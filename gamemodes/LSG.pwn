public OnCameraReachNode(playerid, camera, node)
{
	if(playerDB[playerid][apmokymai]==0)
	{
		return 0;
	}
	/*new msg[128];
	format(msg,sizeof(msg),"Node %i",node);
	SendClientMessage(playerid, -1, msg);*/
	switch(node)
	{
		case 1,3,5,7,9,11,14,16,18,20,21,23,25,28,30,31:
		{
			if(node == 1)
				playerDB[playerid][apmokymai]=3;
			else
				playerDB[playerid][apmokymai]++;
			new title[30];
			new textasz[2048];
			new id = playerDB[playerid][apmokymai]-3;
			if(id < 0)
				id=0;
			retApmokymai(id,title,textasz);

			ShowPlayerDialog(playerid,755,DIALOG_STYLE_MSGBOX,title,BreakingLines(textasz),"Gerai","");
			if(id == 8) // PSYCHO
			{
				PlayAudioStreamForPlayer(playerid, "http://www.lsgyvenimas.lt/sounds/intro2.mp3");
			}
			if(node == 30)
			{
				SetPlayerPoz(playerid,1743.1915,-1944.5928,13.5661, _, _, 0);
				SetPlayerFacingAngle(playerid,173.6375);
			}
			if(node == 31)
			{
				ClearCameraID(camera);
				ExitCamera(playerid);
				SetPlayerPoz(playerid,1743.1915,-1944.5928,13.5661, _, _, 0);
				SetPlayerInterior(playerid, 0);
				SetPlayerFacingAngle(playerid,173.6375);
				SetCameraBehindPlayer(playerid);
				playerDB[playerid][apmokymai]=0;
				//TogglePlayerControllable(playerid,true);
				FirstSpawn[playerid] = 0;
				SetTimerEx("Freezing", 200, 0, "i",playerid);
				StopAudioStreamForPlayer(playerid);	
			}
		}
	}
	
	return 0;
}

public Apmokymai(playerid)
{
	if(!IsPlayerConnected(playerid)) return 1;
	TogglePlayerControllable(playerid,false);
	switch(playerDB[playerid][apmokymai])
	{
		case 1:
		{
			PlayAudioStreamForPlayer(playerid, "http://www.lsgyvenimas.lt/sounds/intro.mp3");
			playerDB[playerid][apmokymai]++;
			SetTimerEx("Apmokymai",1000,false,"i",playerid);
		}
		case 2:
		{
			print("Loading apmokymai!");
			new idas= LoadCameraMover("apmokymai");
			PlayCameraMover(playerid, idas);
		}
		case 3:
		{
			//ShowPlayerDialog(playerid,755,DIALOG_STYLE_MSGBOX,"Apmokymai","Sveiki atvyke i LSG!\nServeryje reikia saugoti zaidima. Tai galite padaryti hotelyje.\n{0066CC}Hoteli galite rasti parase /kur","Gerai","");
			//ShowPlayerDialog(playerid,755,DIALOG_STYLE_MSGBOX,APMOKYMAI[playerDB[playerid][apmokymai]-3][0],BreakingLines(APMOKYMAI[playerDB[playerid][apmokymai]-3][1]),"Gerai","");
			return 1;
		}
		
		
	}
	return 1;
}


stock ResetGunData(playerid)
{
	for(new i;i<13;i++) // update gun data
    {
		GunData[playerid][i][0] = 0;
		GunData[playerid][i][1] = 0;
    }
    ResetPlayerWeapons(playerid);
    NoCheck[playerid]=3;
    return 1;
}
stock UpdateGunData(playerid)
{
	new
        gWeaponData[13][2]
    ;

    if(UpdateWeaponsTimer[playerid] != -1)
   		return;

    for(new i;i<13;i++) // update gun data
    {
    	GetPlayerWeaponData(playerid, i, gWeaponData[i][0],gWeaponData[i][1]);

    	if(GunData[playerid][i][0] == gWeaponData[i][0])
    	{
    		if(0 <= gWeaponData[i][1] < GunData[playerid][i][1] && 0 <= GunData[playerid][i][1] <= 9999)
    		{
    			GunData[playerid][i][1] = gWeaponData[i][1];
    		}

    	}
    	else  // fuck their weapon
    	{
    		GunData[playerid][i][0] = 0;
    		GunData[playerid][i][1] = 0;
    	}

    }

}


forward GivePlayerWeaponEx(playerid,weaponid,ammo);
public GivePlayerWeaponEx(playerid,weaponid,ammo)
{
	if(weaponid > 46 && weaponid < 0)
		return 0;
	new slotz = GetWeaponsSlot(weaponid);
	/*if(!cmd) 
		if(ammo == -100) 
			ammo=100000;*/
	//playerDB[playerid][gunk][weaponid]=true;
	playerDB[playerid][gunk][weaponid]=true;

	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER)
		UpdateGunData(playerid);


	if(GunData[playerid][slotz][0] != weaponid)
	{
		GunData[playerid][slotz][0] = weaponid;
		GunData[playerid][slotz][1] = (ammo > 10000) ? (-100) : (ammo);
	} 
	else
	{
		if(GunData[playerid][slotz][1] == -100) // if had infinity keep infinity
			GunData[playerid][slotz][1] = -100;
		else
			GunData[playerid][slotz][1] += ammo;

		if(GunData[playerid][slotz][1] >= 10000) // became infinity
			GunData[playerid][slotz][1] = -100;
	}


	
	if(UpdateWeaponsTimer[playerid] == -1) // if we dont have a timer add it
	{
		ResetPlayerWeapons(playerid);
		UpdateWeaponsTimer[playerid] = SetTimerEx("UpdateWeapons", 100+GetPlayerPing(playerid), false, "ii", playerid,weaponid);
	}
	NoCheck[playerid]=3;

	return 1;
}
forward UpdateWeapons(playerid,weaponid);
public UpdateWeapons(playerid,weaponid)
{
	UpdateWeaponsTimer[playerid]=-1;
	if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER)
	{
		for(new i;i<13;i++) // update gun data
	    {
	    	new gun = GunData[playerid][i][0];
	    	new ammo = GunData[playerid][i][1];
	    	if(ammo == -100)
	    		ammo = 100000;
	    	if(ammo != 0)
	    		GivePlayerWeapon(playerid, gun, ammo);
	    	else
	    		GunData[playerid][i][0] = 0; // no ammo = no gun
	    }
	    if(weaponid != -1)
	   		SetPlayerArmedWeapon(playerid, weaponid);
	}
	SetPVarInt(playerid, "WeaponsTaken", 0);
	NoCheck[playerid]=3;
}

