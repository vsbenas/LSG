public OnPlayerSelectObject(playerid, type, objectid, modelid, Float:fX, Float:fY, Float:fZ)
{
	if(DEBUG==true) printf("OnPlayerSelectObject:%i",playerid);
	new houseid=GetPlayerHouseID(playerid);
	if(!houseid)
	{
		if(IsPlayerAdmin(playerid))
		{
			new Float:Ro[3];
			printf("Player %d selected object %d", playerid, objectid);
			if(type == SELECT_OBJECT_GLOBAL_OBJECT)
			{
				//SendClientMessage(playerid,COLOR,"Globalus objektas");
				GetObjectRot(objectid,Ro[0],Ro[1],Ro[2]);
				EditObject(playerid, objectid);
			}
			else
			{
				//SendClientMessage(playerid,COLOR,"Streamer objektas");
				GetPlayerObjectRot(playerid,objectid,Ro[0],Ro[1],Ro[2]);
				EditPlayerObject(playerid, objectid);
			}
			SendClientMessage(playerid, 0xFFFFFFFF, "You now are able to edit your object!");
			new msg[128];
			
			
			format(msg,sizeof(msg),"Modelid: %i, %.3f, %.3f, %.3f, rot: %.3f",modelid,fX,fY,fZ,Ro[2]);
			SendClientMessage(playerid, COLOR_PINK, msg);
		}
	}
	
	/*
    
	*/
    return 1;
}
stock IsProdEnvironment()
{
	return GetConsoleVarAsBool("announce");
}
public OnPlayerSelectDynamicObject(playerid, objectid, modelid, Float:x, Float:y, Float:z)
{
	if(DEBUG==true) printf("OnPlayerSelectDynamicObject:%i",playerid);
	new houseid = GetPlayerHouseID(playerid);
	new place = GetPlace(playerid);
	if(houseid && place == PLACE_HOUSE)
	{
		for(new i;i<MAX_BALDAI;i++)
		{
			if(BalduSistema[houseid][i][b_used])
			{
				if(BalduSistema[houseid][i][b_oid]==objectid)
				{
					new pname[MAX_PLAYER_NAME];
					GetPlayerName(playerid, pname, 24);
					if ( strcmp(hInfo[houseid][Name],pname,false) != 0) return SendInfoMessage(playerid,"Sis namas nepriklauso jums!");
					if(PlayerLastBaldai[playerid]==0)
					{
						new query[256];
						format(query,sizeof(query),"SELECT `pav` FROM `baldai_cat` WHERE id=%i LIMIT 1",BalduSistema[houseid][i][b_cat]);
						CancelEdit(playerid);
						mysql_function_query(SQL,query, true,"SQL_IsmestiBaldus","iii",playerid,houseid,i);
						return 1;
					}
					else if(PlayerLastBaldai[playerid]==-1)
					{
						//new query[256];
						//format(query,sizeof(query),"SELECT `pav` FROM `baldai_cat` WHERE id=%i LIMIT 1",BalduSistema[houseid][i][b_cat]);
						CancelEdit(playerid);
						SetPVarInt(playerid, "selected_baldas", i);

						ShowPlayerDialog(playerid, 6951, DIALOG_STYLE_INPUT, "Perveţimas", "Iveskite namo numerá, á kurá norite perveţti đá baldŕ.\nNamas turi bűti nupirktas.", "Gerai", "Atđaukti");


						//mysql_function_query(SQL,query, true,"SQL_IsmestiBaldus","iii",playerid,houseid,i);
						return 1;				
					}
					//EditDynamicObject(playerid, objectid);
					//break;
				}
			}
		}
	}
	else if(place == PLACE_WORLD)
	{
		HandleSelectWorldObject(playerid, objectid);
		return 1;
	}
	else
	{
		if(IsPlayerAdmin(playerid))
		{
			new Float:Ro[3];
			printf("Player %d selected object %d", playerid, objectid);
			GetDynamicObjectRot(objectid, Ro[0],Ro[1],Ro[2]);
			new msg[256];
			format(msg,256,"You now are able to edit your dynamic object %i!", objectid);
			SendClientMessage(playerid, 0xFFFFFFFF, msg);
			EditDynamicObject(playerid, objectid);
			SetPVarInt(playerid, "EditingID", objectid);
			
			format(msg,sizeof(msg),"Modelid: %i, %f, %f, %f, rot: %.3f %.3f %.3f",modelid,x,y,z,Ro[0],Ro[1],Ro[2]);
			SendClientMessage(playerid, COLOR_PINK, msg);
		}
	}
	SendClientMessage(playerid,WHITE," * Tai netinkamas baldas ismetimui ir pervezimui!");
	return 1;
}

