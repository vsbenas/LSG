stock Float:elc_GetVehicleSpeedXY(vehicleid)
{
	new Float:elc_SpeedX, Float:elc_SpeedY, Float:elc_SpeedZ;
	new Float:elc_Speed;
	GetVehicleVelocity(vehicleid, elc_SpeedX, elc_SpeedY, elc_SpeedZ);
	elc_Speed = floatsqroot(floatadd(floatpower(elc_SpeedX, 2.0), floatpower(elc_SpeedY, 2.0)));
	return floatmul(elc_Speed, 200.0);
}
#define MAX_VEHICLE_DISTANCE_UCM    10
new Float:LastCoords[MAX_PLAYERS][3];
new Float:LastVel[MAX_VEHICLES][3];
public OnUnoccupiedVehicleUpdate(vehicleid, playerid, passenger_seat, Float:new_x, Float:new_y, Float:new_z, Float:vel_x, Float:vel_y, Float:vel_z)
{
	/*new msg[128];
	format(msg,sizeof(msg),"Unoccupied update: %i %i %i %f %f %f",vehicleid, playerid, passenger_seat, new_x,new_y,new_z);
	SendClientMessageToAll(-1, msg);*/
	/**/
	if((new_x != new_x || new_y != new_y || new_z != new_z || vel_x != vel_x || vel_y != vel_y || vel_z != vel_z ||
        floatabs(new_x) >= 25000.0 || floatabs(new_y) >= 25000.0 || floatabs(new_z) >= 25000.0 ||
        floatabs(vel_x) >= 100.0 || floatabs(vel_y) >= 100.0 || floatabs(vel_z) >= 100.0))
    {
        AC_Kick(playerid,"CarShot");
        return 0;
    }
    if(vehicleid == carvid_0 || vehicleid == carvid_1 || vehicleid == carvid_2 || vehicleid == carvid_3 || vehicleid == carvid_4 || vehicleid == carvid_5)
	{
		return 0;
	}

	if(PlayerTeleportedSameCar[playerid][0] == vehicleid && passenger_seat > 0)
	{
		if(floatcmp(LastCoords[playerid][0],new_x) == 0 && floatcmp(LastCoords[playerid][1],new_y) == 0 && floatcmp(LastCoords[playerid][2],new_z) == 0)
		{
			PlayerTeleportedSameCar[playerid][1]++;
			if(PlayerTeleportedSameCar[playerid][1] >= 3 && GetPlayerState(playerid) != PLAYER_STATE_PASSENGER) 
			{
				/*Ispejimai[playerid]++;
				if(Ispejimai[playerid] >= 3)
					AC_Ban(playerid,"Car kicker");
				else*/
				
				new Float:distas;
				new foundas = 0;
				foreach(Player, i) {
					if(i != playerid) {
						distas = GetPlayerDistanceFromPoint(i, new_x,new_y,new_z);
						if(distas < 2.5) // its offset with -1 on z coord but just in case make it 2.5
						{
							new warn[64];
							format(warn,sizeof(warn),"Car kicker(on ID %i)",i);
							AC_Warn(playerid,warn);
							foundas = 1;
							break;
						}
					}
				}
				if(foundas == 0) {
					AC_Warn(playerid,"Car kicker??");
					return 0;
				}
				PlayerTeleportedSameCar[playerid][1]=0;	
			}
		}
	} 
	else
	{
		
		PlayerTeleportedSameCar[playerid][0]=vehicleid;
		PlayerTeleportedSameCar[playerid][1]=0;
		LastCoords[playerid][0] = new_x;
		LastCoords[playerid][1] = new_y;
		LastCoords[playerid][2] = new_z;
		
	}
	new Float:ac_x, Float:ac_y, Float:ac_z, Float:ac_dist = GetVehicleDistanceFromPoint(vehicleid, new_x, new_y, new_z);
    GetVehiclePos(vehicleid, ac_x, ac_y, ac_z);
    if(passenger_seat > 0)
    {
        new Float:ac_zDiff = new_z - ac_z;

        new bool:c1 = (vel_z >  LastVel[vehicleid][2]  || ac_zDiff >= -0.8) && 
        				(floatabs(vel_x) > floatabs(LastVel[vehicleid][0]) && floatabs(LastVel[vehicleid][0]) >= 0.3 
        					|| floatabs(vel_y) > floatabs(LastVel[vehicleid][1]) && floatabs(LastVel[vehicleid][1]) >= 0.3);


        new bool:c2 = ac_zDiff >= -5.0 && (floatabs(new_x - ac_x) >= 12.0 || floatabs(new_y - ac_y) >= 12.0);

		new warns = GetPVarInt(playerid,"CarshotWarn");
		if((c1 || c2) && ((GetTickCount() - LeftCarVehicle[vehicleid]) > 3000))
        {
        	
        	warns++;
        	SetPVarInt(playerid, "CarshotWarn", warns);
            if(warns > 4 && !playerDB[playerid][suristas] && !playerDB[playerid][ant])
            {
            	AC_Kick(playerid,"Carshot ");
            	return 0;
            }
			else
				AC_Warn(playerid,"Carshot ");
			
        }
        else if(warns)
        {
        	SetPVarInt(playerid, "CarshotWarn", warns-1);
        }
        LastVel[vehicleid][0] = vel_x;
        LastVel[vehicleid][1] = vel_y;
        LastVel[vehicleid][2] = vel_z;
        return 0;
	}

	if(ac_dist > 50)
    {
        // Reject the update
        new Float:VHP;
		GetVehicleHealth(vehicleid, VHP);
		if(!vehicleDB[vehicleid][dega] && VHP < vehicleDB[vehicleid][OldHP] &&  250.0 <= vehicleDB[vehicleid][OldHP] <= 1000.0)
		{
			SetVehicleHealth(vehicleid, vehicleDB[vehicleid][OldHP]);
		}
        return 0;
    }

	/*if(JobCars[vehicleid][0] != 0)
	{

		new job = JobCars[vehicleid][0];
		new n = JobCars[vehicleid][1];
		new Float:distsq = (new_x - DarbinesCar[job][n][DCX])*(new_x - DarbinesCar[job][n][DCX]) + (new_y - DarbinesCar[job][n][DCY])*(new_y - DarbinesCar[job][n][DCY]) + (new_z - DarbinesCar[job][n][DCZ])*(new_z - DarbinesCar[job][n][DCZ]);
		if(distsq > 9.0)
		{
			static LastRespawn[MAX_PLAYERS];
			static LastRespawnCar[MAX_PLAYERS];
			if(GetTickCount() - LastRespawn[playerid] > 5000 && LastRespawnCar[playerid] == vehicleid)
			{
				SetVehiclePos(DarbinesCar[job][n][DCcar],DarbinesCar[job][n][DCX],DarbinesCar[job][n][DCY],DarbinesCar[job][n][DCZ]);
				SetVehicleZAngle(DarbinesCar[job][n][DCcar],DarbinesCar[job][n][DCR]);
				LastRespawn[playerid] = GetTickCount();
				LastRespawnCar[playerid] = vehicleid;
			}
			return 0;
		}
	}*/
	
 
    /*if(dist > 20)
    {
		new tick = GetTickCount();
		if(tick - PlayerTeleported[playerid] > 5000)
		{
			new msg[127];
			format(msg,sizeof(msg),"Itariamas car teleport(%.1fm)",dist);
			AC_Warn(playerid,msg);
			PlayerTeleported[playerid]=tick;
		}
        return 0;
    }
	*/
	/*new Float:Coo[3];
	GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
	if(GetVehicleDistanceFromPoint(vehicleid, Coo[0],Coo[1],Coo[2]) > 20)
    {
        AC_Warn(playerid,"Itariamas car teleport(2)");
        return 0;
    }*/
	//if(GetPlayerWeapon(playerid)==46) SetPlayerArmedWeapon(playerid,0);
	/*if(GetVehicleModel(vehicleid) != 0)
	{
		new Float:elc_tempposx, Float:elc_tempposy, Float:elc_tempposz;
		GetVehiclePos(vehicleid, elc_tempposx, elc_tempposy, elc_tempposz);
		elc_tempposx = (new_x -elc_tempposx);
		elc_tempposy = (new_y -elc_tempposy);
		elc_tempposz = (new_z -elc_tempposz);
		new Float:XMVDUCM=elc_GetVehicleSpeedXY(vehicleid)+MAX_VEHICLE_DISTANCE_UCM;
		if(!((elc_tempposx < XMVDUCM) && (elc_tempposx > -XMVDUCM)) && ((elc_tempposy < XMVDUCM) && (elc_tempposy > -XMVDUCM)) && ((elc_tempposz < XMVDUCM) && (elc_tempposz > -XMVDUCM)))
		{
			SetVehiclePos(vehicleid, vehicleDB[vehicleid][lastpos][0],vehicleDB[vehicleid][lastpos][1],vehicleDB[vehicleid][lastpos][2]);
			SetVehicleZAngle(vehicleid,vehicleDB[vehicleid][lastpos][3]);
			AC_Warn(playerid,"Big Vehicle teleport");
			return 0;
		}
	}*/
	if(alarmed[vehicleid])
	{
		GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
		if(!VehVars[2] && vehicleid != Carlist[playerid][Carid] && vehicleid != Carlist2[playerid][Carid] && vehicleid != Carlist3[playerid][Carid])
		{
			SetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],true,-1,VehVars[4],VehVars[5],VehVars[6]);
			SetTimerEx("NoAlarm",5000,false,"i",vehicleid);
		}
	}
	if(vehicleDB[vehicleid][rankinis])
	{
		//new Float:Coo[3];
		//GetVehiclePos(vehicleid,Coo[0],Coo[1],Coo[2]);
		if(IsPlayerInRangeOfPointEx(15.0,playerid,new_x,new_y,new_z))
		{
			if(vehicleDB[vehicleid][lastpos][0] != 0.0)
			{
				if(vehicleDB[vehicleid][rankinischeck])
				{
					SetVehiclePos(vehicleid,vehicleDB[vehicleid][lastpos][0],vehicleDB[vehicleid][lastpos][1],vehicleDB[vehicleid][lastpos][2]);
					SetVehicleZAngle(vehicleid,vehicleDB[vehicleid][lastpos][3]);
					vehicleDB[vehicleid][rankinischeck]=false;
				}
				else
				{
					vehicleDB[vehicleid][rankinischeck]=true;
				}
				return 0;
			}
		}
	}
	return 1;
}
stock UzdetiSalma(playerid,model)
{
	if(IsPlayerAttachedObjectSlotUsed(playerid,CAP_SLOT))
		RemovePlayerAttachedObject(playerid,CAP_SLOT);
	new Float:size = 1.0;
	if(model ==18976)
		size = 1.2;
	switch(GetPlayerSkin(playerid))
	{
		case 0, 65, 74, 149, 208, 273:  SetPlayerAttachedObject(playerid, SALMO_SLOT, model, 2, 0.070000, 0.000000, 0.000000, 88.000000, 75.000000, 0.000000, size, size, size);
		case 1..6, 8, 14, 16, 22, 27, 29, 33, 41..49, 82..84, 86, 87, 119, 289: SetPlayerAttachedObject(playerid, SALMO_SLOT, model, 2, 0.070000, 0.000000, 0.000000, 88.000000, 77.000000, 0.000000, size, size, size);
		case 7, 10: SetPlayerAttachedObject(playerid, SALMO_SLOT, model, 2, 0.090000, 0.019999, 0.000000, 88.000000, 90.000000, 0.000000, size, size, size);
		case 9: SetPlayerAttachedObject(playerid, SALMO_SLOT, model, 2, 0.059999, 0.019999, 0.000000, 88.000000, 90.000000, 0.000000, size, size, size);
		case 11..13: SetPlayerAttachedObject(playerid, SALMO_SLOT, model, 2, 0.070000, 0.019999, 0.000000, 88.000000, 90.000000, 0.000000, size, size, size);
		case 15: SetPlayerAttachedObject(playerid, SALMO_SLOT, model, 2, 0.059999, 0.000000, 0.000000, 88.000000, 82.000000, 0.000000, size, size, size);
