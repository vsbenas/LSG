stock RenderTexts(playerid)
{
	for(new i;i<MAX_3DTEXTS;i++) if(TextExists[i])
	{
		if(Streamer_IsInArrayData(STREAMER_TYPE_3D_TEXT_LABEL, Text3D:i, E_STREAMER_PLAYER_ID, playerid))
		{
			Streamer_RemoveArrayData(STREAMER_TYPE_3D_TEXT_LABEL, Text3D:i, E_STREAMER_PLAYER_ID, playerid);
		}
		if(Streamer_IsInArrayData(STREAMER_TYPE_3D_TEXT_LABEL, Text3D:ConvertedText[i], E_STREAMER_PLAYER_ID, playerid))
		{
			Streamer_RemoveArrayData(STREAMER_TYPE_3D_TEXT_LABEL, Text3D:ConvertedText[i], E_STREAMER_PLAYER_ID, playerid);
		}
		new Text3D:id = Text3D:i;
		if(BitFlag_Get(PConfig[playerid],PCFG_RAIDES))
		{
			id = ConvertedText[i];
		}
		Streamer_AppendArrayData(STREAMER_TYPE_3D_TEXT_LABEL, id, E_STREAMER_PLAYER_ID, playerid);
	}
	return 1;
}

