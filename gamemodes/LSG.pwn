}

public LastSprinkles(playerid)
{
    Fountain1Time[playerid] = 0;
    Fountain2Time[playerid] = 0;
    Fountain3Time[playerid] = 0;
    DestroySprinkleID[playerid] = 0;
    return 1;
}

public FountainTimer(playerid)
{
