public LoadPlayerData(playerid)
{
	new name[MAX_PLAYER_NAME],file[128];
	GetPlayerName(playerid,name,sizeof(name));
	format(file,sizeof(file),"SELECT `Xp`,`Gangas` FROM `Account` WHERE Name = '%s' LIMIT 1",name);
	mysql_function_query(SQL, file, true, "SQL_XPCheck", "i", playerid);
	return 1;
}
stock MakePurchase(playerid, purchaseList:purchase, extraid = 0)
{
	new oldkred = playerDB[playerid][kreditai];
	if(purchase == PURCHASE_CARSLOT)
	{
		if(!GiveKreditai(playerid, -50))
		{
			ShowSaugykla(playerid);
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			return 1;
		}
		
		new query[256];
		format(query,sizeof(query),"INSERT INTO `CarSaugykla` (`Vardas`,`Typ`) VALUES ('%s',-1)",ReturnName(playerid));
		mysql_query(query);
		SendInfoMessage(playerid,"~g~Sekmingai nusipirkai vieta automobiliui!");
		ShowSaugykla(playerid);
		ProcessAchievement(playerid, 111);
	}
	if(purchase == PURCHASE_VIP)
	{
		if(!GiveKreditai(playerid, -30))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		new query[256];
		format(query,sizeof(query),"UPDATE `Account` SET `Vip`=`Vip`+30 WHERE `Name` = '%s'",ReturnName(playerid));
		mysql_query(query);
		SendInfoMessage(playerid,"Papildete savo vip saskaita 30 dienu!");
		playerDB[playerid][vip]=true;
	}
	if(purchase == PURCHASE_UNBAN)
	{
		new cost = extraid;
		if(!GiveKreditai(playerid, -cost)) //playerDB[playerid][kreditai] < cost)
		{
			new msg[128];
			format(msg,sizeof(msg)," * Jums neuţtenka kreditř! Unbanui reikia bent %i",cost);
			SendClientMessage(playerid,RED,msg);
			new msz[128];
			format(msz,128,"Pirkti kreditus(turite %i)\nGauti unban(%i kreditu)",playerDB[playerid][kreditai],cost);
			ShowPlayerDialog(playerid, 1990, DIALOG_STYLE_LIST, "Kreditai",msz,"Taip","Ne");
			return 1;
		}
		ProcessAchievement(playerid, 123);
		new ip[20];
		GetPlayerIp(playerid,ip,sizeof(ip));
		new uzrasas[128];
		format(uzrasas,128,"DELETE FROM `BANS` WHERE `Vardas` = '%s' or `IP`='%s' LIMIT 1",ReturnName(playerid),ip);
		mysql_query(uzrasas);
		SendInfoMessage(playerid,"~r~Jusu banas buvo nuimtas. Prasome prisijungti is naujo.");
		MLog(playerid,"Atsibanino","s", ip);
		KickEx(playerid);
	}
	if(purchase == PURCHASE_UNJAIL)
	{
		if(!playerDB[playerid][ikalintas]) return SendInfoMessage(playerid,"~r~Jus nesedite kalejime!");
		if(!GiveKreditai(playerid, -5))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		playerDB[playerid][kalejimo_laikas]=1;
		ProcessAchievement(playerid,25);
		SendInfoMessage(playerid,"Jus buvote paleistas is kalejimo!");
	}
	if(purchase == PURCHASE_IST)
	{
		if(GetPlayerWantedLevel(playerid) < 1) return SendInfoMessage(playerid,"~r~Jus neturite zvaigzduciu!");
		if(!GiveKreditai(playerid, -1))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		SetPlayerWantedLevel(playerid, GetPlayerWantedLevel(playerid)-1);
		SendInfoMessage(playerid,"Jums buvo nuimta zvaigzdute!");
	}
	if(purchase == PURCHASE_TEISES)
	{
		if(!GiveKreditai(playerid, -10))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		playerDB[playerid][teises]=true;
		playerDB[playerid][teisesm]=true;
		playerDB[playerid][teisess]=true;
		SendInfoMessage(playerid,"Jums buvo suteiktos visos teises!");
	}
	if(purchase == PURCHASE_SPAZ)
	{
		if(!GiveKreditai(playerid, -10))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		playerDB[playerid][spaz]=true;
		new uzrasas[128];
		format(uzrasas,128,"UPDATE `Account` SET `MLicense`= 30 WHERE `Name` = '%s'",ReturnName(playerid));
		mysql_query(uzrasas);
		SendInfoMessage(playerid,"Jums buvo suteiktas sveikatos pazymejimas menesiui!");
	}
	if(purchase == PURCHASE_GESINTUVAS)
	{
		if(!GiveKreditai(playerid, -1))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		SendInfoMessage(playerid,"Nusipirkote gesintuva!");
		GivePlayerWeaponEx(playerid,42,1500); //pompa
	}
	if(purchase == PURCHASE_FIX)
	{
		if(GetTickCount() - GetPVarInt(playerid, "LastCarFix") < 2 * 60 * 1000)
		{
			return SendInfoMessage(playerid,"Automobili gali taisyti tik kas 2 min");
		}
		if(!IsPlayerInAnyVehicle(playerid) && fs_balloon_pl[playerid][0] != 1)
		{
			SendInfoMessage(playerid,"Turite sedeti automobilyje!");
			return 1;
		}
		if(!GiveKreditai(playerid, -1))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		SetPVarInt(playerid, "LastCarFix", GetTickCount());
		if(IsPlayerInAnyVehicle(playerid))
		{
			LogA(playerid,"Pataise car");
			SendInfoMessage(playerid,"Pataisete automobili!");
			RepairVehicle(GetPlayerVehicleID(playerid));
		}
		else if(fs_balloon_pl[playerid][0] == 1)
		{
			LogA(playerid,"Pataise car");
			SendInfoMessage(playerid,"Pataisete automobili!");
			fs_balloon_set[fs_balloon_pl[playerid][1]][4] = MAX_BALLOON_HP;
		}
	}
	if(purchase == PURCHASE_SOTUMAS)
	{
		if(!GiveKreditai(playerid, -1))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		playerDB[playerid][sotumas]=90.0;
		SendInfoMessage(playerid,"Pasikelete sotuma!");
	}
	if(purchase == PURCHASE_SKIN)
	{
		if(!GiveKreditai(playerid, -10))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		new skinid = extraid;
		SetPlayerSkin(playerid,skinid);
		playerDB[playerid][drabuziai]=skinid;
		SendInfoMessage(playerid,"Sveikiname nusipirkus naujaji skina!");
		new uzrasas[256];
		//SendClientMessage(playerid,RED," * Butinai issaugokite zaidima, antraip dings jusu skinas.");
		format(uzrasas,sizeof(uzrasas),"INSERT INTO `Spinta`(`Vardas`,`Skin`,`LastUsed`) VALUES ('%s',%i,NOW())",ReturnName(playerid),skinid);
		mysql_query(uzrasas);
		ProcessAchievement(playerid,48);
	}
	if(purchase == PURCHASE_LOTO)
	{
		if(!GiveKreditai(playerid, -100))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		playerDB[playerid][loterijos]++;
		ShowPlayerDialog(playerid, 2333, DIALOG_STYLE_MSGBOX,"Loterija","Sveikiname nusipirkus loterijos bilietŕ.\n\nJá panaudoti galite parađć {EE0000}/loto\nJei đios dienos siűlomi automobiliai jűsř nedomina - loterijoje dalyvaukite rytoj.","Gerai","");
	}
	if(purchase == PURCHASE_SPALVA)
	{
		if(!GiveKreditai(playerid, -20))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		new listitem = extraid;
		SendInfoMessage(playerid,"Sveikiname nusipirkus naujaja spalva!");
		SendClientMessage(playerid,YELLOW," * Spalva galite pasirinkti inventoriuje parađć /i");
		//ShowPlayerDialog(playerid,2001,DIALOG_STYLE_LIST,"Spalvos","Balta\nPilka\nZalia\nMelyna\nZydra\nRozine\nOranzine\nRaudona\nGeltona","Gerai","Atsaukti");
		new string[128];
		switch(listitem)
		{
			case 0: format(string,sizeof(string),"0xFFFFFFFF"),SetPlayerColor(playerid,0xFFFFFFFF);
			case 1: format(string,sizeof(string),"0xCCCCCCFF"),SetPlayerColor(playerid,0xA8A8A8FF);//SetPlayerColor(playerid,0xCCCCCCFF);
			case 2: format(string,sizeof(string),"0x00FF00FF"),SetPlayerColor(playerid,0x00FF00FF);
			case 3: format(string,sizeof(string),"0x0033FFFF"),SetPlayerColor(playerid,0x0033FFFF);
			case 4: format(string,sizeof(string),"0x33FFFFFF"),SetPlayerColor(playerid,0x33FFFFFF);
			case 5: format(string,sizeof(string),"0xFF00FFFF"),SetPlayerColor(playerid,0xFF00FFFF);
			case 6: format(string,sizeof(string),"0xFF6600FF"),SetPlayerColor(playerid,0xFF6600FF);
			case 7: format(string,sizeof(string),"0xFF0000FF"),SetPlayerColor(playerid,0xFF0000FF);
			case 8: format(string,sizeof(string),"0xFFFF00FF"),SetPlayerColor(playerid,0xFFFF00FF);
			// naujos spalvos comming up:
			//{FFCCCC}Sviesiai rozine\n{33FFCC}Electric\n{003300}Tamsiai zalia\n{660000}Tamsiai raudona\n{CCFFFF}Sviesiai melyna\n{6600CC}Violetine
			case 9: format(string,sizeof(string),"0xFFCCCCFF"),SetPlayerColor(playerid,0xFFCCCCFF);
			case 10: format(string,sizeof(string),"0x33FFCCFF"),SetPlayerColor(playerid,0x33FFCCFF);
			case 11: format(string,sizeof(string),"0x003300FF"),SetPlayerColor(playerid,0x003300FF);
			case 12: format(string,sizeof(string),"0x660000FF"),SetPlayerColor(playerid,0x660000FF);
			case 13: format(string,sizeof(string),"0xCCFFFFFF"),SetPlayerColor(playerid,0xCCFFFFFF);
			case 14: format(string,sizeof(string),"0x6600CCFF"),SetPlayerColor(playerid,0x6600CCFF);
		}
		new query[150];
		format(query,sizeof(query),"UPDATE Spalvos Set `Set`=0 WHERE Vardas='%s'",ReturnName(playerid));
		mysql_query(query);
		format(query,sizeof(query),"INSERT INTO Spalvos (Vardas,Color,`Set`) VALUES ('%s','%s',1)",ReturnName(playerid),string);
		mysql_query(query);
	}
	if(purchase == PURCHASE_STILIUS)
	{
		if(!GiveKreditai(playerid, -10))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		SendInfoMessage(playerid,"Sveikiname nusipirkus naujaji stiliu!");
		playerDB[playerid][wstyle]=extraid;
		new uzrasas[128];
		format(uzrasas,sizeof(uzrasas),"INSERT INTO `Stiliai`(`Vardas`,`Stilius`) VALUES ('%s',%i)",ReturnName(playerid),extraid);
		mysql_query(uzrasas);
	}
	if(purchase == PURCHASE_NUMERIAI)
	{
		if(playerDB[playerid][paskutinisrubas]==0) return SendInfoMessage(playerid,"O kur tavo masina?");
		new inputtext[128];
		GetPVarString(playerid, "MasinosNr", inputtext, 128); // SetPVarString(playerid,"MasinosNr", inputtext);
		if(strlen(inputtext) < 3)
		{
			return SendInfoMessage(playerid,"Klaida!");
		}
		if(!GiveKreditai(playerid, -10))
		{
			SendInfoMessage(playerid,"~r~Truksta kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}

		if(playerDB[playerid][paskutinisrubas]==1)
		{
			GetVehiclePos(Carlist[playerid][Carid],Carlist[playerid][X],Carlist[playerid][Y],Carlist[playerid][Z]);
			GetVehicleZAngle(Carlist[playerid][Carid],Carlist[playerid][Rotation]);
			Carlist[playerid][VirtualW] = GetVehicleVirtualWorld(Carlist[playerid][Carid]);
			new carid = Carlist[playerid][Carid];
			Carlist[playerid][Gas]=floatround(vehicleDB[carid][gas]);
			Carlist[playerid][Energy]=floatround(vehicleDB[carid][energy]);
			Carlist[playerid][Rida] = vehicleDB[carid][rida];
			SetVehicleParamsForAll(Carlist[playerid][Carid],0,0);
			DestroyVehicle(Carlist[playerid][Carid]);
			Carlist[playerid][Carid]=-1;
			Carlist[playerid][Carid]=CreateTunedCar(playerid);
			new stringas[50];
			new msg[128];
			format(stringas,sizeof(stringas),"%s",inputtext);
			format(msg,sizeof(msg),"Aciu, kad naudojates musu paslaugomis! Jusu naujas numeris: %s",stringas);
			SendInfoMessage(playerid,msg);
			format(stringas,sizeof(stringas),"{000000}%s",stringas);
			SetVehicleNumberPlate(Carlist[playerid][Carid],stringas);
			format(Carlist[playerid][NumPlate],50,stringas);
			playerDB[playerid][paskutinisrubas]=0;
		}
		else if(playerDB[playerid][paskutinisrubas]==2)
		{
			GetVehiclePos(Carlist2[playerid][Carid],Carlist2[playerid][X],Carlist2[playerid][Y],Carlist2[playerid][Z]);
			GetVehicleZAngle(Carlist2[playerid][Carid],Carlist2[playerid][Rotation]);
			Carlist2[playerid][VirtualW] = GetVehicleVirtualWorld(Carlist2[playerid][Carid]);
			new carid = Carlist2[playerid][Carid];
			Carlist2[playerid][Gas]=floatround(vehicleDB[carid][gas]);
			Carlist2[playerid][Energy]=floatround(vehicleDB[carid][energy]);
			Carlist2[playerid][Rida] = vehicleDB[carid][rida];
			SetVehicleParamsForAll(Carlist2[playerid][Carid],0,0);
			DestroyVehicle(Carlist2[playerid][Carid]);
			Carlist2[playerid][Carid]=-1;
			Carlist2[playerid][Carid]=CreateTunedCar2(playerid);
			new stringas[50];
			new msg[128];
			format(stringas,sizeof(stringas),"%s",inputtext);
			format(msg,sizeof(msg),"Aciu, kad naudojates musu paslaugomis! Jusu naujas numeris: %s",stringas);
			SendInfoMessage(playerid,msg);
			format(stringas,sizeof(stringas),"{000000}%s",stringas);
			SetVehicleNumberPlate(Carlist2[playerid][Carid],stringas);
			format(Carlist2[playerid][NumPlate],50,stringas);
			playerDB[playerid][paskutinisrubas]=0;
		}
		else if(playerDB[playerid][paskutinisrubas]==3)
		{
			GetVehiclePos(Carlist3[playerid][Carid],Carlist3[playerid][X],Carlist3[playerid][Y],Carlist3[playerid][Z]);
			GetVehicleZAngle(Carlist3[playerid][Carid],Carlist3[playerid][Rotation]);
			Carlist3[playerid][VirtualW] = GetVehicleVirtualWorld(Carlist3[playerid][Carid]);
			new carid = Carlist3[playerid][Carid];
			Carlist3[playerid][Gas]=floatround(vehicleDB[carid][gas]);
			Carlist3[playerid][Energy]=floatround(vehicleDB[carid][energy]);
			Carlist3[playerid][Rida] = vehicleDB[carid][rida];
			SetVehicleParamsForAll(Carlist3[playerid][Carid],0,0);
			DestroyVehicle(Carlist3[playerid][Carid]);
			Carlist3[playerid][Carid]=-1;
			Carlist3[playerid][Carid]=CreateTunedCar3(playerid);
			new stringas[50];
			new msg[128];
			format(stringas,sizeof(stringas),"%s",inputtext);
			format(msg,sizeof(msg),"Aciu, kad naudojates musu paslaugomis! Jusu naujas numeris: %s",stringas);
			SendInfoMessage(playerid,msg);
			format(stringas,sizeof(stringas),"{000000}%s",stringas);
			SetVehicleNumberPlate(Carlist3[playerid][Carid],stringas);
			format(Carlist3[playerid][NumPlate],50,stringas);
			playerDB[playerid][paskutinisrubas]=0;
		}
	}
	if(purchase == PURCHASE_VARDAS)
	{
		if(playerDB[playerid][kreditai] < 25)
		{
			SendInfoMessage(playerid,"~r~Neuztenka kreditu!");
			new kredita[30];
			format(kredita,sizeof(kredita),"Turite %i kreditř",playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 1989, DIALOG_STYLE_TABLIST, kredita , PASLAUGU_DIALOG, "Pirkti", "Atsaukti");
			return 1;
		}
		new inputtext[24];
		GetPVarString(playerid, "NewName", inputtext, 24);

		new currentname[24];
		GetPlayerName(playerid,currentname,24);
		new isejo2 = SetPlayerName(playerid, inputtext);
		new isejo = InvalidNickKick(playerid, false);

		if(isejo==1)
		{
			SetPlayerName(playerid,currentname);
			return ShowPlayerDialog(playerid,89,DIALOG_STYLE_INPUT,"Vardo keitimas","Jusu Vardas turi buti Vardas_Pavarde formatu.\nIveskite pageidaujama varda savo veikejui.\nVardas gali buti lietuviskas arba angliskas.{FF0000}\nJusu vardas netinkamas.","Gerai","Atgal");
		}
		else if(isejo2==-1 || extraid == 1)
		{
			SetPlayerName(playerid,currentname);
			return ShowPlayerDialog(playerid,89,DIALOG_STYLE_INPUT,"Vardo keitimas","Jusu Vardas turi buti Vardas_Pavarde formatu.\nIveskite pageidaujama varda savo veikejui.\nVardas gali buti lietuviskas arba angliskas.{FF0000}\nToks vardas jau naudojamas.","Gerai","Atgal");
		}
		else if(isejo2==0)
		{
			SetPlayerName(playerid,currentname);
			return ShowPlayerDialog(playerid,89,DIALOG_STYLE_INPUT,"Vardo keitimas","Jusu Vardas turi buti Vardas_Pavarde formatu.\nIveskite pageidaujama varda savo veikejui.\nVardas gali buti lietuviskas arba angliskas.{FF0000}\nTai dabartinis jusu vardas.","Gerai","Atgal");
		}
		else SendInfoMessage(playerid,"~g~Vardo keitimas sekmingas!");

		NameChangeQuery(currentname, inputtext);

		MLog(playerid,"Vardo keitimas is","s",currentname);

		GiveKreditai(playerid, -25);
		
		GetPlayerName(playerid, StoredNames[playerid], MAX_PLAYER_NAME);
		
	}
	new difference = oldkred - playerDB[playerid][kreditai];
	if(difference != 0)
		LogSpend(playerid, difference, purchase, extraid);
	return 1;
}

stock NameChangeQuery(currentname[], newname[])
{
	new query[256];
	format(query,sizeof(query),"UPDATE `Account` SET `Name`='%s' WHERE `Name`='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Bizniai` SET `Owner`='%s' WHERE `Owner`='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Namai` SET `Name`='%s' WHERE `Name`='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Namai` SET `Renter`='%s' WHERE `Renter`='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Cars` SET `Owner`='%s' WHERE `Owner`='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Gangs` SET `Leader`='%s' WHERE `Leader`='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Config` SET `value`='%s' WHERE `value`='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE Spinta Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Kaledos11` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Bagazine` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Stiliai` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Spalvos` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Darbines` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `gangcars` Set lastuser='%s' WHERE lastuser='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Pastas` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Discord` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Achievements` Set Name='%s' WHERE Name='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Kaledos` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `CarSaugykla` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `Phones` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	format(query,sizeof(query),"UPDATE `PlayerKVS` Set Vardas='%s' WHERE Vardas='%s'",newname,currentname);
	mysql_query(query);
	//format(query,sizeof(query),"UPDATE `Worlds` Set owner='%s' WHERE owner='%s'", newname, currentname);
	//mysql_query(query);
	foreach(Businesses,i)
	{
		if(BusinessInfo[i][bOwned] && strcmp(BusinessInfo[i][bOwner],currentname,false) == 0)
		{
			format(BusinessInfo[i][bOwner],24,newname);
			new idx =i;
			new string[128];
			format(string, sizeof(string), VERSLAS_NEPARDUODAMAS, BusinessInfo[i][bName],BusinessInfo[i][bOwner],GetBussinessType(BusinessInfo[idx][bType]));
			DestroyDynamic3DTextLabel(businesstext[i]);
			businesstext[i] = CreateDynamic3DTextLabel(string,0x00BC00FF,BusinessInfo[i][bEnterX],BusinessInfo[i][bEnterY],BusinessInfo[i][bEnterZ],40.0, _,_, 1);
		}
	}
	foreach(Houses,i)
	{
		if(0==strcmp(currentname,hInfo[i][Name],false))
		{
			format(hInfo[i][Name],24,newname);
			new zinute[128];
			new houseid = i;
			DestroyDynamic3DTextLabel(HouseText[houseid]);
			format(zinute,sizeof(zinute),"{FFFFFF}Namas Nr.: {FF0000}%i\n{FFFFFF}Savininkas: {FF0000}%s",houseid,hInfo[houseid][Name]);
			new vw;
			if(hInfo[houseid][daugiabutis]) vw=(MAX_HOUSES*2+MAX_BUSINESSES+hInfo[houseid][daugiabutis]-1);
			HouseText[houseid] = CreateDynamic3DTextLabel(zinute, COLOR_WHITE, hInfo[houseid][iconx], hInfo[houseid][icony], hInfo[houseid][iconz], 50, _,_, 1,vw);
		}
		if(0==strcmp(currentname,hInfo[i][Renter],false))
		{
			format(hInfo[i][Renter],24,newname);
		}
	}
	for(new i; i<MAX_FAMILY;i++)
	{
		if(0==strcmp(FamilyInfo[i][FamilyLeader],currentname,false))
			format(FamilyInfo[i][FamilyLeader],MAX_PLAYER_NAME,"%s",newname);
		if(0==strcmp(FamilyInfo[i][FamilySubstitute],currentname,false))
			format(FamilyInfo[i][FamilySubstitute],MAX_PLAYER_NAME,"%s",newname);
	}
}

stock LogSpend(playerid, amount, purchaseList:purchase, extraid = 0)
{
	new service[50];
	switch(purchase)
	{
		case PURCHASE_NONE: service="None";
		case PURCHASE_CARSLOT: service="Carslot";
		case PURCHASE_VIP: service="Vip";
		case PURCHASE_UNBAN: service="Unban";
		case PURCHASE_UNJAIL: service="Unjail";
		case PURCHASE_IST: service="Ist";
		case PURCHASE_TEISES: service="Teises";
		case PURCHASE_SPAZ: service="Spaz";
		case PURCHASE_GESINTUVAS: service="Gesintuvas";
		case PURCHASE_FIX: service="Carfix";
		case PURCHASE_SOTUMAS: service="Sotumas";
		case PURCHASE_SKIN: service="Skin";
		case PURCHASE_LOTO: service="Loto";
		case PURCHASE_SPALVA: service="Spalva";
		case PURCHASE_STILIUS: service="Stilius";
		case PURCHASE_NUMERIAI: service="Numeriai";
		case PURCHASE_VARDAS: service="Vardas";
		default: service="Nezinomas";
	}
	new query[512];
	format(query,sizeof(query),"INSERT INTO Kreditai (Name,Action,Amount,Time,Service,Details) VALUES ('%s','spend','%i',NOW(),'%s','%i')",ReturnName(playerid),amount,service,extraid);
	mysql_query(query);
}
stock LogKredituSell(playerid, amount, toplayerid, price)
{
	new query[512];
	format(query,sizeof(query),"INSERT INTO Kreditai (Name,Action,Amount,Time,Buyer,Price) VALUES ('%s','sell','%i',NOW(),'%s','%i')",ReturnName(playerid),amount,ReturnName(toplayerid),price);
	mysql_query(query);
}
stock GiveKreditai(playerid, amount)
{
	if(!IsPlayerConnected(playerid))
	{
		return 0;
	}
	if(playerDB[playerid][kreditai] + amount < 0)
	{
		return 0;
	}

	printf("[kred] %s %i",ReturnName(playerid),amount);
	playerDB[playerid][kreditai] += amount;
	new query[128];
	format(query,128,"UPDATE `Account` SET `Kreditai` = `Kreditai`+(%i) WHERE `Name` = '%s'",amount,ReturnName(playerid));
	mysql_query(query);
	format(query,128,"SELECT Kreditai From Account WHERE `Name` = '%s'",ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_UpdateKred5", "i",playerid);
	return 1;
}

