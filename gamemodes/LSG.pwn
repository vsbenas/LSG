		{
			new gTrailer = GetVehicleTrailer(vehicleid);
			DetachTrailerFromVehicle(vehicleid);
			new x=0;
			if(vehicleDB[gTrailer][dega])
			{
				vehicleDB[gTrailer][dega]=0;
				Iter_Remove(Deganti,gTrailer);
				vehicleDB[gTrailer][sprogs]=0;
