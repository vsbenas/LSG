public CreateRoll(Rollid, Float:xla, Float:yla, Float:zla)
{
	RollParts[Rollid][1] = CreateDynamicObject(1654,xla,yla,zla, 90, 90, 0);
	RollParts[Rollid][2] = CreateDynamicObject(1654,(xla+0.25),yla,zla, 90, 90, 0);
	RollParts[Rollid][3] = CreateDynamicObject(1654,(xla+0.50),yla,zla, 90, 90, 0);
	RollParts[Rollid][4] = CreateDynamicObject(1654,(xla+0.75),yla,zla, 90, 90, 0);
	RollParts[Rollid][5] = CreateDynamicObject(1654,(xla+1.00),yla,zla, 90, 90, 0);
	RollParts[Rollid][6] = CreateDynamicObject(1654,(xla+1.25),yla,zla, 90, 90, 0);
	RollParts[Rollid][7] = CreateDynamicObject(1654,xla,(yla+0.1),zla, 90, 90, 0);
	RollParts[Rollid][8] = CreateDynamicObject(1654,(xla+0.25),(yla+0.1),zla, 90, 90, 0);
	RollParts[Rollid][9] = CreateDynamicObject(1654,(xla+0.50),(yla+0.1),zla, 90, 90, 0);
	RollParts[Rollid][10] = CreateDynamicObject(1654,(xla+0.75),(yla+0.1),zla, 90, 90, 0);
	RollParts[Rollid][11] = CreateDynamicObject(1654,(xla+1.00),(yla+0.1),zla, 90, 90, 0);
	RollParts[Rollid][12] = CreateDynamicObject(1654,(xla+1.25),(yla+0.1),zla, 90, 90, 0);
	UpdateStreamerFW(xla,yla,zla);
	return 1;
}

public DestroyRoll(Rollid)
{
	new Float:xla, Float:yla, Float:zla;
	GetDynamicObjectPos(RollParts[Rollid][1], xla, yla, zla);
	for(new i=1; i != 13; i++) 
		DestroyDynamicObject(RollParts[Rollid][i]);
	UpdateStreamerFW(xla,yla,zla);
	return 1;
}

