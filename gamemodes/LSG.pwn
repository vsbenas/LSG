/*--------------------------------------------------------------------------------------------------
        Function:
                AdjustVector
        Params:
                & Float: vX - x Vector to adjust
                & Float: vY - y Vector to adjust
                & Float: vZ - z Vector to adjust
                Float: oX - x Offset Vector
                Float: oY - y Offset Vector
                const Float: oZ - z Offset Vector
        Return:
                -
        Notes:
                Adjust the vector with the offset
--------------------------------------------------------------------------------------------------*/
 
/*
	GetPlayerCameraWeaponVector by Nero_3D

	native GetPlayerCameraWeaponVector(playerid, & Float: vX, & Float: vY, & Float: vZ);
 */
/*
static AdjustVector(& Float: vX, & Float: vY, & Float: vZ, const Float: oX, const Float: oY, const Float: oZ) {
	switch(floatround(atan2(vX, vY) / 45.0, floatround_floor)) {
		case -1:	vX += oX, vY += oY, vZ += oZ;
		case -2:	vX += oY, vY += oX, vZ += oZ;
		case -3:	vX -= oY, vY += oX, vZ += oZ;
		case -4:	vX -= oX, vY += oY, vZ += oZ;
		case 0:		vX += oX, vY -= oY, vZ += oZ;
		case 1:		vX += oY, vY -= oX, vZ += oZ;
		case 2:		vX -= oY, vY -= oX, vZ += oZ;
		case 3:		vX -= oX, vY -= oY, vZ += oZ;
	}
	return false;
}

stock GetPlayerCameraWeaponVector(playerid, & Float: vX, & Float: vY, & Float: vZ) {
	if(GetPlayerCameraFrontVector(playerid, vX, vY, vZ)) {
		new
			weapon
		;
		if(21 < (weapon = GetPlayerWeapon(playerid)) < 39) {
			switch(weapon) {
				case WEAPON_SNIPER, WEAPON_ROCKETLAUNCHER, WEAPON_HEATSEEKER: {}
				case WEAPON_RIFLE: {
					AdjustVector(vX, vY, vZ, 0.016204, 0.009899, 0.047177);
				}
				case WEAPON_AK47, WEAPON_M4: {
					AdjustVector(vX, vY, vZ, 0.026461, 0.013070, 0.069079);
				}
				default: {
					AdjustVector(vX, vY, vZ, 0.043949, 0.015922, 0.103412);
				}
			}
			return true;
		}
	}
	return false;
}
*/
// new version
stock GetPlayerCameraWeaponVector(playerid, & Float: vX, & Float: vY, & Float: vZ) {
	if(GetPlayerCameraFrontVector(playerid, vX, vY, vZ)) {
		switch(GetPlayerWeapon(playerid)) {
			case WEAPON_SNIPER, WEAPON_ROCKETLAUNCHER, WEAPON_HEATSEEKER: {
				return true;
			}
			case WEAPON_RIFLE: {
				vY = atan2(vX, vY) + 5.0 * floatpower(vZ, 6.0) + 1.1;
				vZ = asin(vZ) - 0.0163 * vZ + 2.0158;

				vX = floatsin(vY, degrees) * floatcos(vZ, degrees);
				vY = floatcos(vY, degrees) * floatcos(vZ, degrees);
				vZ = floatsin(vZ, degrees);
				return true;
			}
			case WEAPON_AK47, WEAPON_M4: {
				vY = atan2(vX, vY) + 3.3 * floatpower(vZ, 4.0) + 1.6;
				vZ = asin(vZ) - 0.0582 * vZ + 3.0083;

				vX = floatsin(vY, degrees) * floatcos(vZ, degrees);
				vY = floatcos(vY, degrees) * floatcos(vZ, degrees);
				vZ = floatsin(vZ, degrees);
				return true;
			}
			case WEAPON_COLT45 .. WEAPON_MP5, WEAPON_TEC9, WEAPON_FLAMETHROWER, WEAPON_MINIGUN: {
				vY = atan2(vX, vY) + 4.25 * floatpower(vZ + 0.05, 4.0) + 2.4;
				vZ = asin(vZ) - 0.1347 * vZ + 4.5065;

				vX = floatsin(vY, degrees) * floatcos(vZ, degrees);
				vY = floatcos(vY, degrees) * floatcos(vZ, degrees);
				vZ = floatsin(vZ, degrees);
				return true;
			}
		}
	}
	return false;
}


new LastDrunk[MAX_PLAYERS];
new LastFPS[MAX_PLAYERS];
new Float:AimAngle[MAX_PLAYERS];
stock SpectateInfo(playerid,isvehicle,speed=0,Float:vehhp=0.0)
{
	static str[256],Float:HP,Float:AR;
	new Float:distas;
	new Float:loss = NetStats_PacketLossPercent(playerid);
	new drunk = GetPlayerDrunkLevel(playerid);
	new FPSx = LastDrunk[playerid]-drunk;
	if(FPSx == 0) {
		FPSx = LastFPS[playerid];
	}
	else
		LastFPS[playerid]=FPSx;
	new adminas = PlayerSpectated[playerid];
	LastDrunk[playerid]=drunk;
	//new FPSx = LastFPS[playerid];
	/*static senasspeed[MAX_PLAYERS];
	static senastaimas[MAX_PLAYERS];
	static Float:pagreitis[MAX_PLAYERS]; */
	GetPlayerHealth(playerid,HP);
	GetPlayerArmour(playerid,AR);
	if(isvehicle)
	{
		/*new taimas = GetTickCount();
		new Float:temp = (speed-senasspeed[playerid])/((taimas - senastaimas[playerid])/1000);
		if(temp > 0.1) pagreitis[playerid]=temp;*/
		format(str,256,"HP:~r~%i~n~~w~AR:~r~%i~n~~w~VHP:~r~%i~n~~w~Greitis:~r~%i~n~~w~Degalai:~r~%.1fL~n~~w~FPS:~r~%i~n~~w~LAG:~r~%.2f~n~~w~Rida:~r~%i",floatround(HP),floatround(AR),floatround(vehhp),speed,vehicleDB[isvehicle-1][gas],FPSx,loss,floatround(vehicleDB[isvehicle-1][rida]));
		/*senasspeed[playerid]=speed;
		senastaimas[playerid]=taimas;*/
	}
	else
	{
		static target;
		target = GetPlayerTargetPlayer(playerid);

		new keys,lr,ud;
		GetPlayerKeys(playerid,keys,ud,lr);
		new yesno;
		if(keys & KEY_HANDBRAKE) 
			yesno='T';
		else 
			yesno='N';
		new yesnofire = 'N';
		if(keys & KEY_FIRE)
			yesnofire = 'T';

		if(target == INVALID_PLAYER_ID)
		{ 
			distas=0.0; 
			if(LastTarget[playerid] != target)
				target = LastTarget[playerid];
			else 
			{
				SetPlayerObjectPos(adminas,Zuvyte[adminas],0.0,0.0,0.0);
			}
		}
		if(target != INVALID_PLAYER_ID && keys & KEY_HANDBRAKE)
		{
			new
				Float:RL_PlayerPos[3], // targetpos
				Float:RL_CameraPos[3],
				Float:RL_CameraVectors[3];
			GetPlayerPos(target, RL_PlayerPos[0], RL_PlayerPos[1], RL_PlayerPos[2]);
			GetPlayerCameraWeaponVector(playerid, RL_CameraVectors[0], RL_CameraVectors[1], RL_CameraVectors[2]);                     
			GetPlayerCameraPos(playerid, RL_CameraPos[0], RL_CameraPos[1], RL_CameraPos[2]);
			GetDistanceFromPointToLine(distas, RL_CameraVectors[0], RL_CameraVectors[1], RL_CameraVectors[2], RL_CameraPos[0], RL_CameraPos[1], RL_CameraPos[2], RL_PlayerPos[0], RL_PlayerPos[1], RL_PlayerPos[2]);
			new Float:an;
			GetPlayerFacingAngle(playerid,an);
			an = (floatround(an + 90.0) % 360);
			new Float:diff = floatabs(AimAngle[playerid] - an);
			if(diff > 30.0) {

				SetPlayerObjectRot(adminas,Zuvyte[adminas],0.0,0.0,an);
				AimAngle[playerid] = an;
			}
			new Float:Zuvis[3];
			ZuviesPos(RL_CameraPos,RL_PlayerPos,RL_CameraVectors,Zuvis[0],Zuvis[1],Zuvis[2]);
			SetPlayerObjectPos(adminas,Zuvyte[adminas],Zuvis[0],Zuvis[1],Zuvis[2]);
			LastTarget[playerid]=target;
		}
		else
			target=-1;
		
		if(drunk > 2000)
			format(str,256,"Kulkos:~r~%i~n~~w~HP:~r~%i~n~~w~AR:~r~%i~n~~w~AIM:~r~%i~n~~w~Mouse(1,2):~r~(%c,%c)~n~~w~AIM dist:~r~%.1f~n~~w~Apsvaiges:~r~%i~n~~w~FPS:~r~%i~n~~w~LAG:~r~%.2f",GetPlayerAmmo(playerid),floatround(HP),floatround(AR),target,yesnofire,yesno,distas,drunk,FPSx,loss);
		else {
			format(str,256,"Kulkos:~r~%i~n~~w~HP:~r~%i~n~~w~AR:~r~%i~n~~w~AIM:~r~%i~n~~w~Mouse(1,2):~r~(%c,%c)~n~~w~AIM dist:~r~%.1f~n~~w~FPS:~r~%i~n~~w~LAG:~r~%.2f~n~~w~Greitis:~r~%i",GetPlayerAmmo(playerid),floatround(HP),floatround(AR),target,yesnofire,yesno,distas,FPSx,loss,GetPlayerSpeed(playerid));
		}
	}

	TextDrawSetString(Spectate[playerid],str);
	TextDrawShowForPlayer(adminas,Spectate[playerid]);
	return 1;
}

