stock retApmokymai(id,title[],string[],titlelen = sizeof(title),stringlen = sizeof(string))
{
	strcat(title,APMOKYMAI[id],titlelen);
	switch(id)
	{
		case 0:
		{
			strcat(string,#DCOLOR"Sveikiname atvykus á "#HCOLOR"Los Santos"#DCOLOR" traukiniř stotá! Esame be galo dëkingi, kad pasirinkote ţaisti műsř serveryje.\n\n\
					Na, o dabar kviečiame susipaţinti su műsř serveriu trumpuose apmokymuose.\n",stringlen);
			strcat(string,"P.S. Nepamirđk uţsiregistruoti "#HCOLOR"www.LSGYVENIMAS.lt"#DCOLOR" forume ir palikti savo atsiliepimŕ apie serverá. Čia gali suţinoti daugiau apie projekto veiklŕ, konkursus, atnaujinimus, teikti pasiulymus \
			bei tiesiog padiskutuoti su kitais ţaidëjais.",stringlen);

		}
		case 1:
		{
			strcat(string,"Didţiŕjŕ laiko dalá serveryje praleisi vairuodamas transporto priemonć, todël labai svarbu nedelsiant iđsilaikyti "#HCOLOR"automobiliř teises"#DCOLOR". Vairavimo mokykloje gali praeiti trumpŕ teorijos kursŕ, \
					iđlaikyti teorijos testŕ ir atlikti vairavimŕ. Nebijok - sunku nebus - tereikes nesudauţius automobilio apvaţiuoti dalá miesto.",stringlen);
		}
		case 2:
		{
			strcat(string,"Serveryje leisdamas laika kaupsi patirties tađkus ("#HCOLOR"XP"#DCOLOR"). Jř reikës norint ásidarbinti á kai kuriuos darbus, todël labai svarbu jř neprarasti - prieđ atsijungdamas butinai iđsaugok ţaidimŕ.",stringlen);

			strcat(string," Tai gali padaryti betkuriame iđ Los Santos "#HCOLOR"vieđbučiř"#DCOLOR", nuosavamam name ar gaujos bazëje, na bet apie tai vëliau.\n"#HCOLOR"Jei atsijungsi neiđsaugojćs ţaidimo - prarasi uţdirbtus patirties tađkus.",stringlen);
				
		}	

		case 3:
		{
			strcat(string,"Los Santos miestŕ valdo mafijos Donai ir gangsteriai, todël pinigus neđiotis kiđenëje yra itin nesaugu. Siűlome atsidaryti banko saskaitŕ betkuriame "#HCOLOR"banke"#DCOLOR", kur jűsř pinigai bus saugűs ir \
	pasiekiami visuose bankomatuose. Banko paslaugos (iđskyrus pervedimus) yra nemokamos. ",stringlen);
		}
		
		case 4:
		{
			strcat(string,"Serveryje bandome atkurti realř gyvenimŕ - todël retkarčiais tau reikës "#HCOLOR"pavalgyti"#DCOLOR". Đtai čia matai vienŕ iđ daugelio LS restoranř. Neturi pinigř valgyti restorane? Maisto gali nusipirkti ir \
	24/7 parduotuvëje ir pasigaminti já savo namuose. Bet tu juk ir namo neturi! Na, turbut teks raustis điuksliř konteineryje, kad numalđintum savo alká... :)\n",stringlen);
			strcat(string,"Restoranuose maistas papildys tavo gyvybës tađkus("#HCOLOR"HP"#DCOLOR") iki 200 - daugiau tavo skrandis neatlaikys.\nSavo alká gali pamatyti prie gyvybiř stulpelio. ",stringlen);
		}

		case 5:
		{
			strcat(string,"Sëkminga karjeros pradţia tau garantuos patogř ir komfortiđkŕ ţaidima műsř serveryje. Siűlome ásidarbinti á pirmŕjá "#HCOLOR"darbŕ be pakvietimo"#DCOLOR" - BMX'eri (tereikia uţlipti ant mëlynu marđkinëliř), \
	kuriame uţ atliktus triukus galësi uţsidirbti pinigř.\nNenori dirbti? Na tuomet árodyk gangsteriams, kad esi naudingas, ir pinigus galësi kalt su jais. Bet ţinok, kad teisësauga kiekvienŕ minutć tave bandys pagauti ir pasodinti á kalëjimŕ. ",stringlen);
		}
		case 6:
		{
			strcat(string,"Kalbant apie teisësaugŕ, đtai "#HCOLOR"darbas su pakvietimu"#DCOLOR" \"Kobra 11\". Đis teisësaugos padalinys gaudo nusikaltelius greitkeliuose, baudţia kontrabandininkus ir seka automobiliř vagis. Čia patekti labai sunku!\
			Tam reikës praeiti atrankŕ á policijŕ bei gauti paaukđtinimŕ á Kobra 11. Tai uţtruks kelias "#HCOLOR"algas"#DCOLOR" - trečiadieniais ir đeđtadieniais direktoriai perveda pinigus ţaidejams á bankŕ uţ pradirbtŕ laikŕ ir surengia ",stringlen);
			strcat(string,""#HCOLOR"atrankas"#DCOLOR". Darbuose su pakvietimu reikia pradirbti bent 100 minučiř.\n\n\
	Visus darbus rasi parađćs "#HCOLOR"/darbai"#DCOLOR" - nelegalus darbai priklauso gangsteriams, todël norint á juos patekti reikës sumokëti kyđá. ",stringlen);
		}
		
		case 7:
		{
			strcat(string,"Jau praëjai pusć apmokymř! LSG gali nusipirkti vienŕ iđ daugelio "#HCOLOR"namř"#DCOLOR", kuriuose galësi saugoti ţaidimŕ, ásirengti savo interjerŕ ir netgi uţsiauginti savo kanapiř! Namai kainuoja gan daug, \
	todël siűlome pradţioje nusipirkti butŕ viename iđ LS daugiabuciř. ",stringlen);
		}
			
		case 8:
		{
			strcat(string,"Serveryje yra 6 "#HCOLOR"gaujos"#DCOLOR", kurias rasi parađćs /gaujos. Čia matai Los Santos Ballas gaujos baze, kurioje nariai gali pasikeisti aprangŕ ("#HCOLOR"SKIN"#DCOLOR"), pasiimti gaujos automobilá, iđsaugoti ţaidimŕ \
	ir gauti ginklř! Gaujos zonose buti yra pavojinga, nes gaujos daţnai uţgrobia viena kitos bazć, todël nepakliűk á műđio laukŕ!\n",stringlen);
			strcat(string,"Beje, gaujai gali priklausyti dirbdamas visus darbus, iđskyrus tuos kurie priklauso "#HCOLOR"teisësaugai"#DCOLOR" (VST, Policija, ARAS, Kareivis ir Kobra 11). ",stringlen);
		}
		case 9:
		{
			strcat(string,"Visas prekes, kuriř tau gali prireikti, gali nusipirkti LS "#HCOLOR"versluose"#DCOLOR". Đie verslai yra "#HCOLOR"nekilnojamas turtas"#DCOLOR", o jř savininkai gauna pelnŕ uţ parduotas prekes. Bankai, restoranai, draudimai, \
	ginklř parduotuves ir t.t. - visi verslai kaţkam priklauso, todël norëdamas uţvaldyti Los Santos pirmiausiai patapk turtingiausiu verslininku.",stringlen);
		}
		
		case 10:
		{
			strcat(string,"Čia matai Lowrider automobiliř turgř. Automobiliř parduotuvëse (/kur) gali nusipirkti iki 3 "#HCOLOR"nuosavř automobiliř"#DCOLOR", o konkursuose gali laimëti ir "#HCOLOR"vienetinius automobilius"#DCOLOR". Susitaupćs pinigř \
	nusipirk mađinŕ, uţsidëk tiuningŕ ir parodyk savo sugebëjimus kelyje - geri lenktynininkai yra vieni turtingiausiř Los Santos ţmoniř.\n",stringlen);
			strcat(string,"Beje, darbinius ir gaujos automobilius irgi gali tiuninguoti - atsijungus "#HCOLOR"TUNE"#DCOLOR" nuo ju nedings. ",stringlen);
		}
		
		case 11:
		{
			strcat(string,"Los Santos Gyvenimas garsëja savo unikalia "#HCOLOR"pokerio sistema"#DCOLOR" - mes esame vienintelis Lietuvos serveris, kuriame gali ţaisti Texas Hold'em pokerá su kitais ţaidëjais. Jei moki ţaisti - tai puikus \
	bűdas greitai uţsidirbti pinigř, tačiau taip pat lengva juos ir prarasti, todel ţaisk atsakingai. Daug ţaideju mëgsta pinigus lođti mesdami "#HCOLOR"monetŕ"#DCOLOR" bei statyti ant kamuoliukř, bet đie lođimo bűdai yra itin rizikingi. ",stringlen);
		}
		
		case 12:
		{
			strcat(string,"Gaujř karai neturëtř prasmes, jei nebűtř dël kaţko kovojama. Gaujos ir teisësauga trečiadieniais ir đeđtadieniais 18:30-19:00 dalyvauja "#HCOLOR"sandëliuose"#DCOLOR". Gaujos kovoja dël 3 narkotikř sandeliř, \
	kuriuos uţemus jos gali nusipirkti narkotikř (ir juos pardavinëti) bei valdyti nelegalř darbŕ. Taip pat jos bando uţimti ir "#HCOLOR"ginklř sandelá"#DCOLOR", kurá gina teisësaugos burys. Đis sandelis suteikia ",stringlen);
			strcat(string,"galimybć nusipirkti "#HCOLOR"COMBAT SHOTGUN"#DCOLOR" tiek teisësaugai, tiek gaujoms. Gaujos nariai čia gali nusipirkti ir bombŕ, su kuria jie gali uţgrobti pastatus ir pavogti iđ jř pinigus. Apie tai suţinosi vëliau. \
	Gangsteriai yra geriausi đaudytojai serveryje - norëdamas pasiekti ju lygi treniruokis "#HCOLOR"Daţasvydyje"#DCOLOR" (/kur). ",stringlen);
		}
		
		case 13:
		{
			strcat(string,"Mirćs kovoje tu vël bűsi prikeltas Los Santos "#HCOLOR"ligoninëje"#DCOLOR". Čia galesi pasigydyti bei ramiai bendrauti su kitais zaidejais, nes tai yra SAUGI ZONA.\nDëmesio! Mirćs tu prarasi visus savo ginklus \
			ir 10 procentř rankoje laikomř pinigř. Dideles pinigř sumas rekomanduojame laikyti banke.",stringlen);
		}
		case 14:
		{
			strcat(string,"Siűlome nedelsiant susipaţinti su "#HCOLOR"LSG taisyklemis"#DCOLOR", kurias gali rasti műsř tinklapyje www.LSGYVENIMAS.lt. Uţ smulkius paţeidimus administratoriai jus gali pasodinti \
	á kalëjimŕ ar iđmesti iđ serverio ("#HCOLOR"KICK"#DCOLOR"), tačiau prasiţengus kelis kartus gausite "#HCOLOR"BAN"#DCOLOR" ir serveryje ţaisti nebegalësite!\n",stringlen);
			strcat(string,"Serveryje veikia grieţta "#HCOLOR"anti-cheat sistema"#DCOLOR", todël bet koks bandymas sukčiauti jus gali privesti prie bano. Nedelsiant iđtrink visas ţaidimŕ lengvinančias programas,\
	nes vien jř turëjimas gali sukelti problemř. ",stringlen);
		}
		
		case 15:
		{
			strcat(string,"Sveikinu áveikus LSG apmokymus! Noriu priminti, kad ţaidimas LSG yra "#HCOLOR"visiđkai nemokamas"#DCOLOR", todël pasikliaujame jűsř parama, kad iđlaikytumëme serverá. Uţ betkokiŕ paramŕ \
	tau gausiai atsidëkosime suteikdami "#HCOLOR"kreditř"#DCOLOR" (/kreditai), uţ kuriuos galësi nusipirkti "#HCOLOR"VIP"#DCOLOR" (/vipinfo), UNBAN, SKIN, UNJAIL ir kitu privilegijř.\nXP, pinigai, direktoriaus ir ",stringlen);
			strcat(string,"administratoriaus privilegijos NIEKADA nebus pardavinëjamos uţ kreditus - todël tik savo darbais galite gauti đias pareigas.\n\n\
	Visas komandas rasi parađćs "#HCOLOR"/pagalba"#DCOLOR", na o iđkilus problemoms nesikuklink ir kreipkis á administracijŕ rađydamas "#HCOLOR"/admin \"klausimas\""#DCOLOR"\n\n",stringlen);
			strcat(string,"Linkime tau pačios didţiausios sëkmës ir stiprybes ásikuriant ţiauriame ir negailëstingame Los Santos mieste.\n\n- Serverio ákurëjas "#HCOLOR"Benas_Vercetti"#DCOLOR" ir visa "#HCOLOR"LSG komanda"#DCOLOR".",stringlen);
		}
		case 16:
		{
			strcat(string,"",stringlen);
		}
	}
}

