}
stock VykdoMisija(playerid, kaledudiena, status) // status 0 = new, 1 = in progress, 2 = done, 3 = prize received
{
    new query[256];
	format(query,256,"Update Kaledos Set `gift%i`=%i WHERE Vardas='%s'",kaledudiena, status,ReturnName(playerid));
	mysql_query(query);
}

stock FormatSMSNumber(number[])
{
	new res[256];
	new j=strlen(number);
	
	if(j <= 4)
	{
		return res;
	}

	if(strcmp(number, "+370", true, 4) == 0 && j == 12)
	{		
		format(res,256,"00");
	}
	else if(strcmp(number, "+353", true, 4)== 0) // test
	{
		format(res,256,"00");
	}
	else if(strcmp(number, "86", true, 2) == 0 && j == 9)
	{
		format(res,256,"00370");
	}
	else if(strcmp(number, "370", true, 3) == 0 && j == 11)
	{
		format(res,256,"003");
	}
	else
	{
		return res;
	}

	for(new i=1;i<j;i++)
	{
		format(res,256,"%s%c",res,number[i]);
	}
	return res;
}

stock GenerateConfirmationNumber()
{
	return 10000 + random(90000);
}
stock TryNumberConfirm(playerid)
{
	new row[512];
	new ipas[24];
	GetPlayerIp(playerid, ipas, 24);
	format(row,sizeof(row),"SELECT * From Phones Where (Vardas='%s' or IP='%s') AND Data > (NOW() - INTERVAL 1 HOUR)",ReturnName(playerid), ipas);
	mysql_function_query(SQL, row, true, "SQL_TryNumberConfirm", "i", playerid);
}
stock SendSMSConfirmation(playerid,number[])
{
	LoginStart[playerid]=GetTickCount();
	new newnumber[128];
	format(newnumber,128, FormatSMSNumber(number));

	if(strlen(newnumber) <= 1)
		return 0;

	new row[512];
	new ipas[24];
	GetPlayerIp(playerid, ipas, 24);
	format(row,sizeof(row),"SELECT * From Phones Where (Vardas <> '%s' AND Numeris = '%s') AND Data > (NOW() - INTERVAL 6 MONTH)",ReturnName(playerid), newnumber);
	mysql_function_query(SQL, row, true, "SQL_CheckIfNumberIsUsed", "is", playerid, newnumber);
	return 1;
}

stock SendSMSConfirmation2(playerid, newnumber[])
{
	new digits = GenerateConfirmationNumber();
	SetPVarInt(playerid, "ConfirmationCode", digits);

	new query[500];
	new ipas[24];
	GetPlayerIp(playerid, ipas, 24);
	format(query,sizeof(query),"REPLACE INTO `Phones`(`Vardas`,`Numeris`,`IP`,`Patvirtinta`,`Kodas`,`Data`) VALUES('%s','%s','%s',0,%i,NOW())",ReturnName(playerid),newnumber,ipas,digits);
	mysql_query(query);

	new smsMessage[256];
	format(smsMessage,256,"Sveiki-%s,-jusu-registracijos-kodas:-%i",ReturnName(playerid),digits);
	
	SendSMSToNumber(playerid, newnumber, smsMessage);

}

stock SendSMSToNumber(playerid, number[], message[])
{
	new string[2500];
	printf("[SMS] Sending SMS for %s. Message %s",ReturnName(playerid), message);
	format(string,sizeof(string),"%s|%s", number, message);
	AddToTaskQueue(playerid, TaskType:SEND_SMS, string);
	SendSmsSuccess(playerid);
}

stock SendSmsSuccess(playerid)
{
	printf("[SMS] Success sending SMS!");
	new msg[512];
	new nr[24];
	GetPVarString(playerid,"telnr",nr,24);
	format(msg,512,"Patvirtinimo kodas issiustas numeriu {ff0000}%s\n\
	{ffffff}Iveskite savo patvirtinimo koda, kad uzbaigtumete registracija.",nr);
	ShowPlayerDialog(playerid,9799,DIALOG_STYLE_INPUT,"Iveskite patvirtinimo koda",msg,"Gerai","Atsaukti");
}

stock ShowGangDialog(playerid)
{
	new pi =playerDB[playerid][pgang];
	if(pi == -1)
		return 0;
	if(FamilyInfo[pi][FamilyIspejimai] == 2)
	{
		SendInfoMessage(playerid, "Negali naudotis gaujos komandomis.");
		return 1;
	}
	if(0==strcmp(FamilyInfo[pi][FamilyLeader],ReturnName(playerid),true)) 
	{
		ShowPlayerDialog(playerid, 5253, DIALOG_STYLE_LIST, "Gaujos lyderis","Pakviesti i gauja\nIsmesti is gaujos\nNario komandos\nGaujos automobiliai\nDabartiniai nariai\nNustatyti limitus\nPerleisti gauja\nApleisti gauja\nSkirti pavaduotoja","Taip","Ne");
		return 1;
	}
	if(0==strcmp(FamilyInfo[pi][FamilySubstitute],ReturnName(playerid),true)) 
	{
		ShowPlayerDialog(playerid, 5253, DIALOG_STYLE_LIST, "Gaujos lyderis","Pakviesti i gauja\nIsmesti is gaujos\nNario komandos\nGaujos automobiliai\nDabartiniai nariai\nNustatyti limitus","Taip","Ne");
		return 1;
	}
	return 0;
}
stock ShowGangNarioDialog(playerid,status=0)
{
	new pi =playerDB[playerid][pgang];
	if(pi == -1)
		return 0;
	if(status == 0)
	{
		ShowPlayerDialog(playerid, 5254, DIALOG_STYLE_LIST, "Gaujos narys","Keisti skina\nSaugoti\nPasiimti ginklus\nGaujos fondas\nGaujos saugykla\nTaisyti automobilius\nPalikti gauja","Gerai","Atsaukti");
	}
	else if(status == 1)
	{
		new gang = pi;
		new msgas[1024];
		
		format(msgas,1024,"Item\tVieta\tPadeta\tLimitas (24h)\n\
			LSD\tSaugykla\t%s\t%i\n\
			Ratai\tSaugykla\t%s\t%i\n\
			Seklos\tSaugykla\t%s\t%i\n\
			Zole\tSaugykla\t%s\t%i\n\
			Amfetaminas\tSaugykla\t%s\t%i\n\
			Deagle\tSaugykla\t%s\t%i\n\
			Sniper Rifle\tSaugykla\t%s\t%i\n\
			Combat Shotgun\tSaugykla\t%s\t%i\n\
			AK-47\tSaugykla\t%s\t%i\n\
			MP5\tSaugykla\t%s\t%i",
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][0]),
			FamilyInfo[gang][SaugyklosLimitai][0],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][1]),
			FamilyInfo[gang][SaugyklosLimitai][1],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][2]),
			FamilyInfo[gang][SaugyklosLimitai][2],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][3]),
			FamilyInfo[gang][SaugyklosLimitai][3],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][4]),
			FamilyInfo[gang][SaugyklosLimitai][4],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][5]),
			FamilyInfo[gang][SaugyklosLimitai][5],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][6]),
			FamilyInfo[gang][SaugyklosLimitai][6],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][7]),
			FamilyInfo[gang][SaugyklosLimitai][7],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][8]),
			FamilyInfo[gang][SaugyklosLimitai][8],
			FormatSaugyklosNum(FamilyInfo[gang][FamilySaugykla][9]),
			FamilyInfo[gang][SaugyklosLimitai][9]);
		ShowPlayerDialog(playerid, 5277, DIALOG_STYLE_TABLIST_HEADERS, "Saugykla", msgas, "Paimti", "Padeti");
	}
	return 1;
}
stock FormatSaugyklosNum(num)
{
	new str[50];
	if(!num)
	{
		str = "{b52463}0";
	}
	else
	{
		format(str,50,"{50cf42}%i",num);
	}
	return str;
}
stock ShowSandelioDialog(playerid, pickupid)
{
	new string[256];
	new gang = playerDB[playerid][pgang];
	if(gang == -1)
		return 1;
	if(pickupid == pickups[0][seklos])
	{
		format(string,sizeof(string),"Turime %i vnt. seklu.\nKiek norite pirkti?\nVieneto kaina: "#COST_SEKLOS"€\n{00FF00}Dienos limitas: %i vnt",KiekYra[0],FamilyInfo[gang][SandelioLimitai][0]);
		if(strcmp(FamilyInfo[gang][FamilyLeader],ReturnName(playerid),true) != 0 && strcmp(FamilyInfo[gang][FamilySubstitute],ReturnName(playerid),true) != 0)
		{
			ShowPlayerDialog(playerid,7600,DIALOG_STYLE_INPUT,"Seklos",string,"Pirkti","Iki");
		}
		else
		{
			ShowPlayerDialog(playerid,7600,DIALOG_STYLE_INPUT,"Seklos",string,"Pirkti","Ataskaita");
		}
		
	}
	else if(pickupid == pickups[0][lsdvieta])
	{
		format(string,sizeof(string),"Turime %i vnt. LSD.\nKiek norite pirkti?\nVieneto kaina: "#COST_LSD"€\n{00FF00}Dienos limitas: %i vnt",KiekYra[1],FamilyInfo[gang][SandelioLimitai][1]);
		if(strcmp(FamilyInfo[gang][FamilyLeader],ReturnName(playerid),true) != 0 && strcmp(FamilyInfo[gang][FamilyLeader],ReturnName(playerid),true) != 0)
		{
			ShowPlayerDialog(playerid,7601,DIALOG_STYLE_INPUT,"LSD",string,"Gerai","Iki");
		}
		else
		{
			ShowPlayerDialog(playerid,7601,DIALOG_STYLE_INPUT,"LSD",string,"Gerai","Ataskaita");
		}
	}
	else if(pickupid == pickups[0][ratuvieta])
	{
		format(string,sizeof(string),"Turime %i vnt. ekstazio.\nKiek norite pirkti?\nVieneto kaina: "#COST_RATAI"€\n{00FF00}Dienos limitas: %i vnt",KiekYra[2],FamilyInfo[gang][SandelioLimitai][2]);
		if(strcmp(FamilyInfo[gang][FamilyLeader],ReturnName(playerid),true) != 0 && strcmp(FamilyInfo[gang][FamilyLeader],ReturnName(playerid),true) != 0)
		{
			ShowPlayerDialog(playerid,7602,DIALOG_STYLE_INPUT,"Ratai",string,"Gerai","Iki");
		}
		else
		{
			ShowPlayerDialog(playerid,7602,DIALOG_STYLE_INPUT,"Ratai",string,"Gerai","Ataskaita");
		}
	}
	return 1;
}
stock ShowTeisesaugaElitiniai(playerid)
{
	printf("%s ziuri teisesaugos elitinius ginklus",ReturnName(playerid));
	new dtext[2048];
	format(dtext,sizeof(dtext),"Ţaidëjas\tTransportas\tAtstumas\n");
	new count = 0;
	new Float:Coo[3];
	GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
	foreach(Player, i)
	{
		if(GetPlayerState(i) == PLAYER_STATE_DRIVER)
		{
			new model = GetVehicleModel(GetPlayerVehicleID(i));
			if(model == 432 || model == 520 || model == 425 || model == 447 || model == 601 || model == 497 || model == 430)
			{
				count ++;
				new Float:coo[3];
				GetPlayerPos(i, coo[0],coo[1],coo[2]);
				new Float:atstumas = ((floatabs(coo[0]-Coo[0])+floatabs(coo[1]-Coo[1])+floatabs(coo[2]-Coo[2]))/3)/100;
				format(dtext,sizeof(dtext),"%s%s\t%s\t{03fc6b}%.1fkm\n",dtext,ReturnName(i),aVehicleNames[model-400],atstumas);
			}
		}
	}
	if(!count)
		return SendInfoMessage(playerid, "Siuo metu elitiniai ginklai nenaudojami!");
	ShowPlayerDialog(playerid, 15653, DIALOG_STYLE_TABLIST_HEADERS, "Elitiniai ginklai", dtext, "Gerai", "");
	return 1;
}

stock Float:GetDistanceFromLastPos(playerid)
{
	new Float:Coo[3];
	GetPlayerPos(playerid, Coo[0],Coo[1],Coo[2]);
	return GetDistanceBetweenPoints(Coo[0],Coo[1],Coo[2],playerDB[playerid][pCurrentPos][0],playerDB[playerid][pCurrentPos][1],playerDB[playerid][pCurrentPos][2]);
}

stock ClearHouse(housenumber,deletebaldai,deleteitems)
{
	new query[256];
	if(deleteitems)
	{
		hInfo[housenumber][zole] = 0;
		hInfo[housenumber][nark] = 0;
		hInfo[housenumber][hmaistas] = 0;
		hInfo[housenumber][lsd] = 0;
		hInfo[housenumber][ratai] = 0;
		hInfo[housenumber][seklos] = 0;
		hInfo[housenumber][hMokesciai]=14;
		hInfo[housenumber][Locked] = 1;
		format(query,sizeof(query),"UPDATE `Namai` SET `Zole`=0,`Nark`=0,`Maistas`=0,`LSD`=0,`Ratai`=0,`Seklos`=0 WHERE `ID`=%i",housenumber);
		mysql_query(query);
		for(new slot=0; slot<12; slot++)
		{
			hInfo[housenumber][gunas][slot]=0;
			hInfo[housenumber][kulkos][slot]=0;
			new kulkoz[50],gunz[50];
			format(kulkoz,sizeof(kulkoz),"Kulkos%i",slot);
			format(gunz,sizeof(gunz),"Ginklas%i",slot);

			format(query,sizeof(query),"UPDATE `Namai` SET `%s`=0,`%s`=0 WHERE `ID`=%i",kulkoz,gunz,housenumber);
			mysql_query(query);
		}
	}
	hInfo[housenumber][Rentable] = 0;
	hInfo[housenumber][Rentcost] = 0;
	format(hInfo[housenumber][Renter], 24, "ForRent");
	if(deletebaldai)
	{
		for(new i;i<MAX_BALDAI;i++)
		{
			if(BalduSistema[housenumber][i][b_used] && BalduSistema[housenumber][i][b_cat] != 13)
			{
				BalduSistema[housenumber][i][b_used]=0;
				DestroyDynamicObject(BalduSistema[housenumber][i][b_oid]);
				BalduSistema[housenumber][i][b_oid]=-1;
			}
		}
		SaveBaldai(housenumber);
	}
	hInfo[housenumber][pinigai] = 0;
	format(hInfo[housenumber][Name],255,"Nera");
	format(query,sizeof(query),"UPDATE `Namai` SET `Name`='%s',`Locked`=1,`Pinigai`=0,`bMokesciai`=14,`Rentable`=0,`Renter`='ForRent' WHERE `ID`=%i",hInfo[housenumber][Name],housenumber);
	mysql_query(query);
}

stock IsCbugEnabled(playerid) 
{
	new place = GetPlace(playerid, /*houses=*/ false);
	return IsPlayerConnected(playerid) && playerDB[playerid][psratasvydis] && dazumap == 3 && (place == PLACE_DUEL || place == PLACE_SRATASVYDIS);
}

stock IsNuomosCar(vehicleid)
{
	return (vehicleid == nuoma1 || vehicleid == nuoma2 || vehicleid == nuoma3 || vehicleid == nuoma4 || vehicleid == nuoma5 || vehicleid == nuoma6 || vehicleid == nuoma7 || vehicleid == nuoma8);
}
stock IsVagiuCar(vehicleid) 
{
	if(vehicleid == slamvan || vehicleid == blista || vehicleid == stafford || vehicleid == sabre || vehicleid == fcr || vehicleid == cheetah || vehicleid == rancher || vehicleid == stallion || vehicleid == tanker || vehicleid == comet)
		return 1;
	if(vehicleid == patriot || vehicleid == sanchez || vehicleid == stretch || vehicleid == feltzer || vehicleid == remington || vehicleid == infernus || vehicleid == buffalo || vehicleid == sentinel || vehicleid == camper || vehicleid == admiral)
		return 2;
	if(vehicleid == blade || vehicleid == freeway || vehicleid == mesa || vehicleid == zr350 || vehicleid == euros || vehicleid == banshee || vehicleid == supergt || vehicleid == journey || vehicleid == huntley || vehicleid == bf)
		return 3;
	if(vehicleid == dune || vehicleid == club || vehicleid == turismo || vehicleid == hotknife || vehicleid == bloodring || vehicleid == voodoo || vehicleid == esperanto || vehicleid == previon || vehicleid == romero || vehicleid == hotring)
		return 4;
	return 0;
}

stock IsVairavimoMokyklosCar(vehicleid)
{
	return (vehicleid == Club1 || vehicleid == Club2 || vehicleid == Club3 || 
			vehicleid == Moto1 || vehicleid == Moto2 || vehicleid == Moto3 || 
			vehicleid == Shamal1 || vehicleid == Shamal2);
}

stock KreditaiResponse(playerid, response)
{
 	playerDB[playerid][textas]=0;
	new kaina = playerDB[playerid][rkaina][0];
	new dealeris = playerDB[playerid][rid][0];
	new kiek = playerDB[playerid][rkiekis][0];
	playerDB[playerid][rid][0] = -1;
	if(!IsPlayerConnected(dealeris)) return SendInfoMessage(playerid,"Pardavejas atsijunge!");
	if(TradingWith[dealeris] != -1) return SendInfoMessage(playerid,"Pardavejas mainosi!");
	new query[128];
	format(query,sizeof(query),"SELECT `Kreditai` FROM `Account` WHERE `Name`='%s' LIMIT 1",ReturnName(playerid));
	new answer = 0;
	if(response)
		answer = 1;
	mysql_function_query(SQL, query, true, "SQL_UpdateKred4", "iiiii", playerid,kaina,dealeris,kiek,answer);
	return 0;
}

stock NarkResponse(playerid, response) 
{
	playerDB[playerid][textas]=0;
	new kaina = playerDB[playerid][rkaina][0];
	new dealeris = playerDB[playerid][rid][0];
	new kiek = playerDB[playerid][rkiekis][0];
	new rusis = playerDB[playerid][rrusis];
	new rusisz[50];
	playerDB[playerid][rid][0] = -1;
	switch(rusis)
	{
		case 1: rusisz="Amfetamino";
		case 2: rusisz="Seklu";
		case 3: rusisz="Kanapiu";
		case 4: rusisz="LSD";
		case 5: rusisz="Ekstazio";
	}
	if(!IsPlayerConnected(dealeris)) return SendInfoMessage(playerid,"Pardavejas atsijunge!");
	if(response)
	{
		if(GetPlayerMoneyA(playerid) < kaina*kiek)
		{
			SendInfoMessage(playerid,"Neturi Litu Ubage");
			SendInfoMessage(playerid,"Neturi Litu Ubagas");
			return 0;
		}
		switch(rusis)
		{
			case 1: 
