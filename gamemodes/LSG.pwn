{
	new datestr[50];
	new day,month,year;
	getdate(year,month,day);
	format(datestr,50,"%i-%i-%i",year,month,day);
	SetPlayerKVS(playerid, "Nuimtiadm", datestr);
	SetPVarInt(playerid, "Nuimtiadm", 1);
}
forward LoadPlayerKVS(playerid);
public LoadPlayerKVS(playerid)
{
	new
		query[256];
	format(query,sizeof(query),"SELECT * From `PlayerKVS` WHERE `Vardas`='%s'",ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_KVS", "i", playerid);
}


stock OnPlayerKVSLoaded(playerid,key[],value[])
{
	if(strcmp(key,"AutoSaved",true)==0 && strcmp(value,"warn",true) == 0)
	{
		ShowPlayerDialog(playerid,7474,DIALOG_STYLE_MSGBOX,"Saugojimas","{FF0000}DËMËSIO!\n\n\
		{FFFFFF}Jűs atsijungëte neiđsisaugojć savo ţaidimo! Taip padarć prarasite visus per praţaistŕ laikŕ sukauptus XP tađkus bei uţdirbtus pinigus!\n\
		Kadangi esate naujokas(-ë), jűsř ţaidimŕ đá kartŕ iđsaugojome automatiđkai, tačiau kitŕ kartŕ prarasite savo uţdirbtus XP.\n\
		Prieđ atsijungiant rekomenduojame iđsisaugoti ţaidimŕ viename iđ vieđbučiř, kurie ţemelapyje paţymëti diskais.\n\
		/kur -> Svarbios vietos -> Vieđbutis","Supratau","");
	}
	if(strcmp(key,"Velykos2022",true)==0)
	{
		SetPVarInt(playerid, "VelykosDone", 1);
	}
	if(strcmp(key,"SFwarned",true)==0)
	{
		SetPVarInt(playerid, "SFwarned", 1);
	}
	if(strcmp(key,"Kaledos2025kvs",true)==0)
	{
		SetPVarInt(playerid, "Kaledos2025kvs", strval(value));
	}
	if(strcmp(key,"Race2023", true) == 0)
	{
		SetPVarInt(playerid, "Race2023", strval(value));
	}
	if(strcmp(key,"Nuked", true) == 0)
	{
		SetPVarInt(playerid, "Nuked", 1);
	}
	if(strcmp(key,"Nuimtiadm", true) == 0)
	{
		SetPVarInt(playerid, "Nuimtiadm", 1);
	}
}
new LastTarget[MAX_PLAYERS];
public OnPlayerDisconnect(playerid, reason)
{
	CheckVelykos(playerid);
	ChristmasPlayerDisconnect(playerid);
	//CleanupKaledos(playerid);
	if(MedikuDB[med_carer] == playerid)
	{
		EndMedicMission();
	}
	if(GetPVarInt(playerid, "LotoShown"))
	{
		HideLotoTextDraws(playerid);
		DestroyLotoTextDraws(playerid);
	}
	if(GetPVarInt(playerid, "Nuked") == 1 && reason == 0) // crashed
	{
		new datestr[50];
		new day,month,year;
		getdate(year,month,day);
		format(datestr,50,"%i-%i-%i",year,month,day);
		SetPlayerKVS(playerid, "Nuked", datestr);
	}
	else if(GetPVarInt(playerid, "Nuked") == 2 && reason == 0) // crashed
	{
		AC_Ban(playerid, "Nelegalios programos", 1, 1);
	}
	DestroyRoges(playerid);
	PlayerTextDrawDestroy(playerid,pPowerTD[playerid]);
	if(BallHolder == playerid)
		RecreateBall();
	if(playerDB[playerid][psratasvydis])
	{
		for(new y=0;y<5;y++)
				TextDrawHideForPlayer(playerid,dazugui[y]);
	}
	if(PlayerPokerWaitQue[playerid] != -1)
	{
		RemovePlayerFromPokerWaitQue(playerid, PlayerPokerWaitQue[playerid]);
	}
	if(SaudyklosStats[playerid][s_id])
	{
		DestroySaudyklosObjektai(playerid);
	}
	if(FPS[playerid]) StopFPS(playerid);
	if(fs_balloon_pl[playerid][0] == 1)
	{
		DestroyBalloon(fs_balloon_pl[playerid][1]);
		SpawnBalloon(fs_balloon_pl[playerid][1]);
		fs_balloon_pl[playerid][0] = 0;
	}
	Iter_Remove(PlayersWalking,playerid);
	Iter_Remove(PlayersFading,playerid);
	Iter_Remove(PlayersDrifting,playerid);
	AutoBulletInfractions[playerid] = 0;
	if(PlayerSlotUsed[playerid]==0)
		return 1;
	PlayerSlotUsed[playerid]=0;
	DestroyPlayerObject(playerid,Zuvyte[playerid]);
	if(playerDB[playerid][hasmoney])
	{
		RemovePlayerAttachedObject(playerid, MESKERE_SLOT);
		playerDB[playerid][hasmoney]=0;
		if(playerDB[playerid][pgang] != -1)
		{
			new msg[128];
			format(msg,128,"[gauja] %s atsijunge ir pamete pinigus!",ReturnName(playerid));
			SendMessageToFamily(playerDB[playerid][pgang],ORANGE,msg);
			SendMessageToTeisesauga(YELLOW,"[racija] Operatorë: Gaujos narys atsijungë ir pametë pinigř maiđŕ! Paimkite já ir pristatykite á policijos departamentŕ!");
		}
		else
		{
			SendMessageToTeisesauga(YELLOW,"[racija] Operatorë: Műsř pareigűnas atsijungë ir pametë pinigř maiđŕ! Paimkite já ir pristatykite á policijos departamentŕ!");
		}
		new Float:Coo[3];
		GetPlayerPos(playerid, Coo[0], Coo[1], Coo[2]);
		if(MoneyBag != -1)
			DestroyPickup(MoneyBag);
		MoneyBag = CreatePickupA(1550, 2, Coo[0],Coo[1],Coo[2],GetPlayerVirtualWorld(playerid));
		dirtym = 0;
	}
	if(InkaUzsakymai[playerid][ustatus])
	{
		PrapisoPinigus(playerid,1);
	}
	if(RocketManager == playerid)
	{
		RocketSet(playerid,false);
	}
	if(DuelKova[playerid] != -1)
	{
		new msg[128];
		format(msg,sizeof(msg),"[DUEL] %s nutraukë kovŕ!",ReturnName(playerid));
		SendClientMessage(playerid, YELLOW,msg);
		SendClientMessage(DuelKova[playerid],YELLOW,msg);
		SetPlayerHealth(DuelKova[playerid],0.0);
	}
	if(Patruliavimas[playerid] != -1)
	{
		GangZoneHideForPlayer(playerid,Patruliai[Patruliavimas[playerid]][gangz]);
		Patruliai[Patruliavimas[playerid]][pplin]--;
		Patruliavimas[playerid]=-1;
		//SendClientMessage(playerid,YELLOW," * Jums buvo atsauktas patruliavimas, kadangi neatvykote i zona arba ja palikote!");
	}
	if(CarLights[playerid] != 0)
	{
		DestroyObject(CarLights[playerid]),CarLights[playerid]=0;
	}
	BeingKicked[playerid]=0;
	if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER) 
		vehicleDB[GetPlayerVehicleID(playerid)][uzeris]=INVALID_PLAYER_ID;
    if(IsPlayerNPC(playerid)) return 1;
    OnPlayerLogout(playerid);
    YRace_OnPlayerDisconnect(playerid);
	DestroyOldCar(playerid);
	if((playerDB[playerid][admin] || playerDB[playerid][plead]) && AdminTimer[playerid])
	{
		MLog(playerid,"Praleido","i",AdminTimer[playerid]);
	}
	if(GetPVarInt(playerid,"relog"))
	{
		new string[128];
		new PIP[24];
		GetPVarString(playerid,"PIP",PIP,24);
		format(string,sizeof(string),"unbanip %s",PIP);
		SendRconCommand(string);
		//SendRconCommand("reloadbans");
	}
	if(Gesino[playerid])
	{
		Gesino[playerid]=false;
		KillTimer(Gesinimaz[playerid]);
		Gesinimaz[playerid]=-1;
	}
	if(PlayerAfk[playerid])
	{
		DestroyDynamic3DTextLabel(PlayerLabel[playerid]);
		PlayerAfk[playerid]=false;
	}
	if(Suristas[playerid] != -1)
	{
		KillTimer(Suristas[playerid]);
		Suristas[playerid]=-1;
	}
	foreach(Player, i)
	{
		if(NoriMainytis[i]==playerid)
		{
			SendInfoMessage(NoriMainytis[i],"Mainai atsaukti!");
			NoriMainytis[i]=-1;
		}
		if(playerDB[i][rid][0] == playerid) 
		{
			SendInfoMessage(playerDB[i][rid][0],"Mainai atsaukti!");
			playerDB[i][rid][0]=-1;
			playerDB[i][rrusis]=0;
		}
		if(playerDB[playerid][admin]) 
			if(PlayerSpectated[i]==playerid) PlayerSpectated[i]=-1;
		if(offerCar[i][0]==playerid)
			offerCar[i]={-1,0};
		if(offerCar2[i][0]==playerid)
			offerCar2[i]={-1,0};
		if(offerCar3[i][0]==playerid)
			offerCar3[i]={-1,0};
		if(playerDB[i][rid][0]==playerid)
			playerDB[i][rid][0]=-1;
		if(playerDB[i][baikeruzd]==playerid)
		{
			new msg[128];
			format(msg,sizeof(msg)," * Jusu ieđkomas ţaidejas %s atsijungë. Atvaţiuokite á bustinć, kad gautumët kitŕ uţduotá!",ReturnName(playerid));
			SendClientMessage(i,RED,msg);
			playerDB[i][baikeruzd]=-1;
			SetPlayerCheckpoint(i,2351.3904,-651.9200,127.6273,5.0);
		}
		if(LastTarget[i] == playerid)
			LastTarget[i] = INVALID_PLAYER_ID;
	}
	if(playerDB[playerid][playingpoker])
	{
		new id=-1,pid=-1;
		for(new x;x<MAX_POKER_GAMES;x++)
		{
			for(new i;i<6;i++)
			{
				if(Poker[x][players][i] == playerid)
				{
					id=x;
					pid=i;
					break;
				}
				if(Poker[x][watching] == playerid)
				{
					Poker[x][watching]=-1;
					id=x;
					for(new ix;ix<5;ix++)
					{
						TextDrawHideForPlayer(playerid,Poker[id][TableKorta][ix]);
						//TextDrawDestroy(TableKorta[i]);
					}
					//TextDrawDestroy(JusuKortos);
					TextDrawHideForPlayer(playerid,Poker[id][BankTD]);
					TextDrawHideForPlayer(playerid,Poker[id][JusuEile]);
					for(new y;y<6;y++)
					{
						TextDrawHideForPlayer(playerid,Poker[id][PokerAction][y]);
						TextDrawHideForPlayer(playerid,Poker[id][PokerMoney][y]);
						TextDrawHideForPlayer(playerid,Poker[id][PokerName][y]);
						for(new z;z<2;z++)
						{
							PlayerTextDrawHide(playerid,Korta[playerid][y][z]);
							PlayerTextDrawDestroy(playerid,Korta[playerid][y][z]);
						}
					}
					for(new z;z<5;z++)
					{
						PlayerTextDrawHide(playerid,Mygtukas[z][playerid]);
						PlayerTextDrawDestroy(playerid,Mygtukas[z][playerid]);
					}
				}
			}
		
		}
		if(id != -1 &&  pid != -1)
		{
			LeaveGame(playerid,id,pid);
		}
	}
	if(TradingWith[playerid] != -1)
	{
		DestroySelectionMenu(playerid);
		CancelSelectTextDraw(playerid);
		if(IsPlayerConnected(TradingWith[playerid]) && TradingWith[TradingWith[playerid]]==playerid)
		{
			DestroySelectionMenu(TradingWith[playerid]);
			CancelSelectTextDraw(TradingWith[playerid]);
			SendInfoMessage(TradingWith[playerid],"Kitas zmogus atsauke mainus!");
			PlayerTextDrawColor(playerid, MainuTD[6][playerid], 0xACCBF1FF);
			PlayerTextDrawShow(playerid, MainuTD[6][playerid]);
		}
		Sutinka{playerid}=false;
		Sutinka{TradingWith[playerid]}=false;
		TradingWith[playerid]=-1;
	}
	if(PlayerSpectated[playerid] != -1)
	{
		EndSpectate(PlayerSpectated[playerid]);
	}
	if(BlinkTime[playerid] != -1) { KillTimer(BlinkTime[playerid]); BlinkTime[playerid]=-1; }
	if(InvalidNickKick(playerid, false)) 
	{
		printf("invalid nick kick!");
		return 1;
	}
	if(KDalyvis[playerid][Dalyvauja])
	{
		KDalyvis[playerid][Dalyvauja]=false;
		KDalyvis[playerid][DabartinisCPs]=0;
		Keliones[Dalyviai]--;
		if(Keliones[Dalyviai] == 0)
		{
			Keliones[Ijungta]=false;
			Keliones[DabartinisCP]=0;
			SendMessageToKlubai(COLOR_WHITE,"[racija] Operatore: Visi dalyviai paliko kelione!");
		}
	}
	if(Keliones[Kurejas]==playerid)
	{
		Keliones[Kurejas]=-1;
		Keliones[Ijungta]=false;
		Keliones[Kuriama]=false;
	}
    if(!reason) LogA(playerid,"Atsijunge(CRASH)");
    else
    {
        if(playerDB[playerid][ant]) LogA(playerid,"Atsijunge(Surakintas)");
        else if(playerDB[playerid][suristas]) LogA(playerid,"Atsijunge(Suristas)");
        else if(InEvent(playerid))
        {
        	LogA(playerid,"Atsijunge(event)");
        	LastEvent[playerid]=0;
			ResetGunData(playerid);
			DisableRemoteVehicleCollisions(playerid,0);
        }
        else
			LogA(playerid,"Atsijunge");
	}
	if(PlayerCow[playerid] != -1)
	{
		DestroyPlayerObject(playerid,PlayerCow[playerid]);
		KillTimer(CowTimer[playerid]);
		CowTimer[playerid]=-1;
	}
	if(MirgaloTimer[playerid] != -1)
	{
		KillTimer(MirgaloTimer[playerid]);
		MirgaloTimer[playerid]=-1;
	}
	if(DEBUG) printf("1");
	if(Sniegas[playerid]!= -1)
	{
		KillTimer(SniegoTimer[playerid]);
		SniegoTimer[playerid]=-1;
		DestroyPlayerObject(playerid,Sniegas[playerid]);
	}
	if(Uzimineja[playerid]> 0)
	{
		Uzimineja[playerid]=0;
	}
	if(playerDB[playerid][skambutis]!= -1)
	{
		new pokalbis = playerDB[playerid][skambutis];
		playerDB[pokalbis][skambutis]=-1;
		SendInfoMessage(playerid,"~b~ Pokalbis baigtas ");
		PlayerPlaySound(pokalbis, 1186, 0.0, 0.0, 0.0); // Isjunge muzika
		playerDB[playerid][skambutis]=-1;
	}
	PlayerTextDrawHide(playerid,VeiksmuTD[playerid]);
	PlayerTextDrawDestroy(playerid,VeiksmuTD[playerid]);
	PlayerTextDrawHide(playerid,DegalasTD[playerid]);
	PlayerTextDrawDestroy(playerid,DegalasTD[playerid]);
	PlayerTextDrawHide(playerid,AkumasTD[playerid]);
	PlayerTextDrawDestroy(playerid,AkumasTD[playerid]);
	PlayerTextDrawHide(playerid,Speedo[playerid]);
	PlayerTextDrawDestroy(playerid,Speedo[playerid]);
	PlayerTextDrawHide(playerid,PlayerText[playerid]);
	PlayerTextDrawDestroy(playerid,PlayerText[playerid]);
	PlayerTextDrawHide(playerid,VehicleHP[playerid]);
	PlayerTextDrawDestroy(playerid,VehicleHP[playerid]);
	_pText[playerid]=0;
	PlayerTextDrawHide(playerid,JobText[playerid]);
	PlayerTextDrawDestroy(playerid,JobText[playerid]);
	TextDrawDestroy(Spectate[playerid]);
	if(Gydosi[playerid] != -1) KillTimer(Gydosi[playerid]);
	Gydosi[playerid]=-1;
	/*if(playerDB[playerid][SpawnTimer] != -1) KillTimer(playerDB[playerid][SpawnTimer]);
	playerDB[playerid][SpawnTimer]=-1;*/

	
	if(playerDB[playerid][ant])
	{
		if(GetPlayerWantedLevel(playerid) > 0 && !playerDB[playerid][ikalintas])
		{
			playerDB[playerid][kalejimo_laikas] = GetPlayerWantedLevel(playerid)*2000;
			new x = GetFreeKamera(playerid);
			JailPlayer(playerid,Kameros[x][0],Kameros[x][1],Kameros[x][2],0,playerDB[playerid][kalejimo_laikas]*1000,0,3180.9961,-966.1835,293.3473,365.7195,0,true); 
			UsedCell[x]=-1;
		}
		else
		{
		    new msg[128],year,month,day;
			getdate(year,month,day);
		    format(msg,sizeof(msg),"[racija] Operatore: %s atsijunge surakintas! Pareigunas ji surakines Dekit foto i foruma(%i-%i).",ReturnName(playerid),month,day);
		    SendMessageToTeisesauga(YELLOW,msg);
			EAtaskaita("Policija",ReturnName(playerid),"Ispejimas","Jus atsijungete surakintas. Yra didele tikimybe, jog busite uzblokuotas.~Apsilankykite musu forume, ir ziurekite ar jus nebuvote apskustas.");
		}
	}
	if(playerDB[playerid][suristas] && !playerDB[playerid][ikalintas])
	{	
		playerDB[playerid][kalejimo_laikas] = 2000+GetPlayerWantedLevel(playerid)*1000;
		SetPlayerWantedLevel(playerid,0);
		new x = GetFreeKamera(playerid);
		JailPlayer(playerid,Kameros[x][0],Kameros[x][1],Kameros[x][2],0,playerDB[playerid][kalejimo_laikas]*1000,0,3180.9961,-966.1835,293.3473,365.7195,0,true); 
		UsedCell[x]=-1;
		EAtaskaita("Baikeriai",ReturnName(playerid),"Ispejimas","Jus atsijungete suristas.~Uz tai gavote 2000 sekundziu kalejimo bausmes.");
	}
	new Float:xealth;
	new vehz;
	if(DEBUG) printf("2");
	if(Carlist[playerid][Carid]!=-1)
	{
		vehz = Carlist[playerid][Carid];
		GetVehicleHealth(vehz, xealth);
	    if(vehicleDB[vehz][dega] || xealth < 300)
		{
			vehicleDB[vehz][dega]=0,vehicleDB[vehz][sprogs]=0;
			DestroyVehicle(vehz);
			Carlist[playerid][Rida]=floatmax(Carlist[playerid][Rida],vehicleDB[vehz][rida]);
			Carlist[playerid][Status]=0;
			Carlist[playerid][Carid]=-1;
		}
	}
	if(Carlist2[playerid][Carid]!=-1)
	{
		vehz = Carlist2[playerid][Carid];
		GetVehicleHealth(vehz, xealth);
	    if(vehicleDB[vehz][dega] || xealth < 300)
		{
			vehicleDB[vehz][dega]=0,vehicleDB[vehz][sprogs]=0;
			DestroyVehicle(vehz);
			Carlist2[playerid][Rida]=floatmax(Carlist2[playerid][Rida],vehicleDB[vehz][rida]);
			Carlist2[playerid][Status]=0;
			Carlist2[playerid][Carid]=-1;
		}
	}
	if(Carlist3[playerid][Carid]!=-1)
	{
		vehz = Carlist3[playerid][Carid];
		GetVehicleHealth(vehz, xealth);
	    if(vehicleDB[vehz][dega] || xealth < 300)
		{
			vehicleDB[vehz][dega]=0,vehicleDB[vehz][sprogs]=0;
			DestroyVehicle(vehz);
			Carlist3[playerid][Rida]=floatmax(Carlist3[playerid][Rida],vehicleDB[vehz][rida]);
			Carlist3[playerid][Status]=0;
			Carlist3[playerid][Carid]=-1;
		}
	}


	if(DEBUG) printf("3");
	print("Before authstate");
	if(playerDB[playerid][authstate]==1 || GetPVarInt(playerid,"PXP") == 0)
	{
		if(!CheckZone(playerid) && playerDB[playerid][apmokymai]==0 && (GetPlayerScore(playerid) >= 20 || GetPlayerMoneyA(playerid) >= 5000 || playerDB[playerid][banke] >= 5000))
		{
			printf("Autosaving %s (%i XP %iEUR %iEUR)",ReturnName(playerid),GetPlayerScore(playerid),GetPlayerMoneyA(playerid),playerDB[playerid][banke]);
			SetPlayerKVS(playerid,"AutoSaved","warn");
			SaveKeyBinds(playerid);
			SavePlayerData(playerid,false);
			SaveMasina(playerid);
		}
	}
	else if(playerDB[playerid][authstate]==4)
	{
		SaveKeyBinds(playerid);
		if(DEBUG) printf("4");
		print("Saving");
	    SavePlayerData(playerid,true);
		if(DEBUG) printf("5");
	    SaveMasina(playerid);
		if(DEBUG) printf("14?");
	}
	if(playerDB[playerid][apmokymai])
	{
		ClearCameraID(GetPlayerCameraID(playerid));
		ExitCamera(playerid);
		playerDB[playerid][apmokymai]=0;
	}
	if(Carlist[playerid][Carid]!=-1)
	{
		SetVehicleParamsForAll(Carlist[playerid][Carid],0,0);
		DestroyVehicle(Carlist[playerid][Carid]);
	}
	if(Carlist2[playerid][Carid]!=-1)
	{
		SetVehicleParamsForAll(Carlist2[playerid][Carid],0,0);
		DestroyVehicle(Carlist2[playerid][Carid]);
	}
	if(Carlist3[playerid][Carid]!=-1)
	{
		SetVehicleParamsForAll(Carlist3[playerid][Carid],0,0);
		DestroyVehicle(Carlist3[playerid][Carid]);
	}
	if (Spectating[playerid][0]!=-1)
	{
		SetVehicleParamsForAll(aVehicleNames[Spectating[playerid][0]][Carid],0,0);
		Spectating[playerid][0]=-1;
	}
	return 1;
}

stock SetNPCSkinCoord(world,int,Float:Xx,Float:Yy,Float:Zz)
{
	//printf("debug(%i):1",npcid);
	new Float:mini=10000.0;
	new bestid;
	for(new i;i<sizeof(NPCCoord);i++)
	{
		if(NPCInt[i]==int)
		{
			new Float:range = GetDistanceBetweenPoints(Xx,Yy,Zz,NPCCoord[i][0],NPCCoord[i][1],NPCCoord[i][2]);
			if(range < mini)
			{
				mini = range;
				bestid=i;
			}
		}
	}
	new actor = CreateActor(NPCSkin[bestid], NPCCoord[bestid][0],NPCCoord[bestid][1],NPCCoord[bestid][2], NPCCoord[bestid][3]);
	SetActorVirtualWorld(actor,world);
	ApplyActorAnimation(actor, "SHOP", "SHP_Serve_Idle", 4.0,1,0,0,0,0);
	/*
	SetPlayerSkin(npcid,NPCSkin[bestid]);
	SetPlayerPos(npcid,NPCCoord[bestid][0],NPCCoord[bestid][1],NPCCoord[bestid][2]);
	SetPlayerFacingAngle(npcid,NPCCoord[bestid][3]);
	SetPlayerFacingAngle(npcid,NPCCoord[bestid][3]);*/
	return 1;
}

public OnPlayerSpawn(playerid)
{
	//printf("Glob %i Priv %i",Spectate[playerid], JobText[playerid]);
	DisableRemoteVehicleCollisions(playerid,0);
	RemovePlayerAttachedObject(playerid, DOVANOS_SLOT);
	if(playerDB[playerid][psratasvydis])
	{
		Sratasvydziosetup(playerid);
		return 1;
	}
	if(HandleWorldSpawn(playerid))
	{
		return 1;
	}
	SetPlayerTeam(playerid,NO_TEAM);
	
	if(IsPlayerNPC(playerid))
	{
		new nname[MAX_PLAYER_NAME];
		GetPlayerName(playerid,nname,MAX_PLAYER_NAME);
		if(0==strcmp(nname,"Bus_Driver",true))
