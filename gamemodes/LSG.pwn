	if(GetPlayerFromCarlistCar(vehicleid) == -1 && GetPlayerFromCarlistCar2(vehicleid) == -1 && GetPlayerFromCarlistCar3(vehicleid) == -1) SetTimerEx("Respawnint",10000,false,"i",vehicleid);
