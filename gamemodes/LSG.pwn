stock SendClientMessageLT(playerid,color,text[])
{
	new textEUR[256];
	for(new i=0, j=strlen(text);i<j;i++)
	{
		switch(text[i]) 
		{
				case 'ŕ': textEUR[i]='a';
				case 'č': textEUR[i]='c';
				case 'ć': textEUR[i]='e';
				case 'ë': textEUR[i]='e';
				case 'á': textEUR[i]='i';
				case 'đ': textEUR[i]='s';
				case 'ř': textEUR[i]='u';
				case 'ű': textEUR[i]='u';
				case 'ţ': textEUR[i]='z';

				case 'Ŕ': textEUR[i]='A';
				case 'Č': textEUR[i]='C';
				case 'Ć': textEUR[i]='E';
				case 'Ë': textEUR[i]='E';
				case 'Á': textEUR[i]='I';
				case 'Đ': textEUR[i]='S';
				case 'Ř': textEUR[i]='U';
				case 'Ű': textEUR[i]='U';
				case 'Ţ': textEUR[i]='Z';
				case '$':
				{
					textEUR[i]='€';
					text[i]='€';
				}
				case 'Ł':
				{
					text[i] = '$';
					textEUR[i]= '$';
				}
				default: textEUR[i]=text[i];
		}
	}
	if(strlen(text) >= 144)
	{
		printf("ERROR: Message too long: %s", text);
	}
	if(BitFlag_Get(PConfig[playerid],PCFG_RAIDES))//if(sulietuvinti[i])
		return SendClientMessage(playerid,color,textEUR);
	else
		return SendClientMessage(playerid,color,text);
}
stock formatwithoutLT(text[])
{
	new textEUR[256];
	for(new i=0, j=strlen(text);i<j;i++)
	{
		switch(text[i]) 
		{
			case 'ŕ': textEUR[i]='a';
			case 'č': textEUR[i]='c';
			case 'ć': textEUR[i]='e';
			case 'ë': textEUR[i]='e';
			case 'á': textEUR[i]='i';
			case 'đ': textEUR[i]='s';
			case 'ř': textEUR[i]='u';
			case 'ű': textEUR[i]='u';
			case 'ţ': textEUR[i]='z';

			case 'Ŕ': textEUR[i]='A';
			case 'Č': textEUR[i]='C';
			case 'Ć': textEUR[i]='E';
			case 'Ë': textEUR[i]='E';
			case 'Á': textEUR[i]='I';
			case 'Đ': textEUR[i]='S';
			case 'Ř': textEUR[i]='U';
			case 'Ű': textEUR[i]='U';
			case 'Ţ': textEUR[i]='Z';
			case '$':
			{
				textEUR[i]='€';
				text[i]='€';
			}
			case 'Ł':
			{
				text[i] = '$';
				textEUR[i]= '$';
			}

			default: textEUR[i]=text[i];
		}
	}
	return textEUR;
}
stock SendClientMessageToAllLT(color,text[])
{
	new textEUR[256];
	for(new i=0, j=strlen(text);i<j;i++)
	{
		switch(text[i]) 
		{
				case 'ŕ': textEUR[i]='a';
				case 'č': textEUR[i]='c';
				case 'ć': textEUR[i]='e';
				case 'ë': textEUR[i]='e';
				case 'á': textEUR[i]='i';
				case 'đ': textEUR[i]='s';
				case 'ř': textEUR[i]='u';
				case 'ű': textEUR[i]='u';
				case 'ţ': textEUR[i]='z';

				case 'Ŕ': textEUR[i]='A';
				case 'Č': textEUR[i]='C';
				case 'Ć': textEUR[i]='E';
				case 'Ë': textEUR[i]='E';
				case 'Á': textEUR[i]='I';
				case 'Đ': textEUR[i]='S';
				case 'Ř': textEUR[i]='U';
				case 'Ű': textEUR[i]='U';
				case 'Ţ': textEUR[i]='Z';
				case '$':
				{
					textEUR[i]='€';
					text[i]='€';
				}
				case 'Ł':
				{
					text[i] = '$';
					textEUR[i]= '$';
				}

				default: textEUR[i]=text[i];
		}
	}
	foreach(Player,i)
	{
		if(BitFlag_Get(PConfig[i],PCFG_RAIDES))//if(sulietuvinti[i])
			SendClientMessage(i,color,textEUR);
		else
			SendClientMessage(i,color,text);
	}
	return 1;
}
