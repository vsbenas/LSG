	new Float:Coo[3];
	GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
	SetPlayerObjectPos(playerid,Sniegas[playerid],Coo[0],Coo[1],Coo[2]-2.0);
	return 1;
}


