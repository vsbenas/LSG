stock LoadGaujuTagai()
{
	new query[256];
	for(new i;i<sizeof(GaujuTagai);i++)
	{
		TagOwnedBy[i]=-1;
		format(query,sizeof(query),"SELECT `Gang` From `Tags` WHERE `ID`=%i",i);
		mysql_function_query(SQL, query, true, "SQL_Tagai", "i", i);
	}
	
	return 1;
}

stock SaveGaujuTagai()
{
	new query[256];
	for(new i;i<sizeof(GaujuTagai);i++)
	{
		format(query,sizeof(query),"UPDATE `Tags` SET `Gang`=%i WHERE `ID`=%i",TagOwnedBy[i],i);
		mysql_query(query);
	}
	return 1;
}
stock ChangeGangTag(playerid,tagid)
{
	if(!IsPlayerInRangeOfPointEx(10.0,playerid,GaujuTagai[tagid][0],GaujuTagai[tagid][1],GaujuTagai[tagid][2])) return 0;
	if(TagObj[tagid] != -1) DestroyDynamicObject(TagObj[tagid]);
	TagObj[tagid] = CreateDynamicObject(FamilyInfo[playerDB[playerid][pgang]][FamilySpray],GaujuTagai[tagid][0],GaujuTagai[tagid][1],GaujuTagai[tagid][2],GaujuTagai[tagid][3],GaujuTagai[tagid][4],GaujuTagai[tagid][5]);
	if(playerDB[playerid][pgang] == 4) // mafia
	{
		SetDynamicObjectMaterialText(TagObj[tagid], 0, "†THE†\nMAFIA", OBJECT_MATERIAL_SIZE_256x256, "Copperplate Gothic Light", 82, 1, 0xBB000000, 0, OBJECT_MATERIAL_TEXT_ALIGN_CENTER);

	}
	else if(playerDB[playerid][pgang] == 5) // dnb
	{

		SetDynamicObjectMaterialText(TagObj[tagid], 0, "Da’\nNĹNG\nBoyZ", OBJECT_MATERIAL_SIZE_128x128, "Segoe Script", 42, 1, 0xBBEEEEEE, 0, OBJECT_MATERIAL_TEXT_ALIGN_CENTER);
	}

	Streamer_Update(playerid);
	TagOwnedBy[tagid] = playerDB[playerid][pgang];
	ProcessAchievement(playerid,72);
	for(new i; i<MAX_FAMILY;i++)
	{
		if(IsPlayerInDynamicArea(playerid,FamilyInfo[i][FamilyZone][2]) && i != TagOwnedBy[tagid])
		{
			new msg[128];
			format(msg,sizeof(msg),"[gauja] %s uzpuole jusu gaujos teritorija!",FamilyInfo[TagOwnedBy[tagid]][FamilyName]);
			SendMessageToFamily(i,WHITE,msg);
			break;
		}
	}	
	
	
	return 1;
}

stock GetClosestTag(playerid,Float:Distance=9999.0)
{
	if(IsPlayerInWorld(playerid))
		return -1;
	new place=-1,Float:Dist;
	for(new i;i<sizeof(GaujuTagai);i++)
	{
		Dist = GetPlayerDistanceFromPoint(playerid,GaujuTagai[i][0],GaujuTagai[i][1],GaujuTagai[i][2]);
		if(Dist < Distance)
		{
			Distance=Dist;
			place=i;
		}
	}
	return place;
}
stock LeaveJob(playerid,stage=0) //LeaveJob(playerid);
{
	if(!stage)
	{
		ShowPlayerDialog(playerid,9654,DIALOG_STYLE_MSGBOX,"Palikti darba","Ar tikrai norite palikti darba?","Taip","Ne");
	}
	else
	{
		if(playerDB[playerid][uniformd])
		{
			SetPlayerSkin(playerid,playerDB[playerid][drabuziai]);
			playerDB[playerid][uniformd]=false;
			ApplyAnimation(playerid,"PLAYIDLES","stretch",4.1,0,0,0,0,0);
		}
		SendInfoMessage(playerid,"Jus palikote savo darba.");
		if(playerDB[playerid][specialybe] >= 80 && playerDB[playerid][specialybe] <= 84) {

			DeletePlayerWeapon(playerid,29);

			SetPVarInt(playerid,"LeftPD",1);
		}
		playerDB[playerid][specialybe]=0;
		playerDB[playerid][uniforma]=-1;
		//ResetPlayerWeapons(playerid);
		DeletePlayerWeaponsForJob(playerid);
		playerDB[playerid][pradirbo]=0;vezaivieta[playerid]=0;
		playerDB[playerid][jobpts]=0;
		SavePlayerData(playerid,true);	
	}
	return 1;
}
stock Pareigos(playerid,pareiga[])
{
	return GetPVarInt(playerid,pareiga);
}
