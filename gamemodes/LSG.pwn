		Carlist3[playerid][mod15]=-1; Carlist3[playerid][mod16]=-1; Carlist3[playerid][mod17]=-1; Carlist3[playerid][Paintjob]=-1; Carlist3[playerid][Gas]=-1; Carlist3[playerid][Sirena]=0; Carlist3[playerid][Energy]=-1;
