		{
			itemname="Seklu";
			playerDB[playerid][seklos]+=Countas;
		}
		else if(Item==51)
		{
			itemname="Zoles";
			playerDB[playerid][zole]+=Countas;
		}	
		else if(Item==52)
		{
			itemname="Amfetamino";
			playerDB[playerid][amfetaminas]+=Countas;
		}
		else if(Item==53)
		{
			itemname="LSD";
			playerDB[playerid][lsd]+=Countas;
		}
		else if(Item==54)
		{
			itemname="Ekstazio";
			playerDB[playerid][ratai]+=Countas;
		}
		else if(Item==55)
		{
			itemname="Pinigu";
			GivePlayerMoneyA(playerid,Countas);
		}
		else if(Item==60)
		{
			itemname="Bomba";
			SetPlayerAttachedObject( playerid, SLOT_KROVINYS, 1575, 1, -0.064613, 0.520760, 0.000000, 0.000000, 84.217391, 0.000000, 1.000000, 1.000000, 1.000000 );
			SetPVarInt(playerid,"Bomba",1);
			ApplyAnimation(playerid, "CARRY", "crry_prtial", 4.0, 1, 1, 1, 1, 1);
		}
		else if(Item==56)
		{
			itemname="Masalo";
			playerDB[playerid][masalas]+=Countas;
		}
		else if(Item==57)
		{
			itemname="Zuvies";
			playerDB[playerid][zuvis]+=Countas;
		}
	}
	new msg[128];
	if(mid == 4)
		format(msg,128," * %s is saugyklos issitraukia %s!",ReturnName(playerid),itemname);
	else
		format(msg,128," * %s is bagazines issitraukia %s!",ReturnName(playerid),itemname);
	SavePlayerData(playerid,true);
	ProxDetector(20.0, playerid, msg, COLOR_CHAT1,COLOR_CHAT2,COLOR_CHAT3,COLOR_CHAT4,COLOR_CHAT5);
	ShowBagazine(playerid);
	return 1;
}
stock GetBankID(idx)
{
	for(new bankid;bankid < TotalBanks;bankid++) if(BankID[bankid]==idx) return bankid;
	return -1;
}
stock AddToBankArray(playerid,idx,kasa)
{
	new bankid = GetBankID(idx);
	for(new que=1;que<MAX_IN_QUE;que++)
	{
		if(BankArray[bankid][kasa][que] == playerid)
		{
			return SendInfoMessage(playerid,"Jus jau turite ceki!"),0;
		
		}
		if(BankArray[bankid][kasa][que] == -1)
		{
			BankArray[bankid][kasa][que]=playerid;
			//printf("Added to bankid %i, kasa %i, que nr: %i",bankid,kasa,que);
			return 1;
		}
	}
	return 0;
}
stock GetCekioNr(idx,kasa)
{
	new mina=0;
	new bankid = GetBankID(idx);
	for(new que=0;que<MAX_IN_QUE;que++)
	{
		if(BankArray[bankid][kasa][que] != -1)
		{
			if(playerDB[BankArray[bankid][kasa][que]][cekis] >= mina) mina = playerDB[BankArray[bankid][kasa][que]][cekis];
		}
	}
	if(!mina) return (random(500)+1);
	else return (mina+1);
}
new BankuWarnings[MAX_PLAYERS];
forward Banks();
public Banks()
{
	/*#define MAX_BANKS 10
	#define MAX_KASOS 4
	#define MAX_IN_QUE 20
	new BankArray[MAX_BANKS][MAX_KASOS][MAX_IN_QUE];*/
	new msg[128];
	for(new bankid;bankid < TotalBanks;bankid++)
	{
		//new idx = BankID[bankid];
		for(new kasa;kasa<MAX_KASOS;kasa++)
		{
			new bool:Change=false;
			if(BankArray[bankid][kasa][0] != -1 && IsPlayerConnected(BankArray[bankid][kasa][0]))
			{
				// operacijos laikas baigesi
				BankuWarnings[BankArray[bankid][kasa][0]]++;
				if(BankuWarnings[BankArray[bankid][kasa][0]] >= 3 || playerDB[BankArray[bankid][kasa][0]][cekis]==0)
				{
					//if(playerDB[BankArray[bankid][kasa][0]][cekis] != BankArray[bankid][kasa][0]
					if(gPlayerDialog[BankArray[bankid][kasa][0]] != -1)
						ShowPlayerDialog(BankArray[bankid][kasa][0], 8342,DIALOG_STYLE_MSGBOX,"Operacija","Operacijos laikas baigesi", "Gerai", "");
					playerDB[BankArray[bankid][kasa][0]][cekis]=0;
					BankArray[bankid][kasa][0]=-1;
					Change=true;
				}
			}
			else
				Change=true;
			if(Change)
			{
				for(new id;id<(MAX_IN_QUE-1);id++)
				{
					BankArray[bankid][kasa][id]=BankArray[bankid][kasa][id+1];
					if(BankArray[bankid][kasa][id] != -1)
					{
						new playerid = BankArray[bankid][kasa][id];
						if(id == 0)
						{
							if(!playerDB[playerid][cekis])
							{
								SendInfoMessage(playerid,"Pasiimkite ceki!");
							}
							else
							{
								SendInfoMessage(playerid,"~y~Jusu eile!");
								SendClientMessage(playerid,YELLOW," * Jusu eile!");
								format(msg,sizeof(msg),"{FFFFFF}Kasa {33FF33}%i\n{FF0000}%i",kasa+1,playerDB[playerid][cekis]);
								UpdateDynamic3DTextLabelText(BankuTextai[bankid][kasa], 0xFFFFFFFF, msg);
								BankuWarnings[BankArray[bankid][kasa][0]]=0;
							}
						}
						else
						{
							if(id==1) SendInfoMessage(playerid,"Pries jus dar 1 zmogus.");
							else
							{
								format(msg,sizeof(msg),"Pries jus dar %i zmones.",id);
								SendInfoMessage(playerid,msg);
							}
						}
					}
				}
			}
		}
	}
	return 1;
}

stock BankSystem(playerid,pickupid)
{
 // new BankuSystem[MAX_BUSINESSES][5];
	if(GetPlace(playerid) != PLACE_BIZ) return 0;
	new vw = GetPlayerVirtualWorld(playerid)-MAX_HOUSES*2;
	if(BusinessInfo[vw][bType] != 17) return 0;
	if(LoadOrderInka(playerid))
		return 1;
	playerDB[playerid][paskutinisrubas]=vw;
	new bankid = GetBankID(vw);
	if(pickupid == pickups[0][bankocekiai])
	{
		ShowPlayerDialog(playerid,8543,DIALOG_STYLE_LIST,"Banko operacijos","Kasa 1: mokëti algas\nKasa 2: pervedimai\nKasa 3: pasiimti banko kortelć\nKasa 4,5: pasiimti/padëti pinigus","Gerai","Atsaukti");
		return 1;
	}	
	if(!playerDB[playerid][cekis]) return SendInfoMessage(playerid,"Privalote pasiimti ceki ir laukti savo eiles!"),1;
	else if(pickupid == pickups[0][bankoalgos])
	{
		//if(playerDB[playerid][cekis] > 100) return SendInfoMessage(playerid,"Jus ne toje kasoje!"),1;
		if(BankArray[bankid][0][0] == playerid)
		{
			if(!playerDB[playerid][plead]) return SendInfoMessage(playerid,"Tau nepriklauso jokia firma!");
			
			new msg[128];
			format(msg,sizeof(msg)," Jusu firmos pelnas {33FF33}%i€{FFFFFF}.\n Norite testi?",pelnas[playerDB[playerid][plead]-1]);
			ShowPlayerDialog(playerid, 605, DIALOG_STYLE_MSGBOX,"Pelnas", msg, "Testi", "Atsaukti");
			return 1;
		}
		else return SendInfoMessage(playerid,"Prasome sulaukti savo eiles!");
	}
	else if(pickupid == pickups[0][bankopervedimai])
	{
		//if(playerDB[playerid][cekis] < 100 || playerDB[playerid][cekis] > 200) return SendInfoMessage(playerid,"Jus ne toje kasoje!"),1;
		if(BankArray[bankid][1][0] == playerid)
		{
			new msg[256];
			if(!playerDB[playerid][kortele]) return SendInfoMessage(playerid,"Jus neturite banko saskaitos.~n~Pasiimkite ja kitoje kasoje.");
			format(msg,sizeof(msg),"{FFFFFF}Pervesti pinigus. Balansas: {33FF33}%i€\n{FFFFFF}Pervesti kreditus. Balansas: {33FF33}%i kred",playerDB[playerid][banke],playerDB[playerid][kreditai]);
			ShowPlayerDialog(playerid, 616, DIALOG_STYLE_LIST,"Bankas", msg, "Taip", "Ne");
			return 1;
		}
		else return SendInfoMessage(playerid,"Prasome sulaukti savo eiles!");	
	}
	else if(pickupid == pickups[0][bankokortele])
	{
		//if(playerDB[playerid][cekis] < 200 || playerDB[playerid][cekis] > 300) return SendInfoMessage(playerid,"Jus ne toje kasoje!"),1;
		if(BankArray[bankid][2][0]==playerid)
		{
			if(!playerDB[playerid][kortele]) 
				ShowPlayerDialog(playerid, 410, DIALOG_STYLE_MSGBOX, "Banko saskaita", "Ar norite atsidaryti banko sŕskaitŕ ir gauti kreditinć kortelć?\nTai jums nieko nekainuos!", "Taip", "Ne");
			else 
				SendInfoMessage(playerid,"Jus jau turite banko kortele.");
			return 1;
		}
		else return SendInfoMessage(playerid,"Prasome sulaukti savo eiles!");	
	}
	else if(pickupid == pickups[0][bankopop])
	{
		//if(playerDB[playerid][cekis] < 300 || playerDB[playerid][cekis] > 400) return SendInfoMessage(playerid,"Jus ne toje kasoje!"),1;
		if(BankArray[bankid][3][0]==playerid)
		{
			new msg[128];
			if(!playerDB[playerid][kortele]) return SendInfoMessage(playerid,"Jus neturite banko saskaitos.~n~Pasiimkite ja kitoje kasoje.");
			format(msg,sizeof(msg)," Jűsř sŕskaitos balansas {33FF33} %i€.\n{FFFFFF} Norite tćsti?",playerDB[playerid][banke]);
			ShowPlayerDialog(playerid, 610, DIALOG_STYLE_MSGBOX,"Bankas", msg, "Taip", "Ne");
			return 1;
		}
		else return SendInfoMessage(playerid,"Prasome sulaukti savo eiles!");	
	}
	else if(pickupid == pickups[1][bankopop])
	{
		//if(playerDB[playerid][cekis] < 400 || playerDB[playerid][cekis] > 500) return SendInfoMessage(playerid,"Jus ne toje kasoje!"),1;
		if(BankArray[bankid][4][0]==playerid)
		{
			new msg[128];
			if(!playerDB[playerid][kortele]) return SendInfoMessage(playerid,"Jus neturite banko saskaitos.~n~Pasiimkite ja kitoje kasoje.");
			format(msg,sizeof(msg)," Jűsř sŕskaitos balansas {33FF33} %i€.\n{FFFFFF} Norite tćsti?",playerDB[playerid][banke]);
			ShowPlayerDialog(playerid, 610, DIALOG_STYLE_MSGBOX,"Bankas", msg, "Taip", "Ne");
			return 1;
		}
		else return SendInfoMessage(playerid,"Prasome sulaukti savo eiles!");	
	}
	return 0;
}

public OnPlayerFloodControl(playerid, iCount, iTimeSpan) 
{
    if(iCount >= 3 && iTimeSpan < 10000 && !IsPlayerNPC(playerid)) 
	{
		new ip[24];
		GetPlayerIp(playerid,ip,24);
		if(0==strcmp(ip,"127.0.0.1",true)) return 1;
        //Ban(playerid);
		SendClientMessage(playerid,RED,"Jus uzblokuotas, nes esate kaltinamas botu atakomis.");
		BanEx(playerid,"Flood Control");
		PlayerSlotUsed[playerid]=0;
    }
	return 1;
}

