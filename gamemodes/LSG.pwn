STREAMER_TAG_3D_TEXT_LABEL:CreateDynamic3DTextLabelExEx(text[], color, Float:x, Float:y, Float:z, Float:drawdistance, attachedplayer = INVALID_PLAYER_ID, attachedvehicle = INVALID_VEHICLE_ID, testlos = 0, worldid = -1, interiorid = -1, playerid = -1, Float:streamdistance = STREAMER_3D_TEXT_LABEL_SD, STREAMER_TAG_AREA:areaid = STREAMER_TAG_AREA:-1, priority = 0)
{
	playerid = INVALID_PLAYER_ID;
	new Text3D:retsa = CreateDynamic3DTextLabel(text,color,x,y,z, drawdistance, attachedplayer, attachedvehicle, testlos, worldid, interiorid, playerid, streamdistance,areaid, priority);
	TextExists[_:retsa] = 1;
	for(new i=0, j=strlen(text);i<j;i++)
	{
		switch(text[i]) 
		{
			case 'ŕ': text[i]='a';
			case 'č': text[i]='c';
			case 'ć': text[i]='e';
			case 'ë': text[i]='e';
			case 'á': text[i]='i';
			case 'đ': text[i]='s';
			case 'ř': text[i]='u';
			case 'ű': text[i]='u';
			case 'ţ': text[i]='z';
			case 'Ŕ': text[i]='A';
			case 'Č': text[i]='C';
			case 'Ć': text[i]='E';
			case 'Ë': text[i]='E';
			case 'Á': text[i]='I';
			case 'Đ': text[i]='S';
			case 'Ř': text[i]='U';
			case 'Ű': text[i]='U';
			case 'Ţ': text[i]='Z';
			case '$': text[i]='€';
		}
	}
	new Text3D:temp = CreateDynamic3DTextLabel(text,color,x,y,z, drawdistance, attachedplayer, attachedvehicle, testlos, worldid, interiorid, playerid, streamdistance,areaid, priority);
	ConvertedText[_:retsa] = temp;

	foreach(Player, idux)
	{
		if(BitFlag_Get(PConfig[idux],PCFG_RAIDES))
		{
			Streamer_AppendArrayData(STREAMER_TYPE_3D_TEXT_LABEL, temp, E_STREAMER_PLAYER_ID, idux);
		}
		else
		{
			Streamer_AppendArrayData(STREAMER_TYPE_3D_TEXT_LABEL, retsa, E_STREAMER_PLAYER_ID, idux);
		}
	}

	return retsa; // ret and ret+1(€)
}
#define CreateDynamic3DTextLabel CreateDynamic3DTextLabelExEx
stock DestroyDynamic3DTextLabelEx(STREAMER_TAG_3D_TEXT_LABEL:id)
{
	if(IsValidDynamic3DTextLabel(id))
	{
		TextExists[_:id] = 0;
		DestroyDynamic3DTextLabel(ConvertedText[_:id]);
	}
	return DestroyDynamic3DTextLabel(id);
}
#define DestroyDynamic3DTextLabel DestroyDynamic3DTextLabelEx
stock UpdateDynamic3DTextLabelTextEx(STREAMER_TAG_3D_TEXT_LABEL:id, color, text[])
{
	new ret = UpdateDynamic3DTextLabelText(id, color, text);
	if(IsValidDynamic3DTextLabel(id))
	{
		for(new i=0, j=strlen(text);i<j;i++)
		{
			switch(text[i]) 
			{
				case 'ŕ': text[i]='a';
				case 'č': text[i]='c';
				case 'ć': text[i]='e';
				case 'ë': text[i]='e';
				case 'á': text[i]='i';
				case 'đ': text[i]='s';
				case 'ř': text[i]='u';
				case 'ű': text[i]='u';
				case 'ţ': text[i]='z';
				case 'Ŕ': text[i]='A';
				case 'Č': text[i]='C';
				case 'Ć': text[i]='E';
				case 'Ë': text[i]='E';
				case 'Á': text[i]='I';
				case 'Đ': text[i]='S';
				case 'Ř': text[i]='U';
				case 'Ű': text[i]='U';
				case 'Ţ': text[i]='Z';
				case '$': text[i]='€';
			}
		}
		UpdateDynamic3DTextLabelText(ConvertedText[_:id],color,text);
	}
	return ret;
}
#define UpdateDynamic3DTextLabelText UpdateDynamic3DTextLabelTextEx


