forward ZvejybosAnim(playerid);
public ZvejybosAnim(playerid)
{
	ApplyAnimation(playerid,"SWORD","sword_idle",1.0,1,0,0,0,0,1);
	new istrauke[32],
	    msg[128],
		randomas=random(16);
	switch(randomas)
	{
	    case 0,5,10,15: istrauke="Batŕ";
	    case 1: istrauke="Kuojŕ";
	    case 2: istrauke="Eđerá";
	    case 3: istrauke="Karđá";
	    case 4: istrauke="Lydekŕ";
	    case 6: istrauke="Starká";
	    case 7: istrauke="Karpá";
	    case 8: istrauke="Plekđnć";
	    case 9: istrauke="Karosŕ";
	    case 11: istrauke="Lynŕ";
	    case 12: istrauke="Kardţuvć";
	    case 13: istrauke="Menkć";
	    case 14: istrauke="Raudć";
	}
	new foundit=0;
	if(random(100) == 50 && zuvele == true)
	{
		zuvele = false;
		foundit = 1; 
		istrauke="Auksinć ţuvelć";
		new sum = 10000+random(10)*1000;
		GivePlayerMoneyA(playerid,sum);
		SetPlayerScore(playerid,GetPlayerScore(playerid)+1000);
		format(msg,sizeof(msg)," * Pagavai auksinć ţuvelć! Ji tau dovanoja 1000 XP ir %i €!",sum);
		SendClientMessage(playerid,TEXTCOL_GOLD,msg);
		PlayerPlaySound(playerid,4201,0,0,0);
		//LogA(playerid,"Pagavo zuvele");
		ProcessAchievement(playerid,105);
	}
	
	if(foundit == 1)
		format(msg,128," * %s pagavo {CCCC00}%s",ReturnName(playerid),istrauke);
	else
		format(msg,128," * %s pagavo {FF0000}%s",ReturnName(playerid),istrauke);
	ProxDetector(5.0, playerid, msg, COLOR_CHAT1,COLOR_CHAT2,COLOR_CHAT3,COLOR_CHAT4,COLOR_CHAT5);

	for(new i=0, j=strlen(istrauke);i<j;i++)
	{
		switch(istrauke[i]) 
		{
			case 'ŕ': istrauke[i]='a';
			case 'č': istrauke[i]='c';
			case 'ć': istrauke[i]='e';
			case 'ë': istrauke[i]='e';
			case 'á': istrauke[i]='i';
			case 'đ': istrauke[i]='s';
			case 'ř': istrauke[i]='u';
			case 'ű': istrauke[i]='u';
			case 'ţ': istrauke[i]='z';
		}
	}
	format(msg,128,"Istraukei~r~ %s~w~!",istrauke);
	SendInfoMessage(playerid,msg);
	if(randomas != 0 && randomas != 5 && randomas != 10 && randomas != 15)
	{
		playerDB[playerid][zuvis]++;
		ProcessAchievement(playerid,31);
	}
}


public Moneta(playerid)
{
	new string[128];
	if(random(2)==0)
    	format(string,sizeof(string)," * Iskrenta Herbas! * { %s }",ReturnName(playerid));
	else
	    format(string,sizeof(string)," * Iskrenta Skaicius! * { %s }",ReturnName(playerid));
	print(string);
	SetTimerEx("GaliKast",500+random(1000),0,"i",playerid);
	new Float:coo[3];
	GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
	foreach (Player, player)
	{
		if(IsPlayerInRangeOfPointEx(30,player,coo[0],coo[1],coo[2]))
		{
			SendClientMessage(player,ORANGE,string);
		}
	}

}

stock Spejimas(playerid,text[])
{
	if(GetPVarInt(playerid,"moneta_text") == 1)
	{
		SetPVarInt(playerid,"moneta_text", 0);
		new spejimas = 0;
		if(strcmp(text, "herbas", true) == 0)
		{
			spejimas = 1;
		}
		else if(strcmp(text, "skaicius", true) == 0)
		{
			spejimas = 2;
		}
		if(spejimas)
		{
			new id = GetPVarInt(playerid, "moneta_id");
			new suma = GetPVarInt(playerid, "moneta_sum");
			
			if(IsPlayerConnected(id) && GetPVarInt(id, "moneta_pasiule") == playerid)
			{
				new Float:Coo[3];
				GetPlayerPos(id,Coo[0],Coo[1],Coo[2]);
				if(!IsPlayerInRangeOfPointEx(10, playerid, Coo[0],Coo[1],Coo[2]) || GetPlayerState(id) == PLAYER_STATE_SPECTATING)
					return SendInfoMessage(playerid,"Zaidejas per toli!");
				if(GetPlayerMoneyA(playerid) < suma)
				{
					SendClientMessage(playerid, ORANGE, " * Neturi pakankamai pinigu!");
					SendClientMessage(id, ORANGE, " * Zaidejas neturi pakankamai pinigu!");
					return 1;
				}
				if(GetPlayerMoneyA(id) < suma)
				{
					SendClientMessage(id, ORANGE, " * Neturi pakankamai pinigu!");
					SendClientMessage(playerid, ORANGE, " * Zaidejas neturi pakankamai pinigu!");
					return 1;
				}
				if(GetTickCount() - GetPVarInt(playerid,"monetaoffertime") > 30000)
					return SendClientMessage(playerid, ORANGE, " * Praejo per daug laiko.");
				GivePlayerMoneyA(playerid,-suma);
				GivePlayerMoneyA(id,-suma);
				IsmestiMoneta(id,suma,spejimas,playerid);
			}
			else
			{
				SendClientMessage(playerid, ORANGE, " * Zaidejas atsijunge!");
				SetPVarInt(playerid, "moneta_text", 0);
				return 1;
			}
		}
		else
		{
			SendClientMessage(playerid, ORANGE, " * Netinkamas spejimas!");
		}
		if(spejimas == 0)
		{
			SetPVarInt(playerid, "monetaoffertime", 0);
			SetPVarInt(GetPVarInt(playerid, "moneta_id"), "monetatime",0);

			SetPVarInt(playerid, "moneta_text", 0);
		}
	}
	return 1;
}
forward MonetaNew(playerid,suma,spejimas,otherplayerid);
public MonetaNew(playerid,suma,spejimas,otherplayerid)
{
	new string[128];
	new res = random(2);
	if(res==0)
    	format(string,sizeof(string)," * Iđkrenta Herbas! * { %s }",ReturnName(playerid));
	else
	    format(string,sizeof(string)," * Iđkrenta Skaičius! * { %s }",ReturnName(playerid));

	if(res+1 == spejimas)
	{
		GivePlayerMoneyA(otherplayerid,suma*2);
		if(suma >= 1000000)
			ProcessAchievement(otherplayerid, 132);
		SendInfoMessage(otherplayerid, "~g~Laimejai!");
		SendInfoMessage(playerid,"~r~Pralaimejai!");
	}
	else
	{
		GivePlayerMoneyA(playerid,suma*2);
		if(suma >= 1000000)
			ProcessAchievement(playerid, 132);
		SendInfoMessage(playerid, "~g~Laimejai!");
		SendInfoMessage(otherplayerid,"~r~Pralaimejai!");
	}



	print(string);
	
	new Float:coo[3];
	GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
	foreach (Player, player)
	{
		if(IsPlayerInRangeOfPointEx(30,player,coo[0],coo[1],coo[2]))
		{
			SendClientMessage(player,ORANGE,string);
		}
	}

}

stock IsmestiMoneta(playerid,suma=0,spejimas=0,otherplayerid=0)
{
	new string[128];
	format(string,sizeof(string)," * %s iđmeta monetŕ á orŕ!",ReturnName(playerid));
	if(suma)
	{
		SetTimerEx("MonetaNew",2000+random(1000),0,"iiii",playerid,suma,spejimas,otherplayerid);
		SetPVarInt(playerid, "nokick", GetTickCount() + 3000);
		SetPVarInt(otherplayerid, "nokick", GetTickCount() + 3000);
	}
	else
		SetTimerEx("Moneta",2000+random(1000),0,"i",playerid);
	new Float:coo[3];
	GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
	foreach (Player, player)
	{
		if(IsPlayerInRangeOfPointEx(30,player,coo[0],coo[1],coo[2]))
		{
			SendClientMessage(player,ORANGE,string);
		}
	}
}

new LastSkelbimas[MAX_PLAYERS];

stock CheckNarkomanas(playerid,type,alert) // 0 - lsd; 1 - ratai; 2 - amfa
{
	ProcessAchievement(playerid,50);
	new vardas[24];
	GetPlayerName(playerid,vardas,MAX_PLAYER_NAME);
	new query[256];
	if(type==0)
	{
		format(query,sizeof(query),"SELECT SUM(`Variable`) From Logs WHERE UPPER(`Zaidejas`)=UPPER('%s') AND Veiksmas='LSD' LIMIT 1",vardas);
		
	}
	else if(type==1)
	{
		format(query,sizeof(query),"SELECT SUM(`Variable`) From Logs WHERE UPPER(`Zaidejas`)=UPPER('%s') AND Veiksmas='Ratai' LIMIT 1",vardas);
	}
	else if(type==2)
	{
		format(query,sizeof(query),"SELECT SUM(`Variable`) From Logs WHERE UPPER(`Zaidejas`)=UPPER('%s') AND Veiksmas='Amfa' LIMIT 1",vardas);
	}
	mysql_function_query(SQL, query, true, "SQL_NarkCheck", "iii", playerid, type,alert);
	return 1;
}
