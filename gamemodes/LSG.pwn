public OnPlayerRequestClass(playerid, classid)
{
    if(IsPlayerNPC(playerid)) return 1;
    //SetPlayerAttachedObject(playerid, DOVANOS_SLOT, 19065, 2, 0.120000, 0.040000, -0.003500, 0, 100, 100, 1.4, 1.4, 1.4);
	if(DEBUG==true) printf("OnPlayerRequestClass:%i",playerid);
    
	if(playerDB[playerid][authstate]==0 && gPlayerDialog[playerid] == -1)
	{
		new query[256]; // Susikuriam string kintamuosius.
		format(query,sizeof(query),"SELECT Xp,Drabuziai,Uniforma,Uniformd,Akiniai,Kepure FROM `Account` WHERE `Name`='%s' LIMIT 1",ReturnName(playerid));
		mysql_function_query(SQL, query, true, "SQL_CheckAcc", "i", playerid);
		//return 1;
		Preloadai(playerid);
	}
	if(playerDB[playerid][mire]) SpawnPlayer(playerid);
	if(!kord[playerid])
	{
		new hour,minute;
		gettime(hour,minute);
		SetPlayerTime(playerid,hour,minute);
		SetPlayerPoz(playerid, CAMERA_X,CAMERA_Y,CAMERA_Z, _, _, 0);
		SetPlayerFacingAngle(playerid, 0);
		SetPlayerCameraPos(playerid, CAMERA_X,CAMERA_Y,CAMERA_Z);

		SetPlayerCameraLookAt(playerid, CAMERA_X,CAMERA_Y,CAMERA_Z);
		kord[playerid]=true;
	}
	Sokimas(playerid);
	//if (playerDB[playerid][SpawnDance]) playerDB[playerid][SpawnTimer] = SetTimerEx("MoveCamera", 50, true, "i", playerid);
	//CameraMovement(playerid);
	if(playerDB[playerid][SpawnDance])
	{
		playerDB[playerid][SpawnDance] = false;
		//MoveCamera(playerid);
	}
	//SpawnPlayer(playerid);
	//new idas= LoadCameraMover("lsgintro01");
	//PlayCameraMover(playerid, idas);

	//PlayerPlaySound(playerid, 1097,-119.9460,23.1096,12.2238); // Muzika
	
	SetTimerEx("Sokimas",100,false,"i",playerid);
	return 1;
}
stock LetPlayerSpawn(playerid, login)
{
	if(login)
	{
		playerDB[playerid][vip]=false;
		if(playerDB[playerid][authstate]!=4)
			playerDB[playerid][authstate]=2; // Zaidejas prisijunges
		SendInfoMessage(playerid,"Jus sekmingai prisijungete! Linkime gero zaidimo ir geros nuotaikos!");
		SetSpawnInfo(playerid,GetPlayerTeam(playerid),GetPlayerSkin(playerid),1743.1915,-1944.5928,13.5661,0.0,0,0,0,0,0,0);
		SpawnPlayer(playerid);
		CancelSelectTextDraw(playerid); 
		TextDrawHideForPlayer(playerid,PassReminder);
		SetTimerEx("OnPlayerLogin",0,false,"ii",playerid, /* registered=*/ 0);
	}
	else
	{
		if(playerDB[playerid][authstate]!=4)
			playerDB[playerid][authstate]=1;
		SendInfoMessage(playerid,"Jus sekmingai prisijungete! Linkime gero zaidimo ir geros nuotaikos!");
		SetTimerEx("OnPlayerLogin",0,false,"ii",playerid, /* registered=*/ 1);
	}
}
public OnPlayerRequestSpawn(playerid)
{
	if(IsPlayerNPC(playerid)) return 1;
	if(DEBUG==true) printf("OnPlayerRequestSpawn:%i",playerid);
	if(playerDB[playerid][authstate]==0){SendInfoMessage(playerid,"Jus pirmiausia privalote prisijungti."); return 0;}
	if(playerDB[playerid][authstate]!=2) return 1;
	playerDB[playerid][pickup]=false;
	SetTimerEx("WantPickup",5000,0,"i",playerid);
	GameTextForPlayer(playerid,"Gero zaidimo",10000,1);
	return 1;
}
