public Gasup(vehicleid,curgass,kof,mokejo,playerid)
{
	if(playerDB[playerid][pila])
	{
		new Float:cpo[3];
		GetVehiclePos(playerDB[playerid][masina],cpo[0],cpo[1],cpo[2]);
		new model = GetVehicleModel(vehicleid);
		if(!IsPlayerInRangeOfPointEx(27,playerid,cpo[0],cpo[1],cpo[2]) || model == 0)
		{
			TogglePlayerControllable(playerid,true);
			playerDB[playerid][pila]=false;
			SendInfoMessage(playerid,"~r~Automobilis per toli");
			return 1;
		}
		if(GetPlayerMoneyA(playerid) >= kof)
		{
			if(vehicleDB[vehicleid][gas] < aBakai[model-400])
			{
				SetTimerEx("Gasup",1000,false,"iiiii",vehicleid,curgass+1,kof,mokejo+kof,playerid);
				vehicleDB[vehicleid][gas]++;
				ProcessAchievement(playerid, 133);
				GivePlayerMoneyA(playerid,-kof);
				new msg[128];
				format(msg,sizeof(msg),"~n~ Ipilta: %iL.~n~Tarifas: %iEUR/l.~n~Suma: %i EUR.~n~Baigti: ~k~~VEHICLE_ENTER_EXIT~",curgass,kof,mokejo);
				GameTextForPlayer(playerid,msg,1100,5);
			}else{
				
				GameTextForPlayer(playerid,"Bakas pilnas",2000,5);
				ProcessAchievement(playerid,75);
				playerDB[playerid][pila]=false;
				EndGasup(playerid,vehicleid,curgass,kof,mokejo);
			}
		}else{
			GameTextForPlayer(playerid,"Jums nebeuztenka pinigu",2000,5);
			playerDB[playerid][pila]=false;
			EndGasup(playerid,vehicleid,curgass,kof,mokejo);
		}
	}else{
		EndGasup(playerid,vehicleid,curgass,kof,mokejo);
	}
	return 1;
}


stock EndGasup(playerid,vehicleid,ipilta,kof,mokejo)
{
	ApplyAnimation(playerid, "HEIST9", "Use_SwipeCard", 4.000000, 0, 0, 0, 0, -1);
	new msg[128];
	SendClientMessage(playerid,BLUE,"* ===== Degalu cekis =====");
	new model = GetVehicleModel(vehicleid);
	if(!model)
		model = 400;
	format(msg,sizeof(msg),"Masina: %s",aVehicleNames[model-400]);
	SendClientMessage(playerid,GREEN,msg);
	format(msg,sizeof(msg),"Isipilta degalu: %i l.",ipilta);
	SendClientMessage(playerid,GREEN,msg);
	format(msg,sizeof(msg),"Tarifas: %i €/l.",kof);
	SendClientMessage(playerid,GREEN,msg);
	SendClientMessage(playerid,BLUE,"* ___________");
	format(msg,sizeof(msg),"Suma: %i €",mokejo);
	SendClientMessage(playerid,GREEN,msg);
	if(!playerDB[playerid][ant] && !playerDB[playerid][suristas]) TogglePlayerControllable(playerid,true);
	if(ipilta >= 20)
	{
		new xa=random(2)+1;
		if(FURU_ATVEZTA[sizeof(FURU_TEKSTAI)-xa]) FURU_ATVEZTA[sizeof(FURU_TEKSTAI)-xa]--;
	}
	foreach(Businesses,i) if(BusinessInfo[i][bOwned] && BusinessInfo[i][bType]==21 && IsPlayerInRangeOfPointEx(200.0,playerid,BusinessInfo[i][bEnterX],BusinessInfo[i][bEnterY],BusinessInfo[i][bEnterZ]))
	{
		if(GetPlayerScore(playerid) > 100) BusinessInfo[i][bEarning]+=floatround(mokejo*2/5);
		return;
	}
}

stock OnVehicleModEx(vehicleid,componentid)
{
	new model = GetVehicleModel(vehicleid);
	foreach(Player,playerid)
	{
		if(vehicleid == PlayerCar[playerid])
		{
			new modas=GetModType(componentid);
			new bool:stop=false;
			if(modas < 1 || modas > 17) return;
			for(new i;i<150;i++)
			{
				if(stop) break;
				for(new x;x<MAX_DARBINES_CAR;x++)
				{
					if(DarbinesCar[i][x][DCmodel]==model)
					{
						if(i<100)
						{
							new query[256];
							format(query,sizeof(query),"UPDATE `Darbines` SET `mod%i`=%i WHERE `Vardas`='%s' AND `Job`=%i AND `Cartype`=%i",modas,componentid,ReturnName(playerid),i,x);
							mysql_query(query);
							stop=true;
						}
						else if(i<110)
						{
							new query[256];
							format(query,sizeof(query),"UPDATE `gangcars` SET `mod%i`=%i WHERE `lastuser`='%s' AND `status`=2",modas,componentid,ReturnName(playerid));
							mysql_query(query);
							stop=true;
						}
					}
				}
			}
		}
	}
}
