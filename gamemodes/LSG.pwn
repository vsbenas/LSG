new UsedCell[sizeof(Kameros)]={-1,-1,...};

stock GetFreeKamera(playerid)
{
	for(new i;i<sizeof(Kameros);i++)
	{
		if(UsedCell[i] == -1)
		{
			UsedCell[i]=playerid;
			return i;
		}
	}
	return random(sizeof(Kameros));
}





