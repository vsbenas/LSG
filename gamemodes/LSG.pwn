		780, 940, 0, 0, 780, 860, 0, 1120, 3340, 3250, 3340, 1650, 3380, 3290, 1590, 830, 800, 1500, 1000, 0, 580, 470, 870, 980, 0, 150, 0, 100, 490, 600, 890, 1000,
		1090, 840, 910, 1200, 1030, 1030, 920, 930, 550, 1050, 1050, 950, 650, 450, 550, 850, 950, 850, 950, 970, 880, 990, 900, 950, 1000, 900, 1000, 900, 2050, 2150, 2130,
		2050, 2130, 2040, 2150, 2040, 2095, 2175, 2080, 2200, 1200, 1040, 940, 1100
	};
	if(GetPlayerInterior(playerid) == 0)
	{
		if(GetPlayerInterior(playerid)!= 0) return 1;
		AC_Ban(playerid,"Tune Hack");
		return 0;
	}
	RepairVehicle(vehicleid);
	if(GetPlayerMoneyA(playerid) < aVehicleComponentPrices[componentid - 1000]) // Check if the player has enough money (This is your server-sided money variable or whatever you use to store it)
    {
        SendInfoMessage(playerid,"~r~Neturi tiek pinigu!");
		AC_Warn(playerid,"Tune be pinigu");
		ResetPlayerMoney(playerid);
        RemoveVehicleComponent(vehicleid,componentid); // Remove the component because they don't have enough money to buy it!
		return 0;
    }
	else
	{
		playerDB[playerid][pinigai]-=aVehicleComponentPrices[componentid - 1000];
		if(componentid == 1010)
		{
			VehicleNitro[vehicleid]=1;
		}
		//GivePlayerMoneyA(playerid, -aVehicleComponentPrices[componentid - 1000]);
	}
	switch(componentid)
	{
	    case 1008..1010: if(IsPlayerInInvalidNosVehicle(playerid)) { RemoveVehicleComponent(vehicleid, componentid); return 0;}
	}
	if(!IsComponentidCompatible(model, componentid)) { RemoveVehicleComponent(vehicleid, componentid); return 0;}
	if(vehicleid == PlayerCar[playerid])
	{
		new modas=GetModType(componentid);
		new bool:stop=false;
		if(modas < 1 || modas > 17) return 1;
		for(new i;i<150;i++)
		{
			if(stop) break;
			for(new x;x<MAX_DARBINES_CAR;x++)
			{
				if(DarbinesCar[i][x][DCmodel]==model)
				{
					if(i<100)
					{
						new query[256];
						format(query,sizeof(query),"UPDATE `Darbines` SET `mod%i`=%i WHERE `Vardas`='%s' AND `Job`=%i AND `Cartype`=%i",modas,componentid,ReturnName(playerid),i,x);
						mysql_query(query);
						stop=true;
					}
					else if(i<110)
					{
						new query[256];
						format(query,sizeof(query),"UPDATE `gangcars` SET `mod%i`=%i WHERE `lastuser`='%s' AND `status`=2",modas,componentid,ReturnName(playerid));
						mysql_query(query);
						stop=true;
					}
				}
			}
		}
	}
	if (playerid!=GetPlayerFromCarlistCar(vehicleid) && playerid!=GetPlayerFromCarlistCar2(vehicleid) && playerid!=GetPlayerFromCarlistCar3(vehicleid) ) {return 1;}
	if(playerid!=-1)
	{
		if(vehicleid == Carlist[playerid][Carid])
		{
			new modas=GetModType(componentid);
			switch (modas)
			{
				case 1: { Carlist[playerid][mod1]=componentid; }
				case 2: { Carlist[playerid][mod2]=componentid; }
				case 3: { Carlist[playerid][mod3]=componentid; }
				case 4: { Carlist[playerid][mod4]=componentid; }
				case 5: { Carlist[playerid][mod5]=componentid; }
				case 6: { Carlist[playerid][mod6]=componentid; }
				case 7: { Carlist[playerid][mod7]=componentid; }
				case 8: { Carlist[playerid][mod8]=componentid; }
				case 9: { Carlist[playerid][mod9]=componentid; }
				case 10: { Carlist[playerid][mod10]=componentid; }
				case 11: { Carlist[playerid][mod11]=componentid; }
				case 12: { Carlist[playerid][mod12]=componentid; }
				case 13: { Carlist[playerid][mod13]=componentid; }
				case 14: { Carlist[playerid][mod14]=componentid; }
				case 15: { Carlist[playerid][mod15]=componentid; }
				case 16: { Carlist[playerid][mod16]=componentid; }
				case 17: { Carlist[playerid][mod17]=componentid; }
				default: { new string[128]; format(string,128,"Unknown component id: %i",componentid); print(string); }
			}
		}
		else if(vehicleid == Carlist2[playerid][Carid])
		{
			new modas=GetModType(componentid);
			switch (modas)
			{
				case 1: { Carlist2[playerid][mod1]=componentid; }
				case 2: { Carlist2[playerid][mod2]=componentid; }
				case 3: { Carlist2[playerid][mod3]=componentid; }
				case 4: { Carlist2[playerid][mod4]=componentid; }
				case 5: { Carlist2[playerid][mod5]=componentid; }
				case 6: { Carlist2[playerid][mod6]=componentid; }
				case 7: { Carlist2[playerid][mod7]=componentid; }
				case 8: { Carlist2[playerid][mod8]=componentid; }
				case 9: { Carlist2[playerid][mod9]=componentid; }
				case 10: { Carlist2[playerid][mod10]=componentid; }
				case 11: { Carlist2[playerid][mod11]=componentid; }
				case 12: { Carlist2[playerid][mod12]=componentid; }
				case 13: { Carlist2[playerid][mod13]=componentid; }
				case 14: { Carlist2[playerid][mod14]=componentid; }
				case 15: { Carlist2[playerid][mod15]=componentid; }
				case 16: { Carlist2[playerid][mod16]=componentid; }
				case 17: { Carlist2[playerid][mod17]=componentid; }
				default: { new string[128]; format(string,128,"Unknown component id: %i",componentid); print(string); }
			}
		}
		else if(vehicleid == Carlist3[playerid][Carid])
		{
			new modas=GetModType(componentid);
			switch (modas)
			{
				case 1: { Carlist3[playerid][mod1]=componentid; }
				case 2: { Carlist3[playerid][mod2]=componentid; }
				case 3: { Carlist3[playerid][mod3]=componentid; }
				case 4: { Carlist3[playerid][mod4]=componentid; }
				case 5: { Carlist3[playerid][mod5]=componentid; }
				case 6: { Carlist3[playerid][mod6]=componentid; }
				case 7: { Carlist3[playerid][mod7]=componentid; }
				case 8: { Carlist3[playerid][mod8]=componentid; }
				case 9: { Carlist3[playerid][mod9]=componentid; }
				case 10: { Carlist3[playerid][mod10]=componentid; }
				case 11: { Carlist3[playerid][mod11]=componentid; }
				case 12: { Carlist3[playerid][mod12]=componentid; }
				case 13: { Carlist3[playerid][mod13]=componentid; }
				case 14: { Carlist3[playerid][mod14]=componentid; }
				case 15: { Carlist3[playerid][mod15]=componentid; }
				case 16: { Carlist3[playerid][mod16]=componentid; }
				case 17: { Carlist3[playerid][mod17]=componentid; }
				default: { new string[128]; format(string,128,"Unknown component id: %i",componentid); print(string); }
			}
		}
	}
	return 1;
}

stock MaybeApplyAutokluboPaintjob(vehicleid, paintjobid)
{
	new model = GetVehicleModel(vehicleid);
	foreach(Player,p)
	{
		if(vehicleid == PlayerCar[p])
		{
			for(new i;i<150;i++)
			{
				for(new x;x<MAX_DARBINES_CAR;x++)
				{
					if(DarbinesCar[i][x][DCmodel]==model)
					{
						if(i == 70 || i == 73) //if(i<100)
						{
							new query[256];
							format(query,sizeof(query),"UPDATE `Darbines` SET `paintjob`=%i WHERE `Vardas`='%s' AND `Job`=%i AND `Cartype`=%i",paintjobid,ReturnName(p),i,x);
							mysql_query(query);
						}
						return 1;
					}
				}
			}
		}
	}
	return 0;
}

public OnVehiclePaintjob(playerid,vehicleid, paintjobid)
{
	if (playerid!=GetPlayerFromCarlistCar(vehicleid) && playerid!=GetPlayerFromCarlistCar2(vehicleid)  && playerid!=GetPlayerFromCarlistCar3(vehicleid)) 
	{
		MaybeApplyAutokluboPaintjob(vehicleid, paintjobid);
		return 1;
	}
	if(playerid!=-1)
	{
		if(vehicleid == Carlist[playerid][Carid])
		{
			Carlist[playerid][Paintjob]=paintjobid;
		}
		else if(vehicleid == Carlist2[playerid][Carid])
		{
			Carlist2[playerid][Paintjob]=paintjobid;
		}
		else if(vehicleid == Carlist3[playerid][Carid])
		{
			Carlist3[playerid][Paintjob]=paintjobid;
		}
	}
	return 1;
}

stock MaybeApplyAutokluboRespray(vehicleid, color1, color2)
{
	new model = GetVehicleModel(vehicleid);
	foreach(Player,p)
	{
		if(vehicleid == PlayerCar[p])
		{
			for(new i;i<150;i++)
			{
				for(new x;x<MAX_DARBINES_CAR;x++)
				{
					if(DarbinesCar[i][x][DCmodel]==model)
					{
						if(i == 70 || i == 73) //if(i<100)
						{
							new query[256];
							format(query,sizeof(query),"UPDATE `Darbines` SET `color1`=%i, `color2`=%i WHERE `Vardas`='%s' AND `Job`=%i AND `Cartype`=%i",color1,color2,ReturnName(p),i,x);
							mysql_query(query);
						}
						return 1;
					}
				}
			}
		}
	}
	return 0;
}

public OnVehicleRespray(playerid,vehicleid, color1, color2)
{
	if(GetVehicleModel(vehicleid) != 0 && color1 != -1)
	{
		//ChangeVehicleColor(vehicleid,color1,color2);
		if (playerid!=GetPlayerFromCarlistCar(vehicleid) && playerid!=GetPlayerFromCarlistCar2(vehicleid) && playerid!=GetPlayerFromCarlistCar3(vehicleid) ) 
		{
			MaybeApplyAutokluboRespray(vehicleid, color1, color2);
			return 1;
		}
		if(playerid!=-1)
		{
			if(vehicleid == Carlist[playerid][Carid])
			{
				if(Carlist[playerid][Color1]!=color1 || Carlist[playerid][Color2] != color2)
					playerDB[playerid][pinigai]-=100;
				Carlist[playerid][Color1]=color1;
				Carlist[playerid][Color2]=color2;
			}
			else if(vehicleid == Carlist2[playerid][Carid])
			{
				if(Carlist2[playerid][Color1]!=color1 || Carlist2[playerid][Color2] != color2)
					playerDB[playerid][pinigai]-=100;
				Carlist2[playerid][Color1]=color1;
				Carlist2[playerid][Color2]=color2;
			}
			else if(vehicleid == Carlist3[playerid][Carid])
			{
				if(Carlist3[playerid][Color1]!=color1 || Carlist3[playerid][Color2] != color2)
					playerDB[playerid][pinigai]-=100;
				Carlist3[playerid][Color1]=color1;
				Carlist3[playerid][Color2]=color2;
			}
		}
	}
	return 1;
}

stock SetVehicleParamsForPlayerEx(carid,playerid,objective,doorslocked)
{
	if(doorslocked == 0)
		VehicleLocked[carid][1]=playerid;
	SetVehicleParamsForPlayer(carid, playerid, objective, doorslocked);
}
public SetVehicleParamsForAll(carid,objective,doorslocked)
{
	GetVehicleParamsEx(carid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
	SetVehicleParamsEx(carid,VehVars[0],VehVars[1],VehVars[2],doorslocked,VehVars[4],VehVars[5],objective);
	VehicleLocked[carid][0]=doorslocked;
	VehicleLocked[carid][2]=GetTickCount();
	//foreach (Player, i) { SetVehicleParamsForPlayerEx(carid,i,objective,doorslocked); }
}

public CreateTunedCar(playerid)
{
	if(IsPlayerConnected(playerid) && Carlist[playerid][Typ]!=-1)
	{
		new carid=CreateVehicle(Carlist[playerid][Typ]+400,Carlist[playerid][X],Carlist[playerid][Y],Carlist[playerid][Z],Carlist[playerid][Rotation],-1,-1,-1);
		//Carlist[playerid][Carid]=carid;
		OnVehicleSpawn(carid);
		if(vehicleDB[carid][dega]) vehicleDB[carid][dega]=0,Iter_Remove(Deganti,carid);
		if(vehicleDB[carid][sprogs]) vehicleDB[carid][sprogs]=0;
		SetVehicleNumberPlate(carid,Carlist[playerid][NumPlate]);
		//SetVehicleToRespawn(carid);
		//SetVehicleNumberPlate(carid,Carlist[playerid][NumPlate]);
		vehicleDB[carid][OldHP]=1000;
		GetVehiclePos(carid,vehicleDB[carid][lastpos][0],vehicleDB[carid][lastpos][1],vehicleDB[carid][lastpos][2]);
		GetVehicleZAngle(carid,vehicleDB[carid][lastpos][3]);
		format(vehicleDB[carid][lastuser],24,"");
		if(Carlist[playerid][Lock]==1)
		{
			SetVehicleParamsForAll(carid,0,1);
			SetVehicleParamsForPlayerEx(carid,playerid,0,0);
		}
		if(Carlist[playerid][mod1]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod1]); }
		if(Carlist[playerid][mod2]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod2]); }
		if(Carlist[playerid][mod3]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod3]); }
		if(Carlist[playerid][mod4]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod4]); }
		if(Carlist[playerid][mod5]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod5]); }
		if(Carlist[playerid][mod6]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod6]); }
		if(Carlist[playerid][mod7]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod7]); }
		if(Carlist[playerid][mod8]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod8]); }
		if(Carlist[playerid][mod9]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod9]); }
		if(Carlist[playerid][mod10]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod10]); }
		if(Carlist[playerid][mod11]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod11]); }
		if(Carlist[playerid][mod12]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod12]); }
		if(Carlist[playerid][mod13]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod13]); }
		if(Carlist[playerid][mod14]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod14]); }
		if(Carlist[playerid][mod15]!=-1) {  AddVehicleComponent(carid,Carlist[playerid][mod15]); }
		if(Carlist[playerid][mod16]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod16]); }
		if(Carlist[playerid][mod17]!=-1) { AddVehicleComponent(carid,Carlist[playerid][mod17]); }
		if(Carlist[playerid][Paintjob]!=-1) { ChangeVehiclePaintjob(carid,Carlist[playerid][Paintjob]); }
		if(Carlist[playerid][Color1]!=-1) { ChangeVehicleColor(carid,Carlist[playerid][Color1],Carlist[playerid][Color2]); }
		if(Carlist[playerid][Gas]!=-1) { vehicleDB[carid][gas]=Carlist[playerid][Gas]; } else { vehicleDB[carid][gas]=50; }
        if(Carlist[playerid][Energy]!=-1) { vehicleDB[carid][energy]=Carlist[playerid][Energy]; } else { vehicleDB[carid][energy]=50; }
		if(Carlist[playerid][VeHP]>255.0) SetVehicleHealth(carid,Carlist[playerid][VeHP]);
		if(Carlist[playerid][Rida] > 0.0)
			vehicleDB[carid][rida] = Carlist[playerid][Rida];
		else
			vehicleDB[carid][rida] = 0.0;
		if(Carlist[playerid][Rankinis]!=0 && !IsAPBike(carid))
		{
			vehicleDB[carid][rankinis]=true;
		}
		else
			vehicleDB[carid][rankinis]=false;
		if(Carlist[playerid][Sirena]!=-1) {
		alarmed[carid]=Carlist[playerid][Sirena];
 		GetVehicleParamsEx(carid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
		SetVehicleParamsEx(carid,VehVars[0],VehVars[1],false,-1,VehVars[4],VehVars[5],VehVars[6]);
		} else { alarmed[carid]=0; }
		AutoPilotas[carid]=0;
		SetVehicleVirtualWorld(carid,Carlist[playerid][VirtualW]);
		return carid;
	}
	return -1;
}

