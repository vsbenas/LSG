		case 3: // 23
		{
			format(msgas,600,"\t\t\t\t\t{cb4335}Los Santos Gyvenimas\n{FFFFFF}\t\t\t\t\t  Đv. Kalëdos 2020\n\n\n\
				Jau supakavau 4 milijardus dovanř, tačiau per visŕ đá stresŕ nebegaliu uţmigti. Gal gali padëti Seneliui nuraminti nervus?\n\n\
				Atneđk man "#TEXT_BLUE"raudono vyno"#TEXT_WHITE" - tik ne iđ apatinës lentynos, nes kitaip pramiegosiu visas Kalëdas.");
			PlayAudioStreamForPlayer(playerid, "http://www.lsgyvenimas.lt/sounds/christmas3.mp3");
		}
		case 4: // 24
		{
			format(msgas,600,"\t\t\t\t\t{cb4335}Los Santos Gyvenimas\n{FFFFFF}\t\t\t\t\t  Đv. Kalëdos 2020\n\n\n\
				Kűčios - turbűt ramiausia đventinio laikotarpio diena.\n\
				Nenoriu tavćs ilgai gaiđinti ir leisiu tau kuo gráţti pas đeimŕ ir draugus. Juk jiems turbűt reikia pagalbos virtuvëje?\n\
				Per visŕ đá dovanř pakavimŕ ađ be galo iđalkau - gal gali man atneđti "#TEXT_BLUE"pavalgyti"#TEXT_WHITE"?\n\
				Tik nepamirđk - điandien ađ mësos nevalgau.");
			PlayAudioStreamForPlayer(playerid, "http://www.lsgyvenimas.lt/sounds/christmas4.mp3");
		}
		case 5: // 25
		{
			format(msgas,600,"\t\t\t\t\t{cb4335}Los Santos Gyvenimas\n{FFFFFF}\t\t\t\t\t  Đv. Kalëdos 2020\n\n\n\
				Turiu didelć problemŕ!!! Bedalinant dovanas vienas iđ mano elniř pamirđo kaip skraidyti, o pusë dovanř dar neiđdalinta!\n\n\n\
				Nebeţinau kaip já pagydyti... Gal turi kaţko, kas padëtř jam paskraidyti? Geriausia, "#TEXT_BLUE"ko nors ţalio"#TEXT_WHITE".\n\
				Paţadu, viskas tik elniams, ađ pats tokiř dalykř niekada neliesčiau!!!");
			PlayAudioStreamForPlayer(playerid, "http://www.lsgyvenimas.lt/sounds/christmas5.mp3");
		}
		case 6: // 26
		{
			format(msgas,600,"\t\t\t\t\t{cb4335}Los Santos Gyvenimas\n{FFFFFF}\t\t\t\t\t  Đv. Kalëdos 2020\n\n\n\
				Whew... Nors ir kilo nesklandumř, kalëdines dovanas pavyko iđdalinti. Bet turbűt geriausia dovana yra ne kaţkŕ gauti, o kaţkŕ duoti.\n\n\
				Todël tavo paskutinë misija (ir dovana) yra ta, kurios pats atidaryti negalësi.\n\
				Padovanok jŕ savo draugui, arba tam, kuriam labiausiai jos reikia - naudok "#TEXT_BLUE"/dovana Vardas_Pavarde"#TEXT_WHITE"\n\
