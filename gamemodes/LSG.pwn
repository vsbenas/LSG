			GetDynamicObjectPos(Light[i][playerid], xla, yla, zla);
			CreateExplosion(xla, yla, zla, 6, 0);
		}
		GetDynamicObjectPos(Light[9][playerid], xla, yla, zla);
		Light[11][playerid] = CreateDynamicObject(1213,xla-7,yla+7,zla+8, 0, 0,0);
		Light[12][playerid] = CreateDynamicObject(1213,xla-7,yla,zla+5, 0, 0,0);
