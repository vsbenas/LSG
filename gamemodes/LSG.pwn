stock Pelnas(playerid,id, suma)
{
	if(suma < 0 || suma > 1000000)
		return 1;
	if(id < 0 || id >= 100)
		return 1;
	if(playerid >= 0 && playerid <= MAX_PLAYERS)
	{
		if(JobPts[playerid] > 2) // 2 operations - then 2 min cooldown
			return 1;
		JobPts[playerid]+=2;
	}
	pelnas[id]+=suma;
	return 1;
}

stock KeyBind(playerid, id, params[])
{
	new varname[20];
	new varname2[20];
	format(varname,20,"KeyBind_%i",id);
	format(varname2,20,"KeyBindSet_%i",id);
	if(strlen(params) <= 1)
	{
		if(GetPVarInt(playerid, varname2) == 0)
		{
			SendClientMessage(playerid, RED, " * Keybind nenustatytas! Daugiau informacijos: /keybind");
			return 1;
		}
		new cmdset[256];
		GetPVarString(playerid, varname,cmdset, 256);
		ignorecmd[playerid] = 1;
		if(cmdset[0] == '/')
		{
			OnPlayerCommandTextReal(playerid,cmdset);
		}
		else
		{
			OnPlayerText(playerid, cmdset);
		}
		ignorecmd[playerid]=0;
	}
	else
	{
		if(params[0] == '/' && params[1] >= '1' && params[1] <= '9')
		{
			SendClientMessage(playerid, -1, "Sios komandos nustatyti negali.");
			return 1;
		}
		new textEUR[256];
		for(new i=0, j=strlen(params);i<j;i++)
		{
			switch(params[i]) 
			{
				case 'ŕ': textEUR[i]='a';
				case 'č': textEUR[i]='c';
				case 'ć': textEUR[i]='e';
				case 'ë': textEUR[i]='e';
				case 'á': textEUR[i]='i';
				case 'đ': textEUR[i]='s';
				case 'ř': textEUR[i]='u';
				case 'ű': textEUR[i]='u';
				case 'ţ': textEUR[i]='z';

				case 'Ŕ': textEUR[i]='A';
				case 'Č': textEUR[i]='C';
				case 'Ć': textEUR[i]='E';
				case 'Ë': textEUR[i]='E';
				case 'Á': textEUR[i]='I';
				case 'Đ': textEUR[i]='S';
				case 'Ř': textEUR[i]='U';
				case 'Ű': textEUR[i]='U';
				case 'Ţ': textEUR[i]='Z';
				case '$': {
					textEUR[i]='€';
				}
				default: textEUR[i]=params[i];
			}
		}
		SetPVarString(playerid, varname, textEUR);
		SetPVarInt(playerid, varname2, 1);
		new msg[256];
		format(msg,256," * Keybind nustatytas! Dabar komanda {FFFFFF}/%i{33CCFF} parađys điŕ ţinutć: {FFFFFF}%s",id,params);
		SendClientMessageEx(playerid, COLOR_LIGHTBLUE, msg, 0xFFFFFFFF);
	}
	return 1;	
}
stock SaveKeyBinds(playerid)
{
	for(new i=1;i<=9;i++)
	{
		new varname[20];
		new varname2[20];
		format(varname,20,"KeyBind_%i",i);
		format(varname2,20,"KeyBindSet_%i",i);

		if(GetPVarInt(playerid, varname2) == 1)
		{
			new query[512];
			new stringas[512];
			new stringasesc[512];
			GetPVarString(playerid, varname, stringas, 512);

			mysql_real_escape_string(stringas,stringasesc);
			format(query,512,"Replace INTO `Keybinds`(Name,Id,Value) VALUES ('%s',%i,'%s')",ReturnName(playerid),i,stringasesc);
			mysql_query(query);
		}
	}
}
stock LoadKeyBinds(playerid)
{
	new query[256];
	format(query,256,"SELECT Id,Value From Keybinds where `Name`='%s'",ReturnName(playerid));
	mysql_function_query(SQL, query, true, "SQL_LoadKeybinds", "i", playerid);
}

stock PassengerCrashCheck(playerid,newstate)
{
	if(newstate == PLAYER_STATE_DRIVER)
	{
		if (GetPlayerVehicleSeat(playerid) != 0)
		{
			// They are a driver, but not in the driver's seat.
			AC_Kick(playerid,"Vehicle crasher 1",1);
		}
	}
	else if(newstate == PLAYER_STATE_PASSENGER)
	{
		new
			model = GetVehicleModel(GetPlayerVehicleID(playerid)) - 400;
		if (model >= 0 && model <= 211)
		{
			model = (FIXES_gscMaxPassengers[model >>> 3] >>> ((model & 7) << 2)) & 0xF;
			if (model == 0 || model == 15)
			{
				// Shouldn't be in this vehicle at all.
				AC_Kick(playerid,"Vehicle crasher 2",1);
			}
			else
			{
				// Slower with "_FIXES_NO_RANGE".
				if (!(0 < GetPlayerVehicleSeat(playerid) <= model))
				{
					// In an out of range seat.
					AC_Kick(playerid,"Vehicle crasher 3",1);
				}
			}
		}
	}
}



stock InitPolygons()
{	

	CA_RemoveBuilding(1226, 265.481, -1581.1, 32.9311, 5.0);
    CA_RemoveBuilding(6518, 280.297, -1606.2, 72.3984, 250.0);
    // ligonines apartamentai
    CA_RemoveBuilding(5766, 1160.96, -1180.58, 70.4141, 250.0); // Awning shadows
	CA_RemoveBuilding(5767, 1160.96, -1180.58, 70.4141, 250.0); // Building
	CA_RemoveBuilding(5964, 1160.96, -1180.58, 70.4141, 250.0); // LOD

	CA_Init();

	// ligonines apartamentai
	CA_CreateObject(19595, 1160.96, -1180.58, 70.4141, 0, 0, 0);
	// parkingas
	CA_CreateObject(19798, 1160.96, -1180.58, 20.4141, 0, 0, 0);

	// beachside
    CA_CreateObject(19596, 280.297, -1606.2, 72.3984, 0, 0, 0);
    // Create the LS BeachSide Building interior object
    CA_CreateObject(19597, 280.297, -1606.2, 72.3984, 0, 0, 0);

	// beachside ready?

	//CA_CreateObject(modelid, Float:x, Float:y, Float:z, Float:rx, Float:ry, Float:rz, bool:add = false)

	new Float:Sequence[3][22]; // 11 points per polygon

	for(new i;i<3;i++)
	{
		new iter = 0;
		
		for(new x;x<11;x++)
		{
			Sequence[i][iter] = PolygonsCoords[i][x][0];
			Sequence[i][iter+1] = PolygonsCoords[i][x][1];
			iter+=2;
		}
		//Polygons[i] = CreateDynamicPolygon(Sequence, -FLOAT_INFINITY, FLOAT_INFINITY); // zcord
	}
	new polyid = 0;
	// ligonines apartamentai.
	for(new i=2;i<NumFloors[2];i++) // skip garage and ground floor
	{
		new Float:zoffset = FloorZOffsets[2][i] + 13.09 + 5.203975; // ligonines apartamentai
		if(i % 2) // lyginis use second poly garage fucked it up so it's reverse. Anyway this works
		{
			Polygons[polyid] = CreateDynamicPolygon(Sequence[0], zoffset, zoffset + 5.0); 
		}
		else
		{
			Polygons[polyid] = CreateDynamicPolygon(Sequence[1], zoffset, zoffset + 5.0); 
		}
		PolygonBuilding[polyid] = 2;
		PolygonAukstas[polyid] = i;
		polyid++;
	}
	// forbidden lift
	ForbiddenArea[0] = CreateDynamicRectangle(1180.1980,-1182.1033, 1183.1724, -1179.0051);

	// beachside apartamentai
	for(new i=2;i<NumFloors[1];i++) // skip garage and ground floor
	{
		new Float:zoffset = FloorZOffsets[1][i] + 12.369267 + 4.5; // beachside apts
		Polygons[polyid] = CreateDynamicPolygon(Sequence[2], zoffset, zoffset + 4.4); 
		PolygonBuilding[polyid] = 1;
		PolygonAukstas[polyid] = i;
		polyid++;
	}
	// forbidden lift
	ForbiddenArea[1] = CreateDynamicRectangle(286.1655,-1610.4930,289.7377,-1608.0852);
}

stock GetPlayerPoly(playerid)
{
	if(!IsPlayerInAnyDynamicArea(playerid))
		return -1;
	for(new i;i<NUM_POLYGONS;i++)
	{
		if(IsPlayerInDynamicArea(playerid, Polygons[i]))
		{
			return i;
		}
	}
	return -1;
}
stock GetPointPoly(Float:px,Float:py,Float:pz)
{
	for(new i;i<NUM_POLYGONS;i++)
	{
		if(IsPointInPoly(Polygons[i],px,py,pz))
		{
			return i;
		}
	}
	return -1;
}
stock GetAptHouseId(playerid)
{
	new polyid = GetPlayerPoly(playerid);
	if(polyid == -1)
		return 0;
	foreach(Houses, i)
	{
		if(hInfo[i][polyId] == polyid)
		{
			return i;
		}
	}
	return 0;
}
stock IsPointInPolyRange(polyid,Float:px,Float:py,Float:pz,Float:range)
{
	range /= 2.0; // divide in half
	if(range == 0.0)
		range = 1.0;
	return IsPointInPoly(polyid,px,py,pz) && IsPointInPoly(polyid,px+range,py,pz) && IsPointInPoly(polyid,px-range,py,pz) && IsPointInPoly(polyid,px,py+range,pz) && IsPointInPoly(polyid,px,py-range,pz) && IsPointInPoly(polyid,px,py,pz-(range/2)) && IsPointInPoly(polyid,px,py,pz+range);
}
stock IsPointInPoly(polyid,Float:px,Float:py,Float:pz)
{
	if(polyid == -1)
		return 0;
	return IsPointInDynamicArea(Polygons[polyid], px,py,pz) && !IsPointInDynamicArea(ForbiddenArea[0], px,py,pz) && !IsPointInDynamicArea(ForbiddenArea[1], px, py, pz);
}


stock GetPlayerHouseID(playerid)
{
	new vwid = GetPlayerVirtualWorld(playerid);
	if(vwid > 0 && vwid < MAX_HOUSES)
		return vwid;
	new poly = GetPlayerPoly(playerid);
	if(poly != -1)
	{
		foreach(Houses, i)
		{
			if(hInfo[i][polyId] == poly)
			{
				return i;
			}
		}
	}
	return 0;
}
stock GetHouseVirtualWorld(hid)
{
	if(hInfo[hid][polyId] == -1)
		return hid;
	else
		return 0;
}
stock GetHouseBaldaiArea(hid)
{
	return hInfo[hid][polyId];
}

