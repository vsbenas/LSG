				{
					KillTimer(NaujasCpTimer);
				}
			 	NaujasCpTimer = SetTimer("NaujasCP", 100, false);
			 	foreach(Player, i)
					if(KDalyvis[i][Dalyvauja]) SendInfoMessage(i,"~b~Keiciasi checkpointas!");
				return 1;
			}
		}
		else
		{
			KDalyvis[playerid][DabartinisCPs]=Keliones[DabartinisCP];
			if(TikrinamDalyvius() == 1)
			{
			 	SetTimer("SkaiciuojamAtlygi", 1000, false);
			}
			return 1;
	  	}
		return 1;
	}
	
	if(playerDB[playerid][DrivingTest] == 1 || playerDB[playerid][MotoTest] == 1 )
	{
		if(gPlayerDrivingCheckpoints[playerid] != 360)
		{
			new i = gPlayerDrivingCheckpoints[playerid]-1;
			if(gPlayerDrivingCheckpoints[playerid] == (sizeof(VAIRAVIMO_CP)-1))
			{
				SetPlayerRaceCheckpoint(playerid,1,VAIRAVIMO_CP[i][0],VAIRAVIMO_CP[i][1],VAIRAVIMO_CP[i][2],0.0,0.0,0.0,4.0);
				gPlayerDrivingCheckpoints[playerid]=360;
			}
			else
			{
				SetPlayerRaceCheckpoint(playerid,0,VAIRAVIMO_CP[i][0],VAIRAVIMO_CP[i][1],VAIRAVIMO_CP[i][2],VAIRAVIMO_CP[i+1][0],VAIRAVIMO_CP[i+1][1],VAIRAVIMO_CP[i+1][2],4.0);
				gPlayerDrivingCheckpoints[playerid]++;
			}
		}
		else
		{
			if(vehicleid == Club1 || vehicleid == Club2 || vehicleid == Club3)
			{
				new Float:Health;
				new testcar = GetPlayerVehicleID(playerid);
				GetVehicleHealth(testcar,Health);
				if(Health < 950.0)
				{
					SendInfoMessage(playerid,"~r~Jus neislaikete testo, nes sudauzete automobili. Prasome pabandyti dar karta");
					GameTextForPlayer(playerid," ~w~Testas neislaikytas.",3000,3);
				}
				else if(Health >= 950.0)
				{
					GameTextForPlayer(playerid," ~w~Testas islaikytas.",3000,3);
					SendInfoMessage(playerid,"~g~Jus islaikete testa.");
					playerDB[playerid][teises]=true;
				}
				RemovePlayerFromVehicle(playerid);
				SetVehicleToRespawn(testcar);
				SetVehicleVirtualWorld(testcar,0);
				SetPlayerVirtualWorld(playerid,0);
				DisablePlayerRaceCheckpoint(playerid);
				playerDB[playerid][DrivingTest] = 0;
				return 1;
			}
			else if(vehicleid == Moto1 || vehicleid == Moto2 || vehicleid == Moto3) 
			{
				new Float:Health2;
				new testcar = GetPlayerVehicleID(playerid);
				GetVehicleHealth(testcar,Health2);
				if(Health2 < 950.0)
				{
					SendInfoMessage(playerid,"~r~Jus neislaikete testo, nes sudauzete automobili. Prasome pabandyti dar karta");
					GameTextForPlayer(playerid," ~w~Testas neislaikytas.",3000,3);
				}
				else if(Health2 >= 950.0)
				{
					playerDB[playerid][teisesm]=true;
					GameTextForPlayer(playerid," ~w~Testas islaikytas.",3000,3);
					SendInfoMessage(playerid,"~g~Jus islaikete testa.");
				}
				RemovePlayerFromVehicle(playerid);
				SetVehicleToRespawn(testcar);
				SetVehicleVirtualWorld(testcar,0);
				SetPlayerVirtualWorld(playerid,0);
				DisablePlayerRaceCheckpoint(playerid);
				playerDB[playerid][MotoTest] = 0;
				return 1;
			}		
	
		}
	}
	else if(playerDB[playerid][FlyingTest] == 1)
	{
		if(gPlayerFlyingCheckpoints[playerid] != 360)
		{
			new i = gPlayerFlyingCheckpoints[playerid]-1;
			if(gPlayerFlyingCheckpoints[playerid] == sizeof(SKRAIDYMO_CP))
			{
				SetPlayerRaceCheckpoint(playerid,4,SKRAIDYMO_CP[i][0],SKRAIDYMO_CP[i][1],SKRAIDYMO_CP[i][2],0.0,0.0,0.0,8.0);
				gPlayerFlyingCheckpoints[playerid] = 360;
			}
			else
			{
				SetPlayerRaceCheckpoint(playerid,3,SKRAIDYMO_CP[i][0],SKRAIDYMO_CP[i][1],SKRAIDYMO_CP[i][2],SKRAIDYMO_CP[i+1][0],SKRAIDYMO_CP[i+1][1],SKRAIDYMO_CP[i+1][2],4.0);
				gPlayerFlyingCheckpoints[playerid]++;
			}
		}
		else
		{
			if(vehicleid == Shamal1 || vehicleid == Shamal2)
			{
				new Float:Health;
				new testcar = GetPlayerVehicleID(playerid);
				GetVehicleHealth(testcar,Health);
				if(Health < 950.0)
				{
					SendInfoMessage(playerid,"~r~Jus neislaikete testo, nes sudauzete automobili. Prasome pabandyti dar karta");
					GameTextForPlayer(playerid," ~w~Testas neislaikytas.",3000,3);
				}
				else if(Health >= 950.0)
				{
					GameTextForPlayer(playerid," ~w~Testas islaikytas.",3000,3);
					SendInfoMessage(playerid,"~g~Jus islaikete testa.");
					playerDB[playerid][teisess]=true;
				}
				RemovePlayerFromVehicle(playerid);
				SetVehicleToRespawn(testcar);
				SetVehicleVirtualWorld(testcar,0);
				SetPlayerVirtualWorld(playerid,0);
				DisablePlayerRaceCheckpoint(playerid);
				playerDB[playerid][FlyingTest] = 0;
				return 1;
			}	
		}
	}

	return 1;
}

