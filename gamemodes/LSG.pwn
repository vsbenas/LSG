stock CheckKovaAch(playerid) {
	if(playerDB[playerid][pKneeSkill] && playerDB[playerid][pGrabSkill] && playerDB[playerid][pKungSkill] && playerDB[playerid][pBoxiSkill])
		ProcessAchievement(playerid, 87);
}
stock Record(playerid)
{
	new recid = Iter_Count(Player);
	if (recid > Server[rekordas] > 1)
	{
		new string[100],queryza[200];
		SendClientMessageToAll(0xFF0000AA, " * * * Naujas zaideju rekordas * * *");
		format(string,100," * * * Naujas: %d * * *",recid);
		SendClientMessageToAll(COLOR_ORANGE, string);
		format(string,100,"Pagerino: %s",ReturnName(playerid));
		SendClientMessageToAll(COLOR_ORANGE, string);
		SendClientMessageToAll(COLOR_ORANGE, " * * * Visiems zaidejams buvo suteikta "#COST_REKORDAS" € Premija! * * *");
		format(queryza,sizeof(queryza),"INSERT INTO `Rekordas`(`Rekordas`,`Data`,`Pagerino`) VALUES (%d,NOW(),'%s')",recid,ReturnName(playerid));
		mysql_query(queryza);
		Server[rekordas]=recid;
		new tick = GetTickCount();
		foreach(Player, i) if(!IsPlayerAfkEx(i,tick)) GivePlayerMoneyA(i,COST_REKORDAS);
	}
//	mysql_free_result();
	return 1;
}
stock Masina(playerid)
{
	new name[MAX_PLAYER_NAME],query[100];
	GetPlayerName(playerid,name,sizeof(name));
	format(query,sizeof(query),"SELECT * FROM `Cars` WHERE `Owner` = '%s' LIMIT 1",name);
	mysql_function_query(SQL, query, true, "SQL_Masina", "i", playerid);
	return 1;
}

new statspsl=1;

//native GetNetworkStats(retstr[], retstr_size);

stock ServerStats(playerid,response)
{
	new string[2048];
	switch(statspsl)
	{
		case 1:
		{
			GetNetworkStats(string, sizeof(string));
		}
		case 2:
		{
			format(string,sizeof(string),"Streamer Info:\nObjects: %i\nPickups: %i\nCheckpoints: %i\nRace Checkpoints: %i\nMap Icons: %i\n3D Text Labels: %i\nAreas: %i.",CountDynamicObjects(),CountDynamicPickups(),CountDynamicCPs(),CountDynamicRaceCPs(),CountDynamicMapIcons(),CountDynamic3DTextLabels(),CountDynamicAreas());
		}
		case 3:
		{
			format(string,sizeof(string),"Atvezta nark: %i\nAtvezta dgl: %i\nAtvezta ak47: %i\nAtvezta MP5: %i\nAtvezta AWP: %i\nMasinu(be vagiu ir nuosavu): %i",Server[atveztan],Server[amp],Server[adgl],Server[aak],Server[aawp],maxvehicles);
		}
		case 4:
		{
			mysql_stat(string);
		}	
		default:
		{
			//native mysql_stat(const destination[], connectionHandle = 1);
			statspsl=1;
//			ServerStats(playerid);
			return 1;
		}
	
	}
	ShowPlayerDialog(playerid,7531,DIALOG_STYLE_MSGBOX,"Server Stats",string,"Toliau","Atnaujinti");
	if(response) statspsl++;
	return 1;
}

stock SaveMasina(playerid)
{
	if(DEBUG) printf("6");
	new name[MAX_PLAYER_NAME];
	new var[4048];
	GetPlayerName(playerid, name, sizeof(name));
	new Float:HP;
	format(var,sizeof(var),"UPDATE `Cars` SET AH_Typ=%i,AH_X='%f',AH_Y='%f',AH_Z='%f',AH_Rot='%f',AH_Status=%i,AH_Lock=%i,AH_Paintjob=%i,AH_Color1=%i,AH_Color2=%i,AH_mod1=%i,AH_mod2=%i,AH_mod3=%i,AH_mod4=%i,AH_mod5=%i,AH_mod6=%i,AH_mod7=%i,AH_mod8=%i,AH_mod9=%i,AH_mod10=%i,AH_mod11=%i,AH_mod12=%i,AH_mod13=%i,AH_mod14=%i,AH_mod15=%i,AH_mod16=%i,AH_mod17=%i,AH_Nr='%s',AH_Draud=%i",
	Carlist[playerid][Typ],Carlist[playerid][X],Carlist[playerid][Y],Carlist[playerid][Z],Carlist[playerid][Rotation],Carlist[playerid][Status],Carlist[playerid][Lock],Carlist[playerid][Paintjob],Carlist[playerid][Color1],Carlist[playerid][Color2],
	Carlist[playerid][mod1],Carlist[playerid][mod2],Carlist[playerid][mod3],Carlist[playerid][mod4],Carlist[playerid][mod5],Carlist[playerid][mod6],Carlist[playerid][mod7],Carlist[playerid][mod8],Carlist[playerid][mod9],Carlist[playerid][mod10],
	Carlist[playerid][mod11],Carlist[playerid][mod12],Carlist[playerid][mod13],Carlist[playerid][mod14],Carlist[playerid][mod15],Carlist[playerid][mod16],Carlist[playerid][mod17],Carlist[playerid][NumPlate],Carlist[playerid][CDraud]);
	format(var,sizeof(var),"%s,AH2_Typ=%i,AH2_X='%f',AH2_Y='%f',AH2_Z='%f',AH2_Rot='%f',AH2_Status=%i,AH2_Lock=%i,AH2_Paintjob=%i,AH2_Color1=%i,AH2_Color2=%i,AH2_mod1=%i,AH2_mod2=%i,AH2_mod3=%i,AH2_mod4=%i,AH2_mod5=%i,AH2_mod6=%i,AH2_mod7=%i,AH2_mod8=%i,AH2_mod9=%i,AH2_mod10=%i,AH2_mod11=%i,AH2_mod12=%i,AH2_mod13=%i,AH2_mod14=%i,AH2_mod15=%i,AH2_mod16=%i,AH2_mod17=%i,AH2_Nr='%s',AH2_Draud=%i",var,
	Carlist2[playerid][Typ],Carlist2[playerid][X],Carlist2[playerid][Y],Carlist2[playerid][Z],Carlist2[playerid][Rotation],Carlist2[playerid][Status],Carlist2[playerid][Lock],Carlist2[playerid][Paintjob],Carlist2[playerid][Color1],Carlist2[playerid][Color2],
	Carlist2[playerid][mod1],Carlist2[playerid][mod2],Carlist2[playerid][mod3],Carlist2[playerid][mod4],Carlist2[playerid][mod5],Carlist2[playerid][mod6],Carlist2[playerid][mod7],Carlist2[playerid][mod8],Carlist2[playerid][mod9],Carlist2[playerid][mod10],
