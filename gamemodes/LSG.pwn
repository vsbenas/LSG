public SavePlayerData(playerid,bool:simple)
{
	if(playerDB[playerid][authstate]==0) return SendClientMessage(playerid,BLUE," * Pirmiausia prisijunk!");
	if(!simple)
	{
		GameTextForPlayer(playerid,"~r~] Saugojamas Tavo zaidimas ]",50000,5);
		ProcessAchievement(playerid,0);
	}
	SavePlayer(playerid,simple);
	SavePlayerAchievements(playerid);
    if(!simple)
    {
		playerDB[playerid][authstate]=4;
		GameTextForPlayer(playerid,"~r~] Tavo duomenys issaugoti ]",1000,5);
	}
	return 1;
}
stock SavePlayerAchievements(playerid)
{
	new query[512];
	new names[24];
	GetPlayerName(playerid,names,24);
	//format(query,sizeof(query),"DELETE FROM Achievements WHERE Name='%s'",names);
	//mysql_ntquery(query);
	for(new i;i<150;i++) 
	{
		if(AchievementChanged[playerid][i] && Achievements[playerid][i] > 0.0)
		{
			new status=0;
			if(Achievements[playerid][i] >= RequiredAchPoints[i]) status=1;
			format(query,sizeof(query),"REPLACE INTO `Achievements`(`Name`,`id`,`progress`,`status`) VALUES('%s',%i,%i,%i)",names,i,floatround(Achievements[playerid][i],floatround_floor),status);
			mysql_query(query);
		}
	}
}
stock InvalidNickCheck(name[])
{
	new where = strfind(name,"_",true);
	new lenght = strlen(name)-1;
	new invalid = strfind(name,"[",true);
	if(invalid == -1) invalid = strfind(name,"]",true);
	if(invalid == -1) invalid = strfind(name,"'",true);
	//if(invalid == -1) invalid = strfind(name,"ss",true);
    //if(invalid == -1) invalid = strfind(name,"zz",true);
	
 //   if(invalid == -1) invalid = strfind(name,"x",true);
//    if(invalid == -1) invalid = strfind(name,"q",true);

	if(name[0] < 65 || name[0] > 90)
	{
		return 1;
	}

	if(name[where+1] < 65 || name[where+1] > 90)
	{
		return 1;
	}

	for(new i = 1; i < where; i++)
	{
		if(name[i] < 97 || name[i] > 122)
		{
			return 1;
		}
	}

	if(where == 0 || where == lenght || where==-1)
	{
		return 1;
	}

	if(strlen(name[where])<4)
	{
		return 1;
	}
	if(strlen(name)>20)
	{
		return 1;
	}
	if(where<3)
	{
		return 1;
	}
	
	if(invalid != -1)
	{
		return 1;
	}

	for(new i = where+2; i < MAX_PLAYER_NAME; i++)
	{
		if(name[i] < 97 || name[i] > 122)
		{
			if(name[i] == 0){i = MAX_PLAYER_NAME; return 0;}
			return 1;
		}
	}
	return 0;
}

stock InvalidNickKick(playerid, kick)
{
	if(IsPlayerNPC(playerid)) return 0;
	//new name[MAX_PLAYER_NAME];
	new name[MAX_PLAYER_NAME];
	GetPlayerName(playerid,name,MAX_PLAYER_NAME);
	new where = strfind(name,"_",true);
	new lenght = strlen(name)-1;
	new invalid = strfind(name,"[",true);
	if(invalid == -1) invalid = strfind(name,"]",true);
	if(invalid == -1) invalid = strfind(name,"'",true);
	//if(invalid == -1) invalid = strfind(name,"ss",true);
    //if(invalid == -1) invalid = strfind(name,"zz",true);
	
 //   if(invalid == -1) invalid = strfind(name,"x",true);
//    if(invalid == -1) invalid = strfind(name,"q",true);

	if(name[0] < 65 || name[0] > 90)
	{
		SendClientMessage(playerid,COLOR,"* Serveris: Jusu slapyvardis netinkamas. Vardas rasosi didziaja raide!");
		SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
		SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
		if(kick)KickEx(playerid);
		return 1;
	}

	if(name[where+1] < 65 || name[where+1] > 90)
	{
		SendClientMessage(playerid,COLOR,"* Serveris: Jusu slapyvardis netinkamas. Pavarde rasosi didziaja raide!");
		SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
		SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
		if(kick)KickEx(playerid);
		return 1;
	}

	for(new i = 1; i < where; i++)
	{
		if(name[i] < 97 || name[i] > 122)
		{
			SendClientMessage(playerid,COLOR,"* Serveris: Jusu slapyvardis netinkamas del: (didziosios raides arba skaiciai vardo vidury)");
			SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
			SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
			if(kick)KickEx(playerid);
			return 1;
		}
	}

	if(where == 0 || where == lenght || where==-1)
	{
		SendClientMessage(playerid,COLOR,"* Serveris: Jusu slapyvardis netinkamas.");
		SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
		SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
		if(kick)KickEx(playerid);
		return 1;
	}

	if(strlen(name[where])<4)
	{
		SendClientMessage(playerid,COLOR,"* Serveris: Jusu pavarde per trumpa");
		SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
		SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
		if(kick)KickEx(playerid);
		return 1;
	}
	if(strlen(name)>20)
	{
		SendClientMessage(playerid,COLOR,"* Serveris: Jusu Vardas_Pavarde per ilgas(daugiausiai 20 simboliu)");
		SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
		SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
		if(kick)KickEx(playerid);
		return 1;
	}
	if(where<3)
	{
		SendClientMessage(playerid,COLOR,"* Serveris: Jusu vardas per trumpas");
		SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
		SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
		if(kick)KickEx(playerid);
		return 1;
	}


	if(invalid != -1)
	{
		SendClientMessage(playerid,COLOR,"* Serveris: Varde rasta netinkamu raidziu.");
		SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
		SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
		if(kick)KickEx(playerid);
		return 1;
	}

	for(new i = where+2; i < MAX_PLAYER_NAME; i++)
	{
		if(name[i] < 97 || name[i] > 122)
		{
			if(name[i] == 0){i = MAX_PLAYER_NAME; return 0;}
			SendClientMessage(playerid,COLOR,"* Serveris: Jusu slapyvardis netinkamas del: (didziosios raides arba skaiciai pavardes vidury)");
			SendClientMessage(playerid,COLOR,"* Serveris: Teisinga slapyvardzio forma butu:");
			SendClientMessage(playerid,COLOR,"* Serveris: Vardas_Pavarde");
			if(kick)KickEx(playerid);
			return 1;
		}
	}
	return 0;
}

public Nekimba(id)
{
	playerDB[id][kimba]=false;
	return 1;
}

stock PayGangs(hh) 
{

	for(new i;i<sizeof(GaujuTagai);i++)
	{
		if(TagOwnedBy[i] != -1)
		{
			new id = TagOwnedBy[i];
			FamilyInfo[id][FamilyFunds]+= hh * 5;
		}
	}

	return 1;
}
stock IsDyrKoefEnabled()
{
	new day,month,year;
	getdate(year,month,day);
	if(month == 12 && day < 25)
	{
		return false;
	}
	return true;
}

public Zaidimas()
{
	new x=0,
		y=0,
		Float:HP,
		vehicleid,
		model,
		tick=GetTickCount(),
		State;
	new hh=1;
	new hour,minute,second;
	gettime(hour,minute,second);
	if(hour == 19) hh=2;

	PayGangs(hh);
	new tickas = GetTickCount();

	foreach(Player, playerid)
	{
		if(playerDB[playerid][authstate] == 4 && (tickas - LastSaved[playerid] > 5 * 60 * 1000)) 
		{
			if(!IsPlayerAfkEx(playerid,tickas))
			{
				printf("[save] Saving %s data...",ReturnName(playerid));
				SavePlayer(playerid,true);
				SaveMasina(playerid);
			}
			else
			{
				printf("[save] %s AFK. Skipping.",ReturnName(playerid));
			}
			LastSaved[playerid] = tickas;
		} 
		
		if(!IsPlayerAfkExEx(playerid, tick))
		{
			if(hh == 2)
			{
				HappyHourMinutes[playerid] ++;
			}
			else
			{
				if(HappyHourMinutes[playerid] >= 53)
					ProcessAchievement(playerid, 110);
				HappyHourMinutes[playerid] = 0;
			}
		}
		PraleidoTime[playerid]++;
		if(PraleidoTime[playerid] >= 60*8) // 8h
			ProcessAchievement(playerid,79);
	    x++;
		if (IsPlayerInRangeOfPointEx(40, playerid,767.2731,14.1037,1000.7003) || IsPlayerInRangeOfPointEx(40, playerid,762.1400,-29.5834,1000.5859) || IsPlayerInRangeOfPointEx(40, playerid,767.8558,-61.9425,1001.2811))
		{
			SendInfoMessage(playerid,"Demesio! Sporto saleje galite ismokti nauju kovos stiliu! /treniruotis");
		}
		else if(IsPlayerInRangeOfPointEx(20.0, playerid, 3171.3145,-868.5535,9.3741)) y++; // jail begimas
		if(playerDB[playerid][stotis])
			ProcessAchievement(playerid,68);
		GaujaCount[playerid]=0;
		if(playerDB[playerid][ikalintas]) ProcessAchievement(playerid,56);
		if(playerDB[playerid][namu]==GetNamuLimit(playerid)) ProcessAchievement(playerid,118);
		new Float:coo[3];
		// achievement checks
		if(playerDB[playerid][teises] && playerDB[playerid][teisesm] && playerDB[playerid][teisess] && playerDB[playerid][spaz]) ProcessAchievement(playerid,28);
		if(GetPlayerMoneyA(playerid) >= 1000000) ProcessAchievement(playerid,44);
		new score = GetPlayerScore(playerid);
		if(score > 500) ProcessAchievement(playerid,37);
		if(score > 100000) ProcessAchievement(playerid,93);
		// end
		GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
		State=GetPlayerState(playerid);
		new playerTyping = IsPlayerTyping(playerid,tick);
		if(playerTyping) 
			AdminTimer[playerid]++;
	
		if(IsPlayerInRangeOfPointEx(15.0,playerid,vairpos[playerid][0],vairpos[playerid][1],vairpos[playerid][2]) || GetPlayerSurfingVehicleID(playerid) != INVALID_VEHICLE_ID || State == PLAYER_STATE_SPECTATING ) 
		{
			/*if(playerDB[playerid][specialybe] != 3 && playerDB[playerid][specialybe]!=20 && playerDB[playerid][specialybe]!=2 && playerDB[playerid][specialybe]!=93) // only taxi is allowed to stay in place
				continue;
			if(!playerTyping) // they cant be afk
				continue;
			if(GetPlayerVehicleID(playerid) != PlayerCar[playerid]) // must be in job car
				continue;
			if(!insafearea)
				continue;*/
			continue;
		}
		if(IsPlayerInVehicle(playerid, Busikas) || GetPlayerSurfingVehicleID(playerid) == Busikas)
			continue;
		//IsPlayerTyping(%0,%1)
		vairpos[playerid][0]=coo[0];
		vairpos[playerid][1]=coo[1];
		vairpos[playerid][2]=coo[2];
		if(!playerDB[playerid][playingpoker] && !playerDB[playerid][narko][0])
		{
			if(playerDB[playerid][sotumas] < 5.0)
			{
				GetPlayerHealth(playerid,HP);
				SetPlayerHealth(playerid,HP-1.0);
				SendInfoMessage(playerid,"Tu labai alkanas! Pavalgyk artimiausiame restorane!");
				ProcessAchievement(playerid,12);
			}
			else if(playerDB[playerid][sotumas] < 10.0)
			{
				GetPlayerHealth(playerid,HP);
				SetPlayerHealth(playerid,HP-0.5);
				SendInfoMessage(playerid," Tu isalkai! Pavalgyk artimiausiame restorane!");
			}
		}
		if(!NoCheck2[playerid])
		{
			new money = GetPlayerMoney(playerid);
			if( money < playerDB[playerid][pinigai] && money > 0 ) playerDB[playerid][pinigai]=money;
			ResetPlayerMoney(playerid);
			GivePlayerMoney(playerid,playerDB[playerid][pinigai]);
		}
		else
			NoCheck2[playerid]--;
		Server[kysiufondas]+=10*hh;
		SetPlayerScore(playerid,(score+((random(2)+2)*hh))); // Xp ++ // random(3)+1
		if(playerInEventCar[playerid]) continue;
		if(IsPlayerInWorld(playerid)) continue;
		new dirba;
		new dir = 1;
		if(playerDB[playerid][plead] && IsDyrKoefEnabled())
		{
			dir = 2;
		}
		if(Patruliavimas[playerid] != -1)
		{
			if(IsPlayerInDynamicArea(playerid,Patruliai[Patruliavimas[playerid]][dynamicarea]))
			{
				if(!playerTyping) continue;
				if(playerDB[playerid][specialybe]==84) dirba=2,pelnas[79]+=(MONEY_KOBRA*hh*dir);
				if(playerDB[playerid][specialybe]==80) dirba=2,pelnas[79]+=(MONEY_POLICININKAI*hh*dir); // pd
				if(playerDB[playerid][specialybe]==81) dirba=2,pelnas[79]+=(MONEY_ARAS*hh*dir); // swat
				if(playerDB[playerid][specialybe]==82) dirba=2,pelnas[79]+=(MONEY_VST*hh*dir); // VST
				if(playerDB[playerid][specialybe]==83) dirba=2,pelnas[79]+=(MONEY_KAREIVIS*hh*dir); // kareivis
				
				if(dirba) Server[afondas]+=(10*hh*dir);
				if(dirba == 2)	playerDB[playerid][pradirbo]+=(1*hh);
				if(playerDB[playerid][pradirbo] > 800) ProcessAchievement(playerid,22);
			}
		}
		if(dirba) 
			continue;
		if(State == PLAYER_STATE_PASSENGER)
		{
			vehicleid = GetPlayerVehicleID(playerid);
			model = GetVehicleModel(vehicleid);
			if(GetPlayerVehicleSeat(playerid) != 1) continue;			
			new vairuotojas = GetDriver(vehicleid);
			if(vairuotojas==INVALID_PLAYER_ID || !IsPlayerConnected(vairuotojas)) continue;
			if(!IsPlayerTyping(playerid,tick)) continue;
			//PlayerAfk2[playerid]=GetTickCount();
			//if(!IsPlayerTyping(playerid,tick)) continue;
			//if(vehicleid == cheetahai[0] || vehicleid == cheetahai[1] || vehicleid == cheetahai[2] || vehicleid == cheetahai[3] || vehicleid == cheetahai[4] || vehicleid == cheetahai[5]) if(playerDB[playerid][specialybe]==84) 
			if(playerDB[vairuotojas][specialybe] >= 80 && playerDB[vairuotojas][specialybe] <= 84)
			{
				switch(model)
				{
					case 415: if(playerDB[playerid][specialybe]==84 && PlayerCar[vairuotojas]==vehicleid) dirba=2,pelnas[79]+=(MONEY_KOBRA*hh*dir);
					case 596,497,523,430,599: if(playerDB[playerid][specialybe]==80) dirba=2,pelnas[79]+=(MONEY_POLICININKAI*hh*dir); // pd
					case 601,427,447,490: if(playerDB[playerid][specialybe]==81) dirba=2,pelnas[79]+=(MONEY_ARAS*hh*dir); // swat
					case 528: if(playerDB[playerid][specialybe]==82) dirba=2,pelnas[79]+=(MONEY_VST*hh*dir); // VST
					case 470,548,564,432,520,433,425: if(playerDB[playerid][specialybe]==83) dirba=2,pelnas[79]+=(MONEY_KAREIVIS*hh*dir); // kareivis
					//case 468: if(playerDB[playerid][specialybe]==83 && PlayerCar[vairuotojas]==vehicleid) dirba=2,pelnas[79]+=(MONEY_KAREIVIS*hh);
				}
			}
			if(playerDB[vairuotojas][specialybe] == 60)
			{
				if(model == 428) // securicar
				{
					if(playerDB[playerid][specialybe] == 60) 
						dirba=2,pelnas[59]+=(MONEY_INKASATORIUS*hh*dir);
				}
			}
			if(playerDB[vairuotojas][specialybe] == 31)
			{
				if(model == 600 || model == 609 || model == 422) // kontra
				{
					if(GetPlayerVehicleSeat(playerid) == 1 && (playerDB[playerid][specialybe] == 31 || playerDB[playerid][specialybe] == 32)) 
						dirba=2,pelnas[89]+=(MONEY_KONTRABANDA*hh*dir); // kontrabanda
				}
			}
			if(dirba) Server[afondas]+=(10*hh*dir);
			if(dirba == 2) playerDB[playerid][pradirbo]+=(1*hh);
			if(playerDB[playerid][pradirbo] > 800) ProcessAchievement(playerid,22);
		}
		if(State == PLAYER_STATE_DRIVER)
		{
			vehicleid = GetPlayerVehicleID(playerid);
			model = GetVehicleModel(vehicleid);
			new Float:tuneMultiplier = GetTuneMultipler(playerid);
			if(vagia[playerid]) 
				dirba=2,pelnas[57]+=(MONEY_VAGIS*hh*dir);
			else
			{
				switch(model)
				{
					case 415: if(PlayerCar[playerid]==vehicleid && playerDB[playerid][specialybe] == 84) dirba=2,pelnas[79]+=(MONEY_KOBRA*hh*dir);
					case 596,497,523,430,599: dirba=2,pelnas[79]+=(MONEY_POLICININKAI*hh*dir); // pd
					case 601,427,447,490: dirba=2,pelnas[79]+=(MONEY_ARAS*hh*dir); // swat
					case 408: dirba=1,playerDB[playerid][banke]+=(MONEY_SIUKSLIAVEZIS*hh); // siuksliavezis
					case 528: dirba=2,pelnas[79]+=(MONEY_VST*hh*dir); // VST
					case 470,548,564,432,520,433,425: dirba=2,pelnas[79]+=(MONEY_KAREIVIS*hh*dir); // kareivis
					//case 468: if(PlayerCar[playerid]==vehicleid) dirba=2,pelnas[79]+=(MONEY_KAREIVIS*hh*dir);
					case 416: dirba=2,pelnas[1]+=(MONEY_MEDIKAI*hh*dir); //greitoji
					case 496,505,469: dirba=2,pelnas[1]+=(MONEY_PMEDIKAI*hh*dir); //greitoji
					case TOWTRUCK: dirba=2,pelnas[5]+=(MONEY_MECHANIKAI*hh*dir); //mech
					case SWEEPER: dirba=1,playerDB[playerid][banke]+=(MONEY_SLAVEJAS*hh); //valytojas
					case 420,438: dirba=2,pelnas[2]+=(MONEY_TAKSISTAI*hh*dir);	// taxas
					case 446,424,460:  dirba=1,playerDB[playerid][banke]+=(MONEY_PAKRANTES_APSAUGA*hh); //pakrantes
					case NEWSVAN,488: dirba=1,playerDB[playerid][banke]+=(MONEY_REPORTERIS*hh); //reporteriai
					case 448: dirba=1,playerDB[playerid][banke]+=(MONEY_PICU_ISVEZIOTOJAS*hh); //picos
					case 546: dirba=1,playerDB[playerid][banke]+=(MONEY_SOKEJA*hh); //sokeja
					case 434,467,474,575: dirba=2,pelnas[69]+=floatround(MONEY_AUTOMANAI*hh*dir*tuneMultiplier); //automanai
					case 461,581: dirba=2,pelnas[69]+=floatround(MONEY_MOTOMANAS*hh*dir*tuneMultiplier); //motomania
					case 463: //baikeriai;
					{
						new faktorius = CalculateBaimesFaktorius(playerid);
						if(faktorius != LastBaimesFaktorius[playerid])
						{
							if(faktorius >= 150) 
							{
								SetVehicleNumberPlate(vehicleid,"{C32705}666");
							}
							else
							{
								SetVehicleNumberPlate(vehicleid,vehicleDB[vehicleid][vnumeris]);
							}
							LastBaimesFaktorius[playerid] = faktorius;
							ShowBaimesFaktorius(playerid, faktorius);
						}
						dirba=2,pelnas[97]+=floatround(MONEY_BAIKERIAI*hh*dir*(faktorius/100.0));
					} 
					case 550: dirba=2,pelnas[57]+=(MONEY_VAGIS*hh*dir); // vagys
					case 507: dirba=1,playerDB[playerid][banke]+=(MONEY_ADVOKATAS*hh); //advokatai
					case HOTDOG: playerDB[playerid][banke]+=(MONEY_HOTDOG*hh); //hotdog
					case 478,453: playerDB[playerid][banke]+=(MONEY_ZVEJYS*hh); //zvej
					case 543: playerDB[playerid][banke]+=(MONEY_PIENAS*hh); //pienas
					case 423: playerDB[playerid][banke]+=(MONEY_LEDAI*hh); //ledai
					case 439: dirba=1,playerDB[playerid][banke]+=(MONEY_KRIMINALISTAS*hh); //kriminal.
					case 587: dirba=2,pelnas[33]+=(MONEY_TURTO_AGENTAS*hh*dir); //nekiln
					case 442: dirba=1,playerDB[playerid][banke]+=(MONEY_KUNIGAS*hh); //kunigas
					case 481: if(PlayerCar[playerid]==vehicleid && playerDB[playerid][specialybe] == 36) dirba=1,playerDB[playerid][banke]+=(MONEY_BMX*hh); //bmx
					case 537,538: dirba=1,playerDB[playerid][banke]+=(MONEY_TRAUKINISTAS*hh); // traukinistas
					case 428: 
					{
						if(playerDB[playerid][specialybe] == 60)
						{
							dirba=2;
							pelnas[59]+=(MONEY_INKASATORIUS*hh*dir);
						}
						else 
						{
							dirba=1,playerDB[playerid][banke]+=(MONEY_BANKININKAS*hh); //Bankininkas
						}
					}
					case 524: dirba=1,playerDB[playerid][banke]+=(MONEY_STATYBININKAS*hh); //Statybininkas
					case 400: dirba=1,playerDB[playerid][banke]+=(MONEY_PASIENIETIS*hh); //pasienis
					case 519,577: dirba=1,playerDB[playerid][banke]+=(MONEY_PILOTAS*hh); // pilotas
					case 407,489: dirba=2,pelnas[65]+=(MONEY_GAISRININKAI*hh*dir); //gaisrininkai
					case 409: dirba=2,pelnas[2]+=(MONEY_TRANSPORTERIAI*hh*dir); //limke
					case 477: dirba=2,pelnas[2]+=(MONEY_TRANSPORTERIAI*hh*dir); //transporteris
					case 421: dirba=2,pelnas[49]+=(MONEY_SKELBEJAI*hh*dir); // skelbejai
					case 514,515,403: dirba=2,pelnas[4]+=(MONEY_FURISTAI*hh*dir); // furistai
					case 419: dirba=2,pelnas[89]+=(MONEY_DEALERIS*hh*dir); // dealeriai
					case 600,609,422: dirba=2,pelnas[89]+=(MONEY_KONTRABANDA*hh*dir); // kontrabanda
					case 414,456,499: dirba=2,pelnas[4]+=(MONEY_KURJERIAI*hh*dir); // kurjeris
					case 431,437: dirba=1,playerDB[playerid][banke]+=(MONEY_AUTOBUSO_VAIRUOTOJAS*hh); //autobusininkas
					case 418: dirba=1,playerDB[playerid][banke]+=(MONEY_MIKRO_VAIRUOTOJAS*hh); //autobusininkas
					case 531,572: dirba=1,playerDB[playerid][banke]+=(MONEY_UKININKAS*hh); // ukininkas
					case 563:// raindance:
					{
						dirba=2;
						if(playerDB[playerid][specialybe]==2)
							pelnas[1]+=(MONEY_MEDIKAI*hh*dir);
						else
							pelnas[65]+=(MONEY_GAISRININKAI*hh*dir);
					}
				}
			}
			if(dirba) Server[afondas]+=(10*hh*dir);
			if(dirba == 2) playerDB[playerid][pradirbo]+=(1*hh);
			if(playerDB[playerid][pradirbo] > 800) ProcessAchievement(playerid,22);
			//OutputGas(playerid,vehicleid,false);
		}

	}
	if(!pabegimas && y >= x/10 && y >= 1)
	{
	    SetTimer("Pabegimas",120000,false);
	    foreach(Player, i) if(playerDB[i][ikalintas]) GameTextForPlayer(i,"~r~Ei!~g~ Rengiamas pabegimas!",2000,1);
		SendMessageToTeisesauga(COLOR,"[racija] Operatore: Kalejime vyksta pabegimas! Turite kelias minutes ji sutramdyt.");
		pabegimas=true;
	}
	CheckForRestart();
}
stock CheckForRestart()
{
	mysql_function_query(SQL, "SELECT value from Config where variable='Restart'", true, "SQL_DeploymentRestart", "");
}
forward HandleRestart(delayMins);
public HandleRestart(delayMins) 
{
	mysql_query("Update Config Set value=0 WHERE variable='Restart'");
	autorestart=false;
	new msg[256];
	if(delayMins == 0)
	{
		Restartas();
		return;
	}
	else if(delayMins == 1)
	{
		format(msg,256," * Serverio restartas uţ minutës!!");
	}
	else
	{
		format(msg,256, " * Serverio restartas uţ %i minučiř!!", delayMins);
	}

	SendClientMessageToAll(RED,msg);
	printf(msg);
	
	SetTimerEx("HandleRestart",60000,false, "i", delayMins - 1);
}

public DegalaiZvejyba()
{
	CheckCarRespawns();
	static 	vehicleid,
			model,
			Float:Coo[4],
			Float:Total,
			kibimas,
			hour,
			minute,
			animlib[32],
			animname[32],
			countaszvejyba,
			tick;
	countaszvejyba = (countaszvejyba + 1) % 3;
	gettime(hour,minute,minute);
	switch(hour)
	{
	    case 22..24,0..6,7..10: kibimas=4;
		case 11,12: kibimas=5;
		case 13..17: kibimas=6;
	    case 18..21: kibimas=5;
	    default: kibimas=4;
	}
	//printf("loop1");
	new hh=1;
	if(hour == 19) hh=2;
	tick = GetTickCount();	
	foreach(Player, playerid)
	{
		if(JobPts[playerid])
			JobPts[playerid]--;
		if(Patruliavimas[playerid] != -1)
		{
			if(!IsPlayerInDynamicArea(playerid,Patruliai[Patruliavimas[playerid]][dynamicarea]))
			{
				GangZoneHideForPlayer(playerid,Patruliai[Patruliavimas[playerid]][gangz]);
				Patruliai[Patruliavimas[playerid]][pplin]--;
				Patruliavimas[playerid]=-1;
				SendClientMessage(playerid,YELLOW," * Jums buvo atsauktas patruliavimas, kadangi neatvykote i zona arba ja palikote!");
			}
		}
		if(!IsPlayerAfkEx(playerid,tick))
		{
			if(GetPlayerScore(playerid) < 300)
			{
				NaujokoPagalba(playerid);
			}
			if(!playerDB[playerid][narko][0])
			{
				if(playerDB[playerid][sotumas] < 0)
				{
					SetPlayerHealth(playerid, 0.0);
					SendInfoMessage(playerid,"~r~Numirei is bado!");
					playerDB[playerid][sotumas]=5.0;
				}
				else if(playerDB[playerid][sotumas] < 5)
				{
					playerDB[playerid][sotumas]=playerDB[playerid][sotumas]-0.10;
					new Float:health;
					GetPlayerHealth(playerid,health);
					if(health > 3.0)
						SetPlayerHealth(playerid,health-0.5);
					else
					{
						SetPlayerHealth(playerid, 0.0);
						SendInfoMessage(playerid,"~r~Numirei is bado!");
						playerDB[playerid][sotumas]=5.0;
					}
				}
				else
					playerDB[playerid][sotumas]=playerDB[playerid][sotumas]-0.10;
			}
			GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
			if(Coo[2] <= 0.0) // in water
			{
				HideProgressBarForPlayer(playerid, Alkis);
			}
			else if(_pStep[playerid] == 0 && BitFlag_Get(PConfig[playerid],PCFG_SHOWALKIS))
			{
				SetProgressBarValue(Alkis, playerDB[playerid][sotumas]+10.0);
				ShowProgressBarForPlayer(playerid, Alkis);
			}

		}
	    if(playerDB[playerid][zvejoja])
		{
			vehicleid=GetClosestVehicleid(playerid, 9);
			if(vehicleid == INVALID_VEHICLE_ID)
				vehicleid = GetPlayerSurfingVehicleID(playerid);
			if(IsPlayerInAnyVehicle(playerid) || vehicleid == INVALID_VEHICLE_ID || !IsABoat(GetVehicleModel(vehicleid))) { playerDB[playerid][zvejoja]=false; SendInfoMessage(playerid,"Zvejoti gali tik is valties!"); ClearAnimations(playerid); continue; }

			
			if(!playerDB[playerid][masalas]) { playerDB[playerid][zvejoja]=false; SendInfoMessage(playerid,"Neber masalo!"); ClearAnimations(playerid); continue; }
			if(playerDB[playerid][zuvis] > 19) {  playerDB[playerid][zvejoja]=false; SendInfoMessage(playerid,"Turi per daug zuvies!"); ClearAnimations(playerid); continue; }
	        GetAnimationName(GetPlayerAnimationIndex(playerid),animlib,32,animname,32);
	        if(strcmp(animlib,"SWORD",true) || strcmp(animname,"sword_idle",true)) 
	        { 
	        	if(strcmp(animlib,"BASEBALL",true) || strcmp(animname,"Bat_IDLE",true))
	        	{
	        		playerDB[playerid][zvejoja]=false; SendInfoMessage(playerid,"Paleidai meskere!"); ClearAnimations(playerid); continue; 

	        	}

			}
	        if(strcmp(animlib, "SWIM", true) == 0)
			{
				SendInfoMessage(playerid,"Zvejoti gali tik is valties!");
				playerDB[playerid][zvejoja]=false;
				ClearAnimations(playerid);
				continue;
			}
			minute=random(kibimas);
	        if(minute==0)
	        {
	            GameTextForPlayer(playerid," ~y~Kimba!!! ~n~~y~ Spauskite~r~ (MOUSE1).",1000,4);
	            SetTimerEx("Nekimba",1000,false,"i",playerid);
	            playerDB[playerid][kimba]=true;
	            playerDB[playerid][masalas]--;
	            continue;
	        }
	        if(random(3)==1) playerDB[playerid][masalas]--;
		}
	    //if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) continue;
	    vehicleid = GetPlayerVehicleID(playerid);
	    if(!vehicleid || IsPlayerAfkEx(playerid,tick)) continue;
		model = GetVehicleModel(vehicleid);
		if(!model) continue;
	    GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
	   	// variklis, lempos
    	if(VehVars[0] && model != BMX && model != MTBIKE && model != BIKE && !IsPlayerNPC(playerid))
		{
		    if(vehicleDB[vehicleid][gas]-aEda[model-400] >= 0)
		    {
		        if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
		        {
		        	GetVehiclePos(vehicleid,Coo[0],Coo[1],Coo[2]);
					if(vehicleDB[vehicleid][lastpos][0] != 0.0 && vehicleDB[vehicleid][lastpos][1] != 0.0 && vehicleDB[vehicleid][lastpos][2] != 0.0)
					{
						Coo[3] = ((floatabs(vehicleDB[vehicleid][lastpos][0]-Coo[0])+floatabs(vehicleDB[vehicleid][lastpos][1]-Coo[1])+floatabs(vehicleDB[vehicleid][lastpos][2]-Coo[2]))/3)/100;
						if(Coo[3] > 0.15)
							vehicleDB[vehicleid][rida] += (GetSpeedEx(vehicleid)/60.0)/3*hh; // km/h -> km/10sec *2 cuz not accurate kas 10 sec tikrina


						if(vehicleDB[vehicleid][rida] >= 9999.9)
						{
							vehicleDB[vehicleid][rida] = 9999.9;
							if(EnteredCarAch[playerid] == 1)
							{
								ProcessAchievement(playerid,113);
								EnteredCarAch[playerid] = 2;
							}
						}
						else
						{
							if(vehicleDB[vehicleid][rida] <= 9998.0)
							{
								if(EnteredCarAch[playerid] == 0)
									EnteredCarAch[playerid] = 1;
							}
						}
						Total = ((aEda[model-400]/2.5)*Coo[3]);
						if(Total < 2.0)
							vehicleDB[vehicleid][gas]-=Total;
						ProcessAchievement(playerid,5,Coo[3]);
						if(model == 420 || model == 438 || model == 477 || model == 409)
							ProcessAchievement(playerid,62,Coo[3]);
					}
			        vehicleDB[vehicleid][lastpos][0]=Coo[0];
					vehicleDB[vehicleid][lastpos][1]=Coo[1];
					vehicleDB[vehicleid][lastpos][2]=Coo[2];
				}
				
		    }
		    else
		    {
				ProcessAchievement(playerid,33);
		        vehicleDB[vehicleid][gas]=0;
				SendInfoMessage(playerid,"Baigesi kuras!");
		        SetVehicleParamsEx(vehicleid,false,VehVars[1],VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
		    }
		}
		if(model == BMX || model == MTBIKE || model == BIKE )
		{
			if(GetPlayerState(playerid) == PLAYER_STATE_DRIVER)
			{
				GetVehiclePos(vehicleid,Coo[0],Coo[1],Coo[2]);
				if(vehicleDB[vehicleid][lastpos][0] != 0.0 && vehicleDB[vehicleid][lastpos] != 0.0 && vehicleDB[vehicleid][lastpos] != 0.0)
				{
					Coo[3] = ((floatabs(vehicleDB[vehicleid][lastpos][0]-Coo[0])+floatabs(vehicleDB[vehicleid][lastpos][1]-Coo[1])+floatabs(vehicleDB[vehicleid][lastpos][2]-Coo[2]))/3)/100;
					ProcessAchievement(playerid,6,Coo[3]);
				}
				/*new msg[129];
				format(msg,129,"%.2f",Coo[3]);
				SendClientMessage(playerid, COLOR, msg);*/
				if(Coo[3] > 0.15)
					vehicleDB[vehicleid][rida] += (GetSpeedEx(vehicleid)/60.0)/3*hh; // km/h -> km/10sec *2 cuz not accurate kas 10 sec tikrina
				vehicleDB[vehicleid][lastpos][0]=Coo[0];
				vehicleDB[vehicleid][lastpos][1]=Coo[1];
				vehicleDB[vehicleid][lastpos][2]=Coo[2];
				
				if(vehicleDB[vehicleid][rida] > 9999.9)
					vehicleDB[vehicleid][rida] = 9999.9;
			}
			
		}
		if(BitFlag_Get(PConfig[playerid],PCFG_SHOWSPEEDO)) //  && !IsAPBike(vehicleid)
		{
			format(animlib,sizeof(animlib),"%.1fL",vehicleDB[vehicleid][gas]);
			PlayerTextDrawSetString(playerid,DegalasTD[playerid],animlib);
			if(!countaszvejyba)
				format(animlib,sizeof(animlib),"R: %.1fkm",vehicleDB[vehicleid][rida]);
			else
				format(animlib,sizeof(animlib),"%.1f%%",vehicleDB[vehicleid][energy]);
			PlayerTextDrawSetString(playerid,AkumasTD[playerid],animlib);
			SetProgressBarMaxValue(Degalai, ((aBakai[model-400] > 0) ? (aBakai[model-400]) : (1)));
			SetProgressBarValue(Degalai, vehicleDB[vehicleid][gas]);
			UpdateProgressBar(Degalai, playerid);
			SetProgressBarValue(Akumas, vehicleDB[vehicleid][energy]);
			UpdateProgressBar(Akumas, playerid);
			PlayerTextDrawShow(playerid,AkumasTD[playerid]);
			PlayerTextDrawShow(playerid,DegalasTD[playerid]);
		}
	}
	MasinuLoop();
	return 1;
}

stock MasinuLoop()
{
	static
			model;
	for(new vehicleid ; vehicleid < MAX_VEHICLES ; vehicleid++)
	{
	    model = GetVehicleModel(vehicleid);
	    if(!model || vehicleid == Busikas) continue;
	    if(model != BMX && model != MTBIKE && model != BIKE)
	    {
			if(Kraunasi[vehicleid])
			{
				if(vehicleDB[vehicleid][energy] < 99.0)
					vehicleDB[vehicleid][energy]+=0.3;
				else 
					Kraunasi[vehicleid]=0;
			}
			GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
		    if(VehVars[1])
			{
			    if(vehicleDB[vehicleid][energy] < 0.6)
			    {
			        vehicleDB[vehicleid][energy]=0;
			        SetVehicleParamsEx(vehicleid,VehVars[0],false,VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
			    }
			    else
			    	vehicleDB[vehicleid][energy]-=0.25;
			}
			if(VehVars[0])
			{
			    if(vehicleDB[vehicleid][energy]<=99) 
			    	vehicleDB[vehicleid][energy]+=0.9;
			    if(vehicleDB[vehicleid][gas]-aEda[model-400] >= 0)
		    	    vehicleDB[vehicleid][gas]-=0.1;
			    else
			    {
			        vehicleDB[vehicleid][gas]=0;
			        SetVehicleParamsEx(vehicleid,false,VehVars[1],VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
			    }
			}
			if((VehVars[0] || VehVars[1]) && isnull(vehicleDB[vehicleid][lastuser]))// && !strlen(vehicleDB[vehicleid][lastuser]))
			{
			    SetVehicleParamsEx(vehicleid,false,false,VehVars[2],-1,false,false,VehVars[6]);
			}
		}
	}
	return 1;
}
public Pabegimas()
{
	new x=0,y=0;
	foreach(Player, i)
	{
		x++;
		if(IsPlayerInRangeOfPointEx(10, i, 3171.3145,-868.5535,9.3741) && !IsPlayerAfk(i)) y++;
	}
	if(y >= x/10)
	{
	    DestroyDynamicObject(siena);
		siena=-1;
	    SetTimer("FixTvora",20000,false);
	    foreach(Player, i) if(playerDB[i][ikalintas]) GameTextForPlayer(i,"~r~Grotos pradauztos!",2000,1);
		SendMessageToTeisesauga(COLOR,"[racija] Operatore: Pabegimas kalejime ivyko. Nuostoliai bus apmoketi is pelno.");
		pelnas[79]-=y*500;
	}
	else
	{
		pabegimas=false;
		foreach(Player, i) if(playerDB[i][ikalintas]) GameTextForPlayer(i,"~r~Pabegimas neivyko!",2000,1);
		SendMessageToTeisesauga(COLOR,"[racija] Operatore: Pabegimas kalejime neivyko.");
	}
	return 1;
}

public FixTvora() return siena = CreateDynamicObject(987, 3168.38842773,-857.89202881,8.37406635,0.00000000,0.00000000,299.99267578),pabegimas=false;


public SecondTimer()
{
	SendClientMessageToAll(0xFFFFFF00," ");
	foreach(Player,i)
	{
		if(KiekFlood[i]) KiekFlood[i]--;
		DamageInbalance[i]=0.0;
	}
	UpdateMap();
	//VelykuEvent();
	return 1;
}

