public NumerioPaieska(playerid,id)
{
	SetTimerEx("GaliKast",2000,0,"i",playerid);
	new Float:Coo[3];
	GetVehiclePos(id,Coo[0],Coo[1],Coo[2]);
	SetPlayerCheckpoint(playerid,Coo[0],Coo[1],Coo[2],20.0);
	new string[128];
	format(string,sizeof(string),"Operatorë: Automobilis rodomas radare(%s)",JB_gSAZones[Get2DZoneEx(Coo[0],Coo[1])][JB_SAZONE_NAME]);
	SendClientMessage(playerid,RED,string);
	//SetTimerEx("GaliKast",2000,0,"i",playerid);
}

stock SearchVehicleID(numeris2[])
{
	new numeris[128];
	format(numeris,128,"{000000}%s",numeris2);
	foreach(Player, i)
	{
		if(Carlist[i][Status] && strlen(Carlist[i][NumPlate]) > 0 && strcmp(Carlist[i][NumPlate],numeris,true) == 0)
			return Carlist[i][Carid];
		else if(Carlist2[i][Status] && strlen(Carlist2[i][NumPlate]) > 0 && strcmp(Carlist2[i][NumPlate],numeris,true) == 0)
			return Carlist2[i][Carid];
		else if(Carlist3[i][Status] && strlen(Carlist3[i][NumPlate]) > 0 && strcmp(Carlist3[i][NumPlate],numeris,true) == 0)
			return Carlist3[i][Carid];
	}
	//print("Zaideju masinos nerasta!");
	for(new i; i < MAX_VEHICLES; i++)
		if(strlen(vehicleDB[i][vnumeris]) > 0 && strcmp(vehicleDB[i][vnumeris],numeris,true) == 0)
			return i;
	return -1;		
}
public OnVehicleSpawn(vehicleid)
{
	static	stringas[50],
			modelis;
	modelis = GetVehicleModel(vehicleid);
	if(modelis == 432)
		SetVehicleHealth(vehicleid,3000.0);
	if(modelis == 428 || modelis == 427)
		SetVehicleHealth(vehicleid, 2000.0);
	VehicleLocked[vehicleid][0]=0;
	format(vehicleDB[vehicleid][nuomuoja],24,"no");
	format(vehicleDB[vehicleid][lastuser],MAX_PLAYER_NAME,"");
	VehicleSpawned[vehicleid]=0;
	VehicleRadio[vehicleid]=0;
	VehicleNitro[vehicleid]=0;
	if(!IsVagiuCar(vehicleid))
	{
		format(stringas,sizeof(stringas),"{000000}%c%c%c %i%i%i",(65+random(26)),(65+random(26)),(65+random(26)),random(10),random(10),random(10));
		
		if(!ArNuosava(vehicleid))
		{
			if(!IsAPlane(modelis) && !IsABoat(modelis))
			{
				SetVehicleNumberPlate(vehicleid,stringas);
				format(vehicleDB[vehicleid][vnumeris],50,stringas);
			}
			if(IsNuomosCar(vehicleid))
			{
				SetVehicleNumberPlate(vehicleid,"{007380}LSG Nuoma");
				format(vehicleDB[vehicleid][vnumeris],50,stringas);
