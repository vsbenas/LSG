public Atristi(playerid)
{
	if(!IsPlayerConnected(playerid)) return 1;
	if(!playerDB[playerid][suristas]) return 1;
	playerDB[playerid][suristas]=false;
	TogglePlayerControllable(playerid,true);
	SendInfoMessage(playerid,"~g~ Atsirisai!!!");
	return 1;
}
stock SetPlayerKVS(playerid, key[], value[])
{
