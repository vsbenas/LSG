stock ShowPlayerKeliones(playerid,deleting)
{
	new query[1024];
	format(query,sizeof(query),"SELECT Keliones.id, name, kurejas, COUNT(cpid) from Keliones JOIN Checkpoints ON Checkpoints.id = Keliones.id WHERE type='kelione' GROUP BY Checkpoints.id ORDER BY Keliones.id + 0 ASC");
	mysql_function_query(SQL, query, true, "SQL_ShowKeliones", "ii", playerid,deleting);
}
stock LoadPlayerKelione(playerid, kelioneid, deleting)
{
	new query[1024];
	format(query,sizeof(query),"SELECT * from Keliones LEFT JOIN Checkpoints ON Checkpoints.id = Keliones.id AND type='kelione' WHERE Keliones.id='%i' ORDER BY cpid ASC", kelioneid);
	mysql_function_query(SQL, query, true, "SQL_LoadKelione", "iii", playerid, kelioneid, deleting);
}

stock SaveKelione(id, playerid)
{
	new query[2048];
	format(query,sizeof(query), "DELETE FROM Checkpoints WHERE type='kelione' AND id='%i'",id);
	mysql_query(query);
	format(query,sizeof(query), "REPLACE INTO Keliones(id, name, kurejas) VALUES ('%i','%s','%s')", id, Keliones[KelionesPavadinimas], ReturnName(playerid));
	mysql_query(query);
	for(new i;i<CP;i++)
	{
		format(query,sizeof(query),"INSERT INTO Checkpoints(type,id,cpid,x,y,z) VALUES ('kelione', '%i', %i, '%f', '%f', '%f')",
			id, i, KelionesKurimas[i][koordx],KelionesKurimas[i][koordy],KelionesKurimas[i][koordz]);
		mysql_query(query);
	}
}
stock LoadAutokluboRace(filename[])
{
	new string[128];
	if(!fexist(filename)) return 0;
    new File:failas = fopen(filename, io_read); 
	new id=-1;
    while(fread(failas, string))
    {
		if(id == -1)
		{
			format(Keliones[KelionesPavadinimas],128,string);
			id++;
		}
        else if(!sscanf(string,"p<;>fff",KelionesKurimas[id][koordx], KelionesKurimas[id][koordy],KelionesKurimas[id][koordz])) // new Float:KelioniuCord[3][MAX_CHECKPOINTS]
        {
            id++;
			// failo formatas:   X;Y;Z (nauja eilute) X;Y;Z (nauja eilute)...
        }
    }
	KelionesKurimas[id][koordx]=0.0;
	KelionesKurimas[id][koordy]=0.0;
	KelionesKurimas[id][koordz]=0.0;
	Keliones[Paskutinysis]=id-1;
	Keliones[DabartinisCP]=0;
	
    fclose(failas);
    return 1;
}
