public PoSpawn(playerid)
{
	playerDB[playerid][pospawn]=true;
}
new PKills[MAX_PLAYERS];
new PTotal[MAX_PLAYERS];
forward KillDueler(playerid);
public KillDueler(playerid)
{	
	ChangeDeathInfo(playerid, INVALID_PLAYER_ID, 24, 1000);
	SetPlayerHealth(playerid,0.0);
	return 1;
}
new FIXES_gsLastAnimation[MAX_PLAYERS];
#define SolveForT(%0) ((%0 + floatsqroot(%0*%0 + 50.4))/14)
#define NUM_GIBS 100
new Gibs[NUM_GIBS];
new gibs_id = 0;

stock CollectGibs(playerid)
{
	for(new i;i<NUM_GIBS;i++)
	{
		if(Gibs[i] != 0)
		{
			new Float:P[3];
			GetObjectPos(Gibs[i], P[0], P[1], P[2]);
			if(IsPlayerInRangeOfPointEx(1.5,playerid, P[0], P[1], P[2]))
			{
				PHY_DeleteObject(Gibs[i]);
				DestroyObject(Gibs[i]);
				Gibs[i]=0;
				if(helovynas)
				{
					if(GetPVarInt(playerid,"Bodyparts") < 18)
						SetPVarInt(playerid,"Bodyparts",GetPVarInt(playerid,"Bodyparts")+1);
					if(GetPVarInt(playerid,"Bodyparts") == 18)
						SendClientMessage(playerid, ORANGE, "[HELOVYNO EVENTAS] Surinkai visus lavonus! Gali eiti atsiimti prizŕ.");
					new msg[125];
					format(msg,125,"Surinkai %i/18 lavonu dalis!",GetPVarInt(playerid,"Bodyparts"));
					SendInfoMessage(playerid,msg);
				}
				else if(GetPVarInt(playerid,"RenkaMesas"))
				{
					new turi = GetPVarInt(playerid, "Mesos");
					if(turi < 10)
						turi ++;
					SetPVarInt(playerid, "Mesos", turi);
					new msg[26];
					format(msg,26,"%i/10",turi);
					SendInfoMessage(playerid,msg);
				}
				else
					SendInfoMessage(playerid,"Kazkas tvarka turi palaikyti...");
				ProcessAchievement(playerid,104);
				ApplyAnimation(playerid, "MISC", "pickup_box", 4.000000, 0, 0, 0, 0, -1);
				break;
			}
		}
	}
}

stock DropGibs(playerid)
{
	new Float:P[3]; 
	GetPlayerPos(playerid,P[0],P[1],P[2]);
	new objs[6] = {2905,2905,2906,2906,2907,2908};
	for(new i;i<6;i++)
	{
		new swap = objs[i];
		new next = random(6);
		objs[i] = objs[next];
		objs[next] = swap;
	}
	for(new i; i <6; i++)
	{
		new Float:sin,Float:cos;
		new Float:speed = (1+random(10))*0.5;
		if(Gibs[gibs_id] != 0)
		{
			PHY_DeleteObject(Gibs[gibs_id]);
			DestroyObject(Gibs[gibs_id]);
		}

		new obj = CreateObject(objs[i], P[0],P[1],P[2]+1.0, 0, 0, random(360));
		if(obj == INVALID_OBJECT_ID)
			return;
		Gibs[gibs_id] = obj;
		gibs_id++;
		if(gibs_id == NUM_GIBS)
			gibs_id = 0;



		new Float:a = i * (360.0 / 6);
		sin = floatsin( -a, degrees );
		cos = floatcos( -a, degrees );

		PHY_InitObject(obj);
		PHY_SetObjectVelocity(obj, speed*sin, speed*cos, speed);

		PHY_SetObjectFriction(obj, 100); // This will stop the object when it touchs the ground.
		PHY_SetObjectGravity(obj, 14.0);
		new Float:T = SolveForT(speed);
		new Float:Zpos;
		MapAndreas_FindZ_For2DCoord(P[0]+speed*sin*T,P[1]+speed*cos*T,Zpos);
		if(Zpos > P[2]+1.5 || Zpos < P[2]-100.0)
			Zpos = P[2]-0.8;
		PHY_SetObjectZBound(obj, Zpos+0.1, _, 0.0); // -0.8
		PHY_SetObjectGhost(obj);
	}
}


public OnPlayerDeath(playerid, killerid, reason)
{
	if(reason == 9)
		DropGibs(playerid);
	if(helovynas)
		DropGibs(playerid);
	if(PlayerPokerWaitQue[playerid] != -1)
	{
		RemovePlayerFromPokerWaitQue(playerid, PlayerPokerWaitQue[playerid]);
	}
	static
		sAnimlib[32],
		sAnimname[32];
	GetAnimationName(FIXES_gsLastAnimation[playerid], sAnimlib, sizeof (sAnimlib), sAnimname, sizeof (sAnimname));
	CancelWorldEdit(playerid);
	if (strcmp(sAnimlib, "PED", true))
	{
		ClearAnimations(playerid);
	}
	if(fs_balloon_pl[playerid][0] == 1) {
		fs_balloon_pl[playerid][0] = 3;
		Iter_Remove(PlayersFading,playerid);
	}
	if(RocketManager == playerid)
	{
		RocketSet(playerid,false);
	}
	if(GetPVarInt(playerid, "PSpectating"))
		return 1;
	if(playerDB[playerid][hasmoney])
	{
		RemovePlayerAttachedObject(playerid, MESKERE_SLOT);
		playerDB[playerid][hasmoney]=0;
		if(playerDB[playerid][pgang] != -1)
		{
			new msg[128];
			format(msg,128,"[gauja] %s mire ir pamete pinigus!",ReturnName(playerid));
			SendMessageToFamily(playerDB[playerid][pgang],ORANGE,msg);
			SendMessageToTeisesauga(YELLOW,"[racija] Operatorë: Gaujos narys numirë ir pametë pinigř maiđŕ! Paimkite já ir pristatykite á policijos departamentŕ!");
		}
		else
		{
			SendMessageToTeisesauga(YELLOW,"[racija] Operatorë: Műsř pareigűnas numirë ir pametë pinigř maiđŕ! Paimkite já ir pristatykite á policijos departamentŕ!");
		}
		new Float:Coo[3];
		GetPlayerPos(playerid, Coo[0], Coo[1], Coo[2]);
		if(MoneyBag != -1)
			DestroyPickup(MoneyBag);
		MoneyBag = CreatePickupA(1550, 2, Coo[0],Coo[1],Coo[2],GetPlayerVirtualWorld(playerid));
		dirtym = 0;
	}
	if(playerDB[playerid][dirtymoney] || InkaUzsakymai[playerid][utype] == 1 && InkaUzsakymai[playerid][uamount] != 5)
	{
		SendClientMessage(playerid,TEXTCOL_GOLD, " * Pametei padirbtus pinigus!");
		RemovePlayerAttachedObject(playerid, MESKERE_SLOT);
		InkaUzsakymai[playerid][utype]=0;
		InkaUzsakymai[playerid][uamount]=0;
		InkaUzsakymai[playerid][ustatus]=0;
		playerDB[playerid][dirtymoney]=false;
		new Float:Coo[3];
		GetPlayerPos(playerid, Coo[0], Coo[1], Coo[2]);
		if(MoneyBag != -1)
			DestroyPickup(MoneyBag);
		MoneyBag = CreatePickupA(1550, 2, Coo[0],Coo[1],Coo[2],GetPlayerVirtualWorld(playerid));
		dirtym = 1;

	}
	else if( InkaUzsakymai[playerid][utype] == 1 && InkaUzsakymai[playerid][uamount] == 5)
	{
		SendClientMessage(playerid,TEXTCOL_GOLD, " * Pametei padirbtus pinigus!");
		RemovePlayerAttachedObject(playerid, MESKERE_SLOT);
		InkaUzsakymai[playerid][utype]=0;
		InkaUzsakymai[playerid][uamount]=0;
		InkaUzsakymai[playerid][ustatus]=0;
		new Float:Coo[3];
		GetPlayerPos(playerid, Coo[0], Coo[1], Coo[2]);
		if(MoneyBag != -1)
			DestroyPickup(MoneyBag);
		MoneyBag = CreatePickupA(1550, 2, Coo[0],Coo[1],Coo[2],GetPlayerVirtualWorld(playerid));
		dirtym = 2;


	}
	if(InkaUzsakymai[playerid][ustatus] == 2 || InkaUzsakymai[playerid][ustatus] == 4)
		PrapisoPinigus(playerid,0);
	if(BallHolder == playerid)
	    RecreateBall();
	if(playerid != INVALID_PLAYER_ID && killerid != INVALID_PLAYER_ID)
	{
		if(playerDB[killerid][pgang] != playerDB[playerid][pgang] && playerDB[playerid][pgang] != -1 && playerDB[killerid][pgang] != -1)
			ProcessAchievement(killerid,64);
	}
	if(HandleWorldDeath(playerid))
	{
		return 1;
	}
	if(playerid != INVALID_PLAYER_ID) if(playerDB[playerid][psratasvydis])
	{
		if(DuelKova[playerid] != -1) 
		{
			SendClientMessage(playerid,YELLOW,"[DUEL] Pralaimëjai!");
			GameTextForPlayer(playerid,"~r~YOU LOSE",3000,0);
			SendClientMessage(DuelKova[playerid],YELLOW,"[DUEL] Laimëjai!");
			GameTextForPlayer(DuelKova[playerid],"~g~YOU WIN",3000,0);
			DuelKova[DuelKova[playerid]]=-1;
			if(DuelKova[playerid] != -1)
				SetTimerEx("KillDueler",2000,false,"i",DuelKova[playerid]);
			DuelKova[playerid]=-1;
			return 1;
		}
		
		if(killerid == INVALID_PLAYER_ID) return 1;
		ProcessAchievement(killerid,17);
		
		PKills[playerid]=0;
		PKills[killerid]++;
		PTotal[killerid]++;
		if(playerDB[killerid][psratasvydis]==1) dazuscore[1]++;
		else if(playerDB[killerid][psratasvydis]==2) dazuscore[0]++;
		//if(PKills[killerid] == 1) return 1;
		new msg[128];
		new kill[30]; 
		new file[128];
		switch(PKills[killerid])
		{
			case 2: // double kill
			{
				kill = "Double Kill";
				if(random(2) == 0)
					file = "http://www.lsgyvenimas.lt/sounds/doublekill1_ultimate.wav";
				else
					file = "http://www.lsgyvenimas.lt/sounds/doublekill2_ultimate.wav";
			}
			case 3:
			{
				kill = "Multi Kill";
				file = "http://www.lsgyvenimas.lt/sounds/multikill_ultimate.wav";
			}
			case 4:
			{
				kill = "Mega Kill";
				file = "http://www.lsgyvenimas.lt/sounds/megakill_ultimate.wav";
			}
			case 5:
			{
				kill = "Ultra Kill";
				file = "http://www.lsgyvenimas.lt/sounds/ultrakill_ultimate.wav";
			}
			case 6:
			{
				kill = "Monster Kill";
				file = "http://www.lsgyvenimas.lt/sounds/monsterkill_ultimate.wav";
			}
			case 7:
			{
				kill = "Ludicrous Kill";
				file = "http://www.lsgyvenimas.lt/sounds/ludicrouskill_ultimate.wav";
			}
			case 8:
			{
				kill = "HOLY S**T";
				file = "http://www.lsgyvenimas.lt/sounds/holyshit_ultimate.wav";
			}
		}
		if(PKills[killerid] > 0 && PKills[killerid] < 9)
		{
			if(PKills[killerid] == 7)
			{
				SendClientMessage(killerid,RED," * LUDICROUS KILL! * Gavai tris rocket launcher raketas!");
				GivePlayerWeaponEx(killerid,WEAPON_ROCKETLAUNCHER,3);
			}
			format(msg,sizeof(msg),"~y~%s~n~~r~%s",ReturnName(killerid),kill);
			if(PKills[killerid] > 1)
			{
				SendInfoMessage(killerid,msg);
				PlayAudioStreamForPlayer(killerid, file);
			}
			SendDeathMessageToPlayer(killerid, killerid, playerid, reason);

			foreach(Player, i) if(i != killerid)
			{
				if(playerDB[i][psratasvydis])
				{
					SendDeathMessageToPlayer(i, killerid, playerid, reason);
					if(PKills[killerid] > 1)
						SendInfoMessage(i,msg);
					if(PKills[killerid] > 5)
						PlayAudioStreamForPlayer(i, file);
				}
			}
		}
		return 1;
	}
	if(playerid != INVALID_PLAYER_ID && !IsPlayerNPC(killerid)) {if(playerDB[playerid][banned] || playerDB[playerid][authstate] == 0) return Kick(playerid);}
	if(killerid != INVALID_PLAYER_ID && !IsPlayerNPC(killerid)) { if(playerDB[killerid][banned] || playerDB[killerid][authstate] == 0) return Kick(killerid);}
	if(GetTickCount() - LastDeath[playerid] < 2000)
	{
		DeathCount[playerid]++;
	}
	if(DeathCount[playerid] >=3)
		AC_Ban(playerid,"Fake Kill",1);
	LastDeath[playerid]=GetTickCount();
	foreach(Player,i) 
	{
		if(LastTarget[i] == playerid)
			LastTarget[i] = INVALID_PLAYER_ID;
