PUB:Freezing(playerid)
{
	SetCameraBehindPlayer(playerid);
	TogglePlayerControllable(playerid, 0);
	SetTimerEx("HackCheck", FREEZE_SECONDS * 1000, 0, "i", playerid);
	//SendClientMessage(playerid, -1, "Krauname zaidima...");
}
PUB:HackCheck(playerid) 
{
	if(!IsPlayerConnected(playerid))
		return 1;
	new Float:x, Float:y, Float:z;
	GetPlayerCameraFrontVector(playerid, x, y, z);
	#pragma unused x
	#pragma unused y
	if(z < -0.8) {
	   // SendClientMessage(playerid, -1, "Zaidimas pakrautas. Galite testi. cheat");
	    AC_Kick(playerid,"Cheats Detected");
	}
	else {
	    //SendClientMessage(playerid, -1, "Zaidimas pakrautas. Galite testi.");
	    TogglePlayerControllable(playerid, 1);
	    SetCameraBehindPlayer(playerid);
		if(!playerDB[playerid][banned])
		{
			CallRemoteFunction("BenoAcCheckHax", "i",playerid);
			CallRemoteFunction("BenoAcCheckV2", "i", playerid);
		}
	}
	return 1;
}
stock CheckInvul(playerid)
{
	if(!IsPlayerConnected(playerid))
		return;

	if(SafeArea(playerid) || (IsPlayerInAnyVehicle(playerid) && GetPlayerInterior(playerid) > 0)) // safe zone - poker or tune garage
		return;
	if(NoCheckTP[playerid] > 0 || playerDB[playerid][mire] || PFreezed[playerid] || GetTickCount() - LastFreezed[playerid] < 5000 || IsPlayerAfkShort(playerid))
		return;
	CallRemoteFunction("BenoAcCheckInvul", "i",playerid);
}
PUB:GetPlayerDialogID(playerid)
{
	return gPlayerDialog[playerid];
}
PUB:ResetDialogid(playerid)
{
	gPlayerDialog[playerid]=-1;
}
PUB:OnBenoAcInvulDetected(playerid)
{
	if(!IsPlayerConnected(playerid))
		return;
	if(SafeArea(playerid) || (IsPlayerInAnyVehicle(playerid) && GetPlayerInterior(playerid) > 0)) // safe zone - poker or tune garage
		return;
	if(playerDB[playerid][mire] || PFreezed[playerid] || GetTickCount() - LastFreezed[playerid] < 5000 || IsPlayerAfkShort(playerid) || GetPlayerSkin(playerid) == 0)
		return;

	AC_Warn(playerid, "Invulnerable(cheat)");
}
PUB:OnBenoAcResults(playerid,Float:result,uniqueid)
{
	if(!IsPlayerConnected(playerid))
		return;
	SavePlayerUniqueId(playerid, uniqueid);
	if(result < 90.0)
	{
		if(IsPlayerAfk(playerid))
		{
			printf("[BENO AC] Zaidejas afk. Tikrinam po 10 sec");
			SetTimerEx("DelayACcheck", 10000, false, "i", playerid);
		}
		else
		{
			SendClientMessage(playerid, -1, " * Jűsř samp versija netinkama. Műsř serveryje privalote naudoti "#SAMP_VERSION" versijŕ.");
			SendClientMessage(playerid, -1, " * Atsisiuntimas: www.sa-mp.com/download.php");
			AC_Kick(playerid,"Netinkamas SAMP");
		}
	}
}
PUB:OnBenoAcSampfuncs(playerid, warn)
{
	if(!IsPlayerConnected(playerid))
		return;
	if(warn == 0)
	{
		AC_Ban(playerid, "Nelegalios programos");
	}
	else if(warn == 1)
	{
		if(GetPVarInt(playerid, "SFwarned") == 1)
		{
			AC_Ban(playerid, "Nelegalios programos 2/2");
		}
		else 
		{
			SetPlayerKVS(playerid,"SFwarned","warn");
			SendClientMessage(playerid, WHITE, " * Jusu sistemoje radome nelegaliř programř. Jei manote, jog tai klaida, prađome perrađyti visŕ savo GTA San Andreas nes kitŕ kartŕ gausite BAN");
			AC_Kick(playerid, "Nelegalios programos 1/2");
		}
	}
}
PUB:OnBenoAcNuked(playerid)
{
	if(!IsPlayerConnected(playerid))
		return;
	if(GetPVarInt(playerid,"Nuked") == 1)
	{
		SetPVarInt(playerid, "Nuked", 2);
	}
	else if(GetPVarInt(playerid, "Nuked") == 0)
	{
		SetPVarInt(playerid, "Nuked", 1);
	}
}
PUB:OnBenoAcNukeRevert(playerid)
{
	SetPVarInt(playerid, "Nuked", 0);
}
PUB:OnBenoAcIgnored(playerid)
{
	if(!IsPlayerConnected(playerid))
		return;
	AC_Kick(playerid, "Nelegalios programos");
}
PUB:BenoAcIsAfk(playerid)
{
	return IsPlayerAfk(playerid);
}
PUB:DelayACcheck(playerid)
{
	if(!IsPlayerConnected(playerid))
		return;
	if(IsPlayerAfk(playerid))
	{
		SetTimerEx("DelayACcheck", 10000, false, "i", playerid);
	}
	else
	{
		CallRemoteFunction("BenoAcCheckHax", "i",playerid);
	}
}
PUB:OnBenoAcCheatDetected(playerid,cheat[])
{
	if(IsPlayerConnected(playerid))
	{
		AC_Kick(playerid,cheat);
	}
}

stock IsInDrill(playerid)
{
	for(new i;i< sizeof(DRILL_CP);i++)
	{
		if (IsPlayerInRangeOfPointEx( 5.0,playerid, DRILL_CP[i][0], DRILL_CP[i][1], DRILL_CP[i][2]))
		{
			return 1;
		}
	}
	return 0;
}
public OnPlayerEnterDynamicCP(playerid, checkpointid)
{
	if(IsPlayerInWorld(playerid))
		return 1;
	if(InkaUzsakymai[playerid][utype] == 0)
	{	
		if(LoadOrderInka(playerid)) return 1;
	}
	if(IsInBiz(playerid))
	{
		//if(GetPlayerScore(playerid) < 100) return SendInfoMessage(playerid,"Sia komanda galite naudotis tik nuo 100 XP.~n~Pavalgyti galite is siuksliu konteineriu.");
		new idx=(GetPlayerVirtualWorld(playerid)-MAX_HOUSES*2);
		new Float:HPas;
		GetPlayerHealth(playerid, HPas);
		new type = BusinessInfo[idx][bType];
		if(playerDB[playerid][issirinkoak]) return SendInfoMessage(playerid,"Jus dar neissirinkote!");
		new header = 0;
		switch(type)
		{
			case 1:
			{
				AddDListItem(playerid, "Kovos Judesiai", 0);
			}
			case 2:
			{
				AddDListItem(playerid, "Ukinës prekës\t ", 1);
				AddDListItem(playerid, "Maistas namo\t{33FF33}"#COST_MAISTAS_NAMO"€", 21);
				header = 1;
			}
			case 3:
			{
				AddDListItem(playerid, "Rűbai\t{33FF33}"#COST_SKINAS"€", 2);
				AddDListItem(playerid, "Uniforma\t{33FF33}"#COST_UNIFORMA"€", 25);
				header = 1;
			}
			case 4:
			{
				AddDListItem(playerid, "Gërimai", 3);
				AddDListItem(playerid, "Narkotikai",29);
				if(strcmp(BusinessInfo[idx][bOwner],ReturnName(playerid),false) == 0 && BusinessInfo[idx][bOwned])
					AddDListItem(playerid, "{00FF00}Parduoti narkotikus",30);
			}
			case 5:
			{
				if(HPas + COST_MAZA_PICA < 200)
					AddDListItem(playerid, "Maţa pica\t{33FF33}"#COST_MAZA_PICA"€", 4);
				else
					AddDListItem(playerid, #TEXT_RED"Maţa pica\t{33FF33}"#COST_MAZA_PICA"€", 4);

				if(HPas + COST_VIDUTINE_PICA < 200)
					AddDListItem(playerid, "Vidutinë pica\t{33FF33}"#COST_VIDUTINE_PICA"€",5);
				else
					AddDListItem(playerid, #TEXT_RED"Vidutinë pica\t{33FF33}"#COST_VIDUTINE_PICA"€", 5);

				if(HPas + COST_DIDELE_PICA < 200)
					AddDListItem(playerid, "Didelë pica\t{33FF33}"#COST_DIDELE_PICA"€", 6);
				else
					AddDListItem(playerid, #TEXT_RED"Didelë pica\t{33FF33}"#COST_DIDELE_PICA"€", 6);

				if(HPas + COST_SALOTOS < 200)
					AddDListItem(playerid, "Salotos\t{33FF33}"#COST_SALOTOS"€", 7);
				else
					AddDListItem(playerid, #TEXT_RED"Salotos\t{33FF33}"#COST_SALOTOS"€", 7);
				AddDListItem(playerid, "Maistas Iđsineđimui\t{33FF33}"#COST_MAISTAS"€", 22);
				header = 1;
			}
			case 6:
			{
				AddDListItem(playerid, "Ginklai\t ", 8);
				AddDListItem(playerid, "Đarvai\t{33FF33}"#COST_ARMOUR"€", 9);
				header = 1;
			}
			case 7:
			{
				AddDListItem(playerid, "Kiosko prekës", 23); // kioskai
			}
			case 8:
			{
				AddDListItem(playerid, "Fejerverkai", 10);
			}
			case 9:
			{
				AddDListItem(playerid, "Sex ţaislai", 11);
				AddDListItem(playerid, "Sex aprangos", 28);
			}
			case 10:
			{
				if(HPas + COST_MESAINIS < 200)
					AddDListItem(playerid, "Mësainis\t{33FF33}"#COST_MESAINIS"€", 12);
				else
					AddDListItem(playerid, #TEXT_RED"Mësainis \t{33FF33}"#COST_MESAINIS"€", 12);

				if(HPas + COST_SURAINIS < 200)
					AddDListItem(playerid, "Sűrainis \t{33FF33}"#COST_SURAINIS"€", 13);
				else
					AddDListItem(playerid, #TEXT_RED"Sűrainis \t{33FF33}"#COST_SURAINIS"€", 13);

