stock SDDI(playerid)
{
	if(IsPlayerInRangeOfPointEx(10.0,playerid,PickupIDs[pickups[0][gunkraut]][0],PickupIDs[pickups[0][gunkraut]][1],PickupIDs[pickups[0][gunkraut]][2]))
		ShowPlayerDialog(playerid, 9008, DIALOG_STYLE_LIST, "Ka krausim?", "Desert eagle\nMp5", "Rinktis", "Iseiti");
	else if(IsPlayerInRangeOfPointEx(10.0,playerid,PickupIDs[pickups[0][gunkraut2]][0],PickupIDs[pickups[0][gunkraut2]][1],PickupIDs[pickups[0][gunkraut2]][2]))
		ShowPlayerDialog(playerid, 9008, DIALOG_STYLE_LIST, "Ka krausim?", "Desert eagle\nMp5\nAk-47", "Rinktis", "Iseiti");
	else if(IsPlayerInRangeOfPointEx(10.0,playerid,PickupIDs[pickups[0][gunkraut3]][0],PickupIDs[pickups[0][gunkraut3]][1],PickupIDs[pickups[0][gunkraut3]][2]))
		ShowPlayerDialog(playerid, 9008, DIALOG_STYLE_LIST, "Ka krausim?", "Desert eagle\nMp5\nAk-47\nAWP", "Rinktis", "Iseiti");
	return 1;
}
stock IsNearPakrovimas(playerid)
{
	if(IsPlayerInRangeOfPointEx(20.0,playerid,PickupIDs[pickups[0][gunkraut]][0],PickupIDs[pickups[0][gunkraut]][1],PickupIDs[pickups[0][gunkraut]][2])
		|| IsPlayerInRangeOfPointEx(20.0,playerid,PickupIDs[pickups[0][gunkraut2]][0],PickupIDs[pickups[0][gunkraut2]][1],PickupIDs[pickups[0][gunkraut2]][2])
			|| IsPlayerInRangeOfPointEx(20.0,playerid,PickupIDs[pickups[0][gunkraut3]][0],PickupIDs[pickups[0][gunkraut3]][1],PickupIDs[pickups[0][gunkraut3]][2]))
		return 1;
	return 0;
}
public OnPlayerClickMap(playerid, Float:fX, Float:fY, Float:fZ)
{
	if(taxiDB[playerid][imti])
	{
		if(GetPlayerVehicleID(taxiDB[playerid][taksistas]) == GetPlayerVehicleID(playerid))
		{
			new Float:coo[6];
			GetPlayerPos(playerid,coo[3],coo[4],coo[5]);
			coo[0] = fX;
			coo[1] = fY;
			coo[2] = fZ;
			new Float:atstumas = ((floatabs(coo[0]-coo[3])+floatabs(coo[1]-coo[4])+floatabs(coo[2]-coo[5]))/3)/100;
			SetPlayerCheckpoint(taxiDB[playerid][taksistas],coo[0],coo[1],coo[2],2);

			new salis1[10],salis2[10];
			new msg[128];
			if(coo[0]-coo[3]>0) salis1="rytus"; else salis1="vakarus";
			if(coo[1]-coo[4]>0) salis2="siaures"; else salis2="pietu";

			format(msg,sizeof(msg),"[LSG Taxi] %s pazymeta vieta rodoma GPS. Ji yra %.1f KM i %s %s nuo jusu.",ReturnName(playerid),atstumas,salis2,salis1);
			
			SendClientMessage(playerid,ORANGE,"[LSG Taxi] Sekmingai pazymejote vieta zemelapyje!");

			SendClientMessage(taxiDB[playerid][taksistas],ORANGE,msg);
		}
		
	}
	else if(playerDB[playerid][admin])
	{
		printf("%s Admin tp!", ReturnName(playerid));
		MapAndreas_FindZ_For2DCoord(fX,fY, fZ);
		if(fX > -6000.0 && fX < 6000.0 && fY > -6000.0 && fY < 6000.0 && fZ > -6000.0 && fZ < 6000.0)
		{
			if(IsPlayerInAnyVehicle(playerid))
				SetVehiclePoz(GetPlayerVehicleID(playerid),fX, fY, fZ+2.0);
			else
				SetPlayerPoz(playerid, fX, fY, fZ+1.0); 
			Surfing[playerid]=INVALID_VEHICLE_ID;
		}
	}
	HandleWorldClickMap(playerid, fX, fY, fZ);
	return 1;
}

forward U2BInfo(playerid, response_code, data[]);
public U2BInfo(playerid, response_code, data[])
{
	if(playerDB[playerid][authstate] > 2) return 1;
	if(response_code == 200)
	{
	    new result[33], u2bstr[33]; new streamedurl[128];
		new crypted = strfind(data, "\"h\"", true, -1);
		strmid(result,data,crypted+7,crypted+39,strlen(data));
		format(u2bstr,sizeof(u2bstr), "%s", result);
		format(streamedurl, sizeof(streamedurl), "http://www.youtube-mp3.org/get?video_id=%s&h=%s",g_StartRadio, u2bstr);
		PlayAudioStreamForPlayer(playerid, streamedurl);
		return 1;
  	}
  	/*else
    {
		SendInfoMessage(playerid,"Fail.");
    }*/
  	return 1;
}


stock Float:GetWeaponDamage(weaponid)
{
	switch(weaponid)
	{
		case 22: return 8.25;
		case 23: return 13.2;
		case 24: return 46.2;
		case 25: return 60.2; //sg
		case 26: return 123.1; // sawedoff
		case 27: return 50.6; // csg
		case 28: return 6.6;
		case 29: return 8.25;
		case 30,31: return 9.9;
		case 32: return 6.6;
		case 33: return 24.75;
		case 34: return 41.25;
		case 38: return 46.2;
	}
	return 0.0;
}




stock CheckSpeed(playerid)
{
    new Keys,ud,lr;
    GetPlayerKeys(playerid,Keys,ud,lr);

    if(ud == KEY_UP && lr != KEY_LEFT && lr != KEY_RIGHT)
    {
        new Float:Velocity[3];
        GetPlayerVelocity(playerid, Velocity[0], Velocity[1], Velocity[2]);
        Velocity[0] = floatsqroot( (Velocity[0]*Velocity[0])+(Velocity[1]*Velocity[1])+(Velocity[2]*Velocity[2]));
        if(Velocity[0] >= 0.11 && Velocity[0] <= 0.13) return 1;
    }
    return 0;
}
stock ReturnWeaponTime(weaponid)
{
	new time=0;
	switch(weaponid)
	{
		case 22: time=150;
		case 23: time=340;
		case 24: time=690;
		case 25: time=870;
		case 27: time=300;
		case 29: time=70;
		case 30: time=110;
		case 31: time=100;
		case 33,34: time=1040;
	}
	return time;
}
new afkghost_warn[MAX_PLAYERS];
new proaim_warn[MAX_PLAYERS];
new shiftaim_warn[MAX_PLAYERS];
new silentaim_warn[MAX_PLAYERS];
new tirestatus[MAX_VEHICLES];
new tirewarnings[MAX_PLAYERS];
forward PadanguCheat(vehicleid,playerid,wep);

public PadanguCheat(vehicleid,playerid,wep)
{
	new panels, doors, lightz, tires;	
	GetVehicleDamageStatus(vehicleid, panels, doors, lightz, tires);
	new speed = GetSpeedEx(vehicleid);
	
	if(tires > 0 && speed >= 10) 
	{
		
		if(tires > tirestatus[vehicleid])
		{
			
			tirewarnings[playerid]++;
			if(tirewarnings[playerid] >= 2)
			{

				new msg[128];
				new temp[24];
				GetWeaponName(wep,temp,sizeof(temp));
				format(msg,128,"Padangu AIM (greitis: %i kmh, ginklas: %s)",speed,temp);
				AC_Warn(playerid,msg);
				tirewarnings[playerid]=0;
			}
			
		}
		else
		{
			tirewarnings[playerid]=0;
		}
		
	}
	else
	{
		tirewarnings[playerid]=0;
	}
	tirestatus[vehicleid]=tires;
    return 1;
}
new LastHitId[MAX_PLAYERS];
new Float:LastShots[MAX_PLAYERS][6];
#define MAX_SHOT_VARIANCE 5.0
public OnPlayerWeaponShot(playerid, weaponid, hittype, hitid, Float:fX, Float:fY, Float:fZ)
{
	if(NotSpawned[playerid] || LastWeaponEx[playerid] != weaponid || playerDB[playerid][authstate]==0) return 0;
	new returnas = 1;
	switch (weaponid)
    {
        case 22 .. 34, 38:
        {
            // valid bullet weapon
            new skin = GetPlayerSkin(playerid);
            if(skin == 92 || skin == 99) // rieduciai
			{
				return 0;
			}
        }
        default:
        {
            // invalid bullet weapon
            return 0; // desync the shot
        }
    }
	new tick = GetTickCount();

	new ShotDelay = 0;
	new Float:ShotDistance = 0.0;
	new Float:AimDist = 0.0;

	new 
		Float:fOriginX, Float:fOriginY, Float:fOriginZ,
		Float:fHitPosX, Float:fHitPosY, Float:fHitPosZ;

	if(hittype == BULLET_HIT_TYPE_PLAYER)
	{
		GetPlayerLastShotVectors(playerid, fOriginX, fOriginY, fOriginZ, fHitPosX, fHitPosY, fHitPosZ);

		ShotDistance = GetDistanceBetweenPoints(fOriginX, fOriginY, fOriginZ, fHitPosX, fHitPosY, fHitPosZ) * 10 / 3;

		if(LastHitId[playerid] == hitid && LastShots[playerid][0] == fOriginX && 
			LastShots[playerid][1] == fOriginY && LastShots[playerid][2] == fOriginZ &&
			LastShots[playerid][3] == fHitPosX && LastShots[playerid][4] == fHitPosY &&
			LastShots[playerid][5] == fHitPosZ && (tick - Lrapid_oldticks[playerid] < 500)
			)
		{
			AC_Warn(playerid, "Shot repeater/nospread");
			returnas = 0;
		}
		LastHitId[playerid] = hitid;
		LastShots[playerid][0] = fOriginX;
		LastShots[playerid][1] = fOriginY;
		LastShots[playerid][2] = fOriginZ;
		LastShots[playerid][3] = fHitPosX;
		LastShots[playerid][4] = fHitPosY;
		LastShots[playerid][5] = fHitPosZ;
	}
	if(Lrapid_oldticks[playerid] == 0) 
		Lrapid_oldticks[playerid] = tick;
	else 
	{
		ShotDelay = (tick-Lrapid_oldticks[playerid]);

		new wtime = ReturnWeaponTime(weaponid);
		if(wtime != 0 && !IsCbugEnabled(playerid))
		{
			/*new msa[120];
			format(msa,120,"Tick: %i, difference: %i, wtime: %i",tick,tick-Lrapid_oldticks[playerid],wtime);
			SendClientMessage(playerid, -1, msa);*/
			for(new i=9;i>0;i--)
				Lrapid_bulletstatus[playerid][i]=Lrapid_bulletstatus[playerid][i-1];
			if(ShotDelay < wtime)
			{
				Lrapid_bulletstatus[playerid][0]=2; // too fast
				new counter;
				for(new i;i<10;i++)
				{
					if(Lrapid_bulletstatus[playerid][i] == 2) counter++;
				}
				if(counter >= 7)
				{
					if(SaudyklosStats[playerid][s_id] != 0)
					{
						DestroySaudyklosObjektai(playerid);
						SendInfoMessage(playerid,"~r~Anti-cheatas tave itare rapid fire, todel buvo nutrauktas tavo bandymas!");
						returnas = 1;
					}
				}
				if(counter >= 8)
				{
					new msgzz[128];
					new itemname[30];
					GetWeaponName(weaponid,itemname,sizeof(itemname));
					format(msgzz,128," Rapid fire(%s), %i/10 kulku issove per greit",itemname,counter);
					AC_Warn(playerid, msgzz, false);
					if(counter== 10)
					{
						RapidWarnings[playerid]++;
						if(RapidWarnings[playerid] >= 5)
							AC_Ban(playerid,"Rapid fire");
					}
					returnas = 0;
				}
				if(weaponid == 24)
				{
					returnas = 0;
				}
			}
			else	
				Lrapid_bulletstatus[playerid][0]=1; // all ok
		}
		Lrapid_oldticks[playerid]=tick;

	}
	
	if(hittype == BULLET_HIT_TYPE_VEHICLE && hitid != INVALID_VEHICLE_ID)
	{
		SetTimerEx("PadanguCheat", 400, false, "iii", hitid,playerid,weaponid);

	}
	if(hittype == BULLET_HIT_TYPE_PLAYER && hitid != INVALID_PLAYER_ID)
	{
		if(PlayerSpectated[hitid] != -1)
		{
			new
				Float:RL_PlayerPos[3]; // targetpos

			new str[256];

			GetPlayerPos(hitid, RL_PlayerPos[0], RL_PlayerPos[1], RL_PlayerPos[2]);

			format(str,256," * Player got shot (ID %i W %i %im %ims)",playerid,weaponid,floatround(ShotDistance),ShotDelay);

			SendClientMessage(PlayerSpectated[hitid],ORANGE,str);

		}
		if(PlayerSpectated[playerid] != -1)
		{
			PlayerPlaySound(PlayerSpectated[playerid], 17802, 0, 0, 0);
		}
		if(BitFlag_Get(PConfig[playerid],PCFG_HITSOUND))
		{
			PlayerPlaySound(playerid, 17802, 0, 0, 0);
		}
		if(playerDB[hitid][mire] && !playerDB[hitid][droppedgibs]) 
		{
			playerDB[hitid][droppedgibs]=true;
			DropGibs(hitid);
		}
	
	}
	else if(hittype == BULLET_HIT_TYPE_VEHICLE)
	{
		VehicleShot[hitid]=tick;
	}
	else if(hittype == BULLET_HIT_TYPE_OBJECT)
	{
		CheckHitBalloon(hitid,weaponid);
	}
	if(SaudyklosStats[playerid][s_id] != 0)
	{
		SaudyklosStats[playerid][s_bullets]++;
		if(hittype == BULLET_HIT_TYPE_PLAYER_OBJECT)
			ShotSaudykla(playerid,weaponid, hitid);
	}


	if(PlayerSpectated[playerid] != -1)
	{
		new
			Float:RL_PlayerPos[3]; // targetpos

		if(hitid != INVALID_PLAYER_ID && hittype== BULLET_HIT_TYPE_PLAYER)
		{
			new str[256];
			GetPlayerPos(hitid, RL_PlayerPos[0], RL_PlayerPos[1], RL_PlayerPos[2]);

			GetDistanceFromPointToLine(AimDist, (fHitPosX-fOriginX), (fHitPosY-fOriginY), (fHitPosZ-fOriginZ), fOriginX, fOriginY, fOriginZ, RL_PlayerPos[0], RL_PlayerPos[1], RL_PlayerPos[2]);

			format(str,256,"Aimdist:%.2f ID %i %im %ims",AimDist,hitid,floatround(ShotDistance),ShotDelay);

			SendClientMessage(PlayerSpectated[playerid],GREEN,str);
		}
		else
		{
			new pidas=GetPlayerTargetPlayer(playerid);
			if(pidas == INVALID_PLAYER_ID)
			{
				pidas = LastTarget[playerid];
			}
			if(pidas != INVALID_PLAYER_ID)
			{
				GetPlayerPos(pidas, RL_PlayerPos[0], RL_PlayerPos[1], RL_PlayerPos[2]);
				GetDistanceFromPointToLine(AimDist, (fHitPosX-fOriginX), (fHitPosY-fOriginY), (fHitPosZ-fOriginZ), fOriginX, fOriginY, fOriginZ, RL_PlayerPos[0], RL_PlayerPos[1], RL_PlayerPos[2]);
				new str[256];
				format(str,256,"Aimdist:%.2f ID %i %im %ims",AimDist,pidas, floatround(ShotDistance),ShotDelay);

				SendClientMessage(PlayerSpectated[playerid],RED,str);
			}
			else
			{
				new str[256];
				format(str,256,"Aimdist:- %im %ims",floatround(ShotDistance),ShotDelay);

				SendClientMessage(PlayerSpectated[playerid],RED,str);
			}
		}
	}
	if(hittype == BULLET_HIT_TYPE_PLAYER && hitid != INVALID_PLAYER_ID)
	{

		if(!IsPlayerInAnyVehicle(playerid))
		{
			switch(weaponid)
			{
				case 27, 23, 25, 29, 30, 31, 33, 24, 38:
				{
					if(CheckSpeed(playerid))
					{
						if(gettime() - LastInfractionTime[playerid] >= AUTOBULLET_RESET_DELAY) AutoBulletInfractions[playerid] = 1;
						else AutoBulletInfractions[playerid]++;
						LastInfractionTime[playerid] = gettime();

						if(AutoBulletInfractions[playerid] == MAX_AUTOBULLET_INFRACTIONS)
						{
							AutoBulletInfractions[playerid] = 0;
							AC_Warn(playerid,"Auto bullet");
						}
					}
				}
			}
		}

		new Float:ac_oX, Float:ac_oY, Float:ac_oZ, Float:ac_hX, Float:ac_hY, Float:ac_hZ;
        GetPlayerLastShotVectors(playerid, ac_oX, ac_oY, ac_oZ, ac_hX, ac_hY, ac_hZ);

        // AFK GHOST
        new Float:ac_dist = GetPlayerDistanceFromPoint(playerid, ac_oX, ac_oY, ac_oZ);
        if(ac_dist > 50.0 || ac_dist > 15.0 && !IsPlayerInAnyVehicle(playerid) &&
        !IsVehicleStreamedIn(GetPlayerSurfingVehicleID(playerid), playerid) &&
        GetPlayerSurfingObjectID(playerid) == INVALID_OBJECT_ID)
        {
        	afkghost_warn[playerid]++;
            if(afkghost_warn[playerid] > 2)
            {
                afkghost_warn[playerid]=0;
                AC_Warn(playerid, "AFK GHOST");
            }

        }
        else afkghost_warn[playerid]=0;

        // SILENT AIM

        new Float:ac_pX, Float:ac_pY, Float:ac_pZ;
        GetPlayerPos(playerid, ac_pX, ac_pY, ac_pZ);
        if(fX == 0.0 && fY == 0.0 && fZ == 0.0 || ac_oX == ac_hX && ac_oY == ac_hY ||
        ac_oX == ac_pX || ac_oY == ac_pY || floatabs(ac_oZ - ac_pZ) < 0.01)
        {
        	silentaim_warn[playerid]++;
            if(silentaim_warn[playerid] > 2)
            {
                silentaim_warn[playerid]=0;
                AC_Warn(playerid,"Silent AIM");
            }
        }
        else
        {
            silentaim_warn[playerid] = 0;

            // PRO AIM


            if(!playerDB[hitid][mire] && !NoCheckTP[hitid] &&
            tick < PlayerTick[hitid] + 1500)
            {
                ac_dist = GetPlayerDistanceFromPoint(hitid, ac_hX, ac_hY, ac_hZ);
                if(ac_dist > 50.0 || ac_dist > 5.0 && !IsPlayerInAnyVehicle(hitid) &&
                !IsVehicleStreamedIn(GetPlayerSurfingVehicleID(hitid), hitid) &&
                GetPlayerSurfingObjectID(hitid) == INVALID_OBJECT_ID)
                {
                	proaim_warn[playerid] ++;
                    if(proaim_warn[playerid] > 2)
                    {
                    	AC_Warn(playerid,"Pro AIM");
                        proaim_warn[playerid] = 0;
                    }

                }
                else proaim_warn[playerid] = 0;
                /*new msgaz[128];
                format(msgaz,128,"%.2f",ac_dist);
                SendClientMessage(playerid, hitid, msgaz);*/
            }
        }

		// SHIFT AIM
		new Keys[3];
		GetPlayerKeys(playerid, Keys[0], Keys[1], Keys[2]);
	    if(Keys[0] & KEY_JUMP && Keys[0] & KEY_HANDBRAKE) // key_aim
	    {
	    	shiftaim_warn[playerid]++;
	    	if(shiftaim_warn[playerid] >= 2)
	    	{
	    		AC_Warn(playerid,"Shift AIM");
	    	}

	    }
	    else
	    {
	    	shiftaim_warn[playerid]=0;
	    }




		//if(IsPlayerAfkExEx(playerid,Lrapid_oldticks[playerid])) return AC_Warn(playerid,"AFK Ghost");
		
		if(SafeArea(hitid) || SafeArea(playerid) || Invul[hitid])
		{
			if(SafeArea(playerid))
			{
				SetPlayerArmedWeapon(playerid, 0);
				SendInfoMessage(playerid,"~y~Sioje vietoje negalima naudotis ginklais");
			}
			return 0;
		}
		if(playerDB[hitid][ant] || playerDB[hitid][suristas] || Bomzauja[hitid] || playerDB[hitid][pila])
		{
			//if(playerDB[playerid][specialybe]!=80 && playerDB[playerid][specialybe] != 82 && playerDB[playerid][specialybe] != 84 && playerDB[playerid][specialybe]!=81 && playerDB[playerid][specialybe]!=83 )
			return 0;
		}
		if(playerDB[playerid][psratasvydis] && playerDB[playerid][psratasvydis]==playerDB[hitid][psratasvydis] && DuelKova[playerid] == -1) return 0;
		if(DEBUG==true && PlayerSpectated[hitid] != -1)
		{
			SendClientMessage(PlayerSpectated[hitid],ORANGE," * Damage done *");
		}
	}
	return returnas;
}
