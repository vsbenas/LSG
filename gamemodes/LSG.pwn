			return 1;
		}
		else if(newkeys & KEY_SECONDARY_ATTACK)
		{
			RemovePlayerAttachedObject(playerid, SALMO_SLOT);
			playerDB[playerid][issirinkoak]=0;
			GameTextForPlayer(playerid," ",3000,3);
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			SendInfoMessage(playerid,"Uzsukite kita karta!");
			return 1;
		}	
	}
	else if(playerDB[playerid][aksesuaras] == 3)
	{
		new skinid=GetPlayerSkin(playerid);

		SetPlayerAttachedObject(playerid, CAP_SLOT, Kepures[playerDB[playerid][issirinkoak]-1], 2, SkinCapsSet[skinid][0], SkinCapsSet[skinid][1],SkinCapsSet[skinid][2], SkinCapsSet[skinid][3], SkinCapsSet[skinid][4], SkinCapsSet[skinid][5]);

		
		//static Kepures[] = {18926,18927,18928,18929,18930,18931,18932,18933,18934,18935,18936,19099,19098,18939,18939,18940,18941,18942,18943,18944};19036
		if(newkeys & KEY_FIRE)
		{
			playerDB[playerid][issirinkoak]++;
			if(playerDB[playerid][issirinkoak]==13)
			{
				playerDB[playerid][issirinkoak]=1;
			}
			
			SetPlayerAttachedObject(playerid, CAP_SLOT, Kepures[playerDB[playerid][issirinkoak]-1], 2, SkinCapsSet[skinid][0], SkinCapsSet[skinid][1],SkinCapsSet[skinid][2], SkinCapsSet[skinid][3], SkinCapsSet[skinid][4], SkinCapsSet[skinid][5]);
			return 1;
		}
		else if(newkeys & KEY_HANDBRAKE)
		{
			playerDB[playerid][issirinkoak]--;
			if(playerDB[playerid][issirinkoak]==0)
			{
				playerDB[playerid][issirinkoak]=12;
			}
			
			SetPlayerAttachedObject(playerid, CAP_SLOT, Kepures[playerDB[playerid][issirinkoak]-1], 2, SkinCapsSet[skinid][0], SkinCapsSet[skinid][1],SkinCapsSet[skinid][2], SkinCapsSet[skinid][3], SkinCapsSet[skinid][4], SkinCapsSet[skinid][5]);
			return 1;
		}
		else if(newkeys & KEY_SPRINT)
		{
			if(GetPlayerMoneyA(playerid) < COST_KEPURES) return SendInfoMessage(playerid,"~r~Neuztenka pinigu!");
			playerDB[playerid][kepure]=playerDB[playerid][issirinkoak];
			BitFlag_On(PConfig[playerid],PCFG_KEPURE);
			playerDB[playerid][issirinkoak]=0;
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			GameTextForPlayer(playerid," ",3000,3);
			SendInfoMessage(playerid,"Gero nesiojimo!");
			GivePlayerMoneyA(playerid, -COST_KEPURES);
			ActorServe(playerid); BusinessMoney(COST_KEPURES);
			return 1;
		}
		else if(newkeys & KEY_SECONDARY_ATTACK)
		{
			if(playerDB[playerid][kepure])
			{
				if(!AttachKepure(playerid,skinid))
					return SendInfoMessage(playerid,"~r~Negali uzsideti kepures ant sio skino!");
			}
			else RemovePlayerAttachedObject(playerid, CAP_SLOT);
			playerDB[playerid][issirinkoak]=0;
			GameTextForPlayer(playerid," ",3000,3);
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			SendInfoMessage(playerid,"Uzsukite kita karta!");
			return 1;
		}	
		
	}
	else if(playerDB[playerid][aksesuaras] == 4) // skinas
	{
		SetPlayerSkin(playerid,Shopas[playerDB[playerid][issirinkoak]-1]);
		if(newkeys & KEY_FIRE)
		{
			playerDB[playerid][issirinkoak]++;
			if(playerDB[playerid][issirinkoak]==Skinu+1)
			{
				playerDB[playerid][issirinkoak]=1;
			}
			
			SetPlayerSkin(playerid,Shopas[playerDB[playerid][issirinkoak]-1]);
			return 1;
		}
		else if(newkeys & KEY_HANDBRAKE)
		{
			playerDB[playerid][issirinkoak]--;
			if(playerDB[playerid][issirinkoak]==0)
			{
				playerDB[playerid][issirinkoak]=Skinu;
			}
			
			SetPlayerSkin(playerid,Shopas[playerDB[playerid][issirinkoak]-1]);
			return 1;
		}
		else if(newkeys & KEY_SPRINT)
		{
			if(GetPlayerMoneyA(playerid) < COST_SKINAS) return SendInfoMessage(playerid,"~r~Neuztenka pinigu!");
			playerDB[playerid][drabuziai]=Shopas[playerDB[playerid][issirinkoak]-1];
			playerDB[playerid][issirinkoak]=0;
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			GameTextForPlayer(playerid," ",3000,3);
			SendInfoMessage(playerid,"Gero nesiojimo!");
			GivePlayerMoneyA(playerid, -COST_SKINAS);
			ActorServe(playerid); BusinessMoney(COST_SKINAS);
			return 1;
		}
		else if(newkeys & KEY_SECONDARY_ATTACK)
		{
			SetPlayerSkin(playerid,playerDB[playerid][paskutinisrubas]);
			playerDB[playerid][issirinkoak]=0;
			GameTextForPlayer(playerid," ",3000,3);
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			SendInfoMessage(playerid,"Uzsukite kita karta!");
			return 1;
		}	
	
	}
	else if(playerDB[playerid][aksesuaras] == 5) // skinas
	{
		SetPlayerSkin(playerid,Shopassex[playerDB[playerid][issirinkoak]-1]);
		if(newkeys & KEY_FIRE)
		{
			playerDB[playerid][issirinkoak]++;
			if(playerDB[playerid][issirinkoak]==Skinusex+1)
			{
				playerDB[playerid][issirinkoak]=1;
			}
			
			SetPlayerSkin(playerid,Shopassex[playerDB[playerid][issirinkoak]-1]);
			return 1;
		}
		else if(newkeys & KEY_HANDBRAKE)
		{
			playerDB[playerid][issirinkoak]--;
			if(playerDB[playerid][issirinkoak]==0)
			{
				playerDB[playerid][issirinkoak]=Skinusex;
			}
			
			SetPlayerSkin(playerid,Shopassex[playerDB[playerid][issirinkoak]-1]);
			return 1;
		}
		else if(newkeys & KEY_SPRINT)
		{
			if(GetPlayerMoneyA(playerid) < COST_SKINAS) return SendInfoMessage(playerid,"~r~Neuztenka pinigu!");
			playerDB[playerid][drabuziai]=Shopassex[playerDB[playerid][issirinkoak]-1];
			playerDB[playerid][issirinkoak]=0;
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			GameTextForPlayer(playerid," ",3000,3);
			SendInfoMessage(playerid,"Gero nesiojimo!");
			GivePlayerMoneyA(playerid, -COST_SKINAS);
			ActorServe(playerid); BusinessMoney(COST_SKINAS);
			return 1;
		}
		else if(newkeys & KEY_SECONDARY_ATTACK)
		{
			SetPlayerSkin(playerid,playerDB[playerid][paskutinisrubas]);
			playerDB[playerid][issirinkoak]=0;
			GameTextForPlayer(playerid," ",3000,3);
			TogglePlayerControllable(playerid,true);
			SetCameraBehindPlayer(playerid);
			SendInfoMessage(playerid,"Uzsukite kita karta!");
			return 1;
		}	
	
	}
	else return SendClientMessage(playerid,COLOR," * KLAIDA!");
	return 1;
}
forward CheckWalk(playerid);
public CheckWalk(playerid) 
{
	new keys,lr,ud;
	GetPlayerKeys(playerid,keys,ud,lr);
	if(keys & KEY_WALK && !Jumped[playerid])
	{
		Iter_Add(PlayersWalking,playerid);
		ApplyAnimation(playerid,"PED",GetAnimNameForWalk(playerDB[playerid][wstyle]),4.1,1,1,1,1,1);
		PlayerWalking[playerid]=1;
	}
}
new LastSpygliai[MAX_PLAYERS];
new LastKeyPress[MAX_PLAYERS];
//new dazuarray[10000];

new PlayerAiming[MAX_PLAYERS];

public OnPlayerKeyStateChange(playerid, newkeys, oldkeys)
{
	if(DEBUG == true)
		printf("OnPlayerKeyStateChange: %i,%i",playerid,newkeys);
	if(playerDB[playerid][authstate]==0) return 1;
	HandleChristmasKeyPress(playerid, newkeys, oldkeys);

	if(gPlayerDialog[playerid]!= -1) return 1;
	//PoolKeyStateChange(playerid, newkeys, oldkeys);
	if(newkeys & KEY_HANDBRAKE)
	{
		PlayerAiming[playerid] = 1;
	}
	else
	{
		PlayerAiming[playerid] = 0;
	}

	new tix = GetTickCount();
	PlayerAfk2[playerid]=tix;
	new State = GetPlayerState(playerid);
	
	if(GetPlace(playerid) == PLACE_FULE)
	{
		ProcessFule(playerid,newkeys,oldkeys);
	}
	else
	{
		if(((newkeys & KEY_WALK) && ((oldkeys & KEY_UP || oldkeys & KEY_DOWN || oldkeys & KEY_LEFT || oldkeys & KEY_RIGHT) || (newkeys & KEY_UP || newkeys & KEY_DOWN || newkeys & KEY_LEFT || newkeys & KEY_RIGHT)))||((oldkeys & KEY_WALK) && (newkeys & KEY_UP || newkeys & KEY_DOWN || newkeys & KEY_LEFT || newkeys & KEY_RIGHT)))
			if(State==PLAYER_STATE_ONFOOT && !Jumped[playerid] && !JumpStatus[playerid] && !(oldkeys & KEY_FIRE) && !(oldkeys & KEY_HANDBRAKE) && !(newkeys & KEY_FIRE) && !(newkeys & KEY_HANDBRAKE) && !(oldkeys & KEY_JUMP) && !(newkeys & KEY_JUMP))
			{
				SetTimerEx("CheckWalk",250,false,"i",playerid);
			}
	}
	
	if(GetPVarInt(playerid, "dazymas"))
	{
		new place = GetPlace(playerid);
		if(place != PLACE_HOUSE && place != PLACE_WORLD)
		{
			SetPVarInt(playerid, "dazymas", 0);
			return 1;
		}
		new idas;
		if(newkeys & KEY_YES)
		{
			idas = (GetPVarInt(playerid, "dazymas")+1 ) % NUM_TEXTURES;
			if(!idas)
				idas++;

		}
		else if(newkeys & KEY_NO)
		{
			idas = GetPVarInt(playerid, "dazymas")-1;
			if(!idas)
				idas = NUM_TEXTURES-1;
		}
		else if(newkeys & KEY_SECONDARY_ATTACK)
		{

			SendClientMessage(playerid, -1, " * Iđsaugojai!");
			//dazuarray[GetPVarInt(playerid, "dazymas")]=1;

			//GoodTextures[GetPVarInt(playerid, "dazymas")]=0;

			if(place == PLACE_HOUSE)
			{
				SaveTexture(GetPlayerHouseID(playerid),GetPVarInt(playerid, "isdoor"),GetPVarInt(playerid, "matid"),GoodTextures[GetPVarInt(playerid, "dazymas")]);
				SetTimerEx("StupidDelay", 1000, false, "ii", playerid,1);
			}
			else
			{
				SetTimerEx("SaveWorldTexture", 1000, false, "ii", playerid);
			}
			SetPVarInt(playerid, "dazymas", 0);
			return 1;
		}
		else
			return 1;
		SetPVarInt(playerid, "dazymas", idas);

		new str[24];
		format(str,24,"~g~%i",GetPVarInt(playerid, "dazymas"));
		GameTextForPlayer(playerid, str, 1000, 3);
		if(place == PLACE_HOUSE)
			Texturize(GetPlayerHouseID(playerid),GetPVarInt(playerid, "isdoor"),GetPVarInt(playerid, "matid"),GoodTextures[GetPVarInt(playerid, "dazymas")]);
		else
			TexturizeWorldObject(playerid, GetPVarInt(playerid, "SelectedObj"), GetPVarInt(playerid, "matid"), GoodTextures[GetPVarInt(playerid, "dazymas")]);
		return 1;
	}

	if(State == PLAYER_STATE_ONFOOT)
	{
		if(newkeys & KEY_FIRE)
		{
			if(playerDB[playerid][pucia])
			{
				SetTimerEx("Putimas", 3000, 0, "i", playerid);
				playerDB[playerid][pucia]=false;
			}
			if(playerDB[playerid][ruko])
			{
				if(!galikast[playerid]) return 1;
				galikast[playerid]=false;
				SetTimerEx("GaliKast",3000, 0, "i", playerid);
				SetTimerEx("Rukymas", 3000, 0, "i", playerid);
				playerDB[playerid][ruko]++;
			}
			/*if(GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_DUCK)
			{
				ClearAnimations(playerid);
				//SendClientMessage(playerid,RED," * Slidebug draudziamas!");
			}*/
		}
		switch (GetPlayerWeapon (playerid))
		{
			case 24, 25, 27, 29, 30, 31, 33, 34: //Deagle, Shotung, SPAS12, MP5, AK47, M4, Rifle, Sniper Rifle
			{

				if (newkeys & KEY_FIRE)
					CBugShot[playerid] = tix; // ((oldkeys & KEY_FIRE) || (oldkeys == KEY_FIRE)) && 
				else if (newkeys & KEY_CROUCH && (GetTickCount () - CBugShot[playerid]) < 500 && !IsCbugEnabled(playerid))
				{
					CBugWarnings[playerid]++;
					if (CBugWarnings[playerid] > 12)
					{
						AC_Kick(playerid,"C-Bug",1);
						return 1;
					}
					if (CBugWarnings[playerid] > 10)
					{
						SendClientMessage (playerid, COLOR_GREEN, " * LSG Anti-Cheat: Prasome nenaudoti CBug, nes gausite kick/ban.");
					}
					/*if(CBugWarnings[playerid] == 5 || CBugWarnings[playerid] == 9)
					{
						AC_Warn(playerid,"C-Bug");
					}*/
					ApplyAnimation( playerid, "PED", "XPRESSscratch", 0.0, 1, 0, 0, 0, 1000, 1 );
				}
			}
			
		}
	
	
	}
	if(newkeys & KEY_FIRE && newkeys & KEY_HANDBRAKE)
	{
		if(State == PLAYER_STATE_DRIVER)
		{
			new vehicleid = GetPlayerVehicleID(playerid);
			if(vehicleDB[vehicleid][uzvedineja]) return 1;
			if(IsPlayerInWorld(playerid)) return 1; // annoying with infinite nos
			new Float:HP;
			GetVehicleHealth(vehicleid,HP);
			if(HP <= 249.9) return 1;
			GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
			new v=vehicleid;
			new modelis = GetVehicleModel(v);
			if(	VehVars[0] && modelis != 509 && modelis != 510 && modelis != 481)
			{
				if(playerDB[playerid][ant] || playerDB[playerid][suristas]) return 1;
				SetTimerEx("Isjungimas",random(1000),false,"ii",vehicleid,playerid);
				SendInfoMessage(playerid,"~r~Isjungineji~w~ masinos varikli...");
				vehicleDB[vehicleid][uzvedineja]=true;
			}
			return 1;
		}

		
	}

	if(newkeys & KEY_ACTION && gPlayerUsingLoopingAnim[playerid])
	{
	    StopLoopingAnim(playerid);
        TextDrawHideForPlayer(playerid,txtAnimHelper);
        return 1;
	}
	else if(newkeys & KEY_ACTION && newkeys & KEY_HANDBRAKE)
	{
	    if((IsPlayerInRangeOfPointEx(100.0,playerid,1153.8246,-1333.6903,1387.0516) || IsPlayerInRangeOfPointEx(100.0,playerid,-204.5060,-1736.0486,676.2687)) && !playerDB[playerid][mire])
		{
			
			if(GetPlayerInterior(playerid)==2)
				SetPlayerPoz(playerid,625.8730,-522.9231,16.4344, 0, _, 0),SetPlayerFacingAngle(playerid,183.3564);
			else if(GetPlayerInterior(playerid)==3)
				SetPlayerPoz(playerid,2034.3160,-1402.1576,17.2962, 0, _, 0),SetPlayerFacingAngle(playerid,183.3564);
			else
				SetPlayerPoz(playerid,1172.8071,-1323.3739,15.4004, 0, _, 0),SetPlayerFacingAngle(playerid,274.5);
			SetCameraBehindPlayer(playerid);
			ApplyAnimation(playerid,"PED","EV_dive",4.0,0,1,1,0,0,1);
			SendInfoMessage(playerid,"~r~Ligonines personalas jus ismete lauk.");
			return 1;
		}
		/*else if(IsPlayerInRangeOfPointEx(100.0,playerid,2234.7390,1656.4895,1008.8934) && !playerDB[playerid][mire] && GetPlayerInterior(playerid) == 1)
		{
			new Float:coo[3];
			GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
			if(coo[2]>1004)
			{
				SetPlayerPoz(playerid,982.1033,-1157.5350,23.8605),SetPlayerFacingAngle(playerid,3.3564);
				SetPlayerInterior(playerid,0);
				ApplyAnimation(playerid,"PED","EV_dive",4.0,0,1,1,0,0,1);
				SendInfoMessage(playerid,"~r~Kazino personalas jus ismete lauk.");
			}
			return 1;
		}*/
	}
	else if(newkeys & KEY_FIRE)
	{
		
		if(ParaStatus[playerid])
		{
			new Float:Coo[3];
			GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
			if(Coo[2] > 100.0)
				ProcessAchievement(playerid,59);
		}
		if(!IsPlayerInAnyVehicle(playerid) && PRESSED(KEY_FIRE))
		{
			if(GetPVarInt(playerid, "Gniuzte")  == 2)
			{
				ApplyAnimation(playerid, "GRENADE", "WEAPON_throw", 4.1, 0, 1, 1, 0, 0,1);
				new Float:x, Float:y, Float:z;
				GetPlayerPos(playerid, x, y, z);
				GetXYInFrontOfPlayer(playerid, x, y, 0.5);

				new obj = CreateObject(1974, x, y, z+0.1, 0,0,0);
				new Float:a;
				GetPlayerFacingAngle(playerid, a);

				new Float:sin = floatsin( -a, degrees );
				new Float:cos = floatcos( -a, degrees );

				new speed = 20;
				new GRAVITY = 10;
				PHY_InitObject(obj);
				PHY_SetObjectVelocity(obj, speed*sin, speed*cos,4);
				GniuztePlayer[obj] = playerid;
				//PHY_SetObjectGhost(obj);
				PHY_SetObjectFriction(obj, 100); // This will stop the object when it touchs the ground.
				PHY_SetObjectGravity(obj, GRAVITY);
				PHY_SetObjectZBound(obj,10.0, _, 0.0);
				PHY_ToggleObjectPlayerColls(obj, 1, 0.0, 1.0,1.0, 1.0);
				RemovePlayerAttachedObject(playerid, SLOT_KROVINYS);
				SetPVarInt(playerid, "Gniuzte", 0);
			}
			else if(GetPVarInt(playerid,"Gniuzte") == 0) 
			{
				new specAction = GetPlayerSpecialAction(playerid);
				if(specAction < 2 && SafeArea(playerid) == 24 && !playerDB[playerid][ant] && !playerDB[playerid][suristas]) // 
				{
					ApplyAnimation(playerid, "BOMBER", "BOM_Plant", 4.0, 0, 0, 0, 0, 0); // Bomb Plant Animation
					SetPVarInt(playerid, "Gniuzte", 1);
					SetTimerEx("Gniuzte", 1500, false, "i", playerid);
				}
			}
			if(IsPlayerAttachedObjectSlotUsed(playerid, SLOT_LAGAMINAS))
			{
				RemovePlayerAttachedObject(playerid, SLOT_LAGAMINAS);
				for(new i;i<10;i++)
				{
					playerDB[playerid][pastas][i]=0;
				}
				SendInfoMessage(playerid,"Ismetei laiskus!");
			}
		 	if(playerDB[playerid][zvejoja])
			{
			    if(playerDB[playerid][kimba])
			    {
			        playerDB[playerid][kimba]=false;
			        ApplyAnimation(playerid, "BASEBALL", "Bat_IDLE", 4.000000, 0, 0, 0, 0, -1);
			        SetTimerEx("ZvejybosAnim", 1000, false, "i",playerid);
			        return 1;
			    }
				SendInfoMessage(playerid,"Istraukei meskere!");
			   	playerDB[playerid][zvejoja]=false;
			   	ClearAnimations(playerid);
			}
		    new weapon = GetPlayerWeapon(playerid);

			/*if(playerDB[playerid][pucia])
			{
				SetTimerEx("Putimas", 3000, 0, "i", playerid);
				playerDB[playerid][pucia]=false;
				return 1;
			}
			if(playerDB[playerid][ruko])
			{
				if(!galikast[playerid]) return 1;
				galikast[playerid]=false;
				SetTimerEx("GaliKast",3000, 0, "i", playerid);
				SetTimerEx("Rukymas", 3000, 0, "i", playerid);
				playerDB[playerid][ruko]++;

				return 1;
			}*/
			if(IsPlayerAttachedObjectSlotUsed(playerid,TAZER_SLOT) && weapon < 2)
		    {
				
		    	ApplyAnimation(playerid,"KNIFE","knife_3",4.1,0,1,1,0,0,1);
				
			    new victimida = GetClosestPlayer(playerid);
				
			    new Float:Coo[3];
			    GetPlayerPos(victimida,Coo[0],Coo[1],Coo[2]);
	        	if(IsPlayerInRangeOfPointEx(2.5,playerid,Coo[0],Coo[1],Coo[2]) && !IsPlayerInAnyVehicle(victimida) && GetPlayerTargetPlayer(playerid) == victimida)
	            {
	            	new Float:health;
	                GetPlayerHealth(victimida, health);
	                SetPlayerHealth(victimida, health - 1.0);
	                SetTimerEx("TimerFall",300,false,"d",victimida);
	                return 1;
	             }
			}
	    	if((IsPlayerInRangeOfPointEx(100,playerid,1153.8246,-1333.6903,1387.0516) || IsPlayerInRangeOfPointEx(100.0,playerid,-204.5060,-1736.0486,676.2687)) && !playerDB[playerid][mire])
			{

				if(GetPlayerInterior(playerid)==2)
					SetPlayerPoz(playerid,625.8730,-522.9231,16.4344, 0, _, 0),SetPlayerFacingAngle(playerid,183.3564);
				else if(GetPlayerInterior(playerid)==3)
					SetPlayerPoz(playerid,2034.3160,-1402.1576,17.2962, 0, _, 0),SetPlayerFacingAngle(playerid,183.3564);
				else
					SetPlayerPoz(playerid,1172.8071,-1323.3739,15.4004, 0, _, 0),SetPlayerFacingAngle(playerid,274.5);
				//SetPlayerPoz(playerid,1172.8071,-1323.3739,15.4004);
				SetCameraBehindPlayer(playerid);
				ApplyAnimation(playerid,"PED","EV_dive",4.0,0,1,1,0,0,1);
				SendInfoMessage(playerid,"~r~Ligonines personalas jus ismete lauk.");
				return 1;
			}
			/*else if(IsPlayerInRangeOfPointEx(100.0,playerid,2234.7390,1656.4895,1008.8934) && !playerDB[playerid][mire] && GetPlayerInterior(playerid) == 1)
			{
				new Float:coo[3];
				GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
				if(coo[2]>1004)
				{
					SetPlayerPoz(playerid,982.1033,-1157.5350,23.8605),SetPlayerFacingAngle(playerid,3.3564);
					SetPlayerInterior(playerid,0);
					ApplyAnimation(playerid,"PED","EV_dive",4.0,0,1,1,0,0,1);
					SendInfoMessage(playerid,"~r~Kazino personalas jus ismete lauk.");
					return 1;
				}
			}*/
			
		}
		else if(IsPlayerInAnyVehicle(playerid))
		{
			if(playerDB[playerid][ruko])
			{
				if(!galikast[playerid]) return 1;
				galikast[playerid]=false;
				SetTimerEx("GaliKast",3000, 0, "i", playerid);
				SetTimerEx("Rukymas", 3000, 0, "i", playerid);
				playerDB[playerid][ruko]++;
			}
			if(playerDB[playerid][pucia])
			{
				SetTimerEx("Putimas", 3000, 0, "i", playerid);
				playerDB[playerid][pucia]=false;
			}
			if(GetPlayerState(playerid) != PLAYER_STATE_DRIVER) return 1;
			new vehicleid = GetPlayerVehicleID(playerid);
			if(vehicleDB[vehicleid][uzvedineja]) return 1;
			new v=vehicleid;
			GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
			new modelis = GetVehicleModel(v);
			if(	!VehVars[0] && (!IsVagiuCar(v) || vagia[playerid]) && modelis != 509 && modelis != 510 && modelis != 481 && IsAutohausCar(v) == -1)
			{
				if(playerDB[playerid][ant] || playerDB[playerid][suristas]) return 1;
				if(JobCars[vehicleid][0]) return 1;
				if(vehicleDB[vehicleid][rankinis]) return SendInfoMessage(playerid,"Rankinis stabdis uztrauktas! Spausk [SPACE], kad ji atleistum!");
				SetTimerEx("Uzvedimas",floatround((2000+random(5000))/AdjustByRida(vehicleid,RIDA_UZVEDIMAS)),false,"ii",vehicleid,playerid);
				SendInfoMessage(playerid,"~g~Uzvedineji~w~ masinos varikli...");
				vehicleDB[vehicleid][uzvedineja]=true;
				return 1;
			}
			else if(VehVars[0] && VehicleNitro[vehicleid])
			{
				if(GetTickCount() - LastNitro[vehicleid] > AdjustByRida(vehicleid,RIDA_NITRO)*1000) 
				{
					//SendClientMessage(playerid, -1, "Adding nitro!");
					AddVehicleComponent(vehicleid, 1010);
					LastNitro[vehicleid]=GetTickCount();
				}
			}
			if(modelis == 407 && !Gesino[playerid])
			{
			    new vehicleidz = GetClosestVehicleid(playerid,999.99,GetPlayerVehicleID(playerid));
				if(IsPlayerInRangeOfPointEx(30.0,playerid,FireDB[fCoo][0],FireDB[fCoo][1],FireDB[fCoo][2]) && FireDB[fVW] == GetPlayerVirtualWorld(playerid))
				{
					Gesino[playerid]=true;
					Gesinimaz[playerid]= SetTimerEx("Gesinimas2",100,true,"i",playerid);
					return 1;
				}
				if (vehicleidz == INVALID_VEHICLE_ID) return 1;
				Gesino[playerid]=true;
				SprayProg[playerid]=0;
				Gesinimaz[playerid]= SetTimerEx("Gesinimas",100,true,"ii",vehicleidz,playerid);
				return 1;
			}
		}
    	
	}
	else if (RELEASED( KEY_FIRE ))
	{
		if(Gesino[playerid])
		{
			Gesino[playerid]=false;
			KillTimer(Gesinimaz[playerid]);
			Gesinimaz[playerid]=-1;
			HideProgressBarForPlayer(playerid,Veiksmai);
			EndVeiksmas(playerid);
			return 1;
		}
	}
	if(RELEASED( KEY_SECONDARY_ATTACK))
	{
		if(KvieciaLifta(playerid))
		{
			Stop(playerid);
			return 1;
		}
	}
	if (newkeys & KEY_SECONDARY_ATTACK)
	{
		if(playerDB[playerid][pucia] || playerDB[playerid][ruko])
		{
			playerDB[playerid][ruko]=0;
			playerDB[playerid][pucia]=false;
			HideProgressBarForPlayer(playerid,Veiksmai);
			EndVeiksmas(playerid);
			
		}
		
		new lid = IsNearLastHouse(playerid);
		if(lid != -1) {
			EnterNamas(playerid,lid);
			return 1;
		}
		if(fs_balloon_pl[playerid][0] == 1)
		{
			new Float:Coo[3];
			GetObjectPos(fs_balloon_set[fs_balloon_pl[playerid][1]][0],Coo[0],Coo[1],Coo[2]);
			new Float:Zcord;
			MapAndreas_FindZ_For2DCoord(Coo[0],Coo[1],Zcord);
			new Float:height = Coo[2] - Zcord;
			new Float:Speedaz = Direction[playerid][0]*Direction[playerid][0] + Direction[playerid][1]*Direction[playerid][1];
			if(height < 10.0 && Speedaz < 1.0) 
			{
				fs_balloon_pl[playerid][0] = 3;
				ClearAnimations(playerid);
			}
			//SendClientMessage(playerid,-1," * Aciu kad naudojates balionu nuoma!");
		}
		else if(fs_balloon_pl[playerid][0] == 3) 
		{
			new id = fs_balloon_pl[playerid][1];
			new Float:Co[3];
			GetObjectPos(fs_balloon_set[id][0],Co[0],Co[1],Co[2]);
			if(IsPlayerInRangeOfPointEx(5.0, playerid, Co[0], Co[1], Co[2]))
			{
				fs_balloon_pl[playerid][0]=1;
				Iter_Add(PlayersFading,playerid);
				SetPlayerPos(playerid,Co[0],Co[1],Co[2]+1.0);
				SetPlayerFacingAngle(playerid, Direction[playerid][2]);
				ApplyAnimation(playerid, "ped", "DRIVE_BOAT", 4.0, 1, 0, 0, 0, 0);
			}

		}

	}
	if(newkeys & KEY_WALK)
	{
		new lid = IsNearLastHouse(playerid);
		if(lid != -1) {
			LockHouse(playerid,lid);
			return 1;
		}
		new world = GetPlayerVirtualWorld(playerid);
		if (0 < world < MAX_HOUSES)
		{
			if(IsPlayerInRangeOfPointEx(3.0, playerid, Inter[ hInfo[world][vidus] ][ IntX ],Inter[ hInfo[world][vidus] ][ IntY ],Inter[ hInfo[world][vidus] ][ IntZ ] ) )
			{
				LockHouse(playerid,world);
				return 1;
			}
			new vid = hInfo[world][vidus];
			if(IsPlayerInRangeOfPointEx(3.0, playerid, KiemoDurys[vid][0], KiemoDurys[vid][1], KiemoDurys[vid][2]) )
			{
				LockHouseKiemas(playerid,world);
				return 1;
			}

		}
		new Float:Coo[3];
		GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
		if(Carlist[playerid][Typ] != -1 && Carlist[playerid][Status]==1)
		{
			if(IsVehicleInRangeOfPoint(Carlist[playerid][Carid],3.0,Coo[0],Coo[1],Coo[2]))
			{
				LockVehicle(playerid,Carlist[playerid][Carid]);
			}
		}
		if(Carlist2[playerid][Typ] != -1 && Carlist2[playerid][Status]==1)
		{
			if(IsVehicleInRangeOfPoint(Carlist2[playerid][Carid],3.0,Coo[0],Coo[1],Coo[2]))
			{
				LockVehicle(playerid,Carlist2[playerid][Carid]);
			}
		}
		if(Carlist3[playerid][Typ] != -1 && Carlist3[playerid][Status]==1)
		{
			if(IsVehicleInRangeOfPoint(Carlist3[playerid][Carid],3.0,Coo[0],Coo[1],Coo[2]))
			{
				LockVehicle(playerid,Carlist3[playerid][Carid]);
			}
		}
	}
	if(newkeys & KEY_SUBMISSION)
	{
		new vehicleid = GetPlayerVehicleID(playerid);
		LockVehicle(playerid,vehicleid);
	}
	if(playerDB[playerid][issirinkoak])
	{
		RenkasiParduotuve(playerid,newkeys);
		return 1;
	}
	if(newkeys & KEY_SUBMISSION && newkeys & KEY_HANDBRAKE && State==PLAYER_STATE_DRIVER) return ShowPlayerDialog(playerid,1687,DIALOG_STYLE_LIST,"Automobilis","Variklis\nLempos\nKapotas\nBagazine\nRadija","Gerai","Iseit");


	/* 
		*************



			CRITICAL SECTION, ONLY EVERY 1 SEC
			
			

		************ 
	*/
	//if(!(newkeys & KEY_CROUCH || newkeys & KEY_)
	//printf("KEY 1");
	new const matcher = KEY_FIRE | KEY_CROUCH | KEY_YES | KEY_NO | KEY_CTRL_BACK | KEY_WALK | KEY_SUBMISSION | KEY_SECONDARY_ATTACK | KEY_ANALOG_UP | KEY_ANALOG_DOWN | KEY_ANALOG_LEFT | KEY_ANALOG_RIGHT;
	if(!(newkeys == KEY_HANDBRAKE && State == PLAYER_STATE_DRIVER || newkeys & matcher))
	{
		//SendClientMessage(playerid,-1,"No Match");
		return 1;
	}
	//printf("KEY 2 %i %i",tix,LastKeyPress[playerid]);
	if(tix - LastKeyPress[playerid] < 1000) 
	{
		//SendClientMessage(playerid,-1,"Nope");
		// do nothing
		return 1;
	}
	//printf("KEY 3");
	LastKeyPress[playerid] = tix;
	if(GetPVarInt(playerid, "choosingmat"))
	{
		new place = GetPlace(playerid);
		if(place != PLACE_HOUSE && place != PLACE_WORLD)
		{
			SetPVarInt(playerid, "choosingmat", 0);
			return 1;
		}
		
		new matid;
		if(newkeys & KEY_YES)
		{
			matid = (GetPVarInt(playerid, "matid") + 1) % 16;
		} 
		else if(newkeys & KEY_NO)
		{
			matid =  GetPVarInt(playerid, "matid")-1;
			if(matid < 0)
				matid = 15;
		}
		else if(newkeys & KEY_SECONDARY_ATTACK)
		{
			SetPVarInt(playerid, "choosingmat", 0);
			//if(!playerDB[playerid][ant] && !playerDB[playerid][suristas])
			//	TogglePlayerControllable(playerid, true);
			if(place == PLACE_HOUSE)
				SetTimerEx("StupidDelay", 1000, false, "ii", playerid,0);
			else
			{
				SetTimerEx("SelectedWorldMat", 1000, false, "i", playerid);
			}
			SendClientMessage(playerid, -1, " * Iđsirinkai!");
			return 1;
		}
		else
		{
			return 1;
		}
		new str[24];
		format(str,24,"~g~%i",matid+1);
		GameTextForPlayer(playerid, str, 1000, 3);
		new hid;

		//TogglePlayerControllable(playerid, false);
		if(place == PLACE_HOUSE)
		{
			hid = GetPlayerHouseID(playerid);
			if(GetPVarInt(playerid, "isdoor") == 0 && hInfo[hid][intobjid][GetPVarInt(playerid, "matid")] > 0)
				Texturize(hid,GetPVarInt(playerid, "isdoor"),GetPVarInt(playerid, "matid"),hInfo[hid][intobjid][GetPVarInt(playerid, "matid")]);
			else
				ResetTextures(hid,GetPVarInt(playerid, "isdoor"),GetPVarInt(playerid, "matid"),0, playerid);
		}
		else
		{
			SetWorldMatTexture(playerid, matid, GetPVarInt(playerid, "matid"));
		}
		SetPVarInt(playerid, "matid", matid);
		//GetDynamicObjectMaterial(STREAMER_TAG_OBJECT objectid, materialindex, modelid, txdname[], texturename[], materialcolor, maxtxdname = sizeof txdname, maxtexturename = sizeof texturename)


		if(place == PLACE_HOUSE)
		{
			Texturize(hid,GetPVarInt(playerid, "isdoor"),GetPVarInt(playerid, "matid"),8932);
		}

		return 1;

	}
	if(newkeys & KEY_CROUCH)
	{
		new vehza = GetPlayerVehicleID(playerid);
		if(vehza && GetPlayerState(playerid)==PLAYER_STATE_DRIVER)
		{
			//IsVehicleInRangeOfPoint
			if(IsVehicleInRangeOfPoint(vehza,5.0,2802.7490,-1416.8666,15.7901))
			{
				//printf("Lauke");
				SetVehiclePosFade(playerid,20,2799.3142,-1410.2111,-4.3838,0.0);	
			}
			else if(IsVehicleInRangeOfPoint(vehza,5.0,2799.3142,-1410.2111,-4.3838))
			{
				//printf("Viduj");
				SetVehiclePosFade(playerid,20,2802.7490,-1416.8666,15.7901,176.3079); // 62.7987,-1524.7314,5.2171
			}
			else if(IsVehicleInRangeOfPoint(vehza,5.0,34.4833,-1536.6711,5.2121)) // isore
			{
				if(GetPlayerMoneyA(playerid) < 50) return SendInfoMessage(playerid,"Truksta pinigu!");
				GivePlayerMoneyA(playerid, -50);
				RotateObject(pasienis,0,0,90);
				SetTimerEx("Varteliai",10000,0,"i",2);
				SendInfoMessage(playerid,"~g~Galite vaziuoti.");
			}
			else if(IsVehicleInRangeOfPoint(vehza,5.0,62.7987,-1524.7314,5.2171)) // vidus
			{
				if(GetPlayerMoneyA(playerid) < 50) return SendInfoMessage(playerid,"Truksta pinigu!");
				GivePlayerMoneyA(playerid, -50);
				RotateObject(pasienis2,0,0,90);
				SetTimerEx("Varteliai",10000,0,"i",3);
				SendInfoMessage(playerid,"~g~Galite vaziuoti.");
			}
			switch(GetVehicleModel(vehza))
			{
			    case 523,430,497,596,597,599,601,427,490,447,470,433,528,415:
				{
					if(80 <= playerDB[playerid][specialybe] <= 84 && PlayerCar[playerid] == vehza)
					{
						new Float:cpo[3];
						GetPlayerPos(playerid,cpo[0],cpo[1],cpo[2]);
						new msg[128];
						foreach (Player, i)
						{
							if(IsPlayerInRangeOfPointEx(15,i,cpo[0],cpo[1],cpo[2]) && i != playerid && GetPlayerState(i) != PLAYER_STATE_PASSENGER && GetPlayerState(i) != PLAYER_STATE_SPECTATING)
							{
								GameTextForPlayer(i,"~w~POLICIJA:~r~ Sustokite!",2000,0);
								//GameTextForPlayer(playerid,"~w~POLICIJA:~r~ Sustokite!",2000,0);
								format(msg,sizeof(msg)," * Ispejote %s sustoti.",ReturnName(i));
								SendClientMessage(playerid, TEXTCOL_RED, msg);
							}
							else if(IsPlayerInRangeOfPointEx(30,i,cpo[0],cpo[1],cpo[2]) && i != playerid && GetPlayerState(i) != PLAYER_STATE_PASSENGER && GetPlayerState(i) != PLAYER_STATE_SPECTATING)
							{
								//GameTextForPlayer(playerid,"~w~POLICIJA:~b~ Prasome pasitraukti i salikele!",2000,0);
								GameTextForPlayer(i,"~w~POLICIJA:~b~ Prasome pasitraukti i salikele!",2000,0);
								format(msg,sizeof(msg)," * Ispejote %s pasitraukti i salikele.",ReturnName(i));
								SendClientMessage(playerid, TEXTCOL_BLUE, msg);
							}
							
						}
					}
				}
			}
		}
		Area51Vartai(playerid);
		cmd_garazas(playerid,"");
		return 1;
	}
	// check gesintuvas and tags
	if(newkeys & KEY_FIRE)
	{
		new weapid = GetPlayerWeapon(playerid);
		if(weapid== 42 && !Gesino[playerid])
		{
			
			new vehicleid = GetClosestVehicleid(playerid);
			if(FireDB[inProgress] && IsPlayerInRangeOfPointEx(30.0,playerid,FireDB[fCoo][0],FireDB[fCoo][1],FireDB[fCoo][2]) && FireDB[fVW] == GetPlayerVirtualWorld(playerid))
			{
				Gesino[playerid]=true;
				//if(Gesinimaz[playerid]) KillTimer(Gesinimaz[playerid]);
				
				Gesinimaz[playerid]= SetTimerEx("Gesintuvas2",100,true,"i",playerid);
				return 1;
			}
			if (vehicleid == INVALID_VEHICLE_ID) return 1;
			Gesino[playerid]=true;
			//if(Gesinimaz[playerid]) KillTimer(Gesinimaz[playerid]);
			SprayProg[playerid]=0;
			Gesinimaz[playerid]= SetTimerEx("Gesintuvas",100,true,"ii",vehicleid,playerid);
			return 1;
		}
		else if(weapid== 41 && !Gesino[playerid])
		{
			
			if(playerDB[playerid][pgang] != -1)
			{
				new tagid = GetClosestTag(playerid,10.0);
				if(tagid != -1)
				{
					Gesino[playerid]=true;
					//if(Gesinimaz[playerid]) KillTimer(Gesinimaz[playerid]);
					Gesinimaz[playerid]= SetTimerEx("Spray",100,true,"ii",playerid,tagid);
					SprayProg[playerid]=0;
					SetProgressBarValue(Veiksmai, 0);
					SetProgressBarMaxValue(Veiksmai,100);
					ShowProgressBarForPlayer(playerid, Veiksmai);
					StartVeiksmas(playerid,"Piesi taga...");
				}
			}
			if(IsPlayerInRangeOfPoint(playerid, 20.0, 1174.0350,-2065.1187,69.0006))
			{
				new year,month,day;
				getdate(year, month, day);
				new hour,minute,second;
				gettime(hour, minute, second);
				if(month == 5 && day == 15 && hour < 16 && !IsPlayerAdmin(playerid))
				{
					return SendInfoMessage(playerid,"~r~Siena dar neatidaryta!");
				}
				else
				{
					Gesino[playerid]=true;
					//if(Gesinimaz[playerid]) KillTimer(Gesinimaz[playerid]);
