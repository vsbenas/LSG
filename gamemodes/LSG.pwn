stock SavePelnai()
{
	new query[128];
	for(new i;i<100;i++)
	{
		format(query,sizeof(query),"Update Pelnai Set Suma=%i WHERE ID=%i",pelnas[i],i);
		mysql_query(query);
	}
	return 1;
}
