stock IsPlayerInRangeOfPointExXY(Float:Range,playerid,Float:x,Float:y,Float:z)
{
	#pragma unused z
	new Float:C[3];
	GetPlayerPos(playerid,C[0],C[1],C[2]);
	return IsPlayerInRangeOfPointEx(Range,playerid,x,y,C[2]); // just xy
}
