	}
}


new Float:OF[3];
forward Shake(step);
public Shake(step)
{
	if(step == 0)
	{
		SetWeather(9);
		DropNuke();
	}
	else if(step == 200)
	{

		SetWeather(19);
	}
	else if(step == 500)
	{
		SetWeather(16);
		new day,month,year;
		getdate(year,month,day);
		/*if(helovynas == 0 && month == 10 && day == 31) 
        {
            CreateProps();
            helovynas = 1;
        }*/
	}
	else if(step == 700)
		SetWeather(19);
	else if(step == 1000)
	{
		//SendClientMessageToAll(ORANGE, "");
		
		SetWeather(20);
	}
	else if(step == 1050)
		SetWeather(16);
	else if(step == 1070)
	{
		SetWeather(19); // 32
		dabartinis=18;
	}
	if(step % 100 == 0 && step > 0 && step < 1000)
	{
		for(new i;i<3;i++)
		{
			new digits = step / 50;
			if(step > 500)
				digits = (1000-step) / 50;
			if(digits == 0) 
				digits++;
			OF[i] = random(digits)*0.6/100;
			if(random(2)==1)
				OF[i] = -OF[i];
		}
	}
	foreach(Player,playerid)
	{
		if(step < 500)
		{
			if(step %2 == 0)
				SetPlayerDrunkLevel(playerid, 0);
			else
				SetPlayerDrunkLevel(playerid,step*20);
		}
		else if(step < 1000)
		{
			new drunk = 1000 - step;
			if(step %2 == 0)
				SetPlayerDrunkLevel(playerid, 0);
			else
				SetPlayerDrunkLevel(playerid,drunk*20);
		}
		//if(step == 1100)
			//FadeOut(plyerid);
		new veh = GetPlayerVehicleID(playerid);
		new ran = random(5);
		new Float:V[3];
		
		
		if(!veh && step % 100 == 0 && step > 0 && step < 1000)
		{
			GetPlayerVelocity(playerid, V[0], V[1], V[2]);
			new switchas = random(3);
			if(switchas)
			{
				if(random(2) == 1)
					ran = -ran;
				V[switchas-1] += ran*1.0/10;

				SetPlayerVelocity(playerid, V[0], V[1], V[2]+0.1);
			}
		}
		if(veh && step < 1000)
		{

			if((floatabs(OF[0]) + floatabs(OF[1]) + floatabs(OF[2]))* (step % 100) / 100 > 0.05)
				SetVehicleAngularVelocity(veh, OF[0] * (step % 100) / 100 ,OF[1] * (step % 100) / 100 ,OF[2] * (step % 100) / 100 );
		}
	}

	if(step < 1100)
		SetTimerEx("Shake", 50, false, "i", step+1);
}
forward Halloween(stage);
public Halloween(stage)
{
	if(stage <= 1)
	{
		SendClientMessageToAll(ORANGE,"[PRANEĐIMAS] Dëmesio! Los Sanos mieste iđmatuotas didelis seisminis aktyvumas! Laukite daugiau ţiniř!");
		//SendRconCommand("hostname Los Santos Gyvenimas [HELOVYNAS]");
	}
	else if(stage == 2)
	{
		SendClientMessageToAll(ORANGE, "[PRANEĐIMAS] Los Santos miestui gresia stiprus ţemës drebëjimas! Laikas kol kas neţinomas...");
	}
	else if(stage == 3 || stage == 4)
	{
		SendClientMessageToAll(ORANGE, "[PRANEĐIMAS] Los Santos miestui gresia stiprus ţemës drebëjimas! Numatomas laikas: spalio 31 d. 17:30.");
	}
	else if(stage == 5)
	{
		SendClientMessageToAll(ORANGE, "[PRANEĐIMAS] Los Santos seismografuose matomas ne tik ţemës drebëjimas, bet ir simboliai: A P O K A L I P S Ë. Numatomas laikas: 17:30");
	}
	else if(stage == 6)
	{
		SendClientMessageToAll(ORANGE, "[PRANEĐIMAS] Jaučiami pirmieji ţemës drebëjimo poţymiai. Mieste skelbiama pavojaus bűsena. Saugokite savo turtŕ. Numatomas laikas: 17:30");
		foreach(Player, i)
		{
			SetPlayerDrunkLevel(i,3000);
		}
	}
	else if(stage == 7)
	{
		SendClientMessageToAll(ORANGE, "[PRANEĐIMAS] Los Santos mieste vyksta stiprus ţemës drebëjimas! Saugokite savo automobilius!");
		Shake(0);
	}
	/*else if(stage >= 8 && stage <= 12)
	{
		if(stage == 8 && helovynas == 0)
			CreateProps();
		SendClientMessageToAll(ORANGE, "[HELOVYNO EVENTAS] LOS SANTOS MIESTE - APOKALIPSË!");
		helovynas = 1;
		//SendRconCommand("hostname Los Santos Gyvenimas [HELOVYNAS]");
	}
	else if(stage == 13)
	{
		SendClientMessageToAll(ORANGE, "[HELOVYNO EVENTAS] Los Santos miestas gráţta á normaliŕ padëtá! (sunaikinti pastatai atsiras po relog)");
		helovynas = 0;
		DestroyProps();
		//SendRconCommand("hostname Los Santos Gyvenimas");
		SetWeather(0);
	}*/
}


stock GetFreeBaldaiSlots(hid)
{
	new count = 0;
	for(new i;i<MAX_BALDAI;i++)
	{
		if(!BalduSistema[hid][i][b_used])
		{
			count ++;
		}
	}
	return count;
}
stock PadetiDovana(hid, objektas)
{
	for(new i;i<MAX_BALDAI;i++)
	{
		if(!BalduSistema[hid][i][b_used])
		{
			BalduSistema[hid][i][b_used]=1;
			BalduSistema[hid][i][b_obj]=objektas;
			BalduSistema[hid][i][b_cat]=13;
			BalduSistema[hid][i][b_x]=0.0;
			BalduSistema[hid][i][b_y]=0.0;
			BalduSistema[hid][i][b_z]=-1000.0;
			BalduSistema[hid][i][b_rx]=0.0;
			BalduSistema[hid][i][b_ry]=0.0;
			BalduSistema[hid][i][b_rz]=0.0;
			CreateBaldas(hid,i);
			return 1;
		}
	}
	return 0;
}
stock HelovynoPickup(playerid,pickupid)
{
	if(pickupid == h_pumpkin)
	{
		ShowPlayerDialog(playerid, 15395, DIALOG_STYLE_MSGBOX, "Helovyno eventas", "{f4b942}HELOVYNO EVENTAS\n\n{FFFFFF}Radai slaptŕ LSG moliugŕ! Dabar já gali pasidëti savo namuose parađćs {FF0000}/padetimoliuga", "Gerai","");
		SetPVarInt(playerid, "Moliugas", 1);
		return 1;
	}
	else if(pickupid == h_pickup)
	{
		if(GetPVarInt(playerid,"Bodyparts") >= 18)
		{
			SendClientMessage(playerid, ORANGE, " * O tu greitas! Uţ surinktus lavonus duodu tau ypatingŕ ţaisliukŕ - neribotŕ Flamethrower!");
			SendClientMessage(playerid, ORANGE, " * Jei mirsi, gali ateiti iđ naujo ávykdyti eventŕ ir duosiu tau naujŕ ginklŕ.");
			GivePlayerWeaponEx(playerid, WEAPON_FLAMETHROWER, 100000);
			if(GetPVarInt(playerid, "NoMoliugas") != 1)
				SetPlayerAttachedObject(playerid, CAP_SLOT, 19320, 2, 0.1, 0, 0.0, 0, 90, 0, 0.65, 0.65, 0.65, 0, 0);


			SetPVarInt(playerid, "Bodyparts", 0);
			SetPVarInt(playerid, "HelovynoEvente",0);
			//ShowPlayerDialog(playerid, 15397, DIALOG_STYLE_LIST, "Prizai", "Balta kaukë\nRaudona kaukë\nŢalia kaukë\nZoro kaukë\nBokso đalmas","Gerai", "Atsaukti");
			return 1;
		}
		SetPVarInt(playerid, "HelovynoEvente",1);
		ShowPlayerDialog(playerid, 15396, DIALOG_STYLE_MSGBOX, "Helovyno eventas", "{f4b942}HELOVYNO EVENTAS\n\n{FFFFFF}Los Santos mieste visiđka apokalipsë! Kiekvienas lavonas nudaţo miesto sienas raudonai ir primëto kűno daliř!\nMan reikia tavo pagalbos sutvarkyti miestŕ. Surink 18 lavonř daliř ir ađ tau duosiu prizŕ.\nSurinkti dalis gali paspaudćs [ENTER].\n\nEventas baigsis lapkričio 1 dienŕ 21:00.", "Gerai", "");
		return 1;
		
	}
	else
		return 0;
}

stock AttachKepure(playerid,skinid)
{
	if(InvalidCapSkin(skinid)) 
		return 0;
	if(playerDB[playerid][kepure]==13) // santa hat
		SetPlayerAttachedObject(playerid, CAP_SLOT, Kepures[playerDB[playerid][kepure]-1], 2, 0.120000, 0.040000, -0.003500, 0, 100, 100, 1.3, 1.3, 1.3);
	else if(playerDB[playerid][kepure] == 14 || playerDB[playerid][kepure] == 15 || playerDB[playerid][kepure] == 16 )
		SetPlayerAttachedObject(playerid, CAP_SLOT, Kepures[playerDB[playerid][kepure]-1], 2,0.093999,0.026000,-0.004999,93.800018,82.199951,-3.300001,1.098000,1.139999,1.173000);
	else if(playerDB[playerid][kepure] == 17)
		SetPlayerAttachedObject(playerid, CAP_SLOT, Kepures[playerDB[playerid][kepure]-1], 2,0.093999,0.026000,-0.004999,93.800018,82.199951,-3.300001,1.098000,1.139999,1.173000);
	else if(playerDB[playerid][kepure] == 18 )
		SetPlayerAttachedObject(playerid, CAP_SLOT, Kepures[playerDB[playerid][kepure]-1], 2,0.093999,0.026000,-0.004999,0,0,0,1.098000,1.139999,1.173000);
	else
		SetPlayerAttachedObject(playerid, CAP_SLOT, Kepures[playerDB[playerid][kepure]-1], 2, SkinCapsSet[skinid][0], SkinCapsSet[skinid][1],SkinCapsSet[skinid][2], SkinCapsSet[skinid][3], SkinCapsSet[skinid][4], SkinCapsSet[skinid][5]);

	return 1;
}

