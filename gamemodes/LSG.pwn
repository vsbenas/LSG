public IsjungimoTime(count)
{
	if(count < 5 && ((LastQuery-GetTickCount() < 1000) || mysql_unprocessed_queries() > 10))
	{
		SetTimerEx("IsjungimoTime",5000,false,"i",count+1);
		return 1;
	}
	else
	{
		SendRconCommand("exit");
		return 1;
	}
}

stock GetPlayersCountByName(playerid,str[])
{
	new n=0;
	foreach(Player, i)
	{
		if(strfind(ReturnName(i),str,true) != -1)
			n++;
		if(n>1) break;
	}
	if(n > 1)
	{
		SendClientMessage(playerid,-1," * Radome daugiau nei viena zaideja, prasome kickinti pagal ID:");
		foreach(Player, i)
		{
			new vardas[24];
			GetPlayerName(i,vardas,24);
			if(strfind(vardas,str,true) != -1)
			{
				new msg[128];
				format(msg,sizeof(msg)," * %s (ID:%i)",vardas,i);
				SendClientMessage(playerid,COLOR,msg);
			}
		}
		return 1;
	}
	return 0;
}


