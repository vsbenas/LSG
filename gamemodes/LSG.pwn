				BalduSistema[hid][i][b_oid]=CreateDynamicObject(BalduSistema[hid][i][b_obj],BalduSistema[hid][i][b_x],BalduSistema[hid][i][b_y],BalduSistema[hid][i][b_z],BalduSistema[hid][i][b_rx],BalduSistema[hid][i][b_ry],BalduSistema[hid][i][b_rz],hid);
				SaveBaldai(hid);
				new msgz[245];
				format(msgz,sizeof(msgz)," * Kiausini pristateme i tavo nama Nr. %i. Ji rasi kategorijoje Dovanos!",hid1);
				SendClientMessage(playerid,-1,msgz);
			
			}
		}
		
	}
	else if(count == 12)
	{
		SendClientMessage(playerid,-1," * Tai buvo paskutinis kiausinis! Dekojame, kad dalyvavote musu evente ir prasome jusu neskelbti kiausiniu vietu viesai!");
