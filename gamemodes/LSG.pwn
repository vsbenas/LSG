forward SetCarHp(vehicleid,Float:health,Float:gasas);
public SetCarHp(vehicleid,Float:health,Float:gasas)
{
	SetVehicleHealth(vehicleid,health);
	vehicleDB[vehicleid][gas]=gasas;
	vehicleDB[vehicleid][energy]=50.0;
	vehicleDB[vehicleid][OldHP]=health;
	return 1;
}
stock DestroyOldCar(playerid)
{
	CheckVelykos(playerid);
	if(CarLights[playerid] != 0)
	{
		DestroyObject(CarLights[playerid]),CarLights[playerid]=0;
	}
	if(PlayerCar[playerid] != -1)
	{
		new model=GetVehicleModel(PlayerCar[playerid]);
		new bool:found=false;
		for(new i;i<150;i++) if(!found)
		{
			for(new x;x<MAX_DARBINES_CAR;x++)
			{
				if(DarbinesCar[i][x][DCmodel]==model)
				{
					if(i<100)
					{
						if(playerDB[playerid][specialybe] != i || vehicleDB[PlayerCar[playerid]][norida] == 1)
							continue;

						new query[343];
						new Float:health;
						GetVehicleHealth(PlayerCar[playerid],health);
						if(health < 301.0)
						{
							format(query,sizeof(query),"UPDATE `Darbines` SET `Status`=0,`Health`='%f',`Degalai`='%f',`rida`='%f' WHERE `Vardas`='%s' AND `Job`=%i AND `Cartype`=%i",health,vehicleDB[PlayerCar[playerid]][gas],vehicleDB[PlayerCar[playerid]][rida],ReturnName(playerid),i,x);
							mysql_query(query);
						}
						else
						{
							if(InkaUzsakymai[playerid][ustatus] == 3 && model == 428 )
							{
								PrapisoPinigus(playerid,1);
							}
							format(query,sizeof(query),"UPDATE `Darbines` SET `Status`=1,`Health`='%f',`Degalai`='%f',`rida`='%f' WHERE `Vardas`='%s' AND `Job`=%i AND `Cartype`=%i",health,vehicleDB[PlayerCar[playerid]][gas],vehicleDB[PlayerCar[playerid]][rida],ReturnName(playerid),i,x);
							mysql_query(query);
						}
					}
					else if(i<110)
					{
						new query[234];
						new Float:health;
						GetVehicleHealth(PlayerCar[playerid],health);
						if(health < 301.0)
						{
							format(query,sizeof(query),"UPDATE `gangcars` SET `status`=0,`health`='400',`gas`='%f',`rida`='%f' WHERE `gang`='%i' AND `lastuser`='%s' AND `status`=2",vehicleDB[PlayerCar[playerid]][gas],vehicleDB[PlayerCar[playerid]][rida],i-100,ReturnName(playerid));
							mysql_query(query);

						}
						else
						{
							format(query,sizeof(query),"UPDATE `gangcars` SET `status`=1,`health`='%f',`gas`='%f',`rida`='%f' WHERE `gang`='%i' AND `lastuser`='%s' AND `status`=2",health,vehicleDB[PlayerCar[playerid]][gas],vehicleDB[PlayerCar[playerid]][rida],i-100,ReturnName(playerid));
							mysql_query(query);
						}
					}
					// else event
					if(vehicleDB[PlayerCar[playerid]][dega])
					{
						vehicleDB[PlayerCar[playerid]][dega]=0;
						Iter_Remove(Deganti,PlayerCar[playerid]);
						vehicleDB[PlayerCar[playerid]][sprogs]=0;
					}
				//	if(GetVehicleTrailer(PlayerCar[playerid]) > 0 ) DestroyVehicle(GetVehicleTrailer(PlayerCar[playerid]));
					if(MiniDarbai[PlayerCar[playerid]] != Text3D:-1) 
					{
						DestroyDynamic3DTextLabel(MiniDarbai[PlayerCar[playerid]]),MiniDarbai[PlayerCar[playerid]]=Text3D:-1;
					}
					found=true;
					break;
				}
			}
		}
		DestroyVehicle(PlayerCar[playerid]);
		PlayerCar[playerid]=-1;
	}
	return 1;
}


stock ProcessAchievement(playerid,id,Float:amount=1.0)
{
	AchievementMain(playerid,id,amount);
}

stock LoadAchievementMax()
{
	mysql_function_query(SQL, "SELECT amount FROM `AchInfo` order by id asc", true, "SQL_LoadAchMax","");
	mysql_function_query(SQL, "SELECT id, SUM(Status) FROM `Achievements` group by id order by id asc", true, "SQL_LoadAchMax2","");
	mysql_function_query(SQL, "SELECT COUNT(DISTINCT Name) FROM `Account` WHERE Xp > 0", true, "SQL_LoadAchMax3","");
}


forward AchievementMain(playerid,id,Float:amount); // progress
public AchievementMain(playerid,id,Float:amount)
{
	if(GetPlayerScore(playerid) < 100) return;
	if(Achievements[playerid][id] < RequiredAchPoints[id])
	{
		AchievementChanged[playerid][id]=1;
		Achievements[playerid][id]+=amount;
		if(Achievements[playerid][id] >= RequiredAchPoints[id])
		{
			AchievementUnlocked(playerid,id);
		}
	}
}

stock AchievementUnlocked(playerid,id)
{
	new query[256];
	format(query,sizeof(query),"SELECT Name,amount From AchInfo Where id=%i",id);
	mysql_function_query(SQL, query, true, "SQL_GetAchName", "ii", playerid,id);
}

stock ShowAchievements(playerid,forplayerid=-1,page=0)
{
	mysql_function_query(SQL, "select * From AchInfo order by id asc", true, "SQL_DumpAchievements", "iii", playerid,forplayerid,page);
}

