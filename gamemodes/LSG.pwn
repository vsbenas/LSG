stock SavePatrul()
{
	mysql_query("Delete from `Patruliai`");
	for(new i;i<MAX_PATRULIU;i++)
	{
		if(Patruliai[i][used])
		{
			new coordsstring[1024];
			format(coordsstring, sizeof(coordsstring), "INSERT INTO `Patruliai`(`Name`,X,Y,`Range`,`Max`) VALUES('%s','%f','%f','%f','%i');",
			Patruliai[i][pavv],
			Patruliai[i][possx],
			Patruliai[i][possy],
			Patruliai[i][rangee],
			Patruliai[i][pplmax]);
			mysql_query(coordsstring);
		}
	}
	return 1;
}	
