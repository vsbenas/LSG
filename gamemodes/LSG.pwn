	{
		MoveDynamicObject(Firerocket[playerid], xla,yla,zla+30, 10);
		MoveDynamicObject(rocketsmoke[playerid], xla,yla,zla+30, 10);
	}
	else if(id==2)
	{
		MoveDynamicObject(Firerocket[playerid], xla,yla,zla+50, 15);
		MoveDynamicObject(rocketsmoke[playerid], xla,yla,zla+50, 15);
	}
	UpdateStreamerFW(xla,yla,zla);
	return 1;
}


public CheckVm(playerid)
{
	if(playerDB[playerid][DrivingTest] == 1 || playerDB[playerid][MotoTest] == 1 || playerDB[playerid][FlyingTest] ==1) return 1;
	return 0;
}

public Bankomatas(playerid)
{
	TogglePlayerControllable(playerid, true);
	playerDB[playerid][atvaziavobank]=false;
	new Float:Coo[3];
	GetVehiclePos(playerDB[playerid][masina],Coo[0],Coo[1],Coo[2]);
	if(!IsPlayerInRangeOfPointEx(15.0,playerid,Coo[0],Coo[1],Coo[2]))
	    return SendInfoMessage(playerid,"Tavo automobilis per toli!");
	if(GetVehicleModel(playerDB[playerid][masina]) != 428)
		return SendInfoMessage(playerid,"Netinkamas automobilis!");
	if(vbankomatams[playerDB[playerid][masina]] == 0)
	    return SendInfoMessage(playerid,"Masinoje nera pinigu!");
	
	new suma = MONEYP_BANKININKAS;
	GivePlayerMoneyA(playerid, suma);
	new msg[128];
	SendInfoMessage(playerid,"Papildei bankomata, gavai "#MONEYP_BANKININKAS"EUR Premija!");
	SendClientMessage(playerid, ORANGE, msg);
	vbankomatams[playerDB[playerid][masina]]=0;
	vezaibanko[playerid]=0;
	ClearAnimations(playerid);
	SetPlayerCheckpoint(playerid,1506.6062,-1751.7847,13.6705,7);
	return 1;
}

public Papilde(playerid,vehicleid)
{
	TogglePlayerControllable(playerid, true);
    new pickupid;
    new skaicius = random(8);
	switch(skaicius)
	{
	    case 0: pickupid = pickups[0][bankomatas];
	    case 1: pickupid = pickups[0][bankomatas]+2;
	    case 2: pickupid = pickups[0][bankomatas]+3;
	    case 3: pickupid = pickups[0][bankomatas]+4;
	    case 4: pickupid = pickups[0][bankomatas]+5;
	    case 5: pickupid = pickups[0][bankomatas]+6;
	    case 6: pickupid = pickups[0][bankomatas]+7;
	    case 7: pickupid = pickups[1][bankomatas];
	}
	vezaibanko[playerid] = pickupid;
	SetPlayerCheckpoint(playerid,PickupIDs[pickupid][0],PickupIDs[pickupid][1],PickupIDs[pickupid][2],30.0);
	new string[100];
	format(string,sizeof(string),"Reikalingas bankomato papildymas!~n~ Vaziuokite prie bankomato Nr.%i!",skaicius+1);
    SendInfoMessage(playerid,string);
    vbankomatams[vehicleid]=1;
    return 1;
}

