native gpci(playerid, serial[], maxlen);
stock PendingBan(playerid)
{
	/*if(!mysql_ping()) mysql_reconnect();
	if(!mysql_ping()) return SendRconCommand("exit");*/
	if(!IsPlayerConnected(playerid)) return 0;
	new
		query[128];
	format(query,sizeof(query),"SELECT * From `Pending` WHERE `Name`='%s' LIMIT 1",ReturnName(playerid));
	//mysql_query(query);
	mysql_function_query(SQL, query, true, "SQL_Pending", "i", playerid);
	new hashas[128];
	gpci(playerid,hashas,sizeof(hashas));
	printf("%s has joined(%s)",ReturnName(playerid),hashas);
	format(query,sizeof(query),"SELECT * From `HBans` WHERE `Hash`='%s' LIMIT 1",hashas);
	mysql_function_query(SQL, query, true, "SQL_HBans", "i", playerid);
	return 1;
}

