		Light[36][playerid] = CreateDynamicObject(1213,xla-7,yla,zla+5, 0, 0,0);
		Light[37][playerid] = CreateDynamicObject(1213,xla,yla,zla-5, 0, 0,0);
		Light[38][playerid] = CreateDynamicObject(1213,xla,yla-7,zla+8, 0, 0,0);
		GetDynamicObjectPos(Light[8][playerid], xla, yla, zla);
		Light[39][playerid] = CreateDynamicObject(1213,xla-4,yla-7,zla-8, 0, 0,0);
