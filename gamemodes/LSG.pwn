stock ProxyCheck(playerid)
{
	new ip[16];
	GetPlayerIp(playerid, ip, sizeof ip);
	new
		query[128];
	format(query,sizeof(query),"SELECT * From `Whitelist` WHERE `Name`='%s' OR `Ip`='%s' LIMIT 1",ReturnName(playerid),ip);
