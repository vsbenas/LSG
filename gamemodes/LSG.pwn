				return 1;
			}
			SlavejoCP[playerid]++;
			if(SlavejoCP[playerid] >= sizeof(Traktoristu_CP))
			{
				GivePlayerMoneyA(playerid, MONEYP_UKININKAS*2);
				ProcessAchievement(playerid, 130);
				SendInfoMessage(playerid,"Marsrutas baigtas!");
				ProcessAchievement(playerid,76);
