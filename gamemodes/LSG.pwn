stock ReloadGangIspejimai()
{
	mysql_function_query(SQL, "SELECT * FROM `Ispejimai` WHERE entity='gang'", true, "SQL_GangIspejimai", "");
}
stock AddGangIspejimas(playerid, gangid, count, reason[])
{
	new query[512];
	new reasonas[256];
	mysql_real_escape_string(reason, reasonas);
	FamilyInfo[gangid][ApleidimoDelay] = 3 + random(2);
	format(query,sizeof(query),"INSERT INTO Ispejimai(`entity`,`id`,`time`,`count`,`by`,`reason`) VALUES('gang','%i',NOW(),%i,'%s','%s')", gangid, count, ReturnName(playerid), reasonas);
	mysql_query(query);
	ReloadGangIspejimai();
	new msg[1024];
	format(msg,sizeof(msg),"Jusu gauja %s gavo ispejima %i/2 nuo %s. Prieţastis: %s.",FamilyInfo[gangid][FamilyName], count, ReturnName(playerid), reasonas);
	EAtaskaita("Serveris",FamilyInfo[gangid][FamilyLeader],"Gaujos ispejimas",msg);
	MLog(playerid,"Uzdejo ispejima", "iss", count, FamilyInfo[gangid][FamilyName], reasonas);
}
stock EmptyGang(gangid)
{
	foreach(Player, playerid)
	{
		if(playerDB[playerid][pgang] == gangid)
		{
			if(strcmp(FamilyInfo[gangid][FamilySubstitute],ReturnName(playerid),true) != 0 && strcmp(FamilyInfo[gangid][FamilyLeader],ReturnName(playerid),true) != 0 )
			{
				SendClientMessage(playerid,COLOR, "[gauja] Jusu gauja subyrëjo!");
				SetPVarInt(playerid,"LeftGang",1);	
				playerDB[playerid][pgang]=-1;
			}
		}
	}
	new query[512];
	format(query,sizeof(query),"UPDATE Account Set Gangas=-1 where Gangas=%i And Name NOT IN ('%s','%s')",gangid,FamilyInfo[gangid][FamilySubstitute], FamilyInfo[gangid][FamilyLeader]);
	mysql_query(query);
	SaveFamily(gangid);
}
stock DeleteGangIspejimai(id,playerid, reason[])
{
	new query[256];
	format(query,sizeof(query),"DELETE FROM Ispejimai WHERE entity='gang' AND id='%i'", id);
	mysql_query(query);
	new reasonas[256];
	mysql_real_escape_string(reason, reasonas);
	ReloadGangIspejimai();
	if(playerid != -1)
	{
		new msg[1024];
		format(msg,sizeof(msg),"Jusu gaujai %s buvo nuimti ispejimai nuo %s. Prieţastis: %s.",FamilyInfo[id][FamilyName], ReturnName(playerid), reasonas);
		EAtaskaita("Serveris",FamilyInfo[id][FamilyLeader],"Gaujos ispejimas",msg);
		MLog(playerid,"Nueme ispejimus","ss",FamilyInfo[id][FamilyName], reason);
	}
}

stock ApleistiGaujas()
{
	for(new ix;ix<MAX_FAMILY;ix++)
	{
		if(FamilyInfo[ix][FamilyIspejimai] >= 2)
		{
			if(FamilyInfo[ix][ApleidimoDelay] > 0)
			{
				FamilyInfo[ix][ApleidimoDelay] --;
			}
			if(FamilyInfo[ix][ApleidimoDelay] == 0)
			{
				format(FamilyInfo[ix][FamilyLeader], 32, "Nera");
				format(FamilyInfo[ix][FamilySubstitute],24,"Nera");
				DeleteGangIspejimai(ix, -1, "");
			}
			SaveFamily(ix);
		}
	}
}

stock SaveFamily(id)
{
	if(id < 0)
		return 1;
	new filex[1024];
	//format(filex,sizeof(filex),"UPDATE `Gangs` SET `Leader`='%s',`Substitute`='%s',`Funds`=%i,`Limit`=%i WHERE `ID`=%i",FamilyInfo[id][FamilyLeader],FamilyInfo[id][FamilySubstitute],FamilyInfo[id][FamilyFunds],FamilyInfo[id][FamilyLimit],id);
	//
	new sandelioLimitai[256];
	format(sandelioLimitai,256,"%i|%i|%i",
		FamilyInfo[id][SandelioLimitai][0],
		FamilyInfo[id][SandelioLimitai][1],
		FamilyInfo[id][SandelioLimitai][2]);
		
	new saugyklosLimitai[256];
	format(saugyklosLimitai,256,"%i|%i|%i|%i|%i|%i|%i|%i|%i|%i",
		FamilyInfo[id][SaugyklosLimitai][0],
		FamilyInfo[id][SaugyklosLimitai][1],
		FamilyInfo[id][SaugyklosLimitai][2],
		FamilyInfo[id][SaugyklosLimitai][3],
		FamilyInfo[id][SaugyklosLimitai][4],
		FamilyInfo[id][SaugyklosLimitai][5],
		FamilyInfo[id][SaugyklosLimitai][6],
		FamilyInfo[id][SaugyklosLimitai][7],
		FamilyInfo[id][SaugyklosLimitai][8],
		FamilyInfo[id][SaugyklosLimitai][9]);

	new saugykla[256];
	format(saugykla,256,"%i|%i|%i|%i|%i|%i|%i|%i|%i|%i",
		FamilyInfo[id][FamilySaugykla][0],
		FamilyInfo[id][FamilySaugykla][1],
		FamilyInfo[id][FamilySaugykla][2],
		FamilyInfo[id][FamilySaugykla][3],
		FamilyInfo[id][FamilySaugykla][4],
		FamilyInfo[id][FamilySaugykla][5],
		FamilyInfo[id][FamilySaugykla][6],
		FamilyInfo[id][FamilySaugykla][7],
		FamilyInfo[id][FamilySaugykla][8],
		FamilyInfo[id][FamilySaugykla][9]);

	format(filex,sizeof(filex),"REPLACE INTO Gangs(`ID`,`Leader`,`Substitute`,`Funds`,`Limit`,`SandelioLimitai`,`SaugyklosLimitai`,`Saugykla`,`Delay`) VALUES('%i','%s','%s','%i','%i','%s','%s','%s',%i)", 
		id, 
		FamilyInfo[id][FamilyLeader],
		FamilyInfo[id][FamilySubstitute],
		FamilyInfo[id][FamilyFunds],
		FamilyInfo[id][FamilyLimit], 
		sandelioLimitai, saugyklosLimitai, saugykla,
		FamilyInfo[id][ApleidimoDelay]);
	mysql_query(filex);
	return 1;
}

stock SaveNarko(id)
{
	new filex[128];
	format(filex,sizeof(filex),"UPDATE `Sandeliai` SET `Priklauso`=%i,`Atvezta`=%i,`Bomba`=%i WHERE `Numeris`=%i",PlaceOwnedBy[id],KiekYra[id],BombaYra[id],id);
	mysql_query(filex);
	return 1;
}

