	if(DEBUG) printf("9");

	//mysql_query(var);
	return 1;
}


public Tobulinti(houseid)
{
	printf("Tobulinti %i.",houseid);

	if(hInfo[houseid][vidus] == 30) return 1;
	hInfo[houseid][tobulina] = 0;
	hInfo[houseid][vidus]++;
	new query[128];
	format(query,sizeof(query),"UPDATE `Namai` SET `Vidus`=%i,`Tobulina`=0 WHERE `ID`=%i",hInfo[houseid][vidus],houseid);
	mysql_query(query);
	return 1;
}

public Tobulinti2(houseid,lvl)
{
	printf("Tobulinti %i.",houseid);
	if(!hInfo[houseid][vidus] || !lvl) return 1;
	hInfo[houseid][tobulina] = 0;
	hInfo[houseid][vidus]=lvl;
	new query[128];
	format(query,sizeof(query),"UPDATE `Namai` SET `Vidus`=%i WHERE `ID`=%i",hInfo[houseid][vidus],houseid);
	mysql_query(query);
	return 1;
}

