{
	for(new i=1;i<MAX_HOUSES;i++) if(strval(hInfo[i][Name]) == 0 && strlen(hInfo[i][Name]) < 3) return i;
	return -1;
}

stock VerslaiCount(playerid) {
	new pname[MAX_PLAYER_NAME];
	new count = 0;
	GetPlayerName(playerid,pname,MAX_PLAYER_NAME);

    foreach(Businesses,i) if(BusinessInfo[i][bOwned] && 0==strcmp(BusinessInfo[i][bOwner],pname,false))
	{
		count ++;
	}
	return count;
}
stock ArTuriBiz(playerid)
{
	new pname[MAX_PLAYER_NAME];
	GetPlayerName(playerid,pname,MAX_PLAYER_NAME);
    for(new i; i<MAX_BUSINESSES;i++) if(BusinessInfo[i][bOwned] && 0==strcmp(BusinessInfo[i][bOwner],pname,false)) return i;
	return -1;
}

stock GetHouseCost(type)
{
	new randomas,normalvalue;
	switch(type)
	{
		case 1: normalvalue=10000,randomas=random(500);
		case 2: normalvalue=100000,randomas=random(500);
		case 3: normalvalue=200000,randomas=random(1000);
		case 4: normalvalue=350000,randomas=random(1500);
		case 5: normalvalue=500000,randomas=random(2000);
	}

	return (normalvalue+(randomas*100));
}

stock GetPlace(playerid, houses = true)
{
	new world = GetPlayerVirtualWorld(playerid);
	if(houses && GetPlayerHouseID(playerid))
		return PLACE_HOUSE;
	else if(!world) 
		return PLACE_NONE; // nk
	else if(playerDB[playerid][lektuvas] != -1) 
		return PLACE_PLANE; // lektuve
	else if(world < MAX_HOUSES ) 
		return PLACE_HOUSE; // name
	else if(world > MAX_HOUSES && world < MAX_HOUSES*2)
			return PLACE_GARAGE;
	else if(world >= MAX_HOUSES*2 && world < MAX_HOUSES*2+MAX_BUSINESSES) 
		return PLACE_BIZ; // biznyje.
	else if(world == 30000) 
		return PLACE_FULE;
	//else if(world >= MAX_HOUSES*2+MAX_BUSINESSES) return PLACE_DAUGIABUTIS;
	else if(world == 20000) 
		return PLACE_BASEINAS;
	else if(world == 20001) 
		return PLACE_SRATASVYDIS;
	else if(world >= 10000 && world <= 11000) 
		return PLACE_DUEL;
	else if(world > 20001 && world < 21002) 
		return PLACE_VMTEST;
	else if(world >= 100000 && world < 200000)
		return PLACE_WORLD;
	return -1;
}

stock ApleistiVerslai()
{
	new msg[256];
	new string[128];
	foreach(Businesses, i) if(BusinessInfo[i][bOwned])
	{
		if(BusinessInfo[i][bMokesciai] < 0)
		{
			if(BusinessInfo[i][bMokesciai] <= -14)
			{
				format(msg,sizeof(msg),"Jusu versla(%s) apleido anstoliai, kadangi laiku nesusimokejote mokesciu.",BusinessInfo[i][bName]);
				EAtaskaita("Antstoliai",BusinessInfo[i][bOwner],"Verslas",msg);
				format(BusinessInfo[i][bOwner],64,"Nera");
				BusinessInfo[i][bOwned]=0;
				BusinessInfo[i][bEarning]=0;
				format(BusinessInfo[i][bName],24,"-");
				format(string, sizeof(string), VERSLAS_PARDUODAMAS,GetBussinessType(BusinessInfo[i][bType]),BusinessInfo[i][bPrice]);
				DestroyDynamic3DTextLabel(businesstext[i]);
				businesstext[i] = CreateDynamic3DTextLabel(string,0x00BC00FF,BusinessInfo[i][bEnterX],BusinessInfo[i][bEnterY],BusinessInfo[i][bEnterZ],40.0, _,_, 1);
				continue;
			}
			else
			{
				new sumas = ((-BusinessInfo[i][bMokesciai])*100+1000);
				new dienos = ((-14-BusinessInfo[i][bMokesciai])*-1);
				format(msg,sizeof(msg),"Veluojate sumoketi mokescius uz versla(%s).~Reikia moketi %iEUR.~Jusu verslas bus konfiskuotas po %id.~Mokescius susimoketi galite savivaldybeje(/kur)",BusinessInfo[i][bName],sumas,dienos);
				EAtaskaita("Antstoliai",BusinessInfo[i][bOwner],"Verslas",msg);
			}
		}
		else if(BusinessInfo[i][bMokesciai] == 2)
		{
			new dienos = ((-14-BusinessInfo[i][bMokesciai])*-1);
			format(msg,sizeof(msg),"Reikia sumoketi mokescius uz versla(%s).~Reikia moketi 1000EUR.~Jusu verslas bus konfiskuotas po %id.~Mokescius susimoketi galite savivaldybeje(/kur)",BusinessInfo[i][bName],dienos);

			EAtaskaita("Antstoliai",BusinessInfo[i][bOwner],"Verslas",msg);
		}
		BusinessInfo[i][bMokesciai]--;
		BusinessInfo[i][bPaeme]=0;
	}
	// dabar namai
	foreach(Houses, i) if(strcmp(hInfo[i][Name],"Nera",true) != 0)
	{
		if(hInfo[i][hMokesciai] < 0)
		{
			if(hInfo[i][hMokesciai] <= -14)
			{
				format(msg,sizeof(msg),"Jusu nama nr.%i apleido anstoliai, kadangi laiku nesusimokejote mokesciu.",i);
				EAtaskaita("Antstoliai",hInfo[i][Name],"Namas",msg);
				new housenumber=i;
				ClearHouse(housenumber, /*deletebaldai=*/ true, /* deleteitems=*/ false);
				//format(query,sizeof(query),"DELETE FROM `baldai` WHERE houseid=%i",housenumber);
				//mysql_query(query);
				new vw;
				if(hInfo[housenumber][daugiabutis]) vw=(MAX_HOUSES*2+MAX_BUSINESSES+hInfo[housenumber][daugiabutis]-1);
				DestroyPickup(HousePickup[housenumber]);
				HousePickup[housenumber] = CreatePickupA(1273, 23, hInfo[housenumber][iconx], hInfo[housenumber][icony], hInfo[housenumber][iconz],vw);
				new zinute[512];
				DestroyDynamic3DTextLabel(HouseText[housenumber]);
				format(zinute,sizeof(zinute),"Namas Nr.: {FF0000}%i",housenumber);
				HouseText[housenumber] = CreateDynamic3DTextLabel(zinute, COLOR_WHITE, hInfo[housenumber][iconx], hInfo[housenumber][icony], hInfo[housenumber][iconz], 50, _,_, 1,vw);
				continue;
			}
			else
			{
				new sumas = (((-hInfo[i][hMokesciai])+1)*100);
				new dienos = ((-14-hInfo[i][hMokesciai])*-1);
				format(msg,sizeof(msg),"Veluojate sumoketi mokescius uz nama Nr.%i.~Reikia moketi %iEUR.~Jusu namas bus konfiskuotas po %id.~Mokescius susimoketi galite savivaldybeje(/kur)",i,sumas,dienos);
				EAtaskaita("Antstoliai",hInfo[i][Name],"Namas",msg);
			}
		}
		else if(hInfo[i][hMokesciai] == 2)
		{
			new dienos = ((-14-hInfo[i][hMokesciai])*-1);
			format(msg,sizeof(msg),"Reikia sumoketi mokescius uz nama Nr.%i.~Reikia moketi 100EUR.~Jusu namas bus konfiskuotas po %id.~Mokescius susimoketi galite savivaldybeje(/kur)",i,dienos);

			EAtaskaita("Antstoliai",hInfo[i][Name],"Namas",msg);
		}
		hInfo[i][hMokesciai]--;
		new querfr[240];
		format(querfr,sizeof(querfr),"UPDATE `Namai` SET `bMokesciai`=%i WHERE ID=%i",hInfo[i][hMokesciai],i);
		mysql_query(querfr);
	}
	return 1;
}

stock GetDistanceBetweenPlayers(playerid, playerid2)
{
	new Float:x1,Float:y1,Float:z1,Float:x2,Float:y2,Float:z2;
	GetPlayerPos(playerid,x1,y1,z1);
	GetPlayerPos(playerid2,x2,y2,z2);
	return floatround(floatsqroot((x2-x1)*(x2-x1)+(y2-y1)*(y2-y1)+(z2-z1)*(z2-z1)));
}

stock PlayerFacePlayer(playerid, targetplayerid)
{
	SetPlayerFacingAngle(playerid, 0);
	SetPlayerFacingAngle(targetplayerid, 180);
	return true;
}


stock Get2DZone(playerid) //Credits to Cueball, Betamaster, Mabako, and Simon (for finetuning).
{
	new Float:x, Float:y, Float:z;
	GetPlayerPos(playerid, x, y, z);
 	for(new i = 0; i != sizeof(JB_gSAZones); i++ )
		if(x >= JB_gSAZones[i][JB_SAZONE_AREA][0] && x <= JB_gSAZones[i][JB_SAZONE_AREA][3] && y >= JB_gSAZones[i][JB_SAZONE_AREA][1] && y <= JB_gSAZones[i][JB_SAZONE_AREA][4])
		    return i;
	return 0;
}
stock Get2DZoneEx(Float:Ix,Float:Iy) //Credits to Cueball, Betamaster, Mabako, and Simon (for finetuning).
{
 	for(new i = 0; i != sizeof(JB_gSAZones); i++ )
		if(Ix >= JB_gSAZones[i][JB_SAZONE_AREA][0] && Ix <= JB_gSAZones[i][JB_SAZONE_AREA][3] && Iy >= JB_gSAZones[i][JB_SAZONE_AREA][1] && Iy <= JB_gSAZones[i][JB_SAZONE_AREA][4])
		    return i;
	return 0;
}
stock Taisymas(playerid,repair)
{
	if(IsPlayerInAnyVehicle(playerid))
	{
	    SendInfoMessage(playerid,"Privalote stoveti prie masinos kapoto!");
		return 0;
	} 
	new Float:x,Float:y;
	new vehicleid = GetClosestVehicleid(playerid);
	new Float:Coo[3];
	if(vehicleid != INVALID_VEHICLE_ID)
	    GetVehiclePos(vehicleid,Coo[0],Coo[1],Coo[2]);
	if(vehicleid == INVALID_VEHICLE_ID || !IsPlayerInRangeOfPointEx(5.0,playerid,Coo[0],Coo[1],Coo[2]))
	{
	    SendInfoMessage(playerid,"Jus per toli nuo masinos!");
        return 0;
	} 
	/*if(GetVehicleModel(vehicleid) == 504 || GetVehicleModel(vehicleid) == 502 || GetVehicleModel(vehicleid) == 494  || GetVehicleModel(vehicleid) == 503)
	{
		SendInfoMessage(playerid,"Sios masinos taisyti negalite!");
	    return 0;
	}*/
	GetXYInFrontOfVehicle(vehicleid,x,y,4.0);
	GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
	SetPlayerPoz(playerid,x,y,Coo[2]-0.7, _, _, 0);
	new
        Float:a;
    GetVehicleZAngle( vehicleid, a );
	SetPlayerFacingAngle(playerid,a);
	TogglePlayerControllable(playerid,false);
	ApplyAnimation(playerid,"CAR","Fixn_Car_Loop",1.000,0,0,0,1,5000,1);
	SetTimerEx("Taisymas2",5000,false,"iiii",playerid,vehicleid,1,repair);
	new Float:Coo2[3];
	GetXYInFrontOfVehicle(vehicleid,Coo2[0],Coo2[1],8.0);
	SetPlayerCameraPos(playerid,Coo2[0],Coo2[1],Coo[2]+1.0);
	SetPlayerCameraLookAt(playerid,x,y,Coo[2]-0.7);
	return 1;
}

public Taisymas2(playerid,vehicleid,lvl,repair)
{
	if(!IsPlayerConnected(playerid)) return 1;
    if(lvl==1)
	{
		if(repair == 1) RepairVehicle(vehicleid);
		else if(repair == 2)
		{
			RepairVehicle(vehicleid);
			SetVehicleHealth(vehicleid, 2000.0);
		}
		else SetVehicleHealth(vehicleid, 1000.0);
		ApplyAnimation(playerid,"CAR","Fixn_Car_Out",1.000,0,0,0,0,1000,1);
		SetTimerEx("Taisymas2",1000,false,"iiii",playerid,vehicleid,2,repair);
	}
    else if(lvl==2)
    {
		ApplyAnimation(playerid, "CARRY", "crry_prtial", 1.0, 0, 0, 0, 0, 0);
		new Float:Coo[3];
		GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
		GetXYInFrontOfVehicle(vehicleid,Coo[0],Coo[1],5.0);
		SetPlayerPoz(playerid,Coo[0],Coo[1],Coo[2], _, _, 0);
		SetTimerEx("Atfreezint",500,false,"i",playerid);
		SetCameraBehindPlayer(playerid);
		if(FPS[playerid])  AttachCameraToObject(playerid, FirstPersonObject[playerid]);
    }
    return 1;
}

stock GetXYInFrontOfVehicle(vehicleid, &Float:x, &Float:y, Float:distance)
{
    new
        Float:a;
    GetVehiclePos( vehicleid, x, y, a );
    GetVehicleZAngle( vehicleid, a );
    x += ( distance * floatsin( -a, degrees ));
    y += ( distance * floatcos( -a, degrees ));
}
stock GetXYBehindPlayer(playerid, &Float:x, &Float:y, Float:distance)
{
    new
        Float:a;
    GetPlayerPos( playerid, x, y, a );
    GetPlayerFacingAngle( playerid, a );
    x -= ( distance * floatsin( -a, degrees ));
    y -= ( distance * floatcos( -a, degrees ));
}

