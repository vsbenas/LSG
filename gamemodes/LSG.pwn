		GameTextForPlayer(playerid," ~y~ Testas ~r~ neislaikytas ~n~ ~w~ Nes jus palikote Motocikla.~n~ Prasome bandyti is naujo.",5000,3);
		new testcar;
		testcar = GetPlayerVehicleID(playerid);
		SetPlayerVirtualWorld(playerid,0);
		SetVehicleVirtualWorld(GetPlayerVehicleID(playerid),0);
		RemovePlayerFromVehicle(playerid);
		SetVehicleToRespawn(testcar);
		playerDB[playerid][MotoTest] = 0;
		DisablePlayerRaceCheckpoint(playerid);
	}












	//GetVehiclePos(vehicleid,vehicleDB[vehicleid][lastpos][0],vehicleDB[vehicleid][lastpos][1],vehicleDB[vehicleid][lastpos][2]);
	//GetVehicleZAngle(vehicleid,vehicleDB[vehicleid][lastpos][3]);

//Autobuso cp panaikinimas
	if(autoDB[playerid][currentCP] != -1)
	{
		DisablePlayerCheckpoint(playerid);
		autoDB[playerid][currentCP] = -1;
	}
//Siuklevezio cp panaikinimas
	if(siuksliuDB[playerid][dabartinisCP] != -1)
	{
		DisablePlayerCheckpoint(playerid);
		siuksliuDB[playerid][dabartinisCP] = -1;
	}
	if(playerDB[playerid][pCar] == vehicleid)
		SetTimerEx("CheckDega", 2000, false, "ii",playerid,vehicleid);
	return 1;
}
forward CheckDega(playerid,vehicleid);
public CheckDega(playerid,vehicleid)
{
	new Float:vhp;
	GetVehicleHealth(vehicleid, vhp);
	if(vhp >= 250.0)
		return 1;
	new veh = vehicleid;
	new model = GetVehicleModel(veh);
	
	if(!model)
		return 1;

	printf("On fire after CheckDega %i %i",playerid,vehicleid);

	if(!vehicleDB[veh][dega])
	{
		//SendClientMessage(playerid, -1, "Padegam!");
		switch(model)
		{
			case 592,577,511,512,593,520,553,476,519,460,51,546,3425,417,487,488,563,469,BMX,BIKE,MTBIKE: return 1;
			case 556,444,452,495,494,502,503,571,471,539,504: return 1; // event
			case 441,464,465,501,564: return 1; // RC cars
		}
		vehicleDB[veh][dega]=3000;
		
		Iter_Add(Deganti,veh);
		vehicleDB[veh][sprogs]=5;
		GetVehicleParamsEx(veh,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
		if(PlayerCar[playerid] != veh)
			VehVars[5] = true;
		SetVehicleParamsEx(veh,false,VehVars[1],VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
		foreach(Player, i) if(IsPlayerInVehicle(i,veh)) RemovePlayerFromVehicle(i);
	}
	return 1;
}
//new PVEH[MAX_PLAYERS];
forward CheckDarbineSpawn(playerid);
public CheckDarbineSpawn(playerid) {
	new ve = PlayerCar[playerid];
	new mo = GetVehicleModel(ve);
	new bool:stop = false;
	new Float:dist = 1000.0;
	for(new i;i<100;i++)
	{
		//if(stop) break;
		for(new x;x<MAX_DARBINES_CAR;x++)
		{
			if(DarbinesCar[i][x][DCmodel]==mo)
			{
				stop=true;
				new Float:tempdist = GetVehicleDistanceFromPoint(ve,DarbinesCar[i][x][DCX],DarbinesCar[i][x][DCY],DarbinesCar[i][x][DCZ]);
				if(tempdist < dist)
					dist=tempdist;
			}
		}
	}
	//printf("%f",dist);
	if(stop && dist <= 5.0)
	{
		return 1;
	}
	return 0;
}
new EnteredCarAch[MAX_PLAYERS];
public OnPlayerStateChange(playerid, newstate, oldstate)
{
	if(DEBUG==true) printf("OnPlayerStateChange:%i,%i",playerid,newstate);
	IsPlayerSteppingInVehicle[playerid] = -1;
	ChristmasStateChange(playerid, newstate, oldstate);

	if(IsPlayerNPC(playerid)) return 1;
	if(Uzimineja[playerid])
	{
		SendInfoMessage(playerid,"~r~Jus nebeuziminejate sandelio!");
		Uzimineja[playerid]=0;
		HideProgressBarForPlayer(playerid,Veiksmai);
		EndVeiksmas(playerid);
	}
	if(PlayerSpectated[playerid] != -1)
	{
		UpdateSpectate(PlayerSpectated[playerid], /* force= */ true);
	}
	
	if(newstate == PLAYER_STATE_DRIVER)
    {

		if(playerDB[playerid][banned] || playerDB[playerid][authstate] == 0) return Kick(playerid);
        PlayerEnterTime[playerid] = GetTickCount();


        // anti vehicle tp
        if(AC_PutInVehicle[playerid]== 0)
        {
	        if( PlayerEnterTime[playerid] < EnterVehicleTick[playerid] + 300 || PlayerEnterTime[playerid] == 0)
	        {
	        	AC_Kick(playerid, "Vehicle teleport",1);
	        	return 1;
	        }
	        else if(!playerDB[playerid][admin])
	        {
	        	new Float:ac_dist = GetPlayerDistanceFromPoint(playerid, playerDB[playerid][pCurrentPos][0],playerDB[playerid][pCurrentPos][1],playerDB[playerid][pCurrentPos][2]);
	        	new ac_s = GetVehicleModel(GetPlayerVehicleID(playerid));
				if(ac_dist > 25.0 || ac_dist > 15.0 && ac_s != 577 && ac_s != 592)
				{
					AC_Warn(playerid,"Vehicle teleport");
				}
	        }
	    }
	    AC_PutInVehicle[playerid]=0;
	    PlayerEnterTime[playerid]=0;

		if(gPlayerUsingLoopingAnim[playerid])
		{
			StopLoopingAnim(playerid);
			TextDrawHideForPlayer(playerid,txtAnimHelper);
		}


    }
    else if(oldstate == PLAYER_STATE_DRIVER)
    {

    	if(GetPVarInt(playerid, "sirenon"))
    	{
	    	foreach(Player, i)
			{
				if(80 <= playerDB[i][specialybe] <= 84)
					SetPlayerMarkerForPlayer( i, playerid, (GetPlayerColor( playerid ) & 0xFFFFFF00 ) );
			}
			SetPVarInt(playerid, "sirenon", 0);
		}
		new tick = GetTickCount();
		if(playerDB[playerid][pCar] != 0 && playerDB[playerid][pCar] < MAX_VEHICLES)
		{
			CheckDega(playerid,playerDB[playerid][pCar]);
			LeftCarVehicle[playerDB[playerid][pCar]] = tick;
		}
    	playerDB[playerid][pCar]=0;
    	DestroyRoges(playerid);
		if(playerInEventCar[playerid]) playerInEventCar[playerid]--;
		
		LeftCar[playerid]=tick;
        if((tick-PlayerEnterTime[playerid]) < 220)//player entered and exited vehicle faster than 220 ms.
        {
			EnterWarn{playerid}++;
			if(EnterWarn{playerid} >= 3)
			{
				AC_Kick(playerid,"Vehicle Spam",1);
				return 1;
			}
        }
    }
    if( oldstate == PLAYER_STATE_DRIVER && (newstate == PLAYER_STATE_ONFOOT || newstate == PLAYER_STATE_PASSENGER) )
    {
		if(PlayerCar[playerid] != -1)
		{
			if(CheckDarbineSpawn(playerid) == 1)
			{
				SendClientMessage(playerid,-1," * Jűsř automobilis buvo sunaikintas, nes palikote já automobiliř paëmimo vietoje.");
				Stop(playerid);
				DestroyOldCar(playerid);
			}
		}
		UpdateWeapons(playerid,LastWeapon[playerid]);			
    }

	new vehicleid = GetPlayerVehicleID(playerid);
	/*if(newstate == PLAYER_STATE_PASSENGER)f]
	{
		SetPlayerTeam(playerid,2);
	}*/
	if(newstate == PLAYER_STATE_DRIVER)
	{
		LastNitro[vehicleid] = GetTickCount();
		EnteredCarAch[playerid] = 0;
		if(playerDB[playerid][pCar]==0)
		{
			playerDB[playerid][pCar]=vehicleid;
		}


		if(JobCars[vehicleid][0] > 0)
		{
			new jobid = JobCars[vehicleid][0];
			new num = JobCars[vehicleid][1];
			//TogglePlayerControllable(playerid,false);
			LoadJobCar(playerid,jobid,num);
		}
		vehicleDB[vehicleid][uzeris]=playerid;
		playerDB[playerid][masina]=vehicleid;
		//PVEH[playerid]=vehicleid;
		//SetPlayerTeam(playerid,2);
		LastWeapon[playerid]=GetPlayerWeapon(playerid);

		UpdateGunData(playerid);


        ResetPlayerWeapons     ( playerid );
		SetPVarInt(playerid, "WeaponsTaken", 1);
		SetPlayerArmedWeapon(playerid, 0);
		//new panels, doors, lightas, tires;
		//GetVehicleDamageStatus(vehicleid, panels, doors, lightas, tires);
		//lightas = encode_lights(1, 1, 1, 1);
		SetPVarInt(playerid, "vMainOn", 0);
		//UpdateVehicleDamageStatus(vehicleid, panels, doors, lightas, tires);
		
		if(GetVehicleModel(vehicleid) == 471)
		{
			if(GetPlayerFromCarlistCar(vehicleid) == -1 && GetPlayerFromCarlistCar2(vehicleid) == -1 &&  GetPlayerFromCarlistCar3(vehicleid) == -1 && PlayerCar[playerid] != vehicleid)
			{
				Stop(playerid);
				SendClientMessage(playerid, -1, " * Tai ne tavo automobilis!");
			}
		}
		foreach(Player, i)
		{
			if(PlayerCar[i] == vehicleid)
			{
				if(i != playerid)
				{
					new bool:stop=false;
					new model=GetVehicleModel(vehicleid);
					for(new y;y<150;y++)
					{
						if(!stop)
						{
							for(new x;x<MAX_DARBINES_CAR;x++)
							{
								if(DarbinesCar[y][x][DCmodel] == model)
								{
									stop=true;
									if(y<100)
									{
										/*if(playerDB[playerid][specialybe] == playerDB[i][specialybe] && playerDB[playerid][specialybe] >= 80 && playerDB[playerid][specialybe] <= 84)
										{
											new msg[128];
											format(msg,sizeof(msg)," * Paëmëte kolegos %s automobilá.",ReturnName(i));
											SendClientMessage(playerid, -1,msg);
											format(msg,sizeof(msg)," * Jűsř automobilá paëmë kolega %s.",ReturnName(playerid));
											SendClientMessage(i, -1,msg);
										}
										else */
										if(!playerDB[playerid][admin])
										{
											Stop(playerid);
											new msg[128];
											format(msg,sizeof(msg)," * Jűs negalite vairuoti đio automobilio, nes jis priklauso %s",ReturnName(i));
											SendClientMessage(playerid, -1,msg);
											return 1;
										}
									}
									else if(y >= 100 && y < 110)
									{
										if(playerDB[playerid][pgang] != playerDB[i][pgang])
										{
											if(!playerDB[playerid][admin])
											{
												Stop(playerid);
												new msg[128];
												format(msg,sizeof(msg)," * Jűs negalite vairuoti đio automobilio, nes jis priklauso %s gaujai",FamilyInfo[y-100][FamilyName]);
												SendClientMessage(playerid, -1,msg);
												return 1;
											}
										}
										else
										{
											new query[128];
											format(query,sizeof(query),"UPDATE `gangcars` SET `lastuser`='%s' WHERE `lastuser`='%s' and `status`=2",ReturnName(playerid),ReturnName(i));
											mysql_query(query);
											DestroyOldCar(playerid);
											PlayerCar[playerid]=vehicleid;
											PlayerCar[i]=-1;
										}
									}
								}
							}
						}
					}
				}
				break;
			}
		}
		
	}
	if(oldstate == PLAYER_STATE_PASSENGER)
	{
		if(!playerDB[playerid][klausoimtuvo])
			StopAudioStreamForPlayer(playerid);
		if(taxiDB[playerid][imti]) //TAXI.Skaiciuojam, tik jei pinigai yra imami
		{
			/*new Float:Viet[2][3];
			GetPlayerPos(playerid,Viet[0][0],Viet[0][1],Viet[0][2]);
			Viet[1][0] = taxiDB[playerid][Start][0];
			Viet[1][1] = taxiDB[playerid][Start][1];
			Viet[1][2] = taxiDB[playerid][Start][2];*/
			//((floatround(floatabs(Viet[0][0]-Viet[1][0]))+floatround(floatabs(Viet[0][1]-Viet[1][1]))+floatround(floatabs(Viet[0][2]-Viet[1][2])))/3)/5;


			new kaina;
			new Float:Ex;
			Ex = ((GetTickCount() - taxiDB[playerid][Start])/60000.0);
			//printf("%f/%f/%i",Ex,Ex*MONEYP_TAKSISTAI,floatround(Ex*MONEYP_TAKSISTAI));
			if(playerDB[taxiDB[playerid][taksistas]][specialybe] == 3) kaina = floatround(Ex*MONEYP_TAKSISTAI);
			else if(GetVehicleModel(GetPlayerVehicleID(taxiDB[playerid][taksistas])) == 409) kaina = floatround(Ex*MONEYP_LIMUZINAI);
			else if(playerDB[taxiDB[playerid][taksistas]][specialybe] == 20) kaina = floatround(Ex*MONEYP_TRANSPORTERIAI);			

			PlayerTextDrawHide(taxiDB[playerid][taksistas],JobText[taxiDB[playerid][taksistas]]);
			PlayerTextDrawHide(playerid,JobText[playerid]);
			
			taxiDB[playerid][imti]=false;
			//if(GetVehicleModel(GetPlayerVehicleID(taxiDB[playerid][taksistas]))==409) kaina = kaina*2;
			static lastclient;
			if(lastclient != playerid && kaina > 15)
			{
				playerDB[taxiDB[playerid][taksistas]][jobpts]++;
				lastclient=playerid;
			}
			if(GetPlayerMoneyA(playerid) < kaina)
			{
			
				if(playerDB[playerid][banke] < kaina)
				{
					SendInfoMessage(taxiDB[playerid][taksistas],"Keleivis islipo, Valkata uz dyka paveziojai ..");
					SendInfoMessage(playerid,"Jums neuztenka pinigu!");
					if(playerDB[playerid][banke] > 0) 
					{
						GivePlayerMoneyA(taxiDB[playerid][taksistas],GetPlayerMoneyA(playerid)+playerDB[playerid][banke]);
						playerDB[playerid][banke]=0;
					}
					
					//pelnas[2]+=GetPlayerMoneyA(playerid);
					//ResetPlayerMoneyA(playerid);
				}
				else
				{
					new msg[128];
					format(msg,sizeof(msg),"Keleivis islipo, mokestis uz paslaugas: %i EUR",kaina);
					SendInfoMessage(taxiDB[playerid][taksistas],msg);
					format(msg,sizeof(msg),"Aciu, kad naudojates musu paslaugomis, mokestis: %i EUR",kaina);
					SendInfoMessage(playerid,msg);
					new Float:kofas = 0.7;
					new irankas = floatround(kaina*kofas);
					new ipelna = kaina*8;//kaina-irankas;
					GivePlayerMoneyA(taxiDB[playerid][taksistas],irankas);
					Pelnas(taxiDB[playerid][taksistas],2,ipelna);
					playerDB[playerid][banke]-=kaina;
				}
			}
			else
			{
				if(GetPlayerMoneyA(playerid) < 0)
				{
					SendClientMessage(taxiDB[playerid][taksistas],COLOR,"* Keleivis iđlipo, Jis turejo skola ir norëjo ja perduot tau...");
					//SendClientMessage(playerid,COLOR,"* Jusu pinigai susibugine!");
					ResetPlayerMoneyA(playerid);
				}
				else
				{
					new msg[128];
					format(msg,sizeof(msg),"Keleivis iđlipo, mokestis uţ paslaugas: %i EUR",kaina);
					SendInfoMessage(taxiDB[playerid][taksistas],msg);
					format(msg,sizeof(msg),"Ačiű, kad naudojatës műsř paslaugomis, mokestis: %i EUR",kaina);
					SendInfoMessage(playerid,msg);
					new Float:kofas = 0.7;
					new irankas = floatround(kaina*kofas);
					new ipelna = kaina*8;//kaina-irankas;
					GivePlayerMoneyA(taxiDB[playerid][taksistas],irankas);
					Pelnas(taxiDB[playerid][taksistas],2,ipelna);
					GivePlayerMoneyA(playerid,-kaina);
					//pelnas[2]+=kaina;
				}
			}
			taxiDB[playerid][taksistas] = -1;
		}
	}
	else if(newstate == PLAYER_STATE_ONFOOT)
	{
		KillTimer(BlinkTime[playerid]);
		BlinkTime[playerid]=-1;
	}
	if(playerDB[playerid][pila]) playerDB[playerid][pila]=false;
    aktivuotas[playerid] = false;
	if(newstate == PLAYER_STATE_WASTED) return 1;
	if(newstate != PLAYER_STATE_DRIVER)
	{
		if(!playerDB[playerid][ant] && !playerDB[playerid][suristas])
		TogglePlayerControllable(playerid,true);
	}
	new model = GetVehicleModel(vehicleid);
	
	if(newstate == PLAYER_STATE_DRIVER || newstate == PLAYER_STATE_PASSENGER)
	{
		PassengerCrashCheck(playerid,newstate);
	    if(playerDB[playerid][pila]) RemovePlayerFromVehicle(playerid);
		//playerDB[playerid][pCar]=vehicleid;
		ShowVehicleName(playerid, model);
		if(BitFlag_Get(PConfig[playerid],PCFG_SHOWSPEEDO))
		{
			new string[10];
			TextDrawShowForPlayer(playerid, kmhTD);
			PlayerTextDrawShow(playerid, Speedo[playerid]);
			
			new Float:HP;
			GetVehicleHealth(vehicleid, HP);
			format(string,10,"%.1f",HP);
			PlayerTextDrawSetString(playerid,VehicleHP[playerid],string);
			PlayerTextDrawShow(playerid, VehicleHP[playerid]);
			
			//if(!IsAPBike(vehicleid))
			{
				// degalai, akumas
				SetProgressBarValue(Akumas, vehicleDB[vehicleid][energy]);
				SetProgressBarMaxValue(Degalai, ((aBakai[model-400] > 0) ? (aBakai[model-400]) : (1)));
				SetProgressBarValue(Degalai, vehicleDB[vehicleid][gas]);

				format(string,sizeof(string),"%.1fL",vehicleDB[vehicleid][gas]);
				PlayerTextDrawSetString(playerid,DegalasTD[playerid],string);
				
				format(string,sizeof(string),"%.1f%%",vehicleDB[vehicleid][energy]);
				PlayerTextDrawSetString(playerid,AkumasTD[playerid],string);
				ShowProgressBarForPlayer(playerid,Degalai);
				ShowProgressBarForPlayer(playerid,Akumas);
				PlayerTextDrawShow(playerid, DegalasTD[playerid]);
				PlayerTextDrawShow(playerid, AkumasTD[playerid]);
			}
		}
		else
			SendClientMessage(playerid,COLOR," * Spidometra galite ájungti nustatymuose: naudokite /p");
		if(IsABike(vehicleid) && playerDB[playerid][salmas])
	    {
			UzdetiSalma(playerid,Salmai[playerDB[playerid][salmas]-1]);
		}
	}
	else
	{
		//SetPlayerTeam(playerid,1);
	    RemovePlayerAttachedObject(playerid, SALMO_SLOT);
		/*TextDrawHideForPlayer(playerid,esp[playerid]);
		TextDrawHideForPlayer(playerid,esg[playerid]);
		TextDrawHideForPlayer(playerid,Textdraw0);
		TextDrawHideForPlayer(playerid,Textdraw5); */
		// gas, akum
		HideProgressBarForPlayer(playerid,Degalai);
		HideProgressBarForPlayer(playerid,Akumas);
		PlayerTextDrawHide(playerid,DegalasTD[playerid]);
		PlayerTextDrawHide(playerid,AkumasTD[playerid]);
        TextDrawHideForPlayer(playerid, kmhTD);
        PlayerTextDrawHide(playerid,Speedo[playerid]);
        PlayerTextDrawHide(playerid,JobText[playerid]);      
        PlayerTextDrawHide(playerid,VehicleHP[playerid]);
		/*if(playerDB[playerid][stotis] != 0 && (0 < playerDB[playerid][masina] < 2000) && !playerDB[playerid][klausoisadmin])
		{

			StopAudioStreamForPlayer(playerid);
			playerDB[playerid][klausosi]=0;
			PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[playerDB[playerid][stotis]-1][RADIO_URL],Coo[0],Coo[1],Coo[2],15.0,true);
			//Audio_Set3DPosition(playerid, playerDB[playerid][radija], Coo[0],Coo[1],Coo[2], 20);
			playerDB[playerid][klausosi]=playerDB[playerid][masina];
		}      
		*/
		if(vagia[playerid])
		{
			DisablePlayerCheckpoint(playerid);
			vagia[playerid]=0;
		}
		//if(vezainama[playerid] || vezaibanko[playerid] || vezaivieta[playerid])
		if(vezaibanko[playerid] || (vezaivieta[playerid] && GetPVarInt(playerid, "NukeType") == 0) || bmx[playerid] != -1)
		{
		    DisablePlayerCheckpoint(playerid);
			if(!KDalyvis[playerid][Dalyvauja] && IsInRace(playerid) == 0)
				DisablePlayerRaceCheckpoint(playerid);
		}
	}
	if(oldstate == PLAYER_STATE_DRIVER)
	{
		new tempas=vehicleid;
		vehicleid=playerDB[playerid][masina];
		vehicleDB[vehicleid][uzeris]=INVALID_PLAYER_ID;
	    GetVehicleHealth(vehicleid,vehicleDB[vehicleid][OldHP]);
		GetVehicleHealth(vehicleid,VHealth[vehicleid]);
		VNoCheck[vehicleid]=1;
		if(VehicleRadio[vehicleid] && !playerDB[playerid][klausoimtuvo])
			StopAudioStreamForPlayer(playerid);
		//GetVehiclePos(playerDB[playerid][masina],vehicleDB[playerDB[playerid][masina]][lastpos][0],vehicleDB[playerDB[playerid][masina]][lastpos][1],vehicleDB[playerDB[playerid][masina]][lastpos][2]);
		//GetVehicleZAngle(playerDB[playerid][masina],vehicleDB[playerDB[playerid][masina]][lastpos][3]);
        if(playerDB[playerid][masina] == Club1 && playerDB[playerid][DrivingTest] == 1)
		{
			GameTextForPlayer(playerid," ~y~ Testas ~r~ neislaikytas ~n~ ~w~ Nes jus palikote automobili.~n~ Prasome bandyti is naujo.",5000,3);
			SetVehicleToRespawn(playerDB[playerid][masina]);
			SetPlayerVirtualWorld(playerid,0);
			SetVehicleVirtualWorld(playerDB[playerid][masina],0);
			playerDB[playerid][DrivingTest] = 0;
			DisablePlayerRaceCheckpoint(playerid);
		}
		else if(playerDB[playerid][masina] == Club2 && playerDB[playerid][DrivingTest] == 1)
		{
			GameTextForPlayer(playerid," ~y~ Testas ~r~ neislaikytas ~n~ ~w~ Nes jus palikote automobili.~n~ Prasome bandyti is naujo.",5000,3);
			SetVehicleToRespawn(playerDB[playerid][masina]);
			SetPlayerVirtualWorld(playerid,0);
			SetVehicleVirtualWorld(playerDB[playerid][masina],0);
			playerDB[playerid][DrivingTest] = 0;
			DisablePlayerRaceCheckpoint(playerid);
		}
		else if(playerDB[playerid][masina] == Club3 && playerDB[playerid][DrivingTest] == 1)
		{
			GameTextForPlayer(playerid," ~y~ Testas ~r~ neislaikytas ~n~ ~w~ Nes jus palikote automobili.~n~ Prasome bandyti is naujo.",5000,3);
			SetVehicleToRespawn(playerDB[playerid][masina]);
			SetPlayerVirtualWorld(playerid,0);
			SetVehicleVirtualWorld(playerDB[playerid][masina],0);
			playerDB[playerid][DrivingTest] = 0;
			DisablePlayerRaceCheckpoint(playerid);
		}
