public Gydimas(playerid)
{
	if(!IsPlayerConnected(playerid)) return KillTimer(Gydosi[playerid]),Gydosi[playerid]=-1;
	new Float:HP;
	GetPlayerHealth(playerid,HP);
	if(playerDB[playerid][narko][1] || playerDB[playerid][pligonis])
	{
		if(HP+10 <= 150)
		{
			SetPlayerHealth(playerid,HP+10);
			Gydosi[playerid] = SetTimerEx("Gydimas",3000,false,"i",playerid);
		}
		else
		{
			KillTimer(Gydosi[playerid]);
			Gydosi[playerid]=-1;
			playerDB[playerid][mire]=false;
			TogglePlayerControllable(playerid,true);
			ClearAnimations(playerid, 1);
			SendInfoMessage(playerid,"~y~Jus visiskai sveikas.");
		}
	}
	else
	{
		if(HP+10 <= 100)
		{
			SetPlayerHealth(playerid,HP+10);
			Gydosi[playerid] = SetTimerEx("Gydimas",5000,false,"i",playerid);
		}
		else
		{
			KillTimer(Gydosi[playerid]);
			Gydosi[playerid]=-1;
			playerDB[playerid][mire]=false;
			TogglePlayerControllable(playerid,true);
			ClearAnimations(playerid, 1);
			SendInfoMessage(playerid,"~y~Jus visiskai sveikas.");
			ProcessAchievement(playerid,26);
		}
	}
	return 1;
}

