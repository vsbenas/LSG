stock RadioList(playerid,bool:imtuv)
{
	new string[1024];
	format(string,sizeof(string),"Stabdyti\nKeisti garsa");
	for(new i, j = sizeof(RADIO_PLUGIN); i < j; i++)
	{
		format(string,sizeof(string),"%s\n%s",string,RADIO_PLUGIN[i][RADIO_NAME]);
	}
	new dialog = (imtuv?(9750):(9755));
	ShowPlayerDialog(playerid,dialog,DIALOG_STYLE_LIST,"Radija",string,"Rinktis","Isjungti");
	

}

stock IsCheatPosition (playerid)//Teleporting to these locations is always cheating!
{
	for (new i = 0; i < sizeof (CheatPositions); ++i)
		if (IsPlayerInRangeOfPointEx (5.0, playerid, CheatPositions [i][0], CheatPositions [i][1], CheatPositions [i][2]))
			return true;
	return false;
}





stock PopPlayerTires(playerid)
{
	new vehicleid = GetPlayerVehicleID(playerid);
	if(vehicleid != 0 && !(IsKobraCheetah(vehicleid) && GetVehicleModel(vehicleid) == 415))
	{
		new value[4];
		GetVehicleDamageStatus(vehicleid, value[0], value[1], value[2], value[3]);
		UpdateVehicleDamageStatus(vehicleid, value[0], value[1], value[2], 15);
	}
}
new Text3D:StingerTD[ALLOWED_PICKUPS];
stock CreateLargeStinger(playerid,Float:Xp, Float:Yp, Float:Zp, Float:Ap, virtualworld, timer)
{
	for(new stingerid = 0; stingerid < sizeof(iPickups); stingerid++)
	{
		if(iPickups[stingerid][0] == -1)
		{
		    new Float:dis1 = floatsin(-Ap, degrees), Float:dis2 = floatcos(-Ap, degrees);
			iPickups[stingerid][0] = CreateDynamicObject(2892, Xp, Yp, Zp, 0.0, 0.0, Ap);
			iPickups[stingerid][1] = CreatePickupA(1007, 14, Xp+(4.0*dis1), Yp+(4.0*dis2), Zp, virtualworld);
			iPickups[stingerid][2] = CreatePickupA(1007, 14, Xp+(1.25*dis1), Yp+(1.25*dis2), Zp, virtualworld);
			iPickups[stingerid][3] = CreatePickupA(1007, 14, Xp-(4.0*dis1), Yp-(4.0*dis2), Zp, virtualworld);
			iPickups[stingerid][4] = CreatePickupA(1007, 14, Xp-(1.25*dis1), Yp-(1.25*dis2), Zp, virtualworld);
			YraSpygliu++;
			if(timer > 0)
			{
				SetTimerEx("DestroyStinger", timer, 0, "i", stingerid);
			}
			new tmp[128];
			format(tmp,128,"Spyglius padëjo: {33CC00}%s",ReturnName(playerid));
			StingerTD[stingerid] = CreateDynamic3DTextLabel( tmp, 0xFFFFFFFF,Xp,Yp,Zp+2.0,5.0);
			return stingerid;
		}
	}
	return -1;
}

stock CreateSmallStinger(playerid,Float:Xp, Float:Yp, Float:Zp, Float:Ap, virtualworld, timer)
{
	for(new stingerid = 0; stingerid < sizeof(iPickups); stingerid++)
	{
		if(iPickups[stingerid][0] == -1)
		{
		    new Float:dis1 = floatsin(-Ap, degrees), Float:dis2 = floatcos(-Ap, degrees);
			iPickups[stingerid][0] = CreateDynamicObject(2899, Xp, Yp, Zp, 0.0, 0.0, Ap);
			iPickups[stingerid][1] = CreatePickupA(1007, 14, Xp+(1.5*dis1), Yp+(1.5*dis2), Zp, virtualworld);
			iPickups[stingerid][2] = CreatePickupA(1007, 14, Xp-(1.5*dis1), Yp-(1.5*dis2), Zp, virtualworld);
			YraSpygliu++;
			if(timer > 0)
			{
				SetTimerEx("DestroyStinger", timer, 0, "i", stingerid);
			}
			new tmp[128];
			format(tmp,128,"Spyglius padëjo: {33CC00}%s",ReturnName(playerid));
			StingerTD[stingerid] = CreateDynamic3DTextLabel( tmp, 0xFFFFFFFF,Xp,Yp,Zp+2.0,5.0);
			return stingerid;
		}
	}
	return -1;
}

public DestroyStinger(stingerid)
{
	DestroyDynamicObject(iPickups[stingerid][0]);
	DestroyPickup(iPickups[stingerid][1]);
	DestroyPickup(iPickups[stingerid][2]);
	DestroyPickup(iPickups[stingerid][3]);
	DestroyPickup(iPickups[stingerid][4]);
	iPickups[stingerid][0] = -1;
	iPickups[stingerid][1] = -1;
	iPickups[stingerid][2] = -1;
	iPickups[stingerid][3] = -1;
	iPickups[stingerid][4] = -1;
	DestroyDynamic3DTextLabel(StingerTD[stingerid]);
	StingerTD[stingerid] = Text3D:-1;
	YraSpygliu--;
}
