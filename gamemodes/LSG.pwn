		case 2: SetPlayerFightingStyle(playerid,FIGHT_STYLE_KUNGFU);
		case 3: SetPlayerFightingStyle(playerid,FIGHT_STYLE_GRABKICK);
		case 4: SetPlayerFightingStyle(playerid,FIGHT_STYLE_KNEEHEAD);
