	RemovePlayerAttachedObject(playerid,CUFF_SLOT);
	SetPlayerSpecialAction(playerid, SPECIAL_ACTION_NONE);
	//SetPlayerInterior(playerid,interior);
	//SetPlayerPoz(playerid,x,y,z);
	//SetCameraBehindPlayer(playerid);
	SetPlayerPosFade(playerid,20,x,y,z,interior,0);
	SetPlayerFacingAngle(playerid,a);
	SetPlayerWantedLevel(playerid,0);
	playerDB[playerid][ikalintas]=true;
	playerDB[playerid][suristas]=false;
	//SetPlayerVirtualWorld(playerid, 0);
}

stock FuruRespawn() // ir vagys
{
	new skip[MAX_VEHICLES];
	for(new i;i<MAX_VEHICLES;i++)
	{
		if(GetVehicleModel(i) && IsTrailerAttachedToVehicle(i)) skip[GetVehicleTrailer(i)]=1;
	}
	for(new i;i<MAX_VEHICLES;i++)
	{
		new model = GetVehicleModel(i);
		new v = i;
		if(IsVagiuCar(v))
		{
			new driver = GetDriver(v);
			if(driver == INVALID_PLAYER_ID)
			{
				SetVehicleToRespawn(v);
			}
		}

		
		if(model == 435 || model == 584 || model == 591 || model == 610)
		{
			if(!skip[i])
			{
				new speed = GetSpeedEx(i);
				if(speed < 5)
				{
					SetVehicleToRespawn(i);
				}
			}
		}
	}

}
public GlobalUpdatez()
{
	foreach (Player, i)
	{
        if(playerDB[i][airbrk])
		    playerDB[i][airbrk]--;
		if(CBugWarnings[i])
			CBugWarnings[i]--;
		if(TeleportWarnings[i])
			TeleportWarnings[i]--;
		if(playerDB[i][kalejimo_laikas] < 0)
			playerDB[i][kalejimo_laikas]=0;
		if(PingWarn[i])
			PingWarn[i]--;
		//if(GunWarn{i})
		//	GunWarn{i}--;
		if(EnterWarn{i})
			EnterWarn{i}--;
		if(DeathCount[i])
			DeathCount[i]--;

        TpCarCount[i] = 0;

		if(GetPVarInt(i, "WarnedForKulkos"))
			SetPVarInt(i, "WarnedForKulkos", 0);
	}
	FireTime(); // kas 4 min
	if(NuclearBlast[NukeInProgress] == 3)
	{
		new progressTrash = floatround((NuclearBlast[TotalObjectsDestroyed]*100.0)/(NuclearBlast[TotalObjectsCreated]));
		new progressBuild = floatround((NuclearBlast[TotalObjectsRecovered]*100.0)/NuclearBlast[TotalObjectsNuked]);
		if(progressTrash >= 99 && progressBuild >= 99)
		{
			SendClientMessageToAll(COLOR_GOLD, "[ATOMINE BOMBA] Los santos miestas tapo atstatytas po atominës bombos!");

			DestroyProps();
			NuclearBlast[NukeInProgress] = 4;
		}
		else
		{
			SendClientMessageToAll(-1, " [ATOMINE BOMBA] Los santos mieste sprogo atominë bomba! Prađome visř Los Santos gyventojř laikytis protokolo /atominebomba");
		}
	}
	return 1;
}



SendMessageToFamily(id,color,text[])
{
	foreach(Player, i) if(playerDB[i][pgang]==id && BitFlag_Get(PConfig[i],PCFG_SHOWGCHAT)) SendClientMessage(i,color,text);
}


stock SavePlayer(playerid, bool:simple)
{
	new query[2048],
		weps[2][13],
		Float:coo[3],
		Float:HP,Float:Armour,
		IP[20],
		name[MAX_PLAYER_NAME],
		State;
	State = GetPlayerState(playerid);
	GetPlayerName(playerid,name,MAX_PLAYER_NAME);
	GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
	GetPlayerIp(playerid,IP,sizeof(IP));
	if(playerDB[playerid][psratasvydis] && !simple) 
		SetPlayerVirtualWorld(playerid,0);
	if(State != PLAYER_STATE_DRIVER)
		UpdateGunData(playerid);
	if(State!=PLAYER_STATE_WASTED)
	{

		for (new tmp=0; tmp<13; tmp++)
		{

			if(playerDB[playerid][psratasvydis])
			{
				weps[0][tmp] = playerDB[playerid][spdata][tmp];
				weps[1][tmp] = playerDB[playerid][spdata][12+tmp];
			}
			else
			{
				weps[0][tmp] = GunData[playerid][tmp][0];
				weps[1][tmp] = GunData[playerid][tmp][1];

			}
		}
		GetPlayerHealth(playerid,HP);
		GetPlayerArmour(playerid,Armour);
		if(HP<20.0) HP=20.0;
	}
	else
	{
		HP=20.0;
		Armour=0.0;
	}
	
	if(!simple) // kai issavini
	{
		format(query,sizeof(query),"UPDATE `Account` SET `Money.Pocket` = %i, `Money.Bank` = %i, Seklos = %i, Zole = %i, Wanted = %i, Gangas = %i, Kalejime = %i, Mobsas = %i, Namu = %i, Kepure = %i, Salmas = %i,",
		GetPlayerMoneyA(playerid),playerDB[playerid][banke],playerDB[playerid][seklos],playerDB[playerid][zole],GetPlayerWantedLevel(playerid),playerDB[playerid][pgang],
		playerDB[playerid][kalejimo_laikas],playerDB[playerid][mobsas],playerDB[playerid][namu],playerDB[playerid][kepure],playerDB[playerid][salmas]);

		format(query,sizeof(query),"%s Stilius = %i, pBoxiSkill = %i, pKneeSkill = %i, pKungSkill = %i, pGrabSkill = %i, pElbowSkill = %i, Job = %i, Drabuziai = %i, Uniforma = %i, Uniformd = %i, Adminas = %i, Xp = %i, Lytis = %i,",
	    query,playerDB[playerid][pFS],playerDB[playerid][pBoxiSkill],playerDB[playerid][pKneeSkill],playerDB[playerid][pKungSkill],playerDB[playerid][pGrabSkill],playerDB[playerid][pElbowSkill],playerDB[playerid][specialybe],playerDB[playerid][drabuziai],playerDB[playerid][uniforma],playerDB[playerid][uniformd],playerDB[playerid][admin],GetPlayerScore(playerid),playerDB[playerid][lytis]);

		format(query,sizeof(query),"%s pos_X = '%f', pos_Y = '%f', pos_Z = '%f', Interior = %i, Drugs = %i, MotoLicense = %i, SLicense = %i, Laikrodis = %i, World = %i, Insurance = %i, Teises = %i,Teorinis = %i, Kortele = %i, Imtuvas = %i, IP = '%s', Akiniai=%i WHERE Name = '%s'",
		query,coo[0],coo[1],coo[2],GetPlayerInterior(playerid),playerDB[playerid][amfetaminas],playerDB[playerid][teisesm],playerDB[playerid][teisess],playerDB[playerid][laikrodis], GetPlayerVirtualWorld(playerid),playerDB[playerid][draudimas],playerDB[playerid][teises],playerDB[playerid][teor],playerDB[playerid][kortele],playerDB[playerid][imtuvas],IP,playerDB[playerid][akiniai],name);
	}
	else
	{
		new money = GetPlayerMoneyA(playerid);
		if(playerDB[playerid][playingpoker])
		{
			new id=-1,pid=-1;
			for(new x;x<MAX_POKER_GAMES;x++)
			{
				for(new i;i<6;i++)
				{
					if(Poker[x][players][i] == playerid)
					{
						id=x;
						pid=i;
						break;
					}
				}
			}
			if(id != -1 && pid != -1)
			{
				money += Poker[id][PFondas][pid];
			}
		}
	    format(query,sizeof(query),"UPDATE `Account` SET `Money.Pocket` = %i, `Money.Bank` = %i, Seklos = %i, Zole = %i, Wanted = %i, Gangas = %i, Kalejime = %i, Mobsas = %i, Namu = %i, Ginklas0 = %i, Ammo0 = %i,Ginklas1 = %i, Ammo1 = %i,Ginklas2 = %i, Ammo2 = %i,Ginklas3 = %i, Ammo3 = %i,Ginklas4 = %i, Ammo4 = %i,Ginklas5 = %i, Ammo5 = %i,Ginklas6 = %i, Ammo6 = %i,CFG=%i,Ginklas7=%i,Ammo7=%i,",
	    money,playerDB[playerid][banke],playerDB[playerid][seklos],playerDB[playerid][zole],GetPlayerWantedLevel(playerid),
	    playerDB[playerid][pgang],playerDB[playerid][kalejimo_laikas],playerDB[playerid][mobsas],playerDB[playerid][namu],
	    weps[0][0],weps[1][0],weps[0][1],weps[1][1],weps[0][2],weps[1][2],weps[0][3],weps[1][3],weps[0][4],weps[1][4],weps[0][5],weps[1][5],weps[0][6],weps[1][6],_:PConfig[playerid],weps[0][7],weps[1][7]);

		format(query,sizeof(query),"%s Ginklas8=%i,Ammo8=%i,Ginklas9=%i,Ammo9=%i,Ginklas10=%i,Ammo10=%i,Ginklas11=%i,Ammo11=%i,Job=%i,Uniforma=%i,Uniformd=%i,Adminas=%i,Drugs=%i,MotoLicense=%i,SLicense=%i,Teises=%i,`Lead`=%i,Raktas=%i,Pradirbo=%i,F0=%i,F1=%i,F2=%i,F3=%i,F4=%i,F5=%i,F6=%i,F7=%i,Zuvis=%i,Masalas=%i,Sotumas=%i,LSD=%i,Ratai=%i,Cig=%i,HP=%i,Armour=%i,Naud=%i,",
	   	query,weps[0][8],weps[1][8],weps[0][9],weps[1][9],weps[0][10],weps[1][10],weps[0][11],weps[1][11],
	    playerDB[playerid][specialybe],playerDB[playerid][uniforma],playerDB[playerid][uniformd],playerDB[playerid][admin],
	    playerDB[playerid][amfetaminas],playerDB[playerid][teisesm],playerDB[playerid][teisess],playerDB[playerid][teises],playerDB[playerid][plead],playerDB[playerid][raktas],playerDB[playerid][pradirbo],
		playerDB[playerid][fejerverkai][0],playerDB[playerid][fejerverkai][1],playerDB[playerid][fejerverkai][2],playerDB[playerid][fejerverkai][3],playerDB[playerid][fejerverkai][4],playerDB[playerid][fejerverkai][5],playerDB[playerid][fejerverkai][6],playerDB[playerid][fejerverkai][7],playerDB[playerid][zuvis],playerDB[playerid][masalas],(floatround(playerDB[playerid][sotumas])),playerDB[playerid][lsd],playerDB[playerid][ratai],playerDB[playerid][cigaretes],
		(floatround(HP)),(floatround(Armour)),playerDB[playerid][jobpts]);
		
		format(query,sizeof(query),"%s Bakelis=%i, Insurance = %i, Loterijos = %i, Adrenalinas = %i WHERE Name = '%s'",query,playerDB[playerid][bakelis],playerDB[playerid][draudimas],playerDB[playerid][loterijos],playerDB[playerid][adr],name);
	}
	mysql_query(query);
	return 1;
}

