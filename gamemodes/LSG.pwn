stock PadetiMasina(playerid,id)
{
	new CarArray[ahCar];
	if(id == 0)
		CarArray = Carlist[playerid];
	else if(id == 1)
		CarArray = Carlist2[playerid];
	else if(id == 2)
		CarArray = Carlist3[playerid];

	if(CarArray[Carid] == -1)
	{
		SendInfoMessage(playerid,"Sprogusio automobilio padeti negali!");
		ShowSaugykla(playerid);
		return 0;
	}	
	if(TradingWith[playerid] != -1) 
	{
		SendInfoMessage(playerid, "Uzdaryk mainus");
		return 0;
	} 
	new Float:HP;
	GetVehicleHealth(CarArray[Carid],HP);
    if(vehicleDB[CarArray[Carid]][dega] || HP < 300)
	{
		SendInfoMessage(playerid,"Pataisyk automobili!");
		ShowSaugykla(playerid);
		return 0;
	}
	new name[MAX_PLAYER_NAME];
	new var[4048];
	GetPlayerName(playerid, name, sizeof(name));
	printf("[car saugykla] %s padejo automobili id %i modelis %i i saugykla. Rida %.2f",ReturnName(playerid),id,CarArray[Typ],vehicleDB[CarArray[Carid]][rida]);
	format(var,sizeof(var),"UPDATE `CarSaugykla` SET Typ=%i,X='%f',Y='%f',Z='%f',Rot='%f',`Status`=%i,`Lock`=%i,Paintjob=%i,Color1=%i,Color2=%i,mod1=%i,mod2=%i,mod3=%i,mod4=%i,mod5=%i,mod6=%i,mod7=%i,mod8=%i,mod9=%i,mod10=%i,mod11=%i,mod12=%i,mod13=%i,mod14=%i,mod15=%i,mod16=%i,mod17=%i,Nr='%s',Draud=%i,vw=%i,Sirena=%i",
	CarArray[Typ],CarArray[X],CarArray[Y],CarArray[Z],CarArray[Rotation],CarArray[Status],CarArray[Lock],CarArray[Paintjob],CarArray[Color1],CarArray[Color2],
	CarArray[mod1],CarArray[mod2],CarArray[mod3],CarArray[mod4],CarArray[mod5],CarArray[mod6],CarArray[mod7],CarArray[mod8],CarArray[mod9],CarArray[mod10],
	CarArray[mod11],CarArray[mod12],CarArray[mod13],CarArray[mod14],CarArray[mod15],CarArray[mod16],CarArray[mod17],CarArray[NumPlate],CarArray[CDraud],CarArray[VirtualW],CarArray[Sirena]);

	GetVehicleHealth(CarArray[Carid],HP);
	CarArray[Rida]=vehicleDB[CarArray[Carid]][rida];
	Kraunasi[CarArray[Carid]]=0;
	format(var, sizeof(var), "%s,Gas=%i,Energy=%i,Rankinis=%i,VeHP=%i,Rida=%i",var, (floatround(vehicleDB[CarArray[Carid]][gas])),(floatround(vehicleDB[CarArray[Carid]][energy])),vehicleDB[CarArray[Carid]][rankinis],floatround(HP),floatround(CarArray[Rida]));
	vehicleDB[CarArray[Carid]][rankinis]=false;
	format(var,sizeof(var),"%s WHERE Vardas='%s' AND Id=%i",var,name,GetPVarInt(playerid, "SaugyklosId"));
	
	mysql_query(var);
	SetVehicleParamsForAll(CarArray[Carid] ,0,0);
	DestroyVehicle(CarArray[Carid]);
	ClearCarList(playerid,id+1);
	SendInfoMessage(playerid,"~g~Sekmingai pastatei automobili garaze!");
    return 1;
}

