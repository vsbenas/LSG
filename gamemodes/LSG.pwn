forward OnPlayerTargetActor(playerid, newtarget, oldtarget);
public OnPlayerTargetActor(playerid, newtarget, oldtarget)
{

    if (newtarget != INVALID_ACTOR_ID && newtarget != pdactor1 && newtarget != elfas && newtarget != pdactor2 && newtarget != cezarionpc && newtarget != MedikuDB[med_pedid])
    {
    	new wep = GetPlayerWeapon(playerid);
    	if(wep)
        ApplyActorAnimation(newtarget, "PED", "handsup", 4.1, 0, 0, 0, 1, 0);
    }
    if (oldtarget != INVALID_ACTOR_ID && oldtarget != pdactor1 && oldtarget != elfas && oldtarget != pdactor2 && oldtarget != cezarionpc && oldtarget != MedikuDB[med_pedid])
    {
        ClearActorAnimations(oldtarget);
        if(random(5)==1)
        	ApplyActorAnimation(oldtarget, "COP_AMBIENT", "Coplook_loop", 4.0, 0, 1, 1, 1, -1);
        else
      		ApplyActorAnimation(oldtarget, "SHOP", "SHP_Serve_Idle", 4.0,1,0,0,0,0);
        //ApplyActorAnimation(oldtarget, "SHOP", "SHP_Serve_Idle", 4.0,1,0,0,0,0);
    }
}
new timeset[MAX_PLAYERS];
new targetting[MAX_PLAYERS];
new warnings[MAX_PLAYERS];

new 
	OldSpeed[MAX_PLAYERS];
new 
	Float:PlayerCap[MAX_PLAYERS];

public OnPlayerUpdate(playerid)
{
	if(PlayerNPC[playerid]) 
		return 1;
	if(NotSpawned[playerid]) 
		return 0;

	//raceUpdate(playerid);
	PlayerTick[playerid] = GetTickCount();
    new	veh = GetPlayerVehicleID(playerid);
	if(!veh)
	{
		if(PlayerSpectated[playerid] != -1)
		{
			SpectateInfo(playerid,0);
		}
		FIXES_gsLastAnimation[playerid] = GetPlayerAnimationIndex(playerid);

		if(FIXES_gsLastAnimation[playerid] == 1195)
		{
			Jumped[playerid]=true;
			if(PlayerWalking[playerid])
			{
				Iter_Remove(PlayersWalking, playerid);
				PlayerWalking[playerid]=0;
			}
		}
		else if(Jumped[playerid])
		{
			if(FIXES_gsLastAnimation[playerid] == 1196)
			{
				ApplyAnimation(playerid,"PED","FALL_LAND",4.1,0,0,0,0,0,0);
			}
			if(FIXES_gsLastAnimation[playerid] == 1132)
			{
				SetTimerEx("BhopA",400,false,"i",playerid);
			}
			Jumped[playerid]=false;
			JumpStatus[playerid]=15;
		}
		else if(JumpStatus[playerid]) 
			JumpStatus[playerid]--;


		if(PlayerAiming[playerid]) // set OnPlayerKeyStateChange
		{
			new tid = GetPlayerTargetPlayer(playerid);
			if(targetting[playerid]==0 && tid != INVALID_PLAYER_ID)
			{
				timeset[playerid]=PlayerTick[playerid];
				targetting[playerid]=1;
			}
			else if(targetting[playerid] == 1 && tid == INVALID_PLAYER_ID)
			{
				new time = PlayerTick[playerid] - timeset[playerid];
				targetting[playerid]=0;
				if(time < 500)
				{
					warnings[playerid]++;
					if(warnings[playerid] == 3)
					{
						AC_Warn(playerid,"Trigger AIM");
						warnings[playerid]=0;
					}
				}
			}

		}
		else if(targetting[playerid])
		{
			targetting[playerid] = 0;
			warnings[playerid] = 0;
		}
		new wep = GetPlayerWeapon(playerid);
		switch(wep)
		{
			case WEAPON_MINIGUN,WEAPON_UZI,WEAPON_ROCKETLAUNCHER,WEAPON_HEATSEEKER,32:
			{
				new place = GetPlace(playerid, /* houses= */ false);
				if(playerDB[playerid][admin] || (playerDB[playerid][psratasvydis] && place == PLACE_SRATASVYDIS) || place == PLACE_WORLD)
					return 1;

				if(playerDB[playerid][gunk][wep] && !playerDB[playerid][psratasvydis])
					return 1; // got it from lab

				if(!BeingKicked[playerid])
					AC_Kick(playerid,"Neleistini ginklai");
				return 0;
			}
		}
		return 1;
	}

	// END ON-FOOT SECTION
	// BEGIN DRIVER/PASSENGER SECTION

	new 
		statea = GetPlayerState(playerid);

	new 
			Float:HP,
			Speed,
			str[12];

	//Speed = GetSpeedEx(veh);

	GetSpeedExDefn(veh,Speed); // use define to avoid function call here. 

	GetVehicleHealth(veh,HP);

	if(HP != vehicleDB[veh][OldHP])
    {
    	format(str,12,"%.1f",HP);
		PlayerTextDrawSetString(playerid,VehicleHP[playerid],str);
    }

	if(Speed != OldSpeed[playerid]) // greatly reduced packet count!
	{
		format(str,12,"%d",Speed);
		PlayerTextDrawSetString(playerid,Speedo[playerid],str);
		OldSpeed[playerid]=Speed;
	}
	if(PlayerSpectated[playerid] != -1)
	{
		SpectateInfo(playerid,veh+1,Speed,HP);
	}
	if(statea != PLAYER_STATE_DRIVER)
		return 1;

	// END NON-DRIVER SECTION
	if(IsPlayerInWorld(playerid))
	{
		return 1;
	}
	new Float:Cap = PlayerCap[playerid];

 	if(Speed > 300)
	{

		if(GetPVarInt(playerid,"Nowarn") == 1)
		{
			SetPVarInt(playerid, "Nowarn", 0);
		}
		else
		{
			if(GetVehicleModel(veh) == 537 || GetVehicleModel(veh) == 538)
			{
				AC_Kick(playerid, "Cheats detected 3");
				return 1;
			}
			ProcessAchievement(playerid,92);
			new reason[128];
		    format(reason,sizeof(reason),"SPEED ~%d KM/H",Speed);
		    AC_Warn(playerid,reason);
		}
	    TogglePlayerControllable(playerid,false);
	    if(!Atfreezinti[playerid])
	   		SetTimerEx("Atfreezint",500,false,"i",playerid);
	    Atfreezinti[playerid] = 1;
	}

	if(veh != playerDB[playerid][pCar])  // anti carjack
	{
		if(HP < 300)
		{
			AC_Warn(playerid,"Car boomer");

			new idx;
			new ida = GetPlayerFromCarlistID(veh,idx);
			if(idx != playerid)
			{
				new time_lock = GetTickCount() - VehicleLocked[veh][2];
				new kick = 0;
				//GetVehicleParamsEx(veh,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
				switch(ida)
				{
					case 1: if(Carlist[idx][Lock] && !playerDB[playerid][admin] && !IsAPBike(veh) && time_lock > 5000) {kick = 1;}
					case 2: if(Carlist2[idx][Lock] && !playerDB[playerid][admin] && !IsAPBike(veh)&& time_lock > 5000) {kick = 1;}
					case 3: if(Carlist3[idx][Lock] && !playerDB[playerid][admin] && !IsAPBike(veh)&& time_lock > 5000) {kick = 1;}// return AC_Kick(playerid,"Carjack",1);
					default: {kick = 0;}
				}
				if(kick == 1)
				{
					AC_Kick(playerid,"Car boomer.",1);
					return 0;
				}
			}
			return 0;
		}
	}


    if(HP != vehicleDB[veh][OldHP])
    {		
    	new model = GetVehicleModel(veh);
		if(HP+35.0 < vehicleDB[veh][OldHP])
		{
			if(CheckVelykos(playerid))
			{
				SendInfoMessage(playerid,"Suduzo kiausinis!");
			}
		}
	    if(HP+90.0 < vehicleDB[veh][OldHP])
		{
			GetVehicleParamsEx(veh,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
			if(VehVars[0] && !IsAPBike(veh) && model != 428 && model != 432) // securicar
			{
				if(PlayerTick[playerid]-VehicleShot[veh] > 1000) // not shot
				{
					SetVehicleParamsEx(veh,false,VehVars[1],VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
					SendInfoMessage(playerid,"Uzgeso variklis!");
				}
			}
		}
		if(HP < 250.0)
		{
			if(!vehicleDB[veh][dega])
			{
				switch(model)
				{
					case 592,577,511,512,593,520,553,476,519,460,513,546,425,417,487,488,563,469,BMX,BIKE,MTBIKE: return 1;
					case 556,444,452,495,494,502,503,571,471,539,504: return 1; // event
					case 441,464,465,501,564: return 1; // RC cars
				}
				vehicleDB[veh][dega]=3000;
				
				Iter_Add(Deganti,veh);
				vehicleDB[veh][sprogs]=30;
				GetVehicleParamsEx(veh,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
				if(PlayerCar[playerid] != veh)
					VehVars[5] = true;
				SetVehicleParamsEx(veh,false,VehVars[1],VehVars[2],-1,VehVars[4],VehVars[5],VehVars[6]);
				foreach(Player, i) if(IsPlayerInVehicle(i,veh)) RemovePlayerFromVehicle(i);

			}
			if(HP <= 200.0)
			{
				SetVehicleHealth(veh, 240.0);
			}
			return 1;
		}
		vehicleDB[veh][OldHP]=HP;
	}

    if (Cap != 0.0)
    {
		new
			Float:s_fX,
			Float:s_fY,
			Float:s_fZ,
			Float:s_fVX,
			Float:s_fVY,
			Float:s_fVZ
		;

		// 0.4 + 0.6 * 1/2
		GetVehiclePos( veh, s_fX, s_fY, s_fZ );
		GetVehicleVelocity( veh, s_fVX, s_fVY, s_fVZ );
		
		if(!IsPlayerInRangeOfPointEx( Cap + 0.05, playerid, s_fX + s_fVX, s_fY + s_fVY, s_fZ + s_fVZ ) )
		{
		
			HP = floatsqroot( ( s_fVX * s_fVX ) + ( s_fVY * s_fVY ) + ( s_fVZ * s_fVZ ) );

			s_fVX = ( s_fVX / HP ) * Cap;
			s_fVY = ( s_fVY / HP ) * Cap;
			s_fVZ = ( s_fVZ / HP ) * Cap;

			SetVehicleVelocity( veh, s_fVX, s_fVY, s_fVZ );
		}
    }
	return 1;
}
stock SetCap(playerid,veh)
{
	new model = GetVehicleModel(veh);
	new Float:HP;
	GetVehicleHealth(veh, HP);
	new Float:Cap = 0.0;
	if(model == BIKE || model == MTBIKE)
		Cap=0.4; 
	else if(HP >= 800.0)
		Cap = 0.0;
	else if(HP >= 700.0) 
		Cap = 0.8;
	else if(HP >= 600.0) 
		Cap = 0.7;
	else if(HP >= 500.0) 
		Cap = 0.6;
	else if(HP >= 400.0) 
		Cap = 0.5;
	else if(HP >= 250.0) 
		Cap = 0.4; 

	if(AutoPilotas[veh])
	{
		if(Cap > 0.5 || Cap == 0.0)
			Cap=0.5;
	}
	else if(Cap != 0.0)
	{	
		Cap = Cap + ((1-Cap) * (AdjustByRida(veh,RIDA_SULETEJIMAS) - 1) / 2);
		if(model == BIKE || model == MTBIKE) 
		{
			if(Cap > 0.65) // maxed out
				Cap=10.0;
		}
	}
	PlayerCap[playerid] = Cap;
}


