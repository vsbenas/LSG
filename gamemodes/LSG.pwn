				{
					SendInfoMessage(playerid,"Negali tiek pirkti, nes Nepavilksi !");
					SendInfoMessage(playerid,"Nepavelka");
					return 0;
				}*/
				if(playerDB[dealeris][zole] < kiek) return SendInfoMessage(playerid,"Jis tiek nebeturi!");
				playerDB[dealeris][zole]-=kiek;
				playerDB[playerid][zole]+=kiek;
				GivePlayerMoneyA(playerid,-kaina*kiek);
