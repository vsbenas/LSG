stock Float:floatmax(Float:a, Float:b)
{
	if(a > b) 
	{
		return a;
	}
	return b;
}

stock Float:AdjustByRida(vehicleid=0,parameter,Float:ridele=0.0)
{
	if(vehicleid)
		ridele = vehicleDB[vehicleid][rida];
	new Float:maxrida = 9999.9; // around 53h
	new Float:dalis = ridele/maxrida;
	switch(parameter)
	{
		case RIDA_UZVEDIMAS: // laikas kol uzsiveda masina
		{
			// iki 10x greiciau
			return 1 + 9*dalis;
		}
		case RIDA_REMONTAS:
		{
			// iki 4x pigiau
			return 1 + 3*dalis;
		}
		case RIDA_SULETEJIMAS:
		{
			// iki 2x maziau
			return 1 + dalis;
		}
		case RIDA_UZVEDIMO_TIKIMYBE:
		{
			return 1 + 0.5*dalis;
		}
		case RIDA_NITRO:
		{
			return 60 - 30*dalis;
		}
	}
	return 0.0;
}

