stock GiveRandomItem(playerid)
{
	new x = random(85);
	new itemas;
	if(x < 20) itemas=1;
	else if(x < 30) itemas=2;
	else if(x < 40) itemas=3;
	else if(x < 50) itemas=4;
	else if(x < 60) itemas=5;
	else if(x < 70) itemas=6;
	else if(x < 80) itemas=7;
	else itemas=8 + random(3);
	ApplyItem(playerid,itemas);
	new query[200];
	format(query,sizeof(query),"INSERT INTO `Kaledos11`(Vardas,Itemid) VALUES ('%s',%i)",ReturnName(playerid),itemas);
	mysql_query(query);
	return itemas;
}
stock ReturnItemName(itemid)
{
	new value[20] = "niekas";
	switch(itemid)
	{
		case 1: value="Kaledine Kepure";
		case 2: value="Policijos Skydas";
		case 3: value="Zibintuvelis";
		case 4: value="Gitara";
		case 5: value="Gitara";
		case 6: value="Zaislinis AK47";
		case 7: value="Zaislinis M16";
		case 8,9,10: value="Lazeris";
	}
	return value;
}

stock AddToBagazine(playerid,carid,itemid,count)
{
	new itemname[30];
	new Item=itemid;
	if(Item < 50)
	{
		GetWeaponName(Item,itemname,sizeof(itemname));
	}
	else
	{
		if(Item==50) // nark
		{
			itemname="Seklu";
		}
		else if(Item==51)
		{
			itemname="Zoles";
		}	
		else if(Item==52)
		{
			itemname="Amfetamino";
		}
		else if(Item==53)
		{
			itemname="LSD";
		}
		else if(Item==54)
		{
			itemname="Ekstazio";
		}
		else if(Item==55)
		{
			itemname="Pinigu";
			if(count >= 10000)
				ProcessAchievement(playerid,98);
		}
		else if(Item==56)
		{
			itemname="Masala";
		}
		else if(Item==57)
		{
			itemname="Zuvi";
		}
		else if(Item==60)
		{
			itemname="Bomba";
		}

	}
	new msg[128];
	format(msg,128," * %s i %s padeda %s!",ReturnName(playerid),((carid==4)?("spintele"):("bagazine")),itemname);
	SavePlayerData(playerid,true);
	ProxDetector(20.0, playerid, msg, COLOR_CHAT1,COLOR_CHAT2,COLOR_CHAT3,COLOR_CHAT4,COLOR_CHAT5);
	new query[128];
	format(query,sizeof(query),"SELECT * From Bagazine Where Vardas='%s' AND Masina=%i AND Item=%i",ReturnName(playerid),carid,itemid);
	mysql_function_query(SQL, query, true, "SQL_Bagazas2", "iiii",playerid,carid,itemid,count);
	return 1;
}

stock ReturnItemInfo(Item,Countas)
{
	new str[64];
	new itemname[30];
	if(Item < 50)
	{
		GetWeaponName(Item,itemname,sizeof(itemname));
		format(str,sizeof(str),"%s [%i]",itemname,Countas);
	}
	else
	{
		if(Item==50) // nark
		{
			format(str,sizeof(str),"Seklos [%ivnt.]",Countas);
		}
		else if(Item==51)
		{
			format(str,sizeof(str),"Zole [%ig]",Countas);
		}	
		else if(Item==52)
		{
			format(str,sizeof(str),"Amfetaminas [%ivnt.]",Countas);
		}
		else if(Item==53)
		{
			format(str,sizeof(str),"LSD [%ivnt.]",Countas);
		}
		else if(Item==54)
		{
			format(str,sizeof(str),"Ratai [%ivnt.]",Countas);
		}
		else if(Item==55)
		{
			format(str,sizeof(str),"Pinigai [%i€]",Countas);
		}
		else if(Item==60)
		{
			format(str,sizeof(str),"Bomba");
		}
		else if(Item==56)
		{
			format(str,sizeof(str),"Masalas [%ig]",Countas);
		}
		else if(Item==57)
		{
			format(str,sizeof(str),"Zuvis [%ivnt.]",Countas);
		}
	}
	return str;
}
stock ShowBagazine(playerid)
{
	if(GetPlayerState(playerid) == PLAYER_STATE_SPECTATING)
	{
		printf("%s bande pasideti daiktus i bagazine arba privacia ligonine per pzu",ReturnName(playerid));
		return 1;
	}
	new vehicleid = GetClosestVehicleid(playerid,10.0);
	if(!vehicleid || vehicleid == INVALID_VEHICLE_ID)
	{
		if(GetPlayerInterior(playerid) == 3)
		{
			new row[128];
			format(row,sizeof(row),"SELECT Item,Count From Bagazine Where Vardas='%s' AND Masina=4",ReturnName(playerid));
			mysql_function_query(SQL, row, true, "SQL_Bagazas", "ii",playerid,4);
		}
		return 1;
	}
	GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
	if(VehVars[5] == VEHICLE_PARAMS_ON)
	{
		new Float:poz[3];
		GetVehicleBoot(vehicleid,poz[0],poz[1],poz[2]);
		if(!IsPlayerInRangeOfPointEx(2.5,playerid, poz[0],poz[1],poz[2]))
		{
			return 1;
		}
		new exas;
		new mid = GetPlayerFromCarlistID(vehicleid, exas);
		if(!mid)
		{
			new model = GetVehicleModel(vehicleid);
			if(model == 499 || model == 414 || model == 456)
			{
				return KurjeriuBagazine(playerid,vehicleid);
			}
			return -2;
		}
		new row[128];
		format(row,sizeof(row),"SELECT Item,Count From Bagazine Where Vardas='%s' AND Masina=%i",ReturnName(exas),mid);
		mysql_function_query(SQL, row, true, "SQL_Bagazas", "ii",playerid,mid);
		return 1;
	}
	else 
		return -1;
}
stock KurjeriaiAtveze(playerid,bizid)
{
	new vehicleid = PlayerCar[playerid];
	if(vehicleid < 0)
		return 1;
	new place = vpakrauta[vehicleid]-1;
	if(place != bizid)
		return SendInfoMessage(playerid,"~r~Ne tas verslas!");

	ApplyAnimation(playerid, "MISC", "pickup_box", 4.000000, 0, 0, 0, 0, -1);
	new Float:Coo[3]; 
	GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
	GetXYInFrontOfPlayer(playerid, Coo[0],Coo[1], 1.0); //1221
	new obj = GetPVarInt(playerid, "Boxas");
	Boxas(playerid,0);
	new idas = CreateDynamicObject(obj, Coo[0], Coo[1], Coo[2]-0.6, 0,0,0); //, Float:rx, Float:ry, Float:rz, worldid = -1, interiorid = -1, playerid = -1, Float:streamdistance = STREAMER_OBJECT_SD, Float:drawdistance = STREAMER_OBJECT_DD, STREAMER_TAG_AREA areaid = STREAMER_TAG_AREA -1, priority = 0)
	SetTimerEx("DestroyDynamicObjectLater",10*60*1000,false,"i",idas); // 10 min
	new msg[128];
//		new Float:Dist = GetPlayerDistanceFromPoint(playerid,FURU_PAKROVIMAI[vezaivieta[playerid]-1][0],FURU_PAKROVIMAI[vezaivieta[playerid]-1][1],FURU_PAKROVIMAI[vezaivieta[playerid]-1][2]);
	new cost = MONEYP_KURJERIAI;
	format(msg,sizeof(msg)," * Krovinys iskrautas. Uzdirbai %i€.",cost);
	ProcessAchievement(playerid,76);
	SendClientMessage(playerid,-1,msg);

	playerDB[playerid][jobpts]++;
	GivePlayerMoneyA(playerid, cost+2000);
	Pelnas(playerid,4,cost);
	LoadKurjeriuMission(playerid,1);
	return 1;
}
stock KurjeriuBagazine(playerid,vehicleid)
{
	if(PlayerCar[playerid] != vehicleid)
	{
		return SendInfoMessage(playerid,"~r~Tai ne jusu automobilis!");
	}
	if(GetPVarInt(playerid, "kurjeris_busy"))
		return 1;

	new place = vezaivieta[playerid]-1;
	/*if(IsPlayerInRangeOfPointEx(30.0,playerid,FURU_ISKROVIMAI[place][0],FURU_ISKROVIMAI[place][1],FURU_ISKROVIMAI[place][2]))
	{
		if(!vpakrauta[vehicleid])
		{
			if(FURU_ATVEZTA[vezaivieta[playerid]-1] <= 0) return SendInfoMessage(playerid,"Sio krovinio neber.");
			if(GetPlayerMoneyA(playerid) < 2000) return SendInfoMessage(playerid,"Pakrovimui reikia 2000€!");
			GivePlayerMoneyA(playerid, -2000);
			SendInfoMessage(playerid,"Prasome palaukti.");
			SetPVarInt(playerid,"kurjeris_busy",1);
			TogglePlayerControllable(playerid,false);
			StartSomething(playerid,110,"Krauname..."); 
			ApplyAnimation(playerid, "GANGS", "Invite_Yes", 4.100000, 1, 0, 0, 0, 0);
			FURU_ATVEZTA[vezaivieta[playerid]-1]--;
		}
		else return SendInfoMessage(playerid,"Tu jau pasikroves!");
	}
	else */
	if(vpakrauta[vehicleid]) 
	{
		if(GetPVarInt(playerid, "Boxas"))
		{
			return SendInfoMessage(playerid,"~r~Pristatyk krovini i versla.");
		}
		place = vpakrauta[vehicleid]-1;
		if(IsPlayerInRangeOfPointEx(120.0,playerid,BusinessInfo[place][bEnterX],BusinessInfo[place][bEnterY],BusinessInfo[place][bEnterZ]))
		{
			SendInfoMessage(playerid,"Prasome palaukti.");
			TogglePlayerControllable(playerid,false);
			SetPVarInt(playerid,"kurjeris_busy",1);
			StartSomething(playerid,50,"Iskrauname..."); 
			ApplyAnimation(playerid, "GANGS", "Invite_Yes", 4.100000, 1, 0, 0, 0, 0);
		}
		//else SendClientMessage(playerid,-1,"ne");
	}
	return 1;
}

