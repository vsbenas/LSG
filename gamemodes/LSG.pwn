PlayerText:CreateOfferTextDraw(playerid,Tekstas[])
{
	new PlayerText:Offer = CreatePlayerTextDraw(playerid, 90.000000, 170.000000, Tekstas);
	PlayerTextDrawBackgroundColor(playerid, Offer, 255);
	PlayerTextDrawFont(playerid, Offer, 1);
	PlayerTextDrawLetterSize(playerid, Offer, 0.500000, 1.000000);
	PlayerTextDrawColor(playerid, Offer, -1);
	PlayerTextDrawSetOutline(playerid, Offer, 0);
	PlayerTextDrawSetProportional(playerid, Offer, 1);
	PlayerTextDrawSetShadow(playerid, Offer, 1);
	PlayerTextDrawUseBox(playerid, Offer, 1);
	PlayerTextDrawBoxColor(playerid, Offer, -2004318055);
	PlayerTextDrawTextSize(playerid, Offer, 291.000000, 0.000000);
	PlayerTextDrawShow(playerid, Offer);
	return Offer;
}
PlayerText:CreateReceiveTextDraw(playerid,Tekstas[])
{
	#pragma unused Tekstas
