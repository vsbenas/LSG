new TimeOutJump[MAX_PLAYERS];
stock ProcessFule(playerid,newkeys,oldkeys)
{
	
	new
		tick = GetTickCount(),
		dif;
	if(PRESSED(KEY_JUMP))
	{
		TimeOutJump[playerid]=tick;
		return;
	}	
	if(tick-TimeOutJump[playerid] < 1000)
		return;
	if (PRESSED(KEY_HANDBRAKE))
	{
		pLastTick[playerid] = tick;
		Iter_Add(PlayersFading,playerid);
	}
	else if (RELEASED(KEY_HANDBRAKE))
	{
	    dif = tick - pLastTick[playerid];
	    pLastTick[playerid] = -1;
	    if(dif < 2000)
	    {
		    new
		        Float:ox, Float:oy, Float:oz,
		        Float:x, Float:y, Float:z;
		    GetBallPos(ox, oy, oz);
		    GetPlayerPos(playerid, x, y, z);
		    if(IsPlayerInRangeOfPointEx(1.2,playerid, ox, oy, z) && floatabs(oz - z) < 1.8)
		    {
		        new
		            Float:speed,
		            Float:angle,
		            Float:vx, Float:vy, Float:vz;
		            
				if(dif > 1000)
				    dif = 2000 - dif;
		        speed = (float(dif + 400) / (1000)) * 20.0;
		        
		        if(BallHolder != -1)
		        {
			        DestroyBall();
			        CreateBall();
			        SetObjectPos(Ball, ox, oy, oz);
			        BallHolder = -1;
			    }
		        
		        GetPlayerFacingAngle(playerid, angle);
		        vx = speed * floatsin(-angle, degrees),
		        vy = speed * floatcos(-angle, degrees);
		        vz = /*(newkeys & KEY_SECONDARY_ATTACK) ? (speed / 1.3) :*/ (speed / 5.2);
		        
		        /*GetPlayerCameraFrontVector(playerid, vx, vy, vz);
		        vx *= speed;
		        vy *= speed;
		        vz *= speed * 1.2;
		        if(vz < 0.0)
		            vz = 0.0;*/

				PHY_SetObjectVelocity(Ball, vx, vy, vz);

				if(oz > BallSpawn[2] + (1.0 - 0.875))
				    ApplyAnimation(playerid, "WAYFARER", "WF_Fwd", 4.0, 0, 0, 0, 0, 0);
				else if(dif > 300)
					ApplyAnimation(playerid, "FIGHT_D", "FightD_1", 4.1, 0, 1, 1, 0, 0);
				PlayerPlaySound(playerid, 1130, 0.0, 0.0, 0.0);
				
				LastTouch = playerid;
			}
		}
	}
	
	if (PRESSED(KEY_WALK))
	{
		pLastTick[playerid] = tick;
		Iter_Add(PlayersFading,playerid);
	}
	else if (RELEASED(KEY_WALK))
	{
	    dif = tick - pLastTick[playerid];
	    pLastTick[playerid] = -1;
	    if(dif < 2000)
	    {
		    new
		        Float:ox, Float:oy, Float:oz,
		        Float:x, Float:y, Float:z;
		    GetBallPos(ox, oy, oz);
		    GetPlayerPos(playerid, x, y, z);
		    if(IsPlayerInRangeOfPointEx(1.2,playerid, ox, oy, z) && floatabs(oz - z) < 1.8)
		    {
		        new
		            Float:speed,
		            Float:angle,
		            Float:vx, Float:vy, Float:vz;

				if(dif > 1000)
				    dif = 2000 - dif;
		        speed = (float(dif + 400) / (1000)) * 15.0;

		        if(BallHolder != -1)
		        {
			        DestroyBall();
			        CreateBall();
			        SetObjectPos(Ball, ox, oy, oz);
			        BallHolder = -1;
			    }

		        GetPlayerFacingAngle(playerid, angle);
		        vx = speed * floatsin(-angle, degrees),
		        vy = speed * floatcos(-angle, degrees);
		        vz = speed / 1.3;
				PHY_SetObjectVelocity(Ball, vx, vy, vz);

				if(oz > BallSpawn[2] + (1.0 - 0.875))
				    ApplyAnimation(playerid, "WAYFARER", "WF_Fwd", 4.0, 0, 0, 0, 0, 0);
				else if(dif > 300)
					ApplyAnimation(playerid, "FIGHT_D", "FightD_1", 4.1, 0, 1, 1, 0, 0);
				PlayerPlaySound(playerid, 1130, 0.0, 0.0, 0.0);
				
				LastTouch = playerid;
			}
		}
	}
	
	if (PRESSED(KEY_SECONDARY_ATTACK))
	{
		pLastTick[playerid] = tick;
		Iter_Add(PlayersFading,playerid);
	}
	else if (RELEASED(KEY_SECONDARY_ATTACK))
	{
	    dif = tick - pLastTick[playerid];
	    pLastTick[playerid] = -1;
	    if(dif < 2000)
	    {
		    new
		        Float:ox, Float:oy, Float:oz,
		        Float:x, Float:y, Float:z;
		    GetBallPos(ox, oy, oz);
		    GetPlayerPos(playerid, x, y, z);
		    if(IsPlayerInRangeOfPointEx(1.2,playerid, ox, oy, z) && floatabs(oz - z) < 1.8)
		    {
		        new
		            Float:speed,
		            Float:angle,
		            Float:vx, Float:vy, Float:vz;

				if(dif > 1000)
				    dif = 2000 - dif;
		        speed = (float(dif + 400) / (1000)) * 16.0;

		        if(BallHolder != -1)
		        {
			        DestroyBall();
			        CreateBall();
			        SetObjectPos(Ball, ox, oy, oz);
			        BallHolder = -1;
			    }

		        GetPlayerFacingAngle(playerid, angle);
		        vx = speed * floatsin(-angle, degrees),
		        vy = speed * floatcos(-angle, degrees);
		        vz = speed / 2.0;
				PHY_SetObjectVelocity(Ball, vx, vy, vz);

				if(oz > BallSpawn[2] + (1.0 - 0.875))
				    ApplyAnimation(playerid, "WAYFARER", "WF_Fwd", 4.0, 0, 0, 0, 0, 0);
				else if(dif > 300)
					ApplyAnimation(playerid, "FIGHT_D", "FightD_1", 4.1, 0, 1, 1, 0, 0);
				PlayerPlaySound(playerid, 1130, 0.0, 0.0, 0.0);
				LastTouch = playerid;
			}
		}
	}
	
	if(PRESSED(KEY_FIRE))
	{
	    new
		    Float:ox, Float:oy, Float:oz,
		    Float:x, Float:y, Float:z;
		GetBallPos(ox, oy, oz);
		if(BallHolder == playerid)
		{
		    DestroyBall();
			CreateBall();
			SetObjectPos(Ball, ox, oy, oz);
			BallHolder = -1;
		}
		else
		{
			GetPlayerPos(playerid, x, y, z);
			if(IsPlayerInRangeOfPointEx(1.2,playerid, ox, oy, z) && oz < z && (z - oz) < 1.2)
			{
			    GetObjectRot(Ball, ox, oy, oz);
			    AttachObjectToPlayer(Ball, playerid, 0.0, 0.6, -0.875, ox, oy, oz);
			    
				if(BallHolder != -1)
				    PlayerPlaySound(BallHolder, 1130, 0.0, 0.0, 0.0);
				PlayerPlaySound(playerid, 1130, 0.0, 0.0, 0.0);
				
				BallHolder = playerid;
				LastTouch = playerid;
			}
		}
		ApplyAnimation(playerid, "CARRY", "crry_prtial", 1.0, 0, 0, 0, 0, 0);
	}
}

stock UpdateDazai()
{
		dazutime--;
		if(dazutime == -1)
		{
			//dazutime=3600/4; // 15 min

			new maxid = INVALID_PLAYER_ID;
			new maxkills = -1;
			foreach(Player,i)
			{
				if(playerDB[i][psratasvydis])
				{
					if(PTotal[i] > maxkills)
					{
						maxkills = PTotal[i];
						maxid = i;
					}
					PTotal[i] = 0;
					TogglePlayerControllable(i, false);
				}
			}
			new msgas[256];
			if(dazuscore[0] > dazuscore[1])
			{
				format(msgas,256,#TEXT_GREEN"[DAŢASVYDIS] "#TEXT_RED"Raudoni{FFFFFF} laimëjo!");
			}
			else if(dazuscore[0] < dazuscore[1])
			{
				format(msgas,256,#TEXT_GREEN"[DAŢASVYDIS] "#TEXT_BLUE"Melyni{FFFFFF} laimëjo!");
			}
			else
			{
				format(msgas,256,#TEXT_GREEN"[DAŢASVYDIS]{FFFFFF} Lygiosios!");

			}
			//printf(msgas);
			if(maxid != INVALID_PLAYER_ID && playerDB[maxid][psratasvydis] == 2)
				format(msgas,256,"%s MVP: "#TEXT_RED"%s{FFFFFF} ("#TEXT_GREEN"%i{FFFFFF} nuţudymř).",msgas,ReturnName(maxid),maxkills);
			else if(maxid != INVALID_PLAYER_ID && playerDB[maxid][psratasvydis] == 1)
				format(msgas,256,"%s MVP: "#TEXT_BLUE"%s{FFFFFF} ("#TEXT_GREEN"%i{FFFFFF} nuţudymř).",msgas,ReturnName(maxid),maxkills);
			//printf(msgas);
			//format(msgas,256,"%s Kitas ţemëlapis prasidës po 10 sekundţiř.",msgas);
			//printf(msgas);
			SendMessageToDazaiThird(-1,msgas);
			return 1;
			
		}
		else if(-1 < dazutime < 3)
		{
			foreach(Player, i)
			{
				if(playerDB[i][psratasvydis])
				{
					PlayerPlaySound(i,1056,0.0,0.0,0.0);
				}
			}
		}
		else if(dazutime == -10)
		{
			dazuscore[0] = 0;
			dazuscore[1] = 0;
			dazumap = dazunextmap;
			dazutime=3600/4; // 15 min
			foreach(Player,i)
			{
				if(playerDB[i][psratasvydis])
				{
					SendClientMessage(i,-1,#TEXT_GREEN"[DAŢASVYDIS]{FFFFFF} Pradedamas naujas daţasvydzio raundas!");
					TogglePlayerControllable(i, true);
					Sratasvydziosetup(i);
				}
			}
		}
		else if(60 < dazutime < 64)
		{
			foreach(Player, i)
			{
				if(playerDB[i][psratasvydis])
				{
					SendInfoMessage(i,"~p~Pradedamas balsavimas!");
					PlayerPlaySound(i,1056,0.0,0.0,0.0);
				}
			}
		}
		else if(dazutime == 60)
		{
			new votemenu[256];
			for(new i;i<NUM_ARENOS;i++) 
			{
				dazuvotes[i] = 0;
				format(votemenu,256,"%s%s\n",votemenu,dazuarenos[i]);
			}
			
			foreach(Player, i)
			{
				if(playerDB[i][psratasvydis])
				{
					ShowPlayerDialog(i, 5284, DIALOG_STYLE_LIST, "Balsuokite uţ kitŕ ţemëlapá",votemenu,"Balsuoti","Atđaukti");
				}
			}

		}
		else if(dazutime == 30)
		{
			new maxvotes = dazuvotes[0];
			new maxid = 0;
			for(new i;i<NUM_ARENOS;i++)
			{
				if(dazuvotes[i] > maxvotes)
				{
					maxvotes = dazuvotes[i];
					maxid = i;
				}
			}
			new msg[256];
			format(msg,256,#TEXT_GREEN"[DAŢASVYDIS]{FFFFFF} Balsavimas baigtas! Kitas ţemëlapis: "#TEXT_GREEN"%s{FFFFFF}.",dazuarenos[maxid]);
			dazunextmap = maxid;
			SendMessageToDazaiThird(-1,msg);
		}
		if(dazutime < 0)
			return 1;
		/*if(id == 2 && dazutime[id] % 300 == 0) // kas 5 min
		{
			SetupKiausas();
		}*/
		new stringas[24];
		format(stringas,24,"%i",dazuscore[0]);
		TextDrawSetString(dazugui[0],stringas); // red score
		format(stringas,24,"%i",dazuscore[1]);
		TextDrawSetString(dazugui[1],stringas); // blu score
		format(stringas,24,"%02d:%02d",(dazutime/ 60), (dazutime % 60));
		TextDrawSetString(dazugui[2],stringas); // time
		// now count the ppl
		new red,blue;
		foreach(Player, i)
		{
			if(playerDB[i][psratasvydis]==1) red++;
			else if(playerDB[i][psratasvydis]==2) blue++;	
		}
		if(red > 20)
			red=20;
		if(blue > 20)
			blue=20;

		stringas = str_repeat("|",red);
		TextDrawSetString(dazugui[4],stringas); // atvirksciai krc
		stringas = str_repeat("|",blue);
		TextDrawSetString(dazugui[3],stringas); 
		return 1;
}

stock Valgymas(playerid,Float:kiek)
{
	PlaySound(playerid,32200);
	playerDB[playerid][sotumas] = (playerDB[playerid][sotumas]+kiek <= 100.0) ? playerDB[playerid][sotumas]+kiek : 100.0; 
	if(BitFlag_Get(PConfig[playerid],PCFG_SHOWALKIS))
	{ 
		SetProgressBarValue(Alkis, playerDB[playerid][sotumas]+10.0); 
		ShowProgressBarForPlayer(playerid, Alkis);
	}
}


