	if(hInfo[housenumber][kLocked] == 1)
	{
		if(strcmp(hInfo[housenumber][Name],pname,false)==0)
		{
			SendInfoMessage(playerid,"~g~Jus atrakinote savo namus!");
			hInfo[housenumber][kLocked] = 0;
			return 1;
		}
		else if(strcmp(hInfo[housenumber][Renter],pname,false)==0)
		{
			SendInfoMessage(playerid,"~g~Jus atrakinote savo namus!");
			hInfo[housenumber][kLocked] = 0;
			return 1;
		}
		else
		{
			SendInfoMessage(playerid,"~r~Neturi raktu!");
		}
	}
	else if(hInfo[housenumber][kLocked] == 0)
	{
		if(strcmp(hInfo[housenumber][Name],pname,false)==0)
		{
			SendInfoMessage(playerid,"~r~Jus uzrakinote savo namus!");
			hInfo[housenumber][kLocked] = 1;
			return 1;
		}
		else if(strcmp(hInfo[housenumber][Renter],pname,false)==0)
		{
			SendInfoMessage(playerid,"~r~Jus uzrakinote savo namus!");
			hInfo[housenumber][kLocked] = 1;
			return 1;
		}
		else
		{
			SendInfoMessage(playerid,"~r~Neturi raktu!");
			return 1;
		}
	}
	return 1;
}
stock LockHouse(playerid,housenumber)
{
	new pname[24];
	GetPlayerName(playerid, pname, 24);
	
	if(hInfo[housenumber][Locked] == 1 && !hInfo[housenumber][islauztos])
	{
		if(strcmp(hInfo[housenumber][Name],pname,false)==0)
		{
			SendInfoMessage(playerid,"~g~Jus atrakinote savo namus!");
			hInfo[housenumber][Locked] = 0;
			return 1;
		}
		else if(strcmp(hInfo[housenumber][Renter],pname,false)==0)
		{
			SendInfoMessage(playerid,"~g~Jus atrakinote savo namus!");
			hInfo[housenumber][Locked] = 0;
			return 1;
		}
		else if((fsHouses[housenumber][fobjid] != 0 || strcmp(hInfo[housenumber][Name],"Nera",true) == 0 || GetPVarInt(playerid,"irengineja") == housenumber) && playerDB[playerid][specialybe]==34)
		{
			SendInfoMessage(playerid,"~g~Jus atrakinote namus su NTA raktu!");
			hInfo[housenumber][Locked] = 0;
			return 1;
		}
		else
		{
			SendInfoMessage(playerid,"~r~Neturi raktu!");
		}
	}
	else if(hInfo[housenumber][Locked] == 0 && !hInfo[housenumber][islauztos])
	{
		if(strcmp(hInfo[housenumber][Name],pname,false)==0)
		{
			SendInfoMessage(playerid,"~r~Jus uzrakinote savo namus!");
			hInfo[housenumber][Locked] = 1;
			return 1;
		}
		else if(strcmp(hInfo[housenumber][Renter],pname,false)==0)
		{
			SendInfoMessage(playerid,"~r~Jus uzrakinote savo namus!");
			hInfo[housenumber][Locked] = 1;
			return 1;
		}
		else if(fsHouses[housenumber][fobjid] != 0 && playerDB[playerid][specialybe]==34)
		{
			SendInfoMessage(playerid,"~r~Jus uzrakinote namus su NTA raktu!");
			hInfo[housenumber][Locked] = 1;
			return 1;
		}
		else
		{
			SendInfoMessage(playerid,"~r~Neturi raktu!");
			return 1;
		}
	}
	return 1;
}

stock EnterNamas(playerid,housenumber,kiemas=0)
{
	if(hInfo[housenumber][polyId] != -1)
	{
		return 1;
	}
	new pnamez[30];
	GetPlayerName(playerid, pnamez, sizeof(pnamez));
	if(kiemas == 0 && hInfo[housenumber][Locked]==1 && !hInfo[housenumber][islauztos])
	{
		if(strcmp(hInfo[housenumber][Name],"Nera",true) == 0)
			return SendInfoMessage(playerid,"Sis namas ~r~uzrakintas~w~!~n~ Kvieskite NTA noredami ji pamatyti.");
		else
			return SendInfoMessage(playerid,"Sis namas ~r~uzrakintas~w~!~n~ Spauskite ALT, kad atrakintumet ji.");
	}
	if(hInfo[housenumber][tobulina]==1) return SendInfoMessage(playerid,"Prasome netrugdyti. Namas yra remontuojamas.");
	//SetPlayerVirtualWorld(playerid, housenumber);
	//SetPlayerInterior(playerid, Inter[ hInfo[housenumber][vidus] ][ Int ]);
	//SetPlayerPoz(playerid, Inter[ hInfo[housenumber][vidus] ][ IntX ],Inter[ hInfo[housenumber][vidus] ][ IntY ],Inter[ hInfo[housenumber][vidus] ][ IntZ ]);
	
	if(kiemas == 1)
	{
		if(hInfo[housenumber][kLocked] == 1)
			return SendInfoMessage(playerid,"Kiemo durys uzrakintos!");
		new vid = hInfo[housenumber][vidus];
		if(KiemoDurys[vid][0] == 0)
			return SendInfoMessage(playerid,"Namo interjeras neturi kiemo duru.");
		Stop(playerid);
		SetPlayerPosFade(playerid,25,KiemoDurys[vid][0] ,KiemoDurys[vid][1] ,KiemoDurys[vid][2] ,Inter[ hInfo[housenumber][vidus] ][ Int ],housenumber);

	}
	else {
		Stop(playerid);
		SetPlayerPosFade(playerid,25,Inter[ hInfo[housenumber][vidus] ][ IntX ],Inter[ hInfo[housenumber][vidus] ][ IntY ],Inter[ hInfo[housenumber][vidus] ][ IntZ ],Inter[ hInfo[housenumber][vidus] ][ Int ],housenumber);
	}

	SendInfoMessage(playerid,"Iejote i namus!~n~Noredami iseiti spauskite ~r~ENTER~n~~w~Namo valdymas ~r~~k~~CONVERSATION_NO~");
	if(hInfo[housenumber][hRadio] && ((hInfo[housenumber][hRadio] -1) < sizeof(RADIO_PLUGIN)) && !playerDB[playerid][klausoimtuvo])
	{
		/*
		Audio_Stop(playerid,playerDB[playerid][radija]);*/
		StopAudioStreamForPlayer(playerid);
		PlayAudioStreamForPlayer(playerid,RADIO_PLUGIN[hInfo[housenumber][hRadio]-1][RADIO_URL],Inter[ hInfo[housenumber][vidus] ][ IntX ],Inter[ hInfo[housenumber][vidus] ][ IntY ],Inter[ hInfo[housenumber][vidus] ][ IntZ ],200.0); // zip
		playerDB[playerid][stotis] = hInfo[housenumber][hRadio]-1;
		playerDB[playerid][klausosi] = 0;		
	}
	if (strcmp(hInfo[housenumber][Name],pnamez,false)) return 1;
	SendClientMessage(playerid, WHITE, " * Namo funkcijos:");
	SendClientMessage(playerid, WHITE, "/pavalgyti /saugot /spyna /remontas /lvl /radijan");
	SendClientMessage(playerid, YELLOW, " * Daiktř funkcijos:");
	SendClientMessage(playerid, YELLOW, "/padeti /paimti /baldai /dazyti /leistirengti");
	SendClientMessage(playerid, GREEN, " * Kanapiř funkcijos:");
	SendClientMessage(playerid, GREEN, "/sodinti /laistyti /derlius /israuti");

	ZolesStats(playerid,housenumber);
	return 1;
}

stock ZolesStats(playerid,houseid) 
{
	if(houseid == -1 && GetPlace(playerid) != PLACE_HOUSE)
		return 1;
	new housenumber = houseid == -1 ? GetPlayerHouseID(playerid) : houseid;
	if (strcmp(hInfo[housenumber][Name],ReturnName(playerid),false)) 
		return 1;

	if(hInfo[housenumber][krumeliai] > 0)
	{
		new msg[128], kokybe[128];
		if(hInfo[housenumber][amzius] > 216)
		{
			hInfo[housenumber][krumeliai] = 0;
			SendClientMessage(playerid, ORANGE, "* Nespejote nuimti derliaus, zole peraugo ir tapo beverte, todel jus ja ismetete lauk!");
			return 1;
		}
		format(msg, 128, "Jusu namuose yra %i krumeliu kanapiu!", hInfo[housenumber][krumeliai]);
		SendClientMessage(playerid, BLUE, msg);

		if(hInfo[housenumber][bukle] >= 90)
		{
			format(kokybe, 128, "Puiki!");
			format(msg, 128, "Kanapiu bukle: %s, Dregme: %i proc.", kokybe, hInfo[housenumber][dregme]);
			SendClientMessage(playerid, COLOR_WHITE, msg);
		}
		else if(hInfo[housenumber][bukle] < 90 && hInfo[housenumber][bukle] >= 70)
		{
			format(kokybe, 128, "Gera!");
			format(msg, 128, "Kanapiu bukle: %s, Dregme: %i", kokybe, hInfo[housenumber][dregme]);
			SendClientMessage(playerid, COLOR_LIME, msg);
		}
		else if(hInfo[housenumber][bukle] < 70 && hInfo[housenumber][bukle] >= 50)
		{
			format(kokybe, 128, "Normali");
			format(msg, 128, "Kanapiu bukle: %s, Dregme: %i", kokybe, hInfo[housenumber][dregme]);
			SendClientMessage(playerid, COLOR_GREEN, msg);
		}
		else if(hInfo[housenumber][bukle] < 50 && hInfo[housenumber][bukle] >= 30)
		{
			format(kokybe, 128, "Pakenciama");
			format(msg, 128, "Kanapiu bukle: %s, Dregme: %i", kokybe, hInfo[housenumber][dregme]);
			SendClientMessage(playerid, COLOR_YELLOW, msg);
		}
		else if(hInfo[housenumber][bukle] < 30 && hInfo[housenumber][bukle] >= 10)
		{
			format(kokybe, 128, "Prastoka");
			format(msg, 128, "Kanapiu bukle: %s, Dregme: %i", kokybe, hInfo[housenumber][dregme]);
			SendClientMessage(playerid, ORANGE, msg);
		}
		else if(hInfo[housenumber][bukle] < 10 && hInfo[housenumber][bukle] >= 0)
		{
			format(kokybe, 128, "KOMA! (labai blogai)");
			format(msg, 128, "Kanapiu bukle: %s, Dregme: %i", kokybe, hInfo[housenumber][dregme]);
			SendClientMessage(playerid, RED, msg);
		}
		else
		{
			format(kokybe, 128, "Atsakymas nesuprastas!");
			format(msg, 128, "Kanapiu bukle: %s, Dregme: %i", kokybe, hInfo[housenumber][dregme]);
			SendClientMessage(playerid, BLUE, msg);
		}
		new valandoz = floatround(hInfo[housenumber][amzius]/24, floatround_floor);
		if(valandoz >= 7)
		{
			format(msg, 128, "Augalo amzius: %i d. LAIKAS IMTI DERLIU! /derlius", valandoz);
		}
		else
		{
			format(msg, 128, "Augalo amzius: %i d.", valandoz);
		}
		SendClientMessage(playerid, COLOR_LIME, msg);
		if(valandoz >= 8)
		{
			SendClientMessage(playerid, RED, "Demesio, paskutine diena imti derliui! /derlius");
		}
	}
	return 1;
}

stock ClosestTrainStop(playerid,&Float:GA)
{
	new 
		place=-1;
	GA=99999.99;
	for(new i;i<sizeof(Traukiniu_Pos);i++)
	{
		new Float:Dist = GetPlayerDistanceFromPoint(playerid,Traukiniu_Pos[i][0],Traukiniu_Pos[i][1],Traukiniu_Pos[i][2]);
		if(Dist < GA)
		{
			GA=Dist;
			place=i;
		}
	}
	return place;
}
stock ClosestPlaneStop(playerid,&Float:GA)
{
	new Float:Dist[3];
	Dist[0] = GetPlayerDistanceFromPoint(playerid,PILOTAI_SF[0][0],PILOTAI_SF[0][1],PILOTAI_SF[0][2]);
	Dist[1] = GetPlayerDistanceFromPoint(playerid,PILOTAI_LV[0][0],PILOTAI_LV[0][1],PILOTAI_LV[0][2]);
	Dist[2] = GetPlayerDistanceFromPoint(playerid,PILOTAI_LS[0][0],PILOTAI_LS[0][1],PILOTAI_LS[0][2]);
	new 
		place=-1;
	GA=99999.99;
	for(new i;i<3;i++)
	{
		if(Dist[i] < GA)
		{
			place = i;
			GA = Dist[i];
		}
	}
	return place;
}

stock ClosestPlaneStopEx(playerid,id,&Float:GA)
{
	new 
		place=-1;
	GA=99999.99;
	if(id==0)
	{
		for(new i;i<sizeof(PILOTAI_SF);i++)
		{
			new Float:Dist = GetPlayerDistanceFromPoint(playerid,PILOTAI_SF[i][0],PILOTAI_SF[i][1],PILOTAI_SF[i][2]);
			if(Dist < GA)
			{
				place = i;
				GA = Dist;			
			}
		}
		return place;
	}
	else if(id==1)
	{
		for(new i;i<sizeof(PILOTAI_LV);i++)
		{
			new Float:Dist = GetPlayerDistanceFromPoint(playerid,PILOTAI_LV[i][0],PILOTAI_LV[i][1],PILOTAI_LV[i][2]);
			if(Dist < GA)
			{
				place = i;
				GA = Dist;			
			}
		}
		return place;
	}
	else if(id==2)
	{
		for(new i;i<sizeof(PILOTAI_LS);i++)
		{
			new Float:Dist = GetPlayerDistanceFromPoint(playerid,PILOTAI_LS[i][0],PILOTAI_LS[i][1],PILOTAI_LS[i][2]);
			if(Dist < GA)
			{
				place = i;
				GA = Dist;			
			}
		}
		return place;		
	}
	return -1;
}

stock UpdateJobText(playerid,jobid,place=-1,newplace=-1)
{
	new string[1024];
	switch(jobid)
	{
		case 0:
		{
			if(newplace == -1)
			{
				newplace = place+1;
				if(newplace >= STATIONS2) newplace = 0;
			}
			format(string,sizeof(string),"~r~Autobusai~n~~n~~y~Dabar:~n~~w~%s~n~~y~Kita:~n~~w~%s",Autiku_Stoteles[place],Autiku_Stoteles[newplace]);
		}
		case 1:
		{
			if(newplace == -1)
			{
				newplace = place+1;
				if(newplace >= STATIONS) newplace = 0;
			}
			format(string,sizeof(string),"~r~Mikro Autobusai~n~~n~~y~Dabar:~n~~w~%s~n~~y~Kita:~n~~w~%s",Mikriuku_Stoteles[place],Mikriuku_Stoteles[newplace]);
		}
		case 5:
		{
			if(newplace == -1)
			{
				newplace = place+1;
				if(newplace >= sizeof(Traukiniu_Stotys)) newplace = 0;
			}
			format(string,sizeof(string),"~r~Traukiniai~n~~n~~y~Dabar:~n~~w~%s~n~~y~Kita:~n~~w~%s",Traukiniu_Stotys[place],Traukiniu_Stotys[newplace]);
		}
		case 2: 
		{
			if(newplace == -1)
			{
				
				newplace = random(3);
				if(newplace == place)
					newplace = ((place + 1) % 3);
			}
			format(string,sizeof(string),"~r~Lektuvai~n~~n~~y~Dabar:~n~~w~%s~n~~y~Kita:~n~~w~%s",Pilotu_Stotys[place],Pilotu_Stotys[newplace]);
		}//job="Pilotai";
		case 3: 
		{
			new vehicleid = GetPlayerVehicleID(playerid);
			if(newplace != -1)
			{
				//if(vpakrauta[vehicleid])
				format(string,sizeof(string),"~r~Furistai~n~~n~~y~Dabar:~n~~w~%s Iskrovimas~n~~y~Kita:~n~~w~%s Pakrovimas",FURU_TEKSTAI[place],FURU_TEKSTAI[newplace]);
			}
			else
			{
				vehicleid = GetVehicleTrailer(vehicleid);
				if(vpakrauta[vehicleid]) 
					format(string,sizeof(string),"~r~Furistai~n~~n~~y~Dabar:~n~~w~%s Pakrovimas~n~~y~Kita:~n~~w~%s Iskrovimas",FURU_TEKSTAI[place],FURU_TEKSTAI[place]);
				else 
					format(string,sizeof(string),"~r~Furistai~n~~n~~y~Dabar:~n~~w~%s~n~~y~Kita:~n~~w~%s Pakrovimas",JB_gSAZones[Get2DZone(playerid)][JB_SAZONE_NAME],FURU_TEKSTAI[place]);

			}
			//format(string,sizeof(string),"~r~Furistai~n~~n~~y~Dabar:~n~~w~%s Iskrovimas~n~~y~Kita:~n~~w~%s Pakrovimas",FURU_TEKSTAI[vezaivieta[playerid]-1],FURU_TEKSTAI[vezaivieta[playerid]-1]);
		}//job="Furistai";
		case 4: 
		{
			new vehicleid = GetPlayerVehicleID(playerid);
			
			if(!vpakrauta[vehicleid])
			{
				if(place == -1)
					format(string,sizeof(string),"~r~Kurjeriai~n~~n~~y~Dabar:~n~~w~%s~n~~y~Kita:~n~~w~%s Pakrovimas",JB_gSAZones[Get2DZone(playerid)][JB_SAZONE_NAME],FURU_TEKSTAI[newplace]);//,BusinessInfo[newplace][bName]);
				else
					format(string,sizeof(string),"~r~Kurjeriai~n~~n~~y~Dabar:~n~~w~'%s' Iskrovimas~n~~y~Kita:~n~~w~%s Pakrovimas",BusinessInfo[place][bName],FURU_TEKSTAI[newplace]);//,BusinessInfo[newplace][bName]);
			}
			else
			{
				format(string,sizeof(string),"~r~Kurjeriai~n~~n~~y~Dabar:~n~~w~%s Pakrovimas~n~~y~Kita:~n~~w~'%s' Iskrovimas",FURU_TEKSTAI[place],BusinessInfo[newplace][bName]);//,BusinessInfo[newplace][bName]);
			}
		}//job="Kurjeriai";
		case 6:
		{
			format(string,sizeof(string),"~r~Taksi~n~~n~~y~Dabar:~n~~w~%s~n~~y~Kaina: ~w~%iEUR",JB_gSAZones[Get2DZone(playerid)][JB_SAZONE_NAME],place);//,BusinessInfo[newplace][bName]);
		}
		case 99, 100:
		{	// Iskvietimas.. Taksistas Benas_Vercetti yra 6.5 km nuo jusu. ( 99 rodom klientui)
			// Iskvietimas.. Klientas Benas_Vercetti yra 6.3 km nuo jusu.
			new darbuotojas;
			if(jobid == 99)
				darbuotojas = GetPVarInt(playerid, "PriemeKlienta");
			else
				darbuotojas = GetPVarInt(playerid, "PriemeIskvietima");

			new Float:coo[6];


			if(!IsPlayerConnected(darbuotojas))
			{
				PlayerTextDrawHide(playerid,JobText[playerid]);
				SendClientMessage(playerid, -1, " * Jusu sekamas ţaidëjas atsijungë!");
				SetPVarInt(playerid, "PriemeKlienta", -1);
				SetPVarInt(playerid, "PriemeIskvietima", -1);
				return 1;
			}

			if(GetPlayerInterior(darbuotojas) || GetPlayerVirtualWorld(darbuotojas))
			{
				PlayerTextDrawHide(playerid,JobText[playerid]);
				SendClientMessage(playerid, -1, " * Jusu sekamas ţaidëjas uţëjo á pastatŕ!");
				SetPVarInt(playerid, "PriemeKlienta", -1);
				SetPVarInt(playerid, "PriemeIskvietima", -1);
				return 1;

			}
			if(GetPlayerInterior(playerid) || GetPlayerVirtualWorld(playerid))
			{
				PlayerTextDrawHide(playerid,JobText[playerid]);
				SendClientMessage(playerid, -1, " * Jűs uţëjote á pastatŕ!");
				SetPVarInt(playerid, "PriemeKlienta", -1);
				SetPVarInt(playerid, "PriemeIskvietima", -1);
				return 1;
			}

			GetPlayerPos(darbuotojas,coo[0],coo[1],coo[2]);
			GetPlayerPos(playerid,coo[3],coo[4],coo[5]);
			new Float:distas = ((floatabs(coo[0]-coo[3])+floatabs(coo[1]-coo[4])+floatabs(coo[2]-coo[5]))/3)/100;

			SetPlayerCheckpoint(playerid,coo[0],coo[1],coo[2],5);
			new salis1[10],salis2[10];

			if(coo[0]-coo[3]>0) salis1="rytus"; else salis1="vakarus";
			if(coo[1]-coo[4]>0) salis2="siaures"; else salis2="pietu";

			if(jobid == 100)
				format(string,sizeof(string),"~r~Iskvietimas~n~~n~~w~Klientas ~y~%s~w~ yra ~y~%.1fkm~w~ i %s %s nuo jusu.",ReturnName(darbuotojas),distas, salis2,salis1);//,BusinessInfo[newplace][bName]);
			else
				format(string,sizeof(string),"~r~Iskvietimas~n~~n~~w~%s ~y~%s~w~ yra ~y~%.1fkm~w~ i %s %s nuo jusu.",ReturnJob(playerDB[darbuotojas][specialybe]),ReturnName(darbuotojas),distas,salis2, salis1);//,BusinessInfo[newplace][bName]);
		}

		
	}
/*	TextDrawColor(JobText[playerid],4294967040+255);
	TextDrawBackgroundColor(JobText[playerid],255);
	TextDrawBoxColor(JobText[playerid],150);*/
	PlayerTextDrawSetString(playerid,JobText[playerid],string);
	PlayerTextDrawShow(playerid,JobText[playerid]);
	return newplace;
}

stock CheckPriekaba(playerid,vehicleid,place)
{
	new modelis = IsTrailerAttachedToVehicle(vehicleid);

	new modeliz = GetVehicleModel(GetVehicleTrailer(vehicleid));

	if(!modelis)
	{
		SendInfoMessage(playerid,"~r~Neprikabinta priekaba.");
		return 0;
	}
	if(place >= sizeof(FURU_TEKSTAI)-2)
	{
		if(modeliz != 584)
		{
			SendInfoMessage(playerid,"~r~Netinkama priekaba.");
			return 0;
		}
	}
	else if(!place)
	{
		if(modeliz == 584)
		{
			SendInfoMessage(playerid,"~r~Netinkama priekaba.");
			return 0;
		}
	}
	return 1;
}

public OnPlayerEnterCheckpoint(playerid)
{
    PlayerPlaySound(playerid, 1139,0.0,0.0,0.0); // Muzika
	new State = GetPlayerState(playerid);
    if(NotSpawned[playerid]) return 0;
    if(!IsInBiz(playerid) && !IsInDrill(playerid)) DisablePlayerCheckpoint(playerid);
	HandleChristmasCheckpoint(playerid);
    if(CheckNukeCp(playerid))
    	return 1;
	if(IsPlayerInWorld(playerid))
		return 1;
    if(GetPVarInt(playerid, "PriemeIskvietima") != -1 || GetPVarInt(playerid, "PriemeKlienta") != -1)
	{
		PlayerTextDrawHide(playerid,JobText[playerid]);
		//SendClientMessage(playerid, -1, " * Iđjungei sekimŕ!");
		SetPVarInt(playerid, "PriemeKlienta", -1);
		SetPVarInt(playerid, "PriemeIskvietima", -1);
		return 1;
	}
    if (!NoCheckTP[playerid] && State != PLAYER_STATE_PASSENGER && State != PLAYER_STATE_SPECTATING && !IsPlayerInRangeOfPointEx (350.0,playerid, playerDB[playerid][pCurrentPos][0], playerDB[playerid][pCurrentPos][1], playerDB[playerid][pCurrentPos][2]))
	{
		//new Float:Coo[3];
		TeleportWarnings[playerid]++;
		//printf("%s TP %f,%f,%f -> %f,%f,%f",ReturnName(playerid),playerDB[playerid][pCurrentPos][0], playerDB[playerid][pCurrentPos][1], playerDB[playerid][pCurrentPos][2],Coo[0],Coo[1],Coo[2]);
		if (TeleportWarnings[playerid] >= 3) // 3
		{
			AC_Ban(playerid,"TeleportCP");
			//break;
			return 1;
		}
		else
		{
			new reason[128];
			new zona=Get2DZone(playerid);
			if(zona==26)
			{
				SetPlayerPoz(playerid,playerDB[playerid][pCurrentPos][0], playerDB[playerid][pCurrentPos][1], playerDB[playerid][pCurrentPos][2], _, _, 0);
				TeleportWarnings[playerid]--;
			}
			format(reason,sizeof(reason),"TeleportCP(Vieta: %s)",JB_gSAZones[zona][JB_SAZONE_NAME]);
			AC_Warn(playerid,reason);
			return 1;
		}
	}
    if(GetPlayerVisibleDynamicCP(playerid) == 0  && !IsPlayerInRangeOfPointEx(CPpos[playerid][3]+25.0, playerid, CPpos[playerid][0],CPpos[playerid][1],CPpos[playerid][2]))
    {
    	AC_Warn(playerid,"Paeme checkpoint is toli");
    	return 1;
    }
	
	if(InkaUzsakymai[playerid][utype] == 1)
		LoadOrderInka(playerid);
	new vehid = GetPlayerVehicleID(playerid);
	new model = GetVehicleModel(vehid);
	new vehicleid=vehid;

	if(MedikuDB[med_carer] == playerid && MedikuDB[med_status] == 3)
	{
		if(IsPlayerInRangeOfPointEx(20.0, playerid, Hospitals[MedikuDB[med_hpid]][v_x], Hospitals[MedikuDB[med_hpid]][v_y], Hospitals[MedikuDB[med_hpid]][v_z] )
		|| IsPlayerInRangeOfPointEx(30.0, playerid, Hospitals[MedikuDB[med_hpid]][h_x], Hospitals[MedikuDB[med_hpid]][h_y], Hospitals[MedikuDB[med_hpid]][h_z] ))
		{
			EndMedicMissionSuccess(playerid);
		}

						
	}

	if(playerDB[playerid][specialybe] == 30 && IsPlayerInRangeOfPointEx(30.0,playerid,kvieciakrimic[0],kvieciakrimic[1],kvieciakrimic[2]) && !KrimiIstirta) //&& kvieciakrimi != -1)
	{
		GivePlayerMoneyA(playerid, MONEYP_KRIMINALISTAS);
		SendInfoMessage(playerid,"Nusikaltimas istirtas!");
		kvieciakrimi = -1;
		KrimiIstirta=true;
		return 1;
	}
	if(playerDB[playerid][specialybe] == 14 && vezaivieta[playerid]) // pakrante
	{

		if(IsPlayerInRangeOfPointEx(30.0,playerid,PAKRANTES_CP[vezaivieta[playerid]-1][0],PAKRANTES_CP[vezaivieta[playerid]-1][1],PAKRANTES_CP[vezaivieta[playerid]-1][2]))
		{
			GivePlayerMoneyA(playerid,MONEYP_PAKRANTES_APSAUGA);
			SendInfoMessage(playerid,"Gavai "#MONEYP_PAKRANTES_APSAUGA"EUR!");
			ProcessAchievement(playerid,76);
			vezaivieta[playerid]=random(sizeof(PAKRANTES_CP))+1;
			SetPlayerCheckpoint(playerid,PAKRANTES_CP[vezaivieta[playerid]-1][0],PAKRANTES_CP[vezaivieta[playerid]-1][1],PAKRANTES_CP[vezaivieta[playerid]-1][2],20.0);
			if(model < 400)
				model = 400;
			vehicleDB[vehicleid][gas]=aBakai[model-400]-0.5;
		}
	
	}
	if(playerDB[playerid][specialybe] == 41 && vezaivieta[playerid]) // furos
	{
		new place = vezaivieta[playerid]-1;
		if(IsPlayerInRangeOfPointEx(30.0,playerid,FURU_PAKROVIMAI[place][0],FURU_PAKROVIMAI[place][1],FURU_PAKROVIMAI[place][2]))
		{
			if(!CheckPriekaba(playerid,vehicleid,place)) return 1;
			vehicleid = GetVehicleTrailer(vehicleid);
			if(!vpakrauta[vehicleid])
			{
				if(GetPlayerMoneyA(playerid) < 4000) return SendInfoMessage(playerid,"Pakrovimui reikia 4000EUR!");
				GivePlayerMoneyA(playerid, -4000);
				SendInfoMessage(playerid,"Prasome palaukti.");
				TogglePlayerControllable(playerid,false);
				StartSomething(playerid,187,"Krauname..."); 
			}
			else return SendInfoMessage(playerid,"Tu jau pasikroves!");
		}
		else if(IsPlayerInRangeOfPointEx(30.0,playerid,FURU_ISKROVIMAI[place][0],FURU_ISKROVIMAI[place][1],FURU_ISKROVIMAI[place][2]))
		{
			if(!CheckPriekaba(playerid,vehicleid,place)) return 1;
			vehicleid = GetVehicleTrailer(vehicleid);
			if(vpakrauta[vehicleid])
			{
				SendInfoMessage(playerid,"Prasome palaukti.");
				TogglePlayerControllable(playerid,false);
				StartSomething(playerid,160,"Iskrauname.."); 
			}
			else return SendInfoMessage(playerid,"Tu nepasikroves!");
		}
		return 1;
	}
	else if(playerDB[playerid][specialybe] == 44 && vezaivieta[playerid]) // kurjeriai
	{
		new place = vezaivieta[playerid]-1;
		if(IsPlayerInRangeOfPointEx(30.0,playerid,FURU_ISKROVIMAI[place][0],FURU_ISKROVIMAI[place][1],FURU_ISKROVIMAI[place][2]))
		{
			if(!vpakrauta[vehicleid])
			{
				if(FURU_ATVEZTA[vezaivieta[playerid]-1] <= 0) return SendInfoMessage(playerid,"Sio krovinio neber.");
				if(GetPlayerMoneyA(playerid) < 2000) return SendInfoMessage(playerid,"Pakrovimui reikia 2000EUR!");
				GivePlayerMoneyA(playerid, -2000);
				SendInfoMessage(playerid,"Prasome palaukti.");
				TogglePlayerControllable(playerid,false);
				StartSomething(playerid,110,"Krauname..."); 
				FURU_ATVEZTA[vezaivieta[playerid]-1]--;
			}
			else return SendInfoMessage(playerid,"Tu jau pasikroves!");
		}
		else if(vpakrauta[vehicleid]) 
		{
			place = vpakrauta[vehicleid]-1;
			if(IsPlayerInRangeOfPointEx(120.0,playerid,BusinessInfo[place][bEnterX],BusinessInfo[place][bEnterY],BusinessInfo[place][bEnterZ]))
			{
				SendClientMessage(playerid, -1, " * Atvaţiavai prie verslo! Atidaryk bagaţinć(~k~~TOGGLE_SUBMISSIONS~) ir iđkrauk kroviná.");
			}
			//else SendClientMessage(playerid,-1,"ne");
		}
		else return SendInfoMessage(playerid,"Tu nepasikroves!");
		/*else
		{
			//LoadKurjeriuMission(playerid,1);
		}*/
	
	}
	//if(playerDB[playerid][specialybe] == 79 || playerDB[playerid][admin]) statybininkas
	{
		if(vezaivieta[playerid] && model == 524)
		{
			if(vpakrauta[vehicleid] && IsPlayerInRangeOfPointEx(30.0,playerid,STATYBININKAI[vezaivieta[playerid]-1][0], STATYBININKAI[vezaivieta[playerid]-1][1],STATYBININKAI[vezaivieta[playerid]-1][2]))
			{
				SendInfoMessage(playerid,"Prasome palaukti.");
				TogglePlayerControllable(playerid,false);
				StartSomething(playerid,36,"Pilame_cementa"); 
			}
			else if(!vpakrauta[vehicleid] && IsPlayerInRangeOfPointEx(30.0,playerid,1273.0933,-1250.0557,14.2002))
			{
				SendInfoMessage(playerid,"Prasome palaukti.");
				TogglePlayerControllable(playerid,false);
				StartSomething(playerid,51,"Pilame_cementa"); 
			}
				/*if(!vezaivieta[playerid])
				{
					vezaivieta[playerid]=random(sizeof(STATYBININKAI));
				}
				if(vpakrauta[vehicleid]) SetPlayerCheckpoint(playerid,STATYBININKAI[vezaivieta[playerid]-1][0], STATYBININKAI[vezaivieta[playerid]-1][1],STATYBININKAI[vezaivieta[playerid]-1][2],5.0);
				else SetPlayerCheckpoint(playerid,1273.0933,-1250.0557,14.2002,5.0);*/	
		}
		if(vezaivieta[playerid] && model == 406)
		{
			if(!vpakrauta[vehicleid] && IsPlayerInRangeOfPointEx(30.0,playerid,STATYBININKAI[vezaivieta[playerid]-1][0], STATYBININKAI[vezaivieta[playerid]-1][1],STATYBININKAI[vezaivieta[playerid]-1][2]))
			{
				SendInfoMessage(playerid,"Prasome palaukti.");
				TogglePlayerControllable(playerid,false);
				StartSomething(playerid,37,"Krauname_Siuksles"); 
			}
			else if(vpakrauta[vehicleid] && IsPlayerInRangeOfPointEx(30.0,playerid,2128.4524,-1983.5947,15.0797))
			{
				SendInfoMessage(playerid,"Prasome palaukti.");
				TogglePlayerControllable(playerid,false);
				StartSomething(playerid,52,"Krauname_Siuksles"); 
			}
		}
	}
	if(playerDB[playerid][specialybe] == 71 && IsPlayerInRangeOfPointEx(10.0,playerid,2351.3904,-651.9200,127.6273))
	{
		if(vehicleid)
		{
			new atrakinam=-1;
			foreach(Player,i) if(i!=playerid)
			{
				if(IsPlayerInVehicle(i,vehicleid) && (playerDB[i][ant] || playerDB[i][suristas]))
				{
					atrakinam=i;
					break;
				}
			}
			if(atrakinam != -1)
			{
				if(playerDB[atrakinam][ant])
				{
					SendInfoMessage(playerid,"~y~Pjaunam antrankius...");
					SendInfoMessage(atrakinam,"~y~Pjaunam antrankius...");
					playerDB[playerid][pjauna]=1;
					SetProgressBarMaxValue(Veiksmai, 20);
					SetProgressBarValue(Veiksmai,playerDB[playerid][pjauna]);
					ShowProgressBarForPlayer(playerid, Veiksmai);
					StartVeiksmas(playerid,"Pjauni antrankius");
				}
				else if(playerDB[atrakinam][suristas] && atrakinam == playerDB[playerid][baikeruzd])
				{
					SendInfoMessage(playerid,"~y~Pristatei savo auka!");
					SendClientMessage(playerid,COLOR," * Uz auka gauni "#MONEYP_BAIKERIAI"€ premija, taip pat padides baikeriu pelnas!");
					SendClientMessage(playerid,COLOR," * Gavai nauja virve!");
					GivePlayerMoneyA(playerid,MONEYP_BAIKERIAI);
					playerDB[playerid][jobpts]++;
					RemovePlayerFromVehicle(atrakinam);
					ApplyAnimation(atrakinam, "ped", "cower", 3.0, 1, 0, 0, 0, 0, 1);
					SendClientMessage(atrakinam,RED," * Tave apvoge baikeriai! Virves atrisimas gali uztrukti iki 10 minuciu...");
					playerDB[atrakinam][banke]-=250;
					playerDB[playerid][virve]=true;
					Pelnas(playerid,97,(MONEYP_BAIKERIAI*6)); 
					playerDB[playerid][baikeruzd]=-1;
				}
			}
			else
			{
				if(playerDB[playerid][baikeruzd]==-1)
				{
					new msg[512];
					new PlayerList[MAX_PLAYERS];
					new PlayerID;
					foreach(Player,i)
					{
						if(i != playerid && GetPlayerScore(i) > 1000 && !playerDB[i][ikalintas] && !IsPlayerAfk(i) && playerDB[i][specialybe]!=71)
						{
							PlayerList[PlayerID]=i;
							PlayerID++;
						}
					}
					if(PlayerID < 20) return ShowPlayerDialog(playerid,7842,DIALOG_STYLE_MSGBOX,"Uzduotis","Dabar uzduociu nera. Griskite kai bus daugiau zaideju!","Gerai","");
					new randomid=random(PlayerID);
					new id=PlayerList[randomid];
					playerDB[playerid][baikeruzd]=id;
					LastPjovimas[playerid]=GetTickCount();
					format(msg,sizeof(msg),"{FFFFFF}Sakai neturi darbo?\nMusu firma seniai iesko {FF0000}%s{FFFFFF}.\nSurask ji, surisk ir nuvezk i nurodyta vieta!",ReturnName(id));
					ShowPlayerDialog(playerid,7842,DIALOG_STYLE_MSGBOX,"Uzduotis",msg,"Gerai","");
				}
				else
				{
					new msg[512];
					format(msg,sizeof(msg),"{FFFFFF}Sakai neturi darbo?\nMusu firma seniai iesko {FF0000}%s{FFFFFF}.\nSurask ji, surisk ir nuvezk i nurodyta vieta!",ReturnName(playerDB[playerid][baikeruzd]));
					if(GetTickCount() - LastPjovimas[playerid] > 5*60*1000)
						ShowPlayerDialog(playerid,7842,DIALOG_STYLE_MSGBOX,"Uzduotis",msg,"Gerai","Atsisakyti");
					else
						ShowPlayerDialog(playerid,7842,DIALOG_STYLE_MSGBOX,"Uzduotis",msg,"Gerai","");
				}
				
			}
		}
		return 1;
	}
	if(playerDB[playerid][specialybe] == 54 && model == SWEEPER && IsPlayerInRangeOfPointEx(30.0,playerid,Slaveju_CP[SlavejoCP[playerid]][0],Slaveju_CP[SlavejoCP[playerid]][1],Slaveju_CP[SlavejoCP[playerid]][2]))
	{
		SlavejoCP[playerid]++;
		if(SlavejoCP[playerid] >= sizeof(Slaveju_CP))
		{
			GivePlayerMoneyA(playerid, MONEYP_SLAVEJAS);
			SendInfoMessage(playerid,"Marsrutas baigtas!");
			ProcessAchievement(playerid,76);
			SlavejoCP[playerid]=0;
		}
		SetPlayerCheckpoint(playerid,Slaveju_CP[SlavejoCP[playerid]][0],Slaveju_CP[SlavejoCP[playerid]][1],Slaveju_CP[SlavejoCP[playerid]][2],5.0);
	}
	if((playerDB[playerid][specialybe]== 56 || playerDB[playerid][admin]) && model == 572 && IsPlayerInRangeOfPointEx(30.0,playerid,Ukininku_CP[SlavejoCP[playerid]][0],Ukininku_CP[SlavejoCP[playerid]][1],Ukininku_CP[SlavejoCP[playerid]][2]))
	{
		SlavejoCP[playerid]++;
		if(SlavejoCP[playerid] >= sizeof(Ukininku_CP))
		{
			GivePlayerMoneyA(playerid, MONEYP_UKININKAS);
			ProcessAchievement(playerid, 130);
			SendInfoMessage(playerid,"Marsrutas baigtas!");
			ProcessAchievement(playerid,76);
			SlavejoCP[playerid]=1;
			if((GetTickCount() - UkininkaiTime[playerid]) < 3*60*1000)
			{
				AC_Ban(playerid,"Buginimas ukininkai");
			}
			UkininkaiTime[playerid]=GetTickCount();
		}
		SetPlayerCheckpoint(playerid,Ukininku_CP[SlavejoCP[playerid]][0],Ukininku_CP[SlavejoCP[playerid]][1],Ukininku_CP[SlavejoCP[playerid]][2],5.0);

	
	}
	if((playerDB[playerid][specialybe]== 56 || playerDB[playerid][admin]) && model == 531)
	{
		if(IsPlayerInRangeOfPointEx(30.0,playerid,1059.0536,-305.1050,73.9922))
		{
			if(IsTrailerAttachedToVehicle(GetPlayerVehicleID(playerid)))
			{
				SendInfoMessage(playerid,"~y~Puiku! Dabar vaziuokite i laukus!");
				SlavejoCP[playerid]=0;
				SetPlayerCheckpoint(playerid,Traktoristu_CP[SlavejoCP[playerid]][0],Traktoristu_CP[SlavejoCP[playerid]][1],Traktoristu_CP[SlavejoCP[playerid]][2],5.0);
				return 1;
			}
			else SendInfoMessage(playerid,"Spauskite ~k~~TOGGLE_SUBMISSIONS~(+)");
		}
		/*else if(IsPlayerInRangeOfPointEx(10.0,playerid,Traktoristu_CP2[SlavejoCP[playerid]][0],Traktoristu_CP2[SlavejoCP[playerid]][1],Traktoristu_CP2[SlavejoCP[playerid]][2]))
		{
			if(!IsTrailerAttachedToVehicle(GetPlayerVehicleID(playerid)))
			{
				SendInfoMessage(playerid,"~r~Privalote prisikabinti priekaba!");
				SetPlayerCheckpoint(playerid,1059.0536,-305.1050,73.9922,3.0);
				return 1;
			}
			SlavejoCP[playerid]++;
			if(SlavejoCP[playerid] >= sizeof(Traktoristu_CP2))
			{
				GivePlayerMoneyA(playerid, MONEYP_UKININKAS);
				SendInfoMessage(playerid,"Marsrutas baigtas!");
				SlavejoCP[playerid]=0;
				SetPlayerCheckpoint(playerid,Traktoristu_CP[SlavejoCP[playerid]][0],Traktoristu_CP[SlavejoCP[playerid]][1],Traktoristu_CP[SlavejoCP[playerid]][2],5.0);
				return 1;
			}
			SetPlayerCheckpoint(playerid,Traktoristu_CP2[SlavejoCP[playerid]][0],Traktoristu_CP2[SlavejoCP[playerid]][1],Traktoristu_CP2[SlavejoCP[playerid]][2],5.0);

		}
		*/
