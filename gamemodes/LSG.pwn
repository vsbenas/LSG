	if(vehicleid==cheetahai[4])
	{
		AttachObjectToVehicle(cheetahlights[4], cheetahai[4], 0.409729004, 0.526367188, 0.206963539, 0.0, 0.0, 0.0);
	}
	if(vehicleid==cheetahai[5])
	{
		AttachObjectToVehicle(cheetahlights[5], cheetahai[5], 0.409729004, 0.526367188, 0.206963539, 0.0, 0.0, 0.0);
	}*/
	return 1;
}


new BagazinesItems[MAX_PLAYERS][2];

new SratsvydzioGuns[MAX_PLAYERS][3];



public OnVehicleDeath(vehicleid, killerid)
{
	if(IsPlayerAdmin(killerid))
		SendClientMessage(killerid,-1,"[DEBUG] Vehicle dead");
	new deganti = 0;
	if(vehicleDB[vehicleid][dega])
		deganti = 1;
	vehicleDB[vehicleid][dega]=0;
	VehicleSpawned[vehicleid]=0;
	DestroyDynamic3DTextLabel(MiniDarbai[vehicleid]),MiniDarbai[vehicleid]=Text3D:-1;
	Iter_Remove(Deganti,vehicleid);
	vehicleDB[vehicleid][sprogs]=0;
	vehicleDB[vehicleid][rankinis]=false;
	if(JobCars[vehicleid][0])
	{
		printf("Job car died!");
		DestroyVehicle(vehicleid);
		new job = JobCars[vehicleid][0];
		new n = JobCars[vehicleid][1];
		JobCars[vehicleid][0]=0;
		DarbinesCar[job][n][DCrespawn]=1;
	}
	new idas,playeridas;
	idas = GetPlayerFromCarlistID(vehicleid, playeridas);
	if(killerid != playeridas && killerid != INVALID_PLAYER_ID)
	{
		if(IsPlayerAfkEx(killerid,GetTickCount()-3000) || playerDB[killerid][banned])
		{
			AC_Kick(killerid,"Car boomer", 1);
			return 1;
		}
		if(idas)
		{
			if(playerDB[killerid][masina] != vehicleid || playerDB[killerid][authstate] == 0)
			{
				AC_Warn(killerid,"Susprogdino ne savo automobili(nevairavo)");
				if(!deganti)
					return 1;
			}
			else
			{
				AC_Warn(killerid,"Susprogdino ne savo automobili");
			}
		}
		else
		{
			if(playerDB[killerid][masina] != vehicleid || playerDB[killerid][authstate] == 0)
			{
				AC_Warn(killerid,"Susprogdino darbini automobili(nevairavo) /scar?");
				if(!deganti)
					return 1;
			}
		}
	}
	foreach (Player, playerid)
	{
		if(vehicleid == PlayerCar[playerid])
		{
			CheckVelykos(playerid);
			if(CarLights[playerid] != 0)
			{
				DestroyObject(CarLights[playerid]),CarLights[playerid]=0;
			}
			new model = GetVehicleModel(vehicleid);
			ChristmasHandleVehicleDeath(playerid, vehicleid, model);
			if(InkaUzsakymai[playerid][ustatus] == 3 && model == 428 )
			{
				PrapisoPinigus(playerid,1);
			}
			PlayerCar[playerid]=-1;
			new bool:stop=false;
			if(vehicleDB[vehicleid][norida] == 1)
				stop=true;
			for(new i;i<150;i++)
			{
				if(stop) break;
				for(new x;x<MAX_DARBINES_CAR;x++)
				{
					if(stop) break;
					if(DarbinesCar[i][x][DCmodel]==model)
					{
						if(i < 100)
						{
							new query[256];
							format(query,256,"UPDATE `Darbines` Set `Status`=0,`rida`='%f' WHERE `Job`=%i AND `Cartype`=%i AND `Vardas`='%s'",vehicleDB[vehicleid][rida],i,x,ReturnName(playerid));
							mysql_query(query);
						}
						else if(i < 110)
						{
							new query[256];
							format(query,256,"UPDATE `gangcars` Set `status`=0,`rida`='%f' WHERE `lastuser`='%s' AND `status`=2",vehicleDB[vehicleid][rida],ReturnName(playerid));
							mysql_query(query);
						}
						stop=true;
					}
				}
			}
			SetTimerEx("DelayDestroyWork",3000,0,"i",vehicleid);
		
		}
		if(VehicleRadio[vehicleid] && GetPlayerVehicleID(playerid) == vehicleid)
		{
			StopAudioStreamForPlayer(playerid);
			VehicleRadio[vehicleid]=0;
		}
		/*
		if(playerDB[playerid][klausosi] == vehicleid)
		{
			StopAudioStreamForPlayer(playerid);
			playerDB[playerid][klausosi]=0;
		}  */
		if(playerDB[playerid][lektuvas]==vehicleid)
		{
			//TogglePlayerSpectating(playerid,false);
			SetTimerEx("Parasiutas",1000,false,"i",playerid);
			playerDB[playerid][shealth][0]=5;
			playerDB[playerid][shealth][1]=0;
			SetPlayerHealth(playerid,2);
			new Float:Xz, Float:Yz, Float:Zz, Float:A;
			GetVehiclePos(playerDB[playerid][lektuvas], Xz, Yz, Zz);
			GetVehicleZAngle(playerDB[playerid][lektuvas], A);
			Xz += (5 * floatsin(-floatsub(A, 45.0), degrees)),
			Yz += (5 * floatcos(-floatsub(A, 45.0), degrees));
			SetPlayerInterior(playerid, 0);
			SetPlayerPoz(playerid, Xz, Yz, floatsub(Zz, 0.94), _, _, 0);
			SetCameraBehindPlayer(playerid);
			SetPlayerFacingAngle(playerid, A);
			SetPlayerVirtualWorld(playerid,0);
			playerDB[playerid][lektuvas]=-1;
		}

		if(Carlist[playerid][Carid]==vehicleid)
		{
			SetTimerEx("DelayDestroyCar",3000,0,"ii",playerid,vehicleid);
			new query[128];
			format(query,sizeof(query),"DELETE FROM Bagazine WHERE Vardas='%s' AND Masina=%i",ReturnName(playerid),1);
			mysql_query(query);
			return 1;
		}
		if(Carlist2[playerid][Carid]==vehicleid)
		{
			new query[128];
			format(query,sizeof(query),"DELETE FROM Bagazine WHERE Vardas='%s' AND Masina=%i",ReturnName(playerid),2);
			mysql_query(query);
			SetTimerEx("DelayDestroyCar2",3000,0,"ii",playerid,vehicleid);
			return 1;
		}
		if(Carlist3[playerid][Carid]==vehicleid)
		{
			new query[128];
			format(query,sizeof(query),"DELETE FROM Bagazine WHERE Vardas='%s' AND Masina=%i",ReturnName(playerid),3);
			mysql_query(query);
			SetTimerEx("DelayDestroyCar3",3000,0,"ii",playerid,vehicleid);
			return 1;
		}
	}

	vehicleDB[vehicleid][lastpos][0]=0;
	vehicleDB[vehicleid][lastpos][1]=0;
	vehicleDB[vehicleid][lastpos][2]=0;
	return 1;
}

public OnPlayerClickPlayer(playerid, clickedplayerid, source)
{
	if(playerDB[playerid][authstate] != 4) return 1;
	if(playerDB[playerid][banned]) return 1;
	if(playerid == clickedplayerid) return 1;
	/*if(playerDB[playerid][admin])
	{
		if(!(playerDB[clickedplayerid][authstate]==4 || playerDB[clickedplayerid][authstate]==1 || playerDB[clickedplayerid][authstate]==3 ) || playerDB[clickedplayerid][admin]) return 1;
		Pasisveikino[playerid]=clickedplayerid;
		ShowPlayerDialog(playerid,687,DIALOG_STYLE_MSGBOX,"Veiksmai","Norite iskickinti(uz varda_pavarde)?\nAr pasisveikinti?","Kickinti","Sveikintis");
		return 1;
	}*/
	new msg[128],pname[24],cname[24];
	GetPlayerName(playerid,pname,24);
	GetPlayerName(clickedplayerid,cname,24);
	format(msg, 128, "* Pasisveikinot su %s ID %i!", cname, clickedplayerid);
	SendClientMessage(playerid, 0xFFFFFFFF, msg);
	if(Pasisveikino[playerid]==clickedplayerid) return 1;
	format(msg, 128, "* Su jumis pasisveikino %s ID %i!", pname, playerid);
	SendClientMessage(clickedplayerid, 0xFFFFFFFF, msg);
	Pasisveikino[playerid]=clickedplayerid;
	ProcessAchievement(playerid, 117);
	return 1;
}

public OnPlayerText(playerid, text[])
{
	if(isnull(text)) return 0;
	printf("[chat] [%s]: %s",ReturnName(playerid),formatwithoutLT(text));
	if(GetPlayerState(playerid)==PLAYER_STATE_WASTED || playerDB[playerid][banned] || playerDB[playerid][authstate]==0) return 0;
	PlayerAfk2[playerid]=GetTickCount();
	if(ignorecmd[playerid] == 0)
	{
		MsgCount[playerid]++;
		new var = small_hash(text);
		if(var == PaskutineCmd[playerid])
		{
	 		KiekFlood[playerid]++;
			if(KiekFlood[playerid]>=5)
			{
				new msg[128]; format(msg,128," * LSG Anti-Cheat: %s buvo iđkickintas uţ flood.",ReturnName(playerid));
				SendClientMessageToAll(RED,msg);
		        KickEx(playerid);
				return 1;
			}
		}
		else
		{
			KiekFlood[playerid]=0;
		}
		PaskutineCmd[playerid]=var;
	}
	if(playerDB[playerid][skambutis]!=-1)
	{
		if(playerDB[playerDB[playerid][skambutis]][skambutis] != playerid)
		{
			playerDB[playerDB[playerid][skambutis]][skambutis]=-1;
			return 0;
		}

		new msg[128];
		format(msg,sizeof(msg),"Telefonas: %s",text);
		SendClientMessage(playerDB[playerid][skambutis],0xD9E916FF,msg);
		format(msg,sizeof(msg),"Tu sakai: %s",text);
		SendClientMessage(playerid,0xD9E916FF,msg);
		return 0;
	}
	if(playerDB[playerid][psratasvydis])
	{
		new playertext[256];
		if(playerDB[playerid][psratasvydis] == 2) // 2 raudoni, 1 melyni
			format(playertext,256,#TEXT_GREEN"[DAŢASVYDIS] "#TEXT_RED"%s{FFFFFF}: %s",ReturnName(playerid),text);
		else
			format(playertext,256,#TEXT_GREEN"[DAŢASVYDIS] "#TEXT_BLUE"%s{FFFFFF}: %s",ReturnName(playerid),text);

		SendMessageToDazaiThird(-1,playertext);
		return 0;
	}
	switch(playerDB[playerid][textas])
	{
		case 0:
		{
			Spejimas(playerid,text);
			SetPlayerChatBubble(playerid,text,WHITE,30,10000); // 10 sec.
			if(	playerDB[playerid][zvejoja] || playerDB[playerid][ant] || playerDB[playerid][suristas] || playerDB[playerid][playingpoker] ||
				playerDB[playerid][mire] || GetPlayerState(playerid) == PLAYER_STATE_DRIVER || GetPlayerState(playerid) == PLAYER_STATE_PASSENGER ||
				GetPlayerSpecialAction(playerid) == SPECIAL_ACTION_USEJETPACK ||gPlayerUsingLoopingAnim[playerid] || Jumped[playerid] || JumpStatus[playerid] || fs_balloon_pl[playerid][0] == 1)
			{
			
			}
			else
			{
				ApplyAnimation(playerid,"PED","IDLE_chat",4.1,0, 0, 0, 1, 1);
				SetTimerEx("StabdytiAnim", 1000, false, "i", playerid);
			}
			/*new vehicleid = GetPlayerVehicleID(playerid);
			if(vehicleid)
			{
				if(IsAPlane(GetVehicleModel(vehicleid)) && GetPlayerState(playerid)==PLAYER_STATE_DRIVER)
				{
					new msg[128];
					format(msg,sizeof(msg),"Pilotas %s: {FFFFFF}%s",ReturnName(playerid),text);
					
					foreach(Player, i)
						if(playerDB[i][lektuvas]==vehicleid || i == playerid)
							SendClientMessage(i,COLOR_RED,msg);
							
					return 0;
				}
			}*/
			new Float:Coo[3];
			GetPlayerPos(playerid,Coo[0],Coo[1],Coo[2]);
			new vw=GetPlayerVirtualWorld(playerid);
			new int = GetPlayerInterior(playerid);
			new textEUR[256];
			for(new i=0, j=strlen(text);i<j;i++)
			{
				switch(text[i]) 
				{
					case 'ŕ': textEUR[i]='a';
					case 'č': textEUR[i]='c';
					case 'ć': textEUR[i]='e';
					case 'ë': textEUR[i]='e';
					case 'á': textEUR[i]='i';
					case 'đ': textEUR[i]='s';
					case 'ř': textEUR[i]='u';
					case 'ű': textEUR[i]='u';
					case 'ţ': textEUR[i]='z';

					case 'Ŕ': textEUR[i]='A';
					case 'Č': textEUR[i]='C';
					case 'Ć': textEUR[i]='E';
					case 'Ë': textEUR[i]='E';
					case 'Á': textEUR[i]='I';
					case 'Đ': textEUR[i]='S';
					case 'Ř': textEUR[i]='U';
					case 'Ű': textEUR[i]='U';
					case 'Ţ': textEUR[i]='Z';
					case '$': {
						text[i]='€';
						textEUR[i]='€';
					}
					default: textEUR[i]=text[i];
				}
			}
			new playerInWorld = IsPlayerInWorld(playerid);
			foreach(Player, i)
			{
					if(playerInWorld || IsPlayerInRangeOfPointEx(30.0,i,Coo[0],Coo[1],Coo[2]))
					{
						if(GetPlayerVirtualWorld(i) == vw && GetPlayerInterior(i) == int)
						{
							if(BitFlag_Get(PConfig[i],PCFG_RAIDES))
								SendPlayerMessageToPlayer(i,playerid,textEUR);
							else
								SendPlayerMessageToPlayer(i,playerid,text);
						}
					}
			}
			/*if(playerDB[playerid][lektuvas] != -1)
			{
				new driver = GetDriver(playerDB[playerid][lektuvas]);
				SendPlayerMessageToPlayer(driver,playerid,text);
			}*/
			
			return 0;
		}
		
	//Narkotikai
        
	//Taxi
		case 3:
		{
			
		    playerDB[playerid][textas]=0;
			if(GetPlayerVehicleID(playerid) != GetPlayerVehicleID(keleivis[playerid])) return SendInfoMessage(playerid,"Keleivis jau islipo!"),0;
			if(0==strcmp(text,"taip",true))
			{
				SendInfoMessage(playerid,"Pinigai bus imami");
				taxiDB[keleivis[playerid]][imti]=true;
				SendClientMessage(keleivis[playerid], ORANGE, "[LSG Taxi] Sveiki! Kur norësite vaţiuoti? Galite pasakyti vairuotojui arba paţymëti vietŕ ţemelapyje paspaudć ESC.");
				playerDB[playerid][textas]=0;
				return 0;
			}

			SendInfoMessage(playerid,"Pinigai nebus imami");
			taxiDB[keleivis[playerid]][imti]=false;
			return 0;
		}
		default:
		{
			playerDB[playerid][textas]=0;
		}

	}


	return 1;
}



public NoAlarm(vehicleid)
{
	GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
	SetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],false,-1,VehVars[4],VehVars[5],VehVars[6]);
	return 1;
}
new EnterVehicleTick[MAX_PLAYERS];

public OnPlayerEnterVehicle(playerid, vehicleid, ispassenger)
{
	if (!(0 < vehicleid < MAX_VEHICLES))
	{
		AC_Kick(playerid,"Vehicle crasher 4",1);
		return 0;
	}
	if(DEBUG==true) printf("OnPlayerEnterVehicle:%i",playerid);
	if(!ispassenger) IsPlayerSteppingInVehicle[playerid] = vehicleid;
	if(IsPlayerNPC(playerid)) return 1;
	
	GetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],VehVars[2],VehVars[3],VehVars[4],VehVars[5],VehVars[6]);
	new ac_model = GetVehicleModel(vehicleid);

	if(ac_model == 570 || IsABoat(ac_model)) 
		EnterVehicleTick[playerid] = 0;
	else
		EnterVehicleTick[playerid] = GetTickCount();

	if(ac_model == 471 && !ispassenger)
	{
				// kaledos
		if(GetDriver(vehicleid) != INVALID_PLAYER_ID)
			Stop(playerid);
	}

	if(Kraunasi[vehicleid]) Stop(playerid);
	if(!ArNuosava(vehicleid) && !ispassenger && (playerDB[playerid][admin] || playerDB[playerid][plead]) && strlen(vehicleDB[vehicleid][lastuser]))
	{
	    new msg[128];
	    format(msg,sizeof(msg),"Paskutinis sioje masinoje sedejo: %s",vehicleDB[vehicleid][lastuser]);
		SendInfoMessage(playerid,msg);
	}
	if(alarmed[vehicleid] && !VehVars[2] && GetDriver(vehicleid)==INVALID_PLAYER_ID && vehicleid != Carlist[playerid][Carid] && vehicleid != Carlist2[playerid][Carid] && vehicleid != Carlist3[playerid][Carid])
	{
	    SetVehicleParamsEx(vehicleid,VehVars[0],VehVars[1],true,-1,VehVars[4],VehVars[5],VehVars[6]);
	    SetTimerEx("NoAlarm",5000,false,"i",vehicleid);
	}
	if(playerDB[playerid][ikalintas]){SetPlayerHealth(playerid, 0); return 1;}
	if(vehicleDB[vehicleid][dega]) Stop(playerid);
	if(GetPVarInt(playerid, "Boxas"))
	{
		Stop(playerid);
		Boxas(playerid,1);
		return SendInfoMessage(playerid,"~r~Pristatyk krovini i versla.");
	}
	GetVehiclePos(vehicleid,vehicleDB[vehicleid][lastpos][0],vehicleDB[vehicleid][lastpos][1],vehicleDB[vehicleid][lastpos][2]);
	GetVehicleZAngle(vehicleid,vehicleDB[vehicleid][lastpos][3]);
	new vairuotojas = GetDriver(vehicleid);
	if(vairuotojas != 0 && vairuotojas != playerid && vairuotojas != INVALID_PLAYER_ID)
	{
		if(PlayerAfk[vairuotojas]) Stop(playerid);
	}
	
	if(ispassenger)
	{

	    new	model = GetVehicleModel(vehicleid);
        if (model == 519 || model == 553 || model == 577 || model == 592)
        {
            playerDB[playerid][lektuvas]=vehicleid;
            playerDB[playerid][spdata][24]=GetPlayerSkin(playerid);
			playerDB[playerid][spdata][25]=GetPlayerWantedLevel(playerid);
			GetPlayerHealth(playerid,playerDB[playerid][shealth][0]);
			GetPlayerArmour(playerid,playerDB[playerid][shealth][1]);
            SetPlayerPoz(playerid, 1891.4706,-8156.8750,2.4471, _, _, 0);

			
            TogglePlayerSpectating(playerid, 1);
            PlayerSpectateVehicle(playerid, vehicleid);
        }
		return 1;
	}

//Ilipo vairuotojas
	
	return 1;
}

public OnPlayerExitVehicle(playerid, vehicleid)
