stock GetClosestVehicleid(playerid, Float: radius = 999.999,except = -1)
{
	new Float:dis[2],e[2];
	e[0] = INVALID_VEHICLE_ID;
	dis[0] = radius;
	new Float:coo[6];
	GetPlayerPos(playerid,coo[0],coo[1],coo[2]);
//	(GetVehicleDistanceFromPoint(%0,%2,%3,%4) <= %1)
	new vw = GetPlayerVirtualWorld(playerid);
	for (e[1]=0;e[1]<MAX_VEHICLES;e[1]++)
	{
	    if(e[1]==except || GetVehicleVirtualWorld(e[1]) != vw || !GetVehicleModel(e[1])) continue;
		dis[1] = GetVehicleDistanceFromPoint(e[1],coo[0],coo[1],coo[2]);
		if(dis[1]< dis[0])
		{
			dis[0] = dis[1];
			e[0] = e[1];
		}
	}
	return e[0];
}
