new LastCar[MAX_PLAYERS];
public Gesintuvas(vehicleid,playerid)
{
	if(GetPlayerWeapon(playerid) != 42) return 1;
	new val1,val2;
	GetPlayerWeaponData(playerid,9,val1,val2);
	if(playerDB[playerid][gesintuvok] == val2) return 1;
    playerDB[playerid][gesintuvok]=val2;
	
	new Float:Coo[3];
		//GetVehiclePos(vehicleid,Coo[0],Coo[1],Coo[2]);
	new model = GetVehicleModel(vehicleid);
	if(model == 451 || model ==431 || model == 437 || model == 541) // variklis gale
		GetVehicleBackPos(vehicleid,Coo[0],Coo[1],Coo[2]);
	else
		GetVehicleFrontPos(vehicleid,Coo[0],Coo[1],Coo[2]);
	if(IsPlayerInRangeOfPointEx(6,playerid,Coo[0],Coo[1],Coo[2]))
	{
		new Float:HP;
		GetVehicleHealth(vehicleid,HP);
		if(HP <= 249.9)
		{
			if(IsPlayerAimingAt(playerid,Coo[0],Coo[1],Coo[2],1.5))
			{
			    //if(random(40) != 20) return 1;
				SprayProg[playerid]++;
				SetProgressBarMaxValue(Veiksmai, 70);
				SetProgressBarValue(Veiksmai,SprayProg[playerid]);
				ShowProgressBarForPlayer(playerid, Veiksmai);
				StartVeiksmas(playerid,"Gesinimas");
				if(SprayProg[playerid] >= 68)
				{
					if(playerDB[playerid][specialybe] == 66)
					{
						if(GetTickCount()-LastCar[playerid] > 1000*60*10)
						{
							new msg[128];format(msg,sizeof(msg),"[racija] Operatore: %s uzgesino automobili!",ReturnName(playerid));
							SendMessageToGaisras(ORANGE,msg);
							Pelnas(playerid,65,floatround(MONEYP_GAISRININKAI*15));
							GivePlayerMoneyA(playerid,floatround(MONEYP_GAISRININKAI*2));
							playerDB[playerid][jobpts]++;
							LastCar[playerid] = GetTickCount();
						}
					}
					KillTimer(Gesinimaz[playerid]);
					Gesinimaz[playerid]=-1;
					Gesino[playerid]=false;
					Uzgesinti(vehicleid);
					HideProgressBarForPlayer(playerid,Veiksmai);
					EndVeiksmas(playerid);
				}
				return 1;
			}
		}
	}
	return 1;
}
forward Spray(playerid,tagid);
public Spray(playerid,tagid)
{
	if(GetPlayerWeapon(playerid) != 41) return 1;
	new val1,val2;
	GetPlayerWeaponData(playerid,9,val1,val2);
	if(playerDB[playerid][gesintuvok] == val2) return 1;
    playerDB[playerid][gesintuvok]=val2;
	if(tagid == -1) // special case
	{
		//if(random(40) != 20) return 1;
		SprayProg[playerid]++;
		SetProgressBarValue(Veiksmai, SprayProg[playerid]);
		SetProgressBarMaxValue(Veiksmai,50);
		ShowProgressBarForPlayer(playerid, Veiksmai);
		StartVeiksmas(playerid,"Piesi varda...");
		if(SprayProg[playerid] >= 49)
		{
			HideProgressBarForPlayer(playerid,Veiksmai);
			EndVeiksmas(playerid);
			KillTimer(Gesinimaz[playerid]);
			Gesinimaz[playerid]=-1;
			Gesino[playerid]=false;
			AddPlayerName(playerid);
			return 1;
		}

		return 1;
	}
	if(IsPlayerInRangeOfPointEx(6.0,playerid,GaujuTagai[tagid][0],GaujuTagai[tagid][1],GaujuTagai[tagid][2]))
	{
		if(TagOwnedBy[tagid] != playerDB[playerid][pgang])
		{
			if(IsPlayerAimingAt(playerid,GaujuTagai[tagid][0],GaujuTagai[tagid][1],GaujuTagai[tagid][2],3.0))
			{
			    //if(random(40) != 20) return 1;
				SprayProg[playerid]++;
				SetProgressBarValue(Veiksmai, SprayProg[playerid]);
				SetProgressBarMaxValue(Veiksmai,50);
				ShowProgressBarForPlayer(playerid, Veiksmai);
				StartVeiksmas(playerid,"Piesi taga...");
				if(SprayProg[playerid] >= 49)
				{
					HideProgressBarForPlayer(playerid,Veiksmai);
					EndVeiksmas(playerid);
					KillTimer(Gesinimaz[playerid]);
					Gesinimaz[playerid]=-1;
					Gesino[playerid]=false;
					ChangeGangTag(playerid,tagid);
					return 1;
				}
			}
		}
	}
	return 1;
}

public Gesinimas(vehicleid,playerid)
{
	new Float:Coo[3];
	//GetVehiclePos(vehicleid,Coo[0],Coo[1],Coo[2]);
	new model = GetVehicleModel(vehicleid);
	if(model == 451 || model ==431 || model == 437 || model == 541) // variklis gale
		GetVehicleBackPos(vehicleid,Coo[0],Coo[1],Coo[2]);
	else
		GetVehicleFrontPos(vehicleid,Coo[0],Coo[1],Coo[2]);
	
	if(IsPlayerInRangeOfPointEx(20,playerid,Coo[0],Coo[1],Coo[2]))
	{
		new Float:HP;
		GetVehicleHealth(vehicleid,HP);
		if(HP <= 249.9)
		{
			if(IsPlayerAimingAt(playerid,Coo[0],Coo[1],Coo[2],2.5))
			{
				SprayProg[playerid]++;
				SetProgressBarMaxValue(Veiksmai, 50);
				SetProgressBarValue(Veiksmai,SprayProg[playerid]);
				ShowProgressBarForPlayer(playerid, Veiksmai);
				StartVeiksmas(playerid,"Gesinimas");
				if(SprayProg[playerid] >= 49)
				{
					if(playerDB[playerid][specialybe] == 66)
					{
						if(GetTickCount()-LastCar[playerid] > 1000*60*10)
						{
							new msg[128];format(msg,sizeof(msg),"[racija] Operatore: %s uzgesino automobili!",ReturnName(playerid));
							SendMessageToGaisras(ORANGE,msg);
							Pelnas(playerid,65,floatround(MONEYP_GAISRININKAI*30));
							GivePlayerMoneyA(playerid,floatround(MONEYP_GAISRININKAI*4));
							playerDB[playerid][jobpts]++;
							LastCar[playerid] = GetTickCount();
						}
					}
					
					
					KillTimer(Gesinimaz[playerid]);
					Gesinimaz[playerid]=1;
					//playerDB[playerid][jobpts]++;
					Gesino[playerid]=false;
					Uzgesinti(vehicleid);
					HideProgressBarForPlayer(playerid,Veiksmai);
					EndVeiksmas(playerid);
				}
				return 1;
			}
		}
	}
	return 1;
}
forward Gesintuvas2(playerid);
public Gesintuvas2(playerid)
{
	if(GetPlayerWeapon(playerid) != 42) return 1;
	new val1,val2;
	GetPlayerWeaponData(playerid,9,val1,val2);
	if(playerDB[playerid][gesintuvok] == val2) return 1;
    playerDB[playerid][gesintuvok]=val2;

	if(IsPlayerInRangeOfPointEx(10,playerid,FireDB[fCoo][0],FireDB[fCoo][1],FireDB[fCoo][2]) && FireDB[inProgress])
	{
		if(IsPlayerAimingAt(playerid,FireDB[fCoo][0],FireDB[fCoo][1],FireDB[fCoo][2],2.0))
		{
			if(FireDB[fHealth] <= 10)
			{
				FireDB[fHealth]=0;
				KillTimer(Gesinimaz[playerid]);
				Gesinimaz[playerid]=-1;
				Pelnas(playerid,65,MONEYP_GAISRININKAI*30);
				playerDB[playerid][jobpts]++;
		 		SendMessageToGaisras(ORANGE,"[racija] Operatore: Gaisras buvo uzgesintas!");
		 		GivePlayerMoneyA(playerid,floatround(MONEYP_GAISRININKAI*2));
		 		ProcessAchievement(playerid,97);
				Gesino[playerid]=false;
				FireDB[inProgress]=false;
				DestroyDynamicObject(FireDB[fObj]);
				FireDB[fObj]=-1;
				foreach(Player, i) if(IsPlayerInRangeOfPointEx(50.0,i,FireDB[fCoo][0],FireDB[fCoo][1],FireDB[fCoo][2]) || playerDB[i][specialybe]==66) { HideProgressBarForPlayer(i,Veiksmai); EndVeiksmas(i); }
				return 1;
			}
			FireDB[fHealth]--;
			SetProgressBarMaxValue(Veiksmai, FireDB[fMaxHealth]);
			SetProgressBarValue(Veiksmai, FireDB[fHealth]);
			ShowProgressBarForPlayer(playerid, Veiksmai);
			StartVeiksmas(playerid,"Gesinimas");
			return 1;
		}
	}
	return 1;
}
