		Light[4][playerid] = CreateDynamicObject(354,FRX[playerid]-(0+(random(6))),FRY[playerid]-(0+(random(6))),FRZ[playerid]+(0+(random(6))), 0, 0,0);
		Light[5][playerid] = CreateDynamicObject(354,FRX[playerid]-(0+(random(6))),FRY[playerid]+(0+(random(6))),FRZ[playerid]+(0+(random(6))), 0, 0,0);
		Light[6][playerid] = CreateDynamicObject(354,FRX[playerid]-(0+(random(6))),FRY[playerid],FRZ[playerid]-(0+(random(6))), 0, 0,0);
		Light[7][playerid] = CreateDynamicObject(354,FRX[playerid]-(0+(random(6))),FRY[playerid]-(0+(random(6))),FRZ[playerid]-(0+(random(6))), 0, 0,0);
		Light[8][playerid] = CreateDynamicObject(354,FRX[playerid],FRY[playerid]-(0+(random(6))),FRZ[playerid]+(0+(random(6))), 0, 0,0);
		new Float:xla,Float:yla,Float:zla;
		GetDynamicObjectPos(Light[1][playerid], xla, yla, zla);
		MoveDynamicObject(Light[1][playerid], xla-(0+(random(6))), yla-(0+(random(6))), zla-20, 6);
		GetDynamicObjectPos(Light[2][playerid], xla, yla, zla);
		MoveDynamicObject(Light[2][playerid], xla-(0+(random(6))), yla+(0+(random(6))), zla-20, 5);
		GetDynamicObjectPos(Light[3][playerid], xla, yla, zla);
		MoveDynamicObject(Light[3][playerid], xla-(0+(random(6))), yla, zla-20, 4);
		GetDynamicObjectPos(Light[4][playerid], xla, yla, zla);
		MoveDynamicObject(Light[4][playerid], xla+(0+(random(6))), yla-(0+(random(6))), zla-20, 5);
		GetDynamicObjectPos(Light[5][playerid], xla, yla, zla);
		MoveDynamicObject(Light[5][playerid], xla+(0+(random(6))), yla+(0+(random(6))), zla-20, 5);
		GetDynamicObjectPos(Light[6][playerid], xla, yla, zla);
		MoveDynamicObject(Light[6][playerid], xla+(0+(random(6))), yla, zla-20, 4);
		GetDynamicObjectPos(Light[7][playerid], xla, yla, zla);
		MoveDynamicObject(Light[7][playerid], xla, yla-(0+(random(6))), zla-20, 6);
		GetDynamicObjectPos(Light[8][playerid], xla, yla, zla);
		MoveDynamicObject(Light[8][playerid], xla, yla+(0+(random(6))), zla-20, 5);
		SetTimerEx("lighttimer", 3900, 0, "i", playerid);
		DestroyDynamicObject(Firerocket[playerid]);
